# Tria Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# 🚀 APPLICATION CONFIGURATION
# ===========================================
# Application settings and behavior
NODE_ENV=production
DEFAULT_LANGUAGE=es
SUPPORTED_LANGUAGES=es,en

# ===========================================
# 📧 CONTACT INFORMATION
# ===========================================
# General contact information (public)
CONTACT_EMAIL=contact@triacr.com
CONTACT_PHONE=+50600000000
WHATSAPP_NUMBER=+50600000000

# ===========================================
# 🏢 COMPANY INFORMATION
# ===========================================
# Company details and branding
COMPANY_NAME=tria
COMPANY_WEBSITE=www.triacr.com
COMPANY_DESCRIPTION=Software Development Company

# ===========================================
# 📍 LOCATION INFORMATION
# ===========================================
# Office locations and addresses
COSTA_RICA_ADDRESS=San José, Costa Rica
COSTA_RICA_LATITUDE=9.9281
COSTA_RICA_LONGITUDE=-84.0907

# ===========================================
# 🔗 SOCIAL MEDIA CONFIGURATION
# ===========================================
# Social media platform URLs
SOCIAL_INSTAGRAM=https://instagram.com/triacr
SOCIAL_FACEBOOK=https://facebook.com/triacr
SOCIAL_LINKEDIN=https://linkedin.com/company/triacr
SOCIAL_GITHUB=https://github.com/triacr
SOCIAL_TWITTER=https://twitter.com/triacr

# ===========================================
# 🔧 DEVELOPMENT CONFIGURATION
# ===========================================
# Development and debugging settings
DEBUG_MODE=false
LOG_LEVEL=error
API_BASE_URL=https://api.triacr.com

# ===========================================
# 📊 ANALYTICS & TRACKING
# ===========================================
# Analytics and measurement tools
GOOGLE_ANALYTICS_ID=PLACEHOLDER_ANALYTICS_ID
HOTJAR_ID=
SENTRY_DSN=PLACEHOLDER_SENTRY_DSN

# ===========================================
# 🔐 SECURITY CONFIGURATION
# ===========================================
# Security and authentication
JWT_SECRET=PLACEHOLDER_JWT_SECRET
ENCRYPTION_KEY=PLACEHOLDER_ENCRYPTION_KEY

# Note: This file contains example/placeholder values only.
# Update with your actual values in your production .env file.
# Do not commit real values to version control.
# This file should NOT contain real company data or personal information.
