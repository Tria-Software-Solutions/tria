---
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'tria — Software Enterprise',
  description = 'Software enterprise crafting digital solutions from Costa Rica.',
} = Astro.props;
---
<!doctype html>
<html lang="zxx">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://miller.bslthemes.com/ashley-demo/css/plugins/bootstrap-grid.css" />
  <link rel="stylesheet" href="https://miller.bslthemes.com/ashley-demo/css/plugins/font-awesome.min.css" />
  <link rel="stylesheet" href="https://miller.bslthemes.com/ashley-demo/css/plugins/swiper.min.css" />
  <link rel="stylesheet" href="https://miller.bslthemes.com/ashley-demo/css/plugins/fancybox.min.css" />
  <link rel="stylesheet" href="https://miller.bslthemes.com/ashley-demo/css/style.css" />
</head>
<body>
  <!-- wrapper -->
  <div class="mil-wrapper" id="top">
    <!-- cursor -->
    <div class="mil-ball">
      <span class="mil-icon-1">
        <svg viewBox="0 0 128 128">
          <path d="M106.1,41.9c-1.2-1.2-3.1-1.2-4.2,0c-1.2,1.2-1.2,3.1,0,4.2L116.8,61H11.2l14.9-14.9c1.2-1.2,1.2-3.1,0-4.2	c-1.2-1.2-3.1-1.2-4.2,0l-20,20c-1.2,1.2-1.2,3.1,0,4.2l20,20c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9c1.2-1.2,1.2-3.1,0-4.2	L11.2,67h105.5l-14.9,14.9c-1.2,1.2-1.2,3.1,0,4.2c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9l20-20c1.2-1.2,1.2-3.1,0-4.2L106.1,41.9	z" />
        </svg>
      </span>
      <div class="mil-more-text">More</div>
      <div class="mil-choose-text">Сhoose</div>
    </div>

    <!-- preloader -->
    <div class="mil-preloader">
      <div class="mil-preloader-animation">
        <div class="mil-pos-abs mil-animation-1">
          <p class="mil-h3 mil-muted mil-thin">Software</p>
          <p class="mil-h3 mil-muted">Enterprise</p>
          <p class="mil-h3 mil-muted mil-thin">Innovation</p>
        </div>
        <div class="mil-pos-abs mil-animation-2">
          <div class="mil-reveal-frame">
            <p class="mil-reveal-box"></p>
            <p class="mil-h3 mil-muted mil-thin">triacr.com</p>
          </div>
        </div>
      </div>
    </div>

    <!-- scrollbar progress -->
    <div class="mil-progress-track">
      <div class="mil-progress"></div>
    </div>

    <Header />

    <!-- curtain -->
    <div class="mil-curtain"></div>

    <!-- frame -->
    <div class="mil-frame">
      <div class="mil-frame-top">
        <a href="/" class="mil-logo">tria</a>
        <div class="mil-menu-btn">
          <span></span>
        </div>
      </div>
      <div class="mil-frame-bottom">
        <div class="mil-current-page"></div>
        <div class="mil-back-to-top">
          <a href="#top" class="mil-link mil-dark mil-arrow-place">
            <span>Back to top</span>
          </a>
        </div>
      </div>
    </div>
    <!-- frame end -->

    <!-- content -->
    <div class="mil-content">
      <div id="swupMain" class="mil-main-transition">
        <slot />
        <!-- hidden elements -->
        <div class="mil-hidden-elements">
          <div class="mil-dodecahedron">
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
            <div class="mil-pentagon"><div></div><div></div><div></div><div></div><div></div></div>
          </div>

          <svg class="mil-arrow" viewBox="0 0 128 128">
            <path d="M106.1,41.9c-1.2-1.2-3.1-1.2-4.2,0c-1.2,1.2-1.2,3.1,0,4.2L116.8,61H11.2l14.9-14.9c1.2-1.2,1.2-3.1,0-4.2c-1.2-1.2-3.1-1.2-4.2,0l-20,20c-1.2,1.2-1.2,3.1,0,4.2l20,20c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9c1.2-1.2,1.2-3.1,0-4.2L11.2,67h105.5l-14.9,14.9c-1.2,1.2-1.2,3.1,0,4.2c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9l20-20c1.2-1.2,1.2-3.1,0-4.2L106.1,41.9z" />
          </svg>

          <svg class="mil-lines" viewBox="0 0 44 484" xmlns="http://www.w3.org/2000/svg">
            <path class="mil-move" d="M22 0V484" />
            <path class="mil-move" d="M2 0V484" />
            <path class="mil-move" d="M30 0V484" />
            <rect class="mil-move" x="7" y="10" width="4" height="100" />
            <rect class="mil-move" x="18" y="50" width="4" height="145" />
            <rect class="mil-move" x="34" y="10" width="4" height="110" />
            <rect class="mil-move" x="10" y="105" width="4" height="140" />
            <rect class="mil-move" x="28" y="70" width="4" height="160" />
          </svg>
        </div>
        <!-- hidden elements end -->
      </div>
    </div>
  </div>

  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/jquery.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/swup.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/swiper.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/fancybox.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/gsap.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/smooth-scroll.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/ScrollTrigger.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/plugins/ScrollTo.min.js"></script>
  <script is:inline src="https://miller.bslthemes.com/ashley-demo/js/main.js"></script>
</body>
</html>
