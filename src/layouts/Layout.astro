---
import Header from "../components/Header.astro";
import "../styles/global.css";
import "../styles/tria-theme.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "tria — Software Enterprise",
  description = "Software enterprise crafting digital solutions from Costa Rica.",
} = Astro.props;
---

<!doctype html>
<html lang="zxx">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="stylesheet" href="/vendor/css/bootstrap-grid.css" />
    <link rel="stylesheet" href="/vendor/css/font-awesome.min.css" />
    <link rel="stylesheet" href="/vendor/css/swiper.min.css" />
    <link rel="stylesheet" href="/vendor/css/fancybox.min.css" />
  </head>
  <body>
    <!-- wrapper -->
    <div class="tria-wrapper" id="top">
      <!-- cursor -->
      <div class="tria-ball">
        <span class="tria-icon-1">
          <svg viewBox="0 0 128 128">
            <path
              d="M106.1,41.9c-1.2-1.2-3.1-1.2-4.2,0c-1.2,1.2-1.2,3.1,0,4.2L116.8,61H11.2l14.9-14.9c1.2-1.2,1.2-3.1,0-4.2	c-1.2-1.2-3.1-1.2-4.2,0l-20,20c-1.2,1.2-1.2,3.1,0,4.2l20,20c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9c1.2-1.2,1.2-3.1,0-4.2	L11.2,67h105.5l-14.9,14.9c-1.2,1.2-1.2,3.1,0,4.2c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9l20-20c1.2-1.2,1.2-3.1,0-4.2L106.1,41.9	z"
            ></path>
          </svg>
        </span>
        <div class="tria-more-text">More</div>
        <div class="tria-choose-text">Сhoose</div>
      </div>

      <!-- preloader -->
      <div class="tria-preloader">
        <div class="tria-preloader-animation">
          <div class="tria-pos-abs tria-animation-1">
            <p class="tria-h3 tria-muted tria-thin">Software</p>
            <p class="tria-h3 tria-muted">Enterprise</p>
            <p class="tria-h3 tria-muted tria-thin">Innovation</p>
          </div>
          <div class="tria-pos-abs tria-animation-2">
            <div class="tria-reveal-frame">
              <p class="tria-reveal-box"></p>
              <p class="tria-h3 tria-muted tria-thin">triacr.com</p>
            </div>
          </div>
        </div>
      </div>

      <!-- scrollbar progress -->
      <div class="tria-progress-track">
        <div class="tria-progress"></div>
      </div>

      <Header />

      <!-- curtain -->
      <div class="tria-curtain"></div>

      <!-- frame -->
      <div class="tria-frame">
        <div class="tria-frame-top">
          <a href="/" class="tria-logo"
            ><span data-i="0">t</span><span data-i="1">r</span><span data-i="2"
              >i</span
            ><span data-i="3">a</span><span data-i="4">.</span></a
          >
          <div class="tria-menu-btn">
            <span></span>
          </div>
        </div>
        <div class="tria-frame-bottom">
          <div class="tria-current-page"></div>
          <div class="tria-back-to-top">
            <a href="#top" class="tria-link tria-dark tria-arrow-place">
              <span>Back to top</span>
            </a>
          </div>
        </div>
      </div>
      <!-- frame end -->

      <!-- content -->
      <div class="tria-content">
        <div id="swupMain" class="tria-main-transition">
          <slot />
          <!-- hidden elements -->
          <div class="tria-hidden-elements">
            <div class="tria-dodecahedron">
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
            </div>

            <svg class="tria-arrow" viewBox="0 0 128 128">
              <path
                d="M106.1,41.9c-1.2-1.2-3.1-1.2-4.2,0c-1.2,1.2-1.2,3.1,0,4.2L116.8,61H11.2l14.9-14.9c1.2-1.2,1.2-3.1,0-4.2c-1.2-1.2-3.1-1.2-4.2,0l-20,20c-1.2,1.2-1.2,3.1,0,4.2l20,20c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9c1.2-1.2,1.2-3.1,0-4.2L11.2,67h105.5l-14.9,14.9c-1.2,1.2-1.2,3.1,0,4.2c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9l20-20c1.2-1.2,1.2-3.1,0-4.2L106.1,41.9z"
              ></path>
            </svg>

            <svg
              class="tria-lines"
              viewBox="0 0 44 484"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M22 0V484"></path>
              <path d="M2 0V484"></path>
              <path d="M30 0V484"></path>
              <rect x="7" y="10" width="4" height="100"></rect>
              <rect x="18" y="50" width="4" height="145"></rect>
              <rect x="34" y="10" width="4" height="110"></rect>
              <rect x="10" y="105" width="4" height="140"></rect>
              <rect x="28" y="70" width="4" height="160"></rect>
            </svg>
          </div>
          <!-- hidden elements end -->
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var frame = document.querySelector(".tria-frame");
        var hero = document.querySelector(".tria-banner");
        function check() {
          if (!frame || !hero) return;
          frame.classList.toggle(
            "hero-visible",
            hero.getBoundingClientRect().bottom > 0,
          );
        }
        window.addEventListener("scroll", check, { passive: true });
        check();
        document.addEventListener("swup:contentReplaced", function () {
          hero = document.querySelector(".tria-banner");
          check();
          if (window.initTriaGradient) window.initTriaGradient();
        });
      })();
    </script>
    <script is:inline src="/vendor/js/jquery.min.js"></script>
    <script is:inline src="/vendor/js/swup.min.js"></script>
    <script is:inline src="/vendor/js/swiper.min.js"></script>
    <script is:inline src="/vendor/js/fancybox.min.js"></script>
    <script is:inline src="/vendor/js/gsap.min.js"></script>
    <script is:inline src="/vendor/js/smooth-scroll.js"></script>
    <script is:inline src="/vendor/js/ScrollTrigger.min.js"></script>
    <script is:inline src="/vendor/js/ScrollTo.min.js"></script>
    <script is:inline>
      if (window.innerWidth >= 1201) {
        var spans = document.querySelectorAll(".tria-logo span");
        if (spans.length) {
          gsap.fromTo(
            spans,
            { color: "#ffffff" },
            {
              color: "#000000",
              stagger: 0.08,
              ease: "none",
              scrollTrigger: {
                trigger: ".tria-banner",
                start: "bottom bottom",
                end: "bottom top",
                scrub: true,
              },
            },
          );
        }
      }
    </script>

    <script is:inline src="/tria-main.js"></script>
    <script is:inline src="/tria-gradient.js"></script>
  </body>
</html>
