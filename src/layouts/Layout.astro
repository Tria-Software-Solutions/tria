---
import Header from "../components/Header.astro";
import "../styles/global.css";
import "../styles/tria-theme.css";
import { createT } from "../i18n/utils";
import enData from "../i18n/en.json";
import esData from "../i18n/es.json";

interface Props {
  title?: string;
  description?: string;
}

const locale = Astro.currentLocale || "en";
const t = createT(locale);

const {
  title = "Tria — Software Solutions",
  description = "Software enterprise crafting digital solutions from Costa Rica.",
} = Astro.props;

const pathname = Astro.url.pathname;
const path = pathname.replace(/\/+$/, "") || "/";
const barePath = path.startsWith("/es") ? (path.replace(/^\/es/, "") || "/") : path;
const enHref = barePath;
const esHref = `/es${barePath === "/" ? "" : barePath}`;

const translData = JSON.stringify({ en: enData, es: esData });
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="description" content={description} />
    <title>Tria — Software Solutions</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="stylesheet" href="/assets/css/vendor/bootstrap-grid.css" />
    <link rel="stylesheet" href="/assets/css/vendor/swiper.min.css" />
    <link rel="stylesheet" href="/assets/css/vendor/fancybox.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />

  </head>
  <body>
    <script is:inline set:html={`window.__triaTranslations=${translData};`}></script>
    <!-- wrapper -->
    <div class="tria-wrapper" id="top">
      <!-- cursor -->
      <div class="tria-ball">
        <span class="tria-icon-1">
          <svg viewBox="0 0 128 128">
            <path
              d="M106.1,41.9c-1.2-1.2-3.1-1.2-4.2,0c-1.2,1.2-1.2,3.1,0,4.2L116.8,61H11.2l14.9-14.9c1.2-1.2,1.2-3.1,0-4.2	c-1.2-1.2-3.1-1.2-4.2,0l-20,20c-1.2,1.2-1.2,3.1,0,4.2l20,20c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9c1.2-1.2,1.2-3.1,0-4.2	L11.2,67h105.5l-14.9,14.9c-1.2,1.2-1.2,3.1,0,4.2c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9l20-20c1.2-1.2,1.2-3.1,0-4.2L106.1,41.9	z"
            ></path>
          </svg>
        </span>
        <div class="tria-more-text">More</div>
        <div class="tria-choose-text">Сhoose</div>
      </div>

      <!-- preloader -->
      <div class="tria-preloader">
        <div class="tria-preloader-animation">
          <div class="tria-pos-abs tria-animation-1">
            <p class="tria-h3 tria-muted tria-thin" data-i18n="splash.design">{t("splash.design")}</p>
            <p class="tria-h3 tria-muted" data-i18n="splash.build">{t("splash.build")}</p>
            <p class="tria-h3 tria-muted tria-thin" data-i18n="splash.grow">{t("splash.grow")}</p>
          </div>
          <div class="tria-pos-abs tria-animation-2">
            <div class="tria-reveal-frame">
              <p class="tria-reveal-box"></p>
              <p class="tria-h3 tria-muted tria-thin">triacr.com</p>
            </div>
          </div>
        </div>
      </div>

      <!-- scrollbar progress -->
      <div class="tria-progress-track">
        <div class="tria-progress"></div>
      </div>

      <Header />

      <!-- curtain -->
      <div class="tria-curtain"></div>

      <!-- frame -->
      <div class="tria-frame">
        <div class="tria-frame-top">
          <a href="/" class="tria-logo"
            ><span data-i="0">t</span><span data-i="1">r</span><span data-i="2"
              >i</span
            ><span data-i="3">a</span><span data-i="4">.</span></a
          >
          <div class="tria-menu-btn">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="tria-frame-bottom">
          <div class="tria-frame-bottom-left">
            <div class="tria-current-page"></div>
            <span class="tria-lang-sep">|</span>
            <a href={enHref} class="tria-lang-btn" data-lang="en" class:list={{ "is-active": locale === "en" }}>EN</a>
            <a href={esHref} class="tria-lang-btn" data-lang="es" class:list={{ "is-active": locale === "es" }}>ES</a>
          </div>
          <div class="tria-back-to-top">
            <a href="#top" class="tria-link tria-dark tria-arrow-place">
              <span>Back to top</span>
            </a>
          </div>
        </div>
      </div>
      <!-- frame end -->

      <!-- content -->
      <div class="tria-content">
        <div id="swupMain" class="tria-main-transition">
          <slot />
          <!-- hidden elements -->
          <div class="tria-hidden-elements">
            <div class="tria-dodecahedron">
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="tria-pentagon">
                <div></div><div></div><div></div><div></div><div></div>
              </div>
            </div>

            <i class="tria-arrow fas fa-arrow-right"></i>

            <svg
              class="tria-lines"
              viewBox="0 0 44 484"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M22 0V484"></path>
              <path d="M2 0V484"></path>
              <path d="M30 0V484"></path>
              <rect x="7" y="10" width="4" height="100"></rect>
              <rect x="18" y="50" width="4" height="145"></rect>
              <rect x="34" y="10" width="4" height="110"></rect>
              <rect x="10" y="105" width="4" height="140"></rect>
              <rect x="28" y="70" width="4" height="160"></rect>
            </svg>
          </div>
          <!-- hidden elements end -->
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var frame = document.querySelector(".tria-frame");

        function getThemeAt(clientY) {
          var sections = document.querySelectorAll("[data-section-theme]");
          for (var i = 0; i < sections.length; i++) {
            var rect = sections[i].getBoundingClientRect();
            if (clientY >= rect.top && clientY < rect.bottom) {
              return sections[i].getAttribute("data-section-theme");
            }
          }
          return null;
        }

        function updateTextGradient(el, horizontal) {
          if (!el) return;
          var rect = el.getBoundingClientRect();
          var top = rect.top;
          var bottom = rect.bottom;
          var height = bottom - top;
          if (height <= 0) return;

          var sections = document.querySelectorAll(
            "[data-section-theme]",
          );
          var boundaryY;
          var aboveTheme;
          var belowTheme;

          for (var i = 0; i < sections.length - 1; i++) {
            var r = sections[i].getBoundingClientRect();
            var b = r.bottom;
            if (b > top && b < bottom) {
              var t1 = sections[i].getAttribute("data-section-theme");
              var t2 = sections[i + 1].getAttribute(
                "data-section-theme",
              );
              if (t1 !== t2) {
                boundaryY = b;
                aboveTheme = t1;
                belowTheme = t2;
                break;
              }
            }
          }

          var dir = horizontal ? "to bottom" : "to left";

          if (boundaryY !== undefined) {
            var pct =
              ((boundaryY - top) / height) * 100;
            var c1 = aboveTheme === "dark" ? "#fff" : "#000";
            var c2 = belowTheme === "dark" ? "#fff" : "#000";
            var spread = 20;
            var startPct = Math.max(0, pct - spread);
            var endPct = Math.min(100, pct + spread);

            el.style.backgroundImage =
              "linear-gradient(" +
              dir +
              ", " +
              c1 +
              " 0%, " +
              c1 +
              " " +
              startPct +
              "%, " +
              c2 +
              " " +
              endPct +
              "%, " +
              c2 +
              " 100%)";
            el.style.webkitBackgroundClip = "text";
            el.style.backgroundClip = "text";
            el.style.color = "transparent";
          } else {
            var mid = getThemeAt((top + bottom) / 2);
            var col = mid === "dark" ? "#fff" : "#000";
            el.style.backgroundImage = "";
            el.style.webkitBackgroundClip = "";
            el.style.backgroundClip = "";
            el.style.color = col;
          }
        }

        function updateFrameTheme() {
          if (!frame) return;

          // Logo (horizontal text): per-pixel gradient top→bottom
          updateTextGradient(
            document.querySelector(".tria-frame .tria-logo"),
            true,
          );

          // Hamburger: per-line (3 real spans)
          var menuBtn = document.querySelector(
            ".tria-frame .tria-menu-btn",
          );
          if (menuBtn) {
            var lines = menuBtn.querySelectorAll("span");
            for (var i = 0; i < lines.length; i++) {
              var r = lines[i].getBoundingClientRect();
              lines[i].classList.toggle(
                "tria-on-dark",
                getThemeAt(r.top + r.height / 2) === "dark",
              );
            }
          }

          // Language switcher (bottom frame)
          var langBtns = document.querySelectorAll(
            ".tria-frame-bottom-left .tria-lang-btn",
          );
          for (var b = 0; b < langBtns.length; b++) {
            var r = langBtns[b].getBoundingClientRect();
            langBtns[b].classList.toggle(
              "tria-on-dark",
              getThemeAt(r.top + r.height / 2) === "dark",
            );
          }
          var langSep = document.querySelector(
            ".tria-frame-bottom-left .tria-lang-sep",
          );
          if (langSep) {
            var rs = langSep.getBoundingClientRect();
            langSep.classList.toggle(
              "tria-on-dark",
              getThemeAt(rs.top + rs.height / 2) === "dark",
            );
          }

          // Page name: simple on-dark class toggle (a added by tria-main.js later)
          var pageName = document.querySelector(
            ".tria-frame .tria-frame-bottom .tria-current-page",
          );
          if (pageName) {
            var r = pageName.getBoundingClientRect();
            pageName.classList.toggle(
              "tria-on-dark",
              getThemeAt(r.top + r.height / 2) === "dark",
            );
          }

          // Back-to-top text (rotated -90°): gradient right→left = visual bottom→top
          updateTextGradient(
            document.querySelector(
              ".tria-frame .tria-frame-bottom .tria-back-to-top .tria-link > span",
            ),
            false,
          );

          // Back-to-top icon (whole-element)
          var bttIcon = document.querySelector(
            ".tria-frame .tria-frame-bottom .tria-back-to-top .tria-link .fa-arrow-right",
          );
          if (bttIcon) {
            var r = bttIcon.getBoundingClientRect();
            bttIcon.classList.toggle(
              "tria-on-dark",
              getThemeAt(r.top + r.height / 2) === "dark",
            );
          }
        }

        function initFrameTheme() {
          updateFrameTheme();
          // Re-run after tria-main.js clones page name and arrow
          if (document.readyState === "complete") {
            updateFrameTheme();
          } else {
            window.addEventListener("load", function () {
              updateFrameTheme();
            });
          }
        }

        window.addEventListener("scroll", updateFrameTheme, {
          passive: true,
        });
        window.addEventListener("resize", updateFrameTheme);
        initFrameTheme();

        var __heroCleanup = null;
        var __lastHeroBgEl = null;
        window.__reinitHeroBg = function () {
          var bg = document.querySelector(".tria-hero-bg");
          if (!bg) {
            if (__heroCleanup) { 
              try { __heroCleanup(); } catch(e) {}
              __heroCleanup = null; 
            }
            __lastHeroBgEl = null;
            return;
          }
          if (bg === __lastHeroBgEl && __heroCleanup) {
            return;
          }
          if (__heroCleanup) { 
            try { __heroCleanup(); } catch(e) {}
            __heroCleanup = null; 
          }
          __lastHeroBgEl = bg;
          if (bg.dataset.gradProps && window.__initHeroGradient) {
            try {
              __heroCleanup = window.__initHeroGradient(bg, JSON.parse(bg.dataset.gradProps));
            } catch (e) {
              console.error("Failed to init hero bg:", e);
            }
          }
        };

        document.addEventListener("swup:contentReplaced", function () {
          document.title = "Tria — Software Solutions";
          ScrollTrigger.getAll().forEach(function (st) { st.kill(); });
          updateFrameTheme();
          if (window.initTriaGradient) window.initTriaGradient();
          if (window.__reinitHeroBg) {
            window.__reinitHeroBg();
            setTimeout(window.__reinitHeroBg, 100);
            setTimeout(window.__reinitHeroBg, 300);
          }
        });

        (function pollHeroGradient(retries) {
          if (window.__initHeroGradient && document.querySelector('.tria-hero-bg')) {
            __reinitHeroBg();
          } else if (retries < 50) {
            setTimeout(function () { pollHeroGradient(retries + 1); }, 200);
          }
        })(0);
      })();
    </script>
    <script is:inline src="/assets/js/vendor/jquery.min.js"></script>
    <script is:inline src="/assets/js/vendor/swup.min.js"></script>
    <script is:inline src="/assets/js/vendor/swiper.min.js"></script>
    <script is:inline src="/assets/js/vendor/fancybox.min.js"></script>
    <script is:inline src="/assets/js/vendor/gsap.min.js"></script>
    <script is:inline src="/assets/js/vendor/ScrollTrigger.min.js"></script>
    <script is:inline src="/assets/js/vendor/ScrollTo.min.js"></script>
    <script is:inline src="https://unpkg.com/lenis@1.3.23/dist/lenis.min.js"></script>
    <script is:inline src="/assets/js/tria-main.js"></script>
    <script is:inline src="/assets/js/tria-i18n.js"></script>
    <script is:inline src="/assets/js/tria-gradient.js"></script>
    <script>
    import { initGradient } from "../scripts/hero-gradient";
    window.__initHeroGradient = initGradient;
    if (document.querySelector(".tria-hero-bg") && window.__reinitHeroBg) {
      window.__reinitHeroBg();
    }
    </script>
  </body>
</html>
