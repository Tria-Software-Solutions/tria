                  <i class="tria-marquee-icon ti ti-brand-javascript" data-tip="JavaScript"></i>
                  <i class="tria-marquee-icon ti ti-brand-typescript" data-tip="TypeScript"></i>
                  <i class="tria-marquee-icon ti ti-brand-sass" data-tip="Sass"></i>
                  <i class="tria-marquee-icon ti ti-brand-graphql" data-tip="GraphQL"></i>
                  <i class="tria-marquee-icon ti ti-brand-redux" data-tip="Redux"></i>
                  <i class="tria-marquee-icon ti ti-brand-threejs" data-tip="Three.js"></i>
                  <i class="tria-marquee-icon ti ti-brand-docker" data-tip="Docker"></i>
                  <i class="tria-marquee-icon ti ti-brand-vite" data-tip="Vite"></i>
