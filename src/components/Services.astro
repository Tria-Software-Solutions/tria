<style>
  .tria-services-section {
    position: relative;
    overflow: hidden;
    background: #0b0d17;
  }

  .tria-services-section .tria-suptitle {
    color: rgba(255,255,255,0.5);
  }
  .tria-services-section .tria-suptitle::before {
    background-color: rgba(255,255,255,0.15);
  }
  .tria-services-section h2 {
    color: #fff;
  }

  .tria-services-header-right {
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    padding-bottom: 4px;
  }

  .tria-services-view-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: color 0.4s var(--ease-spring), gap 0.4s var(--ease-spring);
  }

  .tria-services-view-link i {
    font-size: 0.7rem;
    transition: transform 0.4s var(--ease-spring);
  }

  .tria-services-view-link:hover {
    color: var(--accent);
    gap: 14px;
  }

  .tria-services-view-link:hover i {
    transform: translateX(4px);
  }



  /* ── service cards ── */
  .tria-services-grid {
    position: relative;
    z-index: 1;
  }

  .tria-services-grid-item {
    padding: 0;
  }

  .tria-service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 50px 40px;
    height: 100%;
    min-height: 260px;
    text-decoration: none;
    overflow: hidden;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.5s var(--ease-spring);
  }

  .tria-services-grid-item:last-child .tria-service-card {
    border-right: none;
  }

  @media (max-width: 991px) {
    .tria-service-card {
      border-right: none;
      min-height: 220px;
      padding: 40px 30px;
    }
  }

  .tria-service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0;
    padding: 1px;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.06) 60%, transparent 80%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.5s var(--ease-spring);
    pointer-events: none;
  }

  .tria-service-card:hover::after {
    opacity: 0.5;
  }

  .tria-service-card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .tria-service-card-title {
    font-size: 1.15rem;
    font-weight: 400;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.4;
    transition: color 0.3s var(--ease-smooth);
  }

  .tria-service-card:hover .tria-service-card-title {
    color: rgba(255,255,255,0.85);
  }

  .tria-service-card-desc {
    font-size: 0.82rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
    max-width: 280px;
    transition: color 0.3s var(--ease-smooth);
  }

  .tria-service-card:hover .tria-service-card-desc {
    color: rgba(255, 255, 255, 0.55);
  }

  .tria-service-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
    font-size: 13px;
    transition: all 0.4s var(--ease-spring);
    flex-shrink: 0;
    margin-top: 24px;
  }

  .tria-service-card:hover .tria-service-arrow {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: scale(1.015);
    filter: brightness(110%);
  }

  /* ── Tech marquee ── */
  .tria-tech-marquee {
    margin-top: 60px;
    position: relative;
    z-index: 1;
  }

  .tria-tech-marquee-inner {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-marquee-row {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }

  .tria-marquee-track {
    display: flex;
    gap: 10px;
    width: max-content;
    animation: tria-marquee-scroll 40s linear infinite;
  }

  .tria-marquee-row--right .tria-marquee-track {
    animation-direction: normal;
  }

  .tria-marquee-row--left .tria-marquee-track {
    animation-direction: reverse;
  }

  @keyframes tria-marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .tria-marquee-icon {
    font-size: 44px;
    color: rgba(255, 255, 255, 0.12);
    flex-shrink: 0;
    transition: color 0.3s var(--ease-spring);
    cursor: default;
  }

  .tria-marquee-icon:hover {
    color: var(--accent);
  }

  .tria-marquee-track {
    gap: 56px;
  }

  @media (max-width: 768px) {
    .tria-marquee-icon {
      font-size: 32px;
    }
    .tria-marquee-track {
      gap: 38px;
    }
  }
</style>
