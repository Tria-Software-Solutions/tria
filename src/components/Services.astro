---
interface Props {
  translations: any;
}

const { translations } = Astro.props;

const services = [
  { key: 'frontend', title: translations.services.frontend.title, description: translations.services.frontend.description, aria_label: translations.services.frontend.aria_label },
  { key: 'mobile', title: translations.services.mobile.title, description: translations.services.mobile.description, aria_label: translations.services.mobile.aria_label },
  { key: 'backend', title: translations.services.backend.title, description: translations.services.backend.description, aria_label: translations.services.backend.aria_label },
  { key: 'devops', title: translations.services.devops.title, description: translations.services.devops.description, aria_label: translations.services.devops.aria_label },
];
---
<section id="services" class="mil-dark-bg">
  <div class="mi-invert-fix">
    <div class="container mil-p-120-120">
      <div class="mil-mb-120">
        <div class="row">
          <div class="col-lg-10">
            <span class="mil-suptitle mil-light-soft mil-suptitle-right mil-up" set:html={translations.services.supertitle}></span>
          </div>
        </div>
        <div class="mil-complex-text justify-content-center mil-up mil-mb-15">
          <h2 class="mil-h1 mil-muted mil-center" set:html={translations.services.title}></h2>
        </div>
        <div class="mil-complex-text justify-content-center mil-up">
          <h2 class="mil-h1 mil-muted mil-center" set:html={translations.services.subtitle}></h2>
        </div>
      </div>
      <div class="row mil-services-grid m-0">
        {services.map((service) => (
          <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
            <a href="#" class="mil-service-card-sm mil-up">
              <h5 class="mil-muted mil-mb-30" set:html={service.title}></h5>
              <p class="mil-light-soft mil-mb-30">{service.description}</p>
              <div class="mil-button mil-icon-button-sm mil-arrow-place" aria-label={service.aria_label} title={service.aria_label}></div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
