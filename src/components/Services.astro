<!-- services -->
<section class="tria-dark-bg" data-section-theme="dark">
  <div class="mi-invert-fix">
    <div class="tria-animation-frame"></div>
    <div class="container tria-p-120-0">
      <div class="tria-mb-120">
        <div class="row">
          <div class="col-lg-10">
            <span
              class="tria-suptitle tria-light-soft tria-suptitle-right tria-up"
              data-i18n-html="services.suptitle">Full-stack software engineering for<br /> startups and enterprises.</span
            >
          </div>
        </div>
        <div
          class="tria-complex-text justify-content-center tria-up tria-mb-15"
        >
          <h2 class="tria-h1 tria-muted tria-center" data-i18n-html="services.modernSolutions">
            Modern <span class="tria-thin">Solutions</span>
          </h2>
        </div>
        <div class="tria-complex-text justify-content-center tria-up">
          <h2 class="tria-h1 tria-muted tria-center" data-i18n-html="services.forYourBusiness">
            For Your <span class="tria-thin">Business</span>
          </h2>
          <a
            href="/services"
            class="tria-services-button tria-button tria-arrow-place"
            ><span data-i18n="hero.ourServices">Our services</span></a
          >
        </div>
      </div>
      <div class="row tria-services-grid m-0">
        <div class="col-md-6 col-lg-3 tria-services-grid-item p-0">
          <a href="/service" class="tria-service-card-sm tria-up">
            <h5 class="tria-muted tria-mb-30" data-i18n-html="services.softwareDev">Software <br />Development</h5>
            <p class="tria-light-soft tria-mb-30" data-i18n="services.softwareDevDesc">
              Custom web and mobile applications built with modern architectures
              and best practices.
            </p>
            <div class="tria-button tria-icon-button-sm tria-arrow-place"></div>
          </a>
        </div>
        <div class="col-md-6 col-lg-3 tria-services-grid-item p-0">
          <a href="/service" class="tria-service-card-sm tria-up">
            <h5 class="tria-muted tria-mb-30" data-i18n-html="services.cloudDevops">
              Cloud &amp; DevOps <br />Solutions
            </h5>
            <p class="tria-light-soft tria-mb-30" data-i18n="services.cloudDevopsDesc">
              Scalable cloud infrastructure, CI/CD pipelines, and automated
              deployments.
            </p>
            <div class="tria-button tria-icon-button-sm tria-arrow-place"></div>
          </a>
        </div>
        <div class="col-md-6 col-lg-3 tria-services-grid-item p-0">
          <a href="/service" class="tria-service-card-sm tria-up">
            <h5 class="tria-muted tria-mb-30" data-i18n-html="services.aiMl">
              AI &amp; Machine <br />Learning
            </h5>
            <p class="tria-light-soft tria-mb-30" data-i18n="services.aiMlDesc">
              Intelligent systems, predictive models, and data-driven automation
              for your business.
            </p>
            <div class="tria-button tria-icon-button-sm tria-arrow-place"></div>
          </a>
        </div>
        <div class="col-md-6 col-lg-3 tria-services-grid-item p-0">
          <a href="/service" class="tria-service-card-sm tria-up">
            <h5 class="tria-muted tria-mb-30" data-i18n-html="services.itCybersecurity">
              IT &amp; Cybersecurity <br />Consulting
            </h5>
            <p class="tria-light-soft tria-mb-30" data-i18n="services.itCybersecurityDesc">
              Security audits, risk assessments, and strategic technology
              planning.
            </p>
            <div class="tria-button tria-icon-button-sm tria-arrow-place"></div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- services end -->
