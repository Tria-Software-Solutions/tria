---
interface ServiceItem {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

interface Props {
  suptitle?: string;
  heading: string;
  viewAllText?: string;
  viewAllHref?: string;
  services: ServiceItem[];
  showTechMarquee?: boolean;
  showArrow?: boolean;
  padding?: string;
}

const {
  suptitle,
  heading,
  viewAllText,
  viewAllHref = "/services",
  services = [],
  showTechMarquee = true,
  showArrow = true,
  padding = 'tria-p-120-120'
} = Astro.props;
---

<!-- services -->
<section class="tria-services-section" data-section-theme="dark">
  <div class={`container ${padding}`}>
      <div class="tria-mb-120">
        <div class="row align-items-end">
          <div class="col-lg-8">
            {suptitle && <span class="tria-suptitle tria-up">{suptitle}</span>}
            <h2 class="tria-up tria-mt-30" set:html={heading} />
          </div>
          {viewAllText && (
            <div class="col-lg-4 tria-services-header-right">
              <a href={viewAllHref} class="tria-services-view-link">
                <span>{viewAllText}</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          )}
        </div>
      </div>
      <div class="row tria-services-grid g-0">
        {services.map((service, index) => (
          <div class="col-md-6 col-lg-3 tria-services-grid-item">
            <a href={service.href} class="tria-service-card tria-up">
              {service.icon && <i class={`tria-service-card-icon ti ${service.icon} tria-service-card-icon--alone`}></i>}
              <div class="tria-service-card-content">
                <h5 class="tria-service-card-title" set:html={service.title} />
                <p class="tria-service-card-desc">{service.description}</p>
              </div>
              {showArrow && (
                <div class="tria-service-arrow">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              )}
            </a>
          </div>
        ))}
      </div>

  </div>

      {showTechMarquee && (
        <!-- Tech marquee -->
        <div class="tria-tech-marquee tria-up">
          <div class="tria-tech-marquee-inner">
              <div class="tria-marquee-row tria-marquee-row--right">
                <div class="tria-marquee-track">
                  <i class="tria-marquee-icon ti ti-brand-react" data-tip="React"></i>
                  <i class="tria-marquee-icon ti ti-brand-vue" data-tip="Vue"></i>
                  <i class="tria-marquee-icon ti ti-brand-angular" data-tip="Angular"></i>
                  <i class="tria-marquee-icon ti ti-brand-svelte" data-tip="Svelte"></i>
                  <i class="tria-marquee-icon ti ti-brand-solidjs" data-tip="SolidJS"></i>
                  <i class="tria-marquee-icon ti ti-brand-nextjs" data-tip="Next.js"></i>
                  <i class="tria-marquee-icon ti ti-brand-astro" data-tip="Astro"></i>
                  <i class="tria-marquee-icon ti ti-brand-flutter" data-tip="Flutter"></i>
                  <i class="tria-marquee-icon ti ti-brand-python" data-tip="Python"></i>
