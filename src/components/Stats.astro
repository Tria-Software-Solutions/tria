---
interface StatItem {
  value: number;
  suffix: string;
  label: string;
}

interface Props {
  stats: StatItem[];
  padding?: string;
}

const {
  stats = [],
  padding = 'tria-p-90-90'
} = Astro.props;
---

<!-- stats -->
<section id="stats" class="tria-stats-section" data-section-theme="light">
  <div class={`container ${padding}`}>
      <div class="row tria-stats-grid">
        {stats.map((stat) => (
          <div class={`col-6 col-lg-3 tria-stat-item tria-up`}>
            <div class="tria-stat-number">
              <span class="tria-counter" data-target={stat.value}>0</span><span class="tria-stat-suffix">{stat.suffix}</span>
            </div>
            <p class="tria-stat-label tria-dark-soft">{stat.label}</p>
          </div>
        ))}
      </div>
  </div>
</section>
<!-- stats end -->

<style>
  .tria-stats-section {
    position: relative;
    background: #ffffff;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .tria-stats-grid {
    margin-bottom: 0;
  }

  .tria-stat-item {
    padding: 40px 30px;
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    position: relative;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-stat-item:hover {
    background: rgba(6,142,140,0.02);
  }

  .tria-stat-item:last-child {
    border-right: none;
  }

  @media (max-width: 991px) {
    .tria-stat-item:nth-child(2) {
      border-right: none;
    }
    .tria-stat-item:nth-child(3) {
      border-right: 1px solid rgba(0, 0, 0, 0.06);
    }
  }

  @media (max-width: 576px) {
    .tria-stat-item {
      padding: 28px 16px;
    }
    .tria-stat-number {
      margin-bottom: 8px;
    }
    .tria-counter {
      font-size: clamp(2.5rem, 10vw, 3.5rem);
    }
    .tria-stat-suffix {
      font-size: clamp(1.4rem, 5vw, 2rem);
    }
    .tria-stat-label {
      font-size: 0.6rem;
    }
  }

  .tria-stat-number {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 12px;
  }

  .tria-counter {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300;
    color: #0b0d17;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .tria-stat-suffix {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 300;
    color: var(--accent, #068e8c);
    line-height: 1;
  }

  .tria-stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0;
    color: rgba(0,0,0,0.5);
  }


</style>

<script is:inline>
  (function () {
    function animateCounter(el) {
      var target = parseInt(el.getAttribute('data-target'), 10);
      var duration = 2000;
      var start = null;
      function step(ts) {
        if (!start) start = ts;
        var progress = Math.min((ts - start) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target);
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = target;
      }
      requestAnimationFrame(step);
    }

    function initCounters() {
      var counters = document.querySelectorAll('.tria-counter');
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      counters.forEach(function (c) { observer.observe(c); });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCounters);
    } else {
      initCounters();
    }
    document.addEventListener('swup:contentReplaced', initCounters);
  })();
</script>
