---
import Footer from "./Footer.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Footer
  brandName="tria"
  brandHref="/"
  brandDescription={t("footer.description") || ""}
  socialLabel={t("contact.info.followUs") || ""}
  exploreLabel={t("nav.explore") || ""}
  servicesLabel={t("nav.services") || ""}
  projectsLabel={t("nav.projects") || ""}
  contactLabel={t("nav.contactInfo") || ""}
  exploreLinks={[
    { href: "/", label: t("nav.home") || "" },
    { href: "/about", label: t("nav.about") || "" },
    { href: "/team", label: t("nav.team") || "" },
    { href: "/portfolio", label: t("nav.work") || "" },
    { href: "/blog", label: t("nav.blog") || "Blog" },
    { href: "/contact", label: t("nav.contact") || "" }
  ]}
  serviceLinks={[
    { href: "/services#software-dev", label: t("nav.softwareDev") || "", html: true },
    { href: "/services#cloud-devops", label: t("nav.cloudDevops") || "", html: true },
    { href: "/services#ai-ml", label: t("nav.aiMl") || "", html: true },
    { href: "/services#cybersecurity", label: t("nav.cybersecurity") || "", html: true }
  ]}
  projectLinks={[
    { href: "https://choferesdealquiler.vercel.app", label: t("nav.cloudInfra") || "" },
    { href: "/project-2", label: t("nav.fintechDashboard") || "" },
    { href: "/project-3", label: t("nav.ecommerce") || "" },
    { href: "/project-4", label: t("nav.aiAnalytics") || "" },
    { href: "/project-5", label: t("nav.iotFleet") || "" },
    { href: "/project-6", label: t("nav.healthcareData") || "" }
  ]}
  contactLinks={[
    { href: "mailto:hola@triacr.com", label: t("footer.contactLink") || "", icon: "ti-mail" },
    { href: "mailto:support@triacr.com", label: t("footer.supportLink") || "", icon: "ti-headset" },
    { href: "mailto:sales@triacr.com", label: t("footer.salesLink") || "", icon: "ti-briefcase" },
    { href: "https://wa.me/50662164040", label: t("footer.whatsappLink") || "", icon: "ti-brand-whatsapp", external: true }
  ]}
  socialLinks={[
    { href: "https://linkedin.com", label: "LinkedIn", icon: "ti ti-brand-linkedin" },
    { href: "https://x.com", label: "X", icon: "ti ti-brand-x" },
    { href: "https://instagram.com", label: "Instagram", icon: "ti ti-brand-instagram" },
    { href: "https://github.com", label: "GitHub", icon: "ti ti-brand-github" }
  ]}
  copyrightText={t("footer.allRights")?.replace("{year}", String(new Date().getFullYear())) || ""}
  legalLinks={[
    { href: "/privacy", label: t("nav.privacyPolicy") || "" },
    { href: "/terms", label: t("nav.terms") || "" },
    { href: "/cookies", label: t("nav.cookiePolicy") || "" }
  ]}
  showGlow={true}
/>
