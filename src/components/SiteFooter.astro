---
import Footer from "./Footer.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);

// Determine current page path for footer filtering
const pathname = Astro.url.pathname;
const path = pathname.replace(/\/+$/, "") || "/";
const barePath = path.startsWith("/es") ? (path.replace(/^\/es/, "") || "/") : path;

// Filter explore links: exclude the current page
const allExploreLinks = [
  { href: "/", label: t("nav.home") || "" },
  { href: "/about", label: t("nav.about") || "" },
  { href: "/team", label: t("nav.team") || "" }
];

function isCurrent(href: string): boolean {
  const cleanHref = href.replace(/\/+$/, "") || "/";
  // Don't filter anchor links (#section) — they're in-page navigation
  if (cleanHref.includes("#")) return false;
  const pathPart = cleanHref.split("#")[0];
  return barePath === pathPart || barePath.startsWith(pathPart + "/");
}

const exploreLinks = allExploreLinks.filter((link) => !isCurrent(link.href));

// Also filter serviceLinks and projectLinks
const allServiceLinks = [
  { href: "/services/software-dev", label: t("nav.softwareDev") || "" },
  { href: "/services/cloud-devops", label: t("nav.cloudDevops") || "" },
  { href: "/services/ai-ml", label: t("nav.aiMl") || "" },
  { href: "/services/cybersecurity", label: t("nav.cybersecurity") || "" }
];

const allProjectLinks = [
  { href: "/portfolio", label: t("nav.work") || "" },
  { href: "/contact", label: t("nav.contact") || "" }
];

const serviceLinks = allServiceLinks.filter((link) => !isCurrent(link.href));
const projectLinks = allProjectLinks.filter((link) => !isCurrent(link.href));

/* ── Page sections for "On this page" column ── */

function getPageSections(): { href: string; label: string }[] {
  const p = barePath;
  const sections: Record<string, { href: string; label: string }[]> = {
    "/": [
      { href: "/#services", label: t("nav.services") || "Services" },
      { href: "/#featured", label: t("featured.title")?.replace(/<[^>]*>/g, "") || "Featured Work" },
      { href: "/#process", label: t("process.title")?.replace(/<[^>]*>/g, "") || "Process" },
      { href: "/#pricing", label: "Pricing" },
      { href: "/#faq", label: "FAQ" }
    ],
    "/services": [
      { href: "/services/#showcase", label: t("services.showcase.suptitle") || "Capabilities" },
      { href: "/services/#engagement", label: t("services.engagement.suptitle") || "Engagement" }
    ],
    "/about": [
      { href: "/about#values", label: t("about.valuesSuptitle") || "Values" },
      { href: "/about#testimonials", label: "Testimonials" }
    ],
    "/team": [
      { href: "/team#team", label: t("team.suptitle") || "Team" },
      { href: "/team#culture", label: t("team.cultureSuptitle") || "Culture" }
    ],
    "/portfolio": [
      { href: "/portfolio#projects", label: t("portfolio.suptitle") || "Projects" }
    ],
    "/contact": [
      { href: "/contact#contact-form", label: t("contact.heading")?.replace(/<[^>]*>/g, "") || "Contact" },
      { href: "/contact#location", label: t("contact.info.location") || "Location" }
    ]
  };
  // Check service detail pages
  if (p.startsWith("/services/software-dev")) {
    return [
      { href: "/services/software-dev#overview", label: "Overview" },
      { href: "/services/software-dev#features", label: "Features" },
      { href: "/services/software-dev#process", label: "Process" }
    ];
  }
  if (p.startsWith("/services/cloud-devops")) {
    return [
      { href: "/services/cloud-devops#overview", label: "Overview" },
      { href: "/services/cloud-devops#features", label: "Features" },
      { href: "/services/cloud-devops#process", label: "Process" }
    ];
  }
  if (p.startsWith("/services/ai-ml")) {
    return [
      { href: "/services/ai-ml#overview", label: "Overview" },
      { href: "/services/ai-ml#features", label: "Features" },
      { href: "/services/ai-ml#process", label: "Process" }
    ];
  }
  if (p.startsWith("/services/cybersecurity")) {
    return [
      { href: "/services/cybersecurity#overview", label: "Overview" },
      { href: "/services/cybersecurity#features", label: "Features" },
      { href: "/services/cybersecurity#process", label: "Process" }
    ];
  }
  return sections[p] || [];
}

const pageSections = getPageSections();
const footerSectionsLabel = Astro.currentLocale === "es" ? "En esta página" : "On this page";

const footerExploreLabel = t("nav.explore") || "";
const footerServicesLabel = t("nav.services") || "";
const footerProjectsLabel = t("nav.usefulLinks") || "";
const footerContactLabel = t("nav.contactInfo") || "";
const footerNewsletterLabel = t("footer.stayInLoop") || "";
const footerNewsletterPlaceholder = t("footer.emailPlaceholder") || "";
const footerNewsletterHeading = t("footer.newsletterHeading") || "";
const footerSocialLabel = t("contact.info.followUs") || "";
const footerBrandDesc = t("footer.description") || "";
const footerCopyright = t("footer.allRights")?.replace("{year}", String(new Date().getFullYear())) || "";
---

<Footer
  brandName="tria"
  brandHref="/"
  brandDescription={footerBrandDesc}
  socialLabel={footerSocialLabel}
  exploreLabel={footerExploreLabel}
  servicesLabel={footerServicesLabel}
  projectsLabel={footerProjectsLabel}
  contactLabel={footerContactLabel}
  newsletterLabel={footerNewsletterLabel}
  newsletterPlaceholder={footerNewsletterPlaceholder}
  newsletterHeading={footerNewsletterHeading}
  sectionsLabel={footerSectionsLabel}
  pageSections={pageSections}
  exploreLinks={exploreLinks}
  serviceLinks={serviceLinks}
  projectLinks={projectLinks}
  contactLinks={[
    { href: "mailto:hola@triacr.com", label: t("footer.contactLink") || "", icon: "ti-mail" },
    { href: "mailto:support@triacr.com", label: t("footer.supportLink") || "", icon: "ti-headset" },
    { href: "mailto:sales@triacr.com", label: t("footer.salesLink") || "", icon: "ti-briefcase" }
  ]}
  socialLinks={[
    { href: "https://linkedin.com", label: "LinkedIn", icon: "ti ti-brand-linkedin" },
    { href: "https://x.com", label: "X", icon: "ti ti-brand-x" },
    { href: "https://instagram.com", label: "Instagram", icon: "ti ti-brand-instagram" },
    { href: "https://github.com", label: "GitHub", icon: "ti ti-brand-github" }
  ]}
  copyrightText={footerCopyright}
  legalLinks={[
    { href: "/privacy", label: t("nav.privacyPolicy") || "" },
    { href: "/terms", label: t("nav.terms") || "" },
    { href: "/cookies", label: t("nav.cookiePolicy") || "" }
  ]}
  showGlow={true}
/>
