---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<!-- cta -->
<section class="tria-cta-section" data-section-theme="light">
  <div class="tria-cta-glow"></div>
  <div class="container tria-p-120-120">
      <div class="row justify-content-center tria-cta-inner">
        <div class="col-lg-10 tria-center">
          <span class="tria-suptitle tria-light-soft tria-up tria-mb-30" style="display:block;text-align:center;" data-i18n="cta.suptitle">{t("cta.suptitle")}</span>
          <h2 class="tria-cta-heading tria-up tria-mb-60" data-i18n-html="cta.heading" set:html={t("cta.heading")} />
          <div class="tria-cta-actions tria-up">
            <a href="/contact" class="tria-button tria-arrow-place">
              <span data-i18n="cta.startProject">{t("cta.startProject")}</span>
            </a>
            <a href="/portfolio" class="tria-cta-link">
              <span data-i18n="cta.seeWork">{t("cta.seeWork")}</span>
            </a>
          </div>
        </div>
      </div>

      <!-- bottom info row -->
      <div class="row tria-cta-meta tria-up">
        <div class="col-md-4 tria-cta-meta-item">
          <span class="tria-cta-meta-label" data-i18n="cta.responseLabel">{t("cta.responseLabel")}</span>
          <span class="tria-cta-meta-value" data-i18n="cta.responseValue">{t("cta.responseValue")}</span>
        </div>
        <div class="col-md-4 tria-cta-meta-item tria-center">
          <span class="tria-cta-meta-label" data-i18n="cta.locationLabel">{t("cta.locationLabel")}</span>
          <span class="tria-cta-meta-value" data-i18n="cta.locationValue">{t("cta.locationValue")}</span>
        </div>
        <div class="col-md-4 tria-cta-meta-item" style="text-align:right;">
          <span class="tria-cta-meta-label" data-i18n="cta.availabilityLabel">{t("cta.availabilityLabel")}</span>
          <span class="tria-cta-meta-value" data-i18n="cta.availabilityValue">{t("cta.availabilityValue")}</span>
        </div>
      </div>
  </div>
</section>
<!-- cta end -->

<style>
  .tria-cta-section {
    position: relative;
    overflow: hidden;
    background: #ffffff;
  }

  .tria-cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(6,142,140,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .tria-cta-inner {
    position: relative;
    z-index: 1;
  }

  .tria-cta-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 450;
    color: #0b0d17;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .tria-cta-accent {
    color: rgba(0, 0, 0, 0.25);
    font-weight: 300;
    font-style: italic;
  }

  .tria-cta-actions {
    display: flex;
    align-items: center;
    gap: 40px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tria-cta-link {
    font-size: 0.8rem;
    color: rgba(0, 0, 0, 0.4);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-cta-link:hover {
    color: var(--accent);
  }

  /* Meta row */
  .tria-cta-meta {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding-top: 50px;
    margin-top: 90px;
  }

  .tria-cta-meta-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tria-cta-meta-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.3);
  }

  .tria-cta-meta-value {
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.6);
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .tria-cta-meta-item {
      text-align: left !important;
      margin-bottom: 30px;
    }
    .tria-cta-meta-item:last-child {
      margin-bottom: 0;
    }
  }
</style>
