---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<!-- cta -->
<section class="tria-cta-section" data-section-theme="light">
  <div class="tria-cta-glow"></div>
  <div class="container tria-p-120-120">
      <div class="row justify-content-center tria-cta-inner">
        <div class="col-lg-10 tria-center">
          <span class="tria-suptitle tria-light-soft tria-up tria-mb-30" style="display:block;text-align:center;" data-i18n="ctaAlt.suptitle">{t("ctaAlt.suptitle")}</span>
          <h2 class="tria-cta-heading tria-up tria-mb-60" data-i18n-html="ctaAlt.heading" set:html={t("ctaAlt.heading")} />
          <div class="tria-cta-actions tria-up">
            <a href="/contact" class="tria-button tria-arrow-place">
              <span data-i18n="ctaAlt.startProject">{t("ctaAlt.startProject")}</span>
            </a>
            <a href="/portfolio" class="tria-cta-link">
              <span data-i18n="ctaAlt.seeWork">{t("ctaAlt.seeWork")}</span>
            </a>
          </div>
        </div>
      </div>

  </div>
</section>
<!-- cta end -->

<style>
  .tria-cta-section {
    position: relative;
    overflow: hidden;
    background: #f5f6fa;
  }

  .tria-cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(6,142,140,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .tria-cta-inner {
    position: relative;
    z-index: 1;
  }

  .tria-cta-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 450;
    color: #0b0d17;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .tria-cta-accent {
    color: rgba(0, 0, 0, 0.25);
    font-weight: 300;
    font-style: italic;
  }

  .tria-cta-actions {
    display: flex;
    align-items: center;
    gap: 40px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tria-cta-link {
    font-size: 0.8rem;
    color: rgba(0, 0, 0, 0.4);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-cta-link:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
  }
</style>
