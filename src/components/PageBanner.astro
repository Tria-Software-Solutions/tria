---
interface Props {
  suptitleKey?: string;
  headingKey: string;
  descriptionKey?: string;
}

const { suptitleKey, headingKey, descriptionKey } = Astro.props;
const { createT } = await import("../i18n/utils");
const t = createT(Astro.currentLocale);
const hasChildren = await Astro.slots.render("default");
---

<section class="page-hero" data-section-theme="dark">
  <div class="page-hero-bg">
    <div class="page-hero-bg-dots"></div>
    <div class="page-hero-orb page-hero-orb--1"></div>
    <div class="page-hero-orb page-hero-orb--2"></div>
    <div class="page-hero-gradient-overlay"></div>
    <div class="tria-hero-grain"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-2"></div>
    </div>
  </div>
  <div class="container page-hero-inner">
    {hasChildren ? (
      <div class="row">
        <div class="col-lg-8">
          {suptitleKey && <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n={suptitleKey}>{t(suptitleKey)}</span>}
          <h1 class="tria-up page-hero-heading" data-i18n-html={headingKey} set:html={t(headingKey)} />
          {descriptionKey && <p class="tria-up page-hero-sub" data-i18n={descriptionKey}>{t(descriptionKey)}</p>}
        </div>
        <div class="col-lg-4">
          <slot />
        </div>
      </div>
    ) : descriptionKey ? (
      <div class="row">
        <div class="col-lg-7">
          {suptitleKey && <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n={suptitleKey}>{t(suptitleKey)}</span>}
          <h1 class="page-hero-heading tria-up" data-i18n-html={headingKey} set:html={t(headingKey)} />
        </div>
        <div class="col-lg-4 offset-lg-1 tria-up">
          <p class="page-hero-sub" data-i18n={descriptionKey}>{t(descriptionKey)}</p>
        </div>
      </div>
    ) : (
      <div>
        {suptitleKey && <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n={suptitleKey}>{t(suptitleKey)}</span>}
        <h1 class="page-hero-heading tria-up" data-i18n-html={headingKey} set:html={t(headingKey)} />
      </div>
    )}
  </div>
</section>
