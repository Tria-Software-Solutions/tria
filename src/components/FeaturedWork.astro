---
import Button from "./Button.astro";

interface WorkItem {
  category: string;
  title: string;
  description: string;
  href: string;
  gradient: string;
  tags?: string[];
  stat?: string;
  statLabel?: string;
  previewImg?: string;
}

interface Props {
  suptitle?: string;
  heading: string;
  viewAllText?: string;
  viewAllHref?: string;
  ctaText?: string;
  projects: WorkItem[];
  padding?: string;
}

const {
  suptitle,
  heading,
  viewAllText,
  viewAllHref = "/portfolio",
  ctaText = "View project",
  projects = [],
  padding = 'tria-p-120-120'
} = Astro.props;

// Triplicate all cards for seamless infinite scroll in both directions
const allCards = projects.length > 0 ? [...projects, ...projects, ...projects] : [];
---

<section id="featured" class="tria-feat" data-section-theme="light">
  <div class="tria-ambient-temp">
    <div class="tria-at-glow-3"></div>
  </div>

  <div class={`container ${padding}`}>
    <div class="row align-items-end tria-mb-60">
      <div class="col-lg-8">
        {suptitle && <span class="tria-suptitle tria-up">{suptitle}</span>}
        <h2 class="tria-up tria-mt-30" set:html={heading} />
      </div>
      {viewAllText && (
        <div class="col-lg-4 tria-feat-header-right">
          <a href={viewAllHref} class="tria-feat-view-link">
            <span>{viewAllText}</span>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      )}
    </div>

    <div class="tria-feat-track-wrap">
      <div class="tria-feat-track" id="featTrack">
        {allCards.map((card, i) => {
          return (
          <a
            href={card.href}
            class="tria-feat-card"
            data-index={i}
            target={card.href.startsWith('http') ? '_blank' : undefined}
            rel={card.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            <div class="tria-feat-bg" style={`background: ${card.gradient};`}>
              <div class="tria-feat-bg-shift"></div>
            </div>
            <div class="tria-feat-grain"></div>
            <div class="tria-feat-inner">
              {card.previewImg && (
                <div class="tria-feat-img-outer">
                  <div class="tria-feat-img-wrap">
                    <img src={card.previewImg} alt={card.title} class="tria-feat-img" loading="lazy" />
                    <div class="tria-feat-img-glare"></div>
                  </div>
                </div>
              )}
              <div class="tria-feat-info">
                <div class="tria-feat-info-glass"></div>
                <div class="tria-feat-info-content">
                  <span class="tria-feat-cat">{card.category}</span>
                  <h3 class="tria-feat-title">{card.title}</h3>
                  <p class="tria-feat-desc">{card.description}</p>
                  <div class="tria-feat-info-row">
                    {card.tags && card.tags.length > 0 && (
                      <div class="tria-feat-tags">
                        {card.tags.slice(0, 4).map((tag) => (
                          <span class="tria-feat-tag">{tag}</span>
                        ))}
                      </div>
                    )}
                    {card.stat && (
                      <div class="tria-feat-stat">
                        <span class="tria-feat-stat-val">{card.stat}</span>
                        {card.statLabel && <span class="tria-feat-stat-lbl">{card.statLabel}</span>}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
            <div class="tria-feat-glow-edge"></div>
          </a>
          );
        })}
      </div>
    </div>

    {/* Progress bar navigation */}
    <div class="tria-feat-nav">
      <Button iconOnly={true} variant="ghost" size="xs" id="featPrev" aria-label="Previous" className="tria-feat-btn-prev">
        <svg slot="icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3l-5 5 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </Button>
      <div class="tria-feat-progress" id="featProgress">
        {projects.map((_, i) => (
          <button
            class="tria-feat-prog-bar"
            aria-label={`Go to project ${i + 1}`}
            data-index={i}
          ></button>
        ))}
      </div>
      <Button iconOnly={true} variant="ghost" size="xs" id="featNext" aria-label="Next" className="tria-feat-btn-next">
        <svg slot="icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </Button>
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════
     SECTION
     ═══════════════════════════════════════ */
  .tria-feat {
    position: relative;
    background: #f5f7f9;
    overflow: hidden;
  }
  .tria-feat .container { position: relative; z-index: 1; }

  /* ── Header ── */
  .tria-feat h2 { color: #0b0d17; }
  .tria-feat-header-right {
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
  }
  .tria-feat .tria-suptitle {
    color: rgba(0,0,0,0.4);
  }
  .tria-feat .tria-suptitle::before {
    background-color: rgba(0,0,0,0.1);
  }
  .tria-feat-view-link {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.8rem; font-weight: 500;
    color: rgba(0, 0, 0, 0.3);
    text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;
    transition: color 0.4s var(--ease-spring), gap 0.4s var(--ease-spring), transform 0.4s var(--ease-spring);
    flex-shrink: 0;
    will-change: transform;
  }
  .tria-feat-view-link svg { transition: transform 0.4s var(--ease-spring); }
  .tria-feat-view-link:hover { color: var(--accent); gap: 14px; transform: translateY(-1px); }
  .tria-feat-view-link:hover svg { transform: translateX(4px); }

  /* ═══════════════════════════════════════
     TRACK
     ═══════════════════════════════════════ */
  .tria-feat-track-wrap {
    position: relative;
    padding: 0;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }
  .tria-feat-track {
    display: flex; gap: 0;
    overflow-x: auto; overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 10px 0 20px;
    scrollbar-width: none; -ms-overflow-style: none;
    cursor: grab;
  }
  .tria-feat-track::-webkit-scrollbar { display: none; }
  .tria-feat-track:active { cursor: grabbing; }
  .tria-feat-track.is-autoplaying { scroll-snap-type: none !important; }

  /* ═══════════════════════════════════════
     CARD
     ═══════════════════════════════════════ */
  .tria-feat-card {
    position: relative;
    flex-shrink: 0;
    width: calc(100% - 80px);
    max-width: 820px;
    height: 680px;
    border-radius: 28px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    scroll-snap-align: center;
    margin: 0 12px;
    transition: box-shadow 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    transform-style: preserve-3d;
    will-change: transform;
    outline: none;
    border: 1px solid rgba(255,255,255,0.03);
  }

  .tria-feat-card:focus-visible {
    box-shadow: 0 0 0 2px var(--accent), 0 30px 80px rgba(0,0,0,0.5);
  }

  /* (no CSS needed for entrance — handled entirely in JS via inline styles) */

  /* ── Animated gradient BG ── */
  .tria-feat-bg {
    position: absolute; inset: -20px; z-index: 0;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-feat-bg-shift {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 40%, rgba(255,255,255,0.03) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 60%, rgba(6,142,140,0.04) 0%, transparent 50%);
    animation: tria-bg-drift 8s ease-in-out infinite alternate;
  }
  @keyframes tria-bg-drift {
    0% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    100% { transform: translate(15px, -10px) scale(1.1); opacity: 1; }
  }
  .tria-feat-card:hover .tria-feat-bg { transform: scale(1.08); }

  /* ── Grain ── */
  .tria-feat-grain {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    opacity: 0.15; mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat; background-size: 160px 160px;
  }

  /* ── Inner layout ── */
  .tria-feat-inner {
    position: relative; z-index: 2;
    height: 100%;
    display: flex; flex-direction: column;
    padding: 40px 44px 32px;
    transform-style: preserve-3d;
  }

  /* (no .tria-feat-num — removed) */

  /* ═══════════════════════════════════════
     IMAGE WITH 3D PARALLAX
     ═══════════════════════════════════════ */
  .tria-feat-img-outer {
    flex: 1;
    min-height: 0;
    position: relative;
    margin-bottom: 20px;
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  .tria-feat-img-wrap {
    width: 100%;
    height: 100%;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    transform-style: preserve-3d;
    background: rgba(0,0,0,0.3);
    box-shadow: 0 12px 48px rgba(0,0,0,0.4);
    transition: box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-feat-card:hover .tria-feat-img-wrap {
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 80px rgba(6,142,140,0.04);
  }

  .tria-feat-img {
    display: block;
    width: 100%; height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .tria-feat-card:hover .tria-feat-img {
    transform: scale(1.05);
  }

  /* Glass glare overlay on image */
  .tria-feat-img-glare {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: linear-gradient(
      135deg,
      rgba(255,255,255,0.06) 0%,
      transparent 40%,
      transparent 60%,
      rgba(255,255,255,0.02) 100%
    );
    opacity: 0; transition: opacity 0.6s ease;
  }
  .tria-feat-card:hover .tria-feat-img-glare { opacity: 1; }

  /* ── Tags in info section (always visible) ── */
  .tria-feat-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 2px;
  }
  .tria-feat-tag {
    font-size: 0.45rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.3);
    border: 0.5px solid rgba(255,255,255,0.04);
    transition: background 0.4s var(--ease-spring), color 0.4s var(--ease-spring), border-color 0.4s var(--ease-spring);
  }
  .tria-feat-card:hover .tria-feat-tag {
    background: rgba(6,142,140,0.08);
    color: rgba(6,142,140,0.6);
    border-color: rgba(6,142,140,0.08);
  }

  /* ═══════════════════════════════════════
     INFO — GLASS PANEL
     ═══════════════════════════════════════ */
  .tria-feat-info {
    position: relative;
    flex-shrink: 0;
    margin: 0 -44px -32px;
    padding: 0 44px 32px;
    transform: translateZ(30px);
    transform-style: preserve-3d;
  }
  /* Glass overlay background */
  .tria-feat-info-glass {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    pointer-events: none;
    border-radius: 0 0 28px 28px;
    transition: opacity 0.6s ease;
  }
  .tria-feat-info-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .tria-feat-cat {
    font-size: 0.45rem;
    font-weight: 550;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
    transition: opacity 0.4s ease;
  }
  .tria-feat-card:hover .tria-feat-cat { opacity: 1; }
  .tria-feat-title {
    font-size: 1.5rem;
    font-weight: 420;
    color: #fff;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.03em;
    transition: letter-spacing 0.5s var(--ease-spring);
  }
  .tria-feat-card:hover .tria-feat-title { letter-spacing: -0.02em; }
  .tria-feat-desc {
    font-size: 0.7rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.4);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.4s ease;
  }
  .tria-feat-card:hover .tria-feat-desc { color: rgba(255,255,255,0.55); }

  /* ── Info row (tags + stat) ── */
  .tria-feat-info-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 2px;
  }
  .tria-feat-stat {
    display: flex;
    align-items: baseline;
    gap: 5px;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.4s ease;
  }
  .tria-feat-card:hover .tria-feat-stat { opacity: 0.8; }
  .tria-feat-stat-val {
    font-size: 0.65rem;
    font-weight: 450;
    color: rgba(255,255,255,0.5);
    letter-spacing: -0.01em;
  }
  .tria-feat-stat-lbl {
    font-size: 0.4rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.12);
  }

  /* ── Edge glow ── */
  .tria-feat-glow-edge {
    position: absolute; inset: -1px; border-radius: 29px;
    pointer-events: none; z-index: 5;
    opacity: 0; transition: opacity 0.6s ease;
    box-shadow: inset 0 0 0 1px transparent, 0 0 60px transparent;
  }
  .tria-feat-card:hover .tria-feat-glow-edge {
    opacity: 1;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06), 0 0 60px rgba(6,142,140,0.05);
  }

  /* ═══════════════════════════════════════
     PROGRESS NAV
     ═══════════════════════════════════════ */
  .tria-feat-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
    padding: 0;
  }
  .tria-feat-nav :global(.tria-btn--ghost) {
    color: rgba(0,0,0,0.25);
    border: 0.5px solid rgba(0,0,0,0.06);
    background: rgba(0,0,0,0.02);
  }
  .tria-feat-nav :global(.tria-btn--ghost:hover) {
    background: rgba(0,0,0,0.04);
    color: var(--accent);
    border-color: var(--accent);
    transform: none;
    box-shadow: none;
  }
  .tria-feat-nav :global(.tria-btn--ghost:active) {
    transform: scale(0.92);
  }
  .tria-feat-nav :global(.tria-btn--icon-only svg) {
    width: 16px;
    height: 16px;
  }

  .tria-feat-progress {
    display: flex;
    gap: 6px;
    flex: 1;
    max-width: 200px;
  }
  .tria-feat-prog-bar {
    flex: 1;
    height: 3px;
    border-radius: 3px;
    border: none;
    background: rgba(0,0,0,0.06);
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .tria-feat-prog-bar::after {
    content: '';
    position: absolute; left: 0; top: 0;
    height: 100%; width: 0%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-feat-prog-bar.is-active::after { width: 100%; }
  .tria-feat-prog-bar:hover { background: rgba(0,0,0,0.1); }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */

  /* ── 1600+ large screens ── */
  @media (min-width: 1600px) {
    .tria-feat-card { max-width: 860px; height: 700px; }
  }

  /* ── 1200-1599 default (base styles) ── */

  /* ── 992-1199 ── */
  @media (max-width: 1199px) {
    .tria-feat-card { max-width: 680px; height: 600px; }
    .tria-feat-inner { padding: 30px 32px 24px; }
    .tria-feat-title { font-size: clamp(1.15rem, 2.5vw, 1.3rem); }
  }

  /* ── 768-991 ── */
  @media (max-width: 991px) {
    .tria-feat-card {
      width: calc(100% - 56px);
      max-width: none;
      height: 540px;
      margin: 0 10px;
    }
    .tria-feat-inner { padding: 24px 24px 20px; }
    .tria-feat-title { font-size: clamp(1.05rem, 3vw, 1.15rem); }
    .tria-feat-desc { max-width: 100%; }
    .tria-feat-header-right { justify-content: flex-start; padding-bottom: 0; }
    .tria-feat-info { margin: 0 -24px -20px; padding: 0 24px 20px; }
    .tria-feat-info-glass { border-radius: 0 0 24px 24px; }
  }

  /* ── < 768: vertical list, clean white cards ── */
  @media (max-width: 767px) {
    .tria-feat-track {
      flex-direction: column;
      overflow: visible;
      scroll-snap-type: none;
      gap: 2px;
      cursor: default;
      padding: 0;
    }
    .tria-feat-track:active { cursor: default; }
    .tria-feat-card {
      width: 100%;
      max-width: none;
      height: auto;
      margin: 0;
      border-radius: 0;
      background: #fff;
      transition: background 0.4s ease;
      border: none !important;
      min-height: 200px;
      box-shadow: none !important;
    }
    .tria-feat-card:hover {
      background: #f8f9fc;
    }
    .tria-feat-card:focus-visible { box-shadow: 0 0 0 2px var(--accent) !important; }
    .tria-feat-inner {
      padding: 28px 20px 24px;
      height: auto;
    }
    .tria-feat-img-outer {
      flex: none;
      height: 200px;
      margin-bottom: 16px;
      perspective: none;
    }
    .tria-feat-img-wrap {
      border-radius: 12px;
      height: 200px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.04);
      background: #f5f7f9;
    }
    .tria-feat-img {
      object-fit: contain;
      object-position: center;
    }
    .tria-feat-img-glare { display: none; }
    .tria-feat-bg { display: none; }
    .tria-feat-grain { display: none; }
    .tria-feat-glow-edge { display: none; }
    .tria-feat-info {
      position: relative;
      margin: 0;
      padding: 0;
      transform: none;
    }
    .tria-feat-info-glass { display: none; }
    .tria-feat-info-content { gap: 6px; }
    .tria-feat-cat {
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.9;
      display: block;
      margin-bottom: 4px;
    }
    .tria-feat-title {
      font-size: 1.2rem;
      font-weight: 500;
      color: #0b0d17;
      margin-bottom: 8px;
      line-height: 1.3;
      letter-spacing: -0.02em;
    }
    .tria-feat-desc {
      font-size: 0.82rem;
      line-height: 1.6;
      color: rgba(0, 0, 0, 0.45);
      margin: 0;
      -webkit-line-clamp: 2;
    }
    .tria-feat-info-row {
      margin-top: 12px;
      flex-wrap: wrap;
    }
    .tria-feat-tag {
      font-size: 0.45rem;
      padding: 4px 10px;
      background: rgba(6,142,140,0.06);
      color: rgba(6,142,140,0.6);
      border: 0.5px solid rgba(6,142,140,0.08);
    }
    .tria-feat-nav { display: none; }
    .tria-feat-track-wrap {
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
    }
  }

  /* ── < 480 ── */
  @media (max-width: 480px) {
    .tria-feat-inner { padding: 22px 16px 20px; }
    .tria-feat-img-outer { height: 160px; margin-bottom: 14px; }
    .tria-feat-img-wrap { height: 160px; }
    .tria-feat-title { font-size: 1.1rem; margin-bottom: 8px; }
    .tria-feat-desc { font-size: 0.75rem; }
    .tria-feat-cat { font-size: 0.45rem; }
    .tria-feat-tag { font-size: 0.4rem; padding: 3px 8px; }
  }
</style>

<script is:inline>
  (function () {
    /* ── Remove cloned cards on mobile (triplicated for infinite scroll) ── */
    function cleanupMobileCards() {
      if (!isMobile) return;
      var track = document.getElementById('featTrack');
      if (!track) return;
      var cards = track.querySelectorAll('.tria-feat-card');
      var uniqueCount = cards.length / 3;
      if (uniqueCount < 1) return;
      for (var i = cards.length - 1; i >= uniqueCount; i--) {
        cards[i].remove();
      }
    }

    /* ── Intersection Observer for entrance ── */
    var isMobile = window.innerWidth < 768;

    function initReveal() {
      var cards = document.querySelectorAll('.tria-feat-card');
      if (!cards.length) return;

      // Determine unique project count from triplicated cards
      // On mobile, cleanupMobileCards() already removed clones, so cards.length is the unique count
      var uniqueCount = isMobile ? cards.length : Math.round(cards.length / 3);

      var entranceTransform = isMobile
        ? 'translateY(40px)'
        : 'perspective(1200px) translateY(60px) translateZ(-30px)';
      var finalTransform = isMobile
        ? 'translateY(0)'
        : 'perspective(1200px) translateY(0) translateZ(0)';

      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var idx = parseInt(entry.target.getAttribute('data-index')) || 0;
              // Set stagger delay, then set the FINAL inline values.
              // The existing transition will animate from initial to these values.
              entry.target.style.transitionDelay = (idx * 0.06) + 's';
              entry.target.style.opacity = '1';
              entry.target.style.transform = finalTransform;
              // After entrance completes, clear inline transition so 3D tilt can work
              setTimeout(function () {
                entry.target.style.transition = '';
                entry.target.style.transitionDelay = '';
              }, 1200 + (idx * 60));
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

        cards.forEach(function (card, i) {
          // Cloned cards (second and third sets) should start visible —
          // they're duplicates that scroll into view before the observer fires
          if (i >= uniqueCount) {
            card.style.opacity = '1';
            card.style.transform = finalTransform;
            card.style.transition = '';
            // Still observe so we can clear inline styles after entrance
            observer.observe(card);
            return;
          }
          card.style.opacity = '0';
          card.style.transform = entranceTransform;
          card.style.transition = 'opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
          observer.observe(card);
        });
      } else {
        cards.forEach(function (card) {
          card.style.opacity = '1';
          card.style.transform = 'none';
          card.style.transition = '';
        });
      }
    }

    /* ── 3D Perspective Tilt on hover (desktop only) ── */
    function init3DTilt() {
      if (isMobile) return;
      var cards = document.querySelectorAll('.tria-feat-card');
      // Fast transition for the tilt (separate from entrance)
      var tiltTransition = 'transform 0.3s cubic-bezier(0.16, 1, 0.3, 1)';

      cards.forEach(function (card) {
        card.addEventListener('mouseenter', function () {
          // Override entrance transition with fast tilt-only transition
          card.style.transition = tiltTransition;
        });

        card.addEventListener('mousemove', function (e) {
          var rect = card.getBoundingClientRect();
          var x = (e.clientX - rect.left) / rect.width;
          var y = (e.clientY - rect.top) / rect.height;
          var tiltX = (y - 0.5) * -6;
          var tiltY = (x - 0.5) * 6;

          // Apply subtle 3D tilt to the card (no transition during active move = instant)
          card.style.transition = 'none';
          card.style.transform = 'perspective(1200px) rotateX(' + tiltX + 'deg) rotateY(' + tiltY + 'deg) translateZ(0)';

          // Parallax: image shifts slightly opposite to tilt
          var imgWrap = card.querySelector('.tria-feat-img-wrap');
          if (imgWrap) {
            var imgParallaxX = (x - 0.5) * -12;
            var imgParallaxY = (y - 0.5) * -12;
            imgWrap.style.transform = 'translateX(' + imgParallaxX + 'px) translateY(' + imgParallaxY + 'px)';
          }

          // Glare follows the mouse
          var glare = card.querySelector('.tria-feat-img-glare');
          if (glare) {
            glare.style.background = 'radial-gradient(circle at ' + (x * 100) + '% ' + (y * 100) + '%, rgba(255,255,255,0.08) 0%, transparent 60%)';
            glare.style.opacity = '1';
          }
        });

        card.addEventListener('mouseleave', function () {
          // Use fast transition for the return animation
          card.style.transition = tiltTransition;
          card.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg) translateZ(0)';

          var imgWrap = card.querySelector('.tria-feat-img-wrap');
          if (imgWrap) {
            imgWrap.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
            imgWrap.style.transform = 'translateX(0) translateY(0)';
            setTimeout(function () {
              imgWrap.style.transition = '';
            }, 500);
          }

          var glare = card.querySelector('.tria-feat-img-glare');
          if (glare) {
            glare.style.transition = 'opacity 0.4s ease';
            glare.style.opacity = '0';
            setTimeout(function () {
              glare.style.transition = '';
            }, 500);
          }
        });
      });
    }

    /* Module-level rAF id (cleaned up on swup navigation) */
    var featRAFId = null;

    /* ── Carousel: progress bars + arrows + drag-to-scroll (desktop only) ── */
    function initCarousel() {
      if (isMobile) return;
      var track = document.getElementById('featTrack');
      var bars = document.querySelectorAll('.tria-feat-prog-bar');
      var prevBtn = document.getElementById('featPrev');
      var nextBtn = document.getElementById('featNext');
      if (!track || !bars.length) return;

      /* Cancel any previous rAF loop (e.g. from SWUP navigation) */
      stopAutoScroll();

      var isDragging = false;
      var dragDistance = 0;
      var startX = 0;
      var scrollStart = 0;
      var cards = track.querySelectorAll('.tria-feat-card');
      var currentIndex = 0;

      function getCardGap() {
        var c = track.querySelector('.tria-feat-card');
        if (!c) return 24;
        var s = window.getComputedStyle(c);
        return (parseFloat(s.marginLeft) || 0) + (parseFloat(s.marginRight) || 0);
      }

      if (bars.length < 2) return; // single card — no auto-scroll needed

      /* ── Continuous requestAnimationFrame auto-scroll ── */
      var scrollSpeed = 80; // px per second (one card every ~10s)
      var lastFrame = 0;

      function startAutoScroll() {
        if (featRAFId) return;
        lastFrame = 0;
        track.classList.add('is-autoplaying');

        function loop(timestamp) {
          if (!lastFrame) lastFrame = timestamp;
          var delta = Math.min(timestamp - lastFrame, 80); // cap for tab-away
          lastFrame = timestamp;

          var cardEl = track.querySelector('.tria-feat-card');
          if (!cardEl) { featRAFId = requestAnimationFrame(loop); return; }
          var step = cardEl.offsetWidth + getCardGap();
          var setWidth = bars.length * step;

          track.scrollLeft += scrollSpeed * (delta / 1000);

          /* Invisible reset — bidirectional infinite loop */
          if (track.scrollLeft >= setWidth * 2) {
            track.scrollLeft -= setWidth; // entered right clone → back to originals
          } else if (track.scrollLeft < setWidth) {
            track.scrollLeft += setWidth; // entered left clone → jump to right clone
          }

          featRAFId = requestAnimationFrame(loop);
        }

        featRAFId = requestAnimationFrame(loop);
      }

      function stopAutoScroll() {
        if (featRAFId) {
          cancelAnimationFrame(featRAFId);
          featRAFId = null;
        }
        track.classList.remove('is-autoplaying');
      }

      function pauseAutoScroll() {
        stopAutoScroll();
        // scroll-snap re-enabled via .is-autoplaying removal in CSS
      }

      function resumeAutoScroll() {
        if (!featRAFId) startAutoScroll();
      }

      /* ── Inactivity timer ── */
      var resumeTimer = null;

      function scheduleResume(delay) {
        if (resumeTimer) clearTimeout(resumeTimer);
        resumeTimer = setTimeout(function () {
          resumeAutoScroll();
          resumeTimer = null;
        }, delay || 5000);
      }

      function cancelResume() {
        if (resumeTimer) {
          clearTimeout(resumeTimer);
          resumeTimer = null;
        }
      }

      // Prevent click on <a> when user dragged the carousel
      function preventDragNav(e) {
        if (dragDistance > 5) e.preventDefault();
      }

      function updateBars() {
        var cardEl = track.querySelector('.tria-feat-card');
        if (!cardEl) return;
        var step = cardEl.offsetWidth + getCardGap();
        var computed = Math.round(track.scrollLeft / step);
        currentIndex = ((computed % bars.length) + bars.length) % bars.length;

        bars.forEach(function (bar, i) {
          if (i === currentIndex) bar.classList.add('is-active');
          else bar.classList.remove('is-active');
        });
      }

      function scrollToIndex(idx) {
        var total = bars.length;
        currentIndex = ((idx % total) + total) % total;
        var cardEl = track.querySelector('.tria-feat-card');
        if (!cardEl) return;
        track.scrollTo({ left: currentIndex * (cardEl.offsetWidth + getCardGap()), behavior: 'smooth' });
      }

      /* ── Drag to scroll ── */
      track.addEventListener('mousedown', function (e) {
        cancelResume();
        pauseAutoScroll();
        isDragging = true;
        dragDistance = 0;
        startX = e.pageX - track.offsetLeft;
        scrollStart = track.scrollLeft;
        track.style.cursor = 'grabbing';
        cards.forEach(function (c) { c.addEventListener('click', preventDragNav); });
      });

      window.addEventListener('mousemove', function (e) {
        if (!isDragging) return;
        e.preventDefault();
        var x = e.pageX - track.offsetLeft;
        var walk = (x - startX) * 1.2;
        dragDistance = Math.abs(walk);
        track.scrollLeft = scrollStart - walk;
      });

      window.addEventListener('mouseup', function () {
        if (!isDragging) return;
        isDragging = false;
        track.style.cursor = 'grab';
        setTimeout(function () {
          cards.forEach(function (c) { c.removeEventListener('click', preventDragNav); });
          dragDistance = 0;
        }, 10);
        updateBars();
        scheduleResume(5000);
      });

      /* ── Hover pauses, leave resumes ── */
      track.addEventListener('mouseenter', function () {
        cancelResume();
        pauseAutoScroll();
      });

      track.addEventListener('mouseleave', function () {
        if (!isDragging) startAutoScroll();
      });

      /* ── Touch ── */
      track.addEventListener('touchstart', function () {
        cancelResume();
        pauseAutoScroll();
      });

      track.addEventListener('touchend', function () {
        scheduleResume(4000);
      });

      /* ── Arrow buttons ── */
      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          pauseAutoScroll();
          scrollToIndex(currentIndex - 1);
          scheduleResume(6000);
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          pauseAutoScroll();
          scrollToIndex(currentIndex + 1);
          scheduleResume(6000);
        });
      }

      /* ── Progress bars ── */
      bars.forEach(function (bar) {
        bar.addEventListener('click', function () {
          pauseAutoScroll();
          var idx = parseInt(this.getAttribute('data-index'));
          scrollToIndex(idx);
          scheduleResume(6000);
        });
      });

      /* ── Scroll listener ── */
      track.addEventListener('scroll', updateBars);

      /* ── Init ── */
      // Start at the beginning of the original set (middle third)
      track.scrollLeft = bars.length * (cards[0].offsetWidth + getCardGap());
      updateBars();
      startAutoScroll();
    }

    /* ── Init ── */
    function init() {
      cleanupMobileCards();
      initReveal();
      init3DTilt();
      initCarousel();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('swup:contentReplaced', init);
  })();
</script>
