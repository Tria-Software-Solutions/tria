---
---

<!-- featured work -->
<section class="tria-work-section" data-section-theme="light">
  <div class="container tria-p-120-0">
    <div class="row align-items-end tria-mb-60">
      <div class="col-lg-8">
        <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="featured.suptitle">Selected Work</span>
        <h2 class="tria-up tria-mt-30" data-i18n-html="featured.title">
          Featured <span class="tria-thin">Projects</span>
        </h2>
      </div>
      <div class="col-lg-4 tria-work-header-right">
        <a href="/work" class="tria-button tria-arrow-place tria-up">
          <span data-i18n="featured.viewAll">View all work</span>
        </a>
      </div>
    </div>
  </div>

  <div class="tria-work-grid">
    <a href="/work" class="tria-work-item tria-work-item--large tria-up" data-category="FinTech">
      <div class="tria-work-img-wrap">
        <div class="tria-work-img" style="background: linear-gradient(135deg, #0b0d17 0%, #1a1f35 50%, #56051d 100%);"></div>
        <div class="tria-work-overlay">
          <div class="tria-work-meta">
            <span class="tria-work-category">FinTech</span>
            <span class="tria-work-year">2024</span>
          </div>
          <div class="tria-work-grid-content">
            <h3 class="tria-work-name">FinTech Dashboard Platform</h3>
            <p class="tria-work-desc">Real-time analytics engine processing 10M+ transactions daily with sub-100ms latency.</p>
          </div>
          <div class="tria-work-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
        </div>
        <!-- Abstract visual element -->
        <div class="tria-work-abstract tria-work-abstract--fintech">
          <div class="tria-fa-grid">
            <div></div><div></div><div></div>
            <div></div><div></div><div></div>
            <div></div><div></div><div></div>
          </div>
        </div>
      </div>
    </a>

    <a href="/work" class="tria-work-item tria-up" data-category="Cloud">
      <div class="tria-work-img-wrap">
        <div class="tria-work-img" style="background: linear-gradient(135deg, #1a1f35 0%, #2d3561 100%);"></div>
        <div class="tria-work-overlay">
          <div class="tria-work-meta">
            <span class="tria-work-category">Cloud</span>
            <span class="tria-work-year">2024</span>
          </div>
          <div class="tria-work-grid-content">
            <h3 class="tria-work-name">Cloud Infrastructure Suite</h3>
            <p class="tria-work-desc">Multi-cloud orchestration platform reducing ops overhead by 60%.</p>
          </div>
          <div class="tria-work-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
        </div>
        <div class="tria-work-abstract tria-work-abstract--cloud">
          <div class="tria-cloud-rings">
            <div></div><div></div><div></div>
          </div>
        </div>
      </div>
    </a>

    <a href="/work" class="tria-work-item tria-up" data-category="AI/ML">
      <div class="tria-work-img-wrap">
        <div class="tria-work-img" style="background: linear-gradient(135deg, #0d1117 0%, #56051d 100%);"></div>
        <div class="tria-work-overlay">
          <div class="tria-work-meta">
            <span class="tria-work-category">AI / ML</span>
            <span class="tria-work-year">2023</span>
          </div>
          <div class="tria-work-grid-content">
            <h3 class="tria-work-name">AI-Powered Analytics</h3>
            <p class="tria-work-desc">Predictive models delivering 94% accuracy across 15 business verticals.</p>
          </div>
          <div class="tria-work-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
        </div>
        <div class="tria-work-abstract tria-work-abstract--ai">
          <div class="tria-neural-dots"></div>
        </div>
      </div>
    </a>

    <a href="/work" class="tria-work-item tria-work-item--wide tria-up" data-category="Healthcare">
      <div class="tria-work-img-wrap">
        <div class="tria-work-img" style="background: linear-gradient(135deg, #111827 0%, #1f2d40 50%, #0d3050 100%);"></div>
        <div class="tria-work-overlay">
          <div class="tria-work-meta">
            <span class="tria-work-category">Healthcare</span>
            <span class="tria-work-year">2023</span>
          </div>
          <div class="tria-work-grid-content">
            <h3 class="tria-work-name">Healthcare Data Platform</h3>
            <p class="tria-work-desc">HIPAA-compliant data platform serving 200+ healthcare providers with real-time patient insights.</p>
          </div>
          <div class="tria-work-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </div>
    </a>
  </div>

  <div class="container tria-p-60-120">
    <div class="tria-work-cta tria-up">
      <p class="tria-work-cta-text" data-i18n="featured.ctaText">Have a project in mind?</p>
      <a href="/contact" class="tria-link tria-arrow-place">
        <span data-i18n="featured.ctaLink">Let's talk</span>
        <i class="fas fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>
<!-- featured work end -->

<style>
  .tria-work-header-right {
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    padding-bottom: 4px;
  }

  /* Work grid layout */
  .tria-work-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto;
    gap: 2px;
    background: #f5f3ef;
  }

  .tria-work-item {
    overflow: hidden;
    cursor: pointer;
    display: block;
    text-decoration: none;
    position: relative;
  }

  /* Large item: spans 7 columns */
  .tria-work-item--large {
    grid-column: span 7;
    grid-row: span 2;
  }

  /* Small items: 5 columns */
  .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide) {
    grid-column: span 5;
  }

  /* Wide bottom item: full width */
  .tria-work-item--wide {
    grid-column: span 12;
  }

  .tria-work-img-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 340px;
    overflow: hidden;
  }

  .tria-work-item--large .tria-work-img-wrap {
    min-height: 640px;
  }

  .tria-work-item--wide .tria-work-img-wrap {
    min-height: 280px;
  }

  .tria-work-img {
    position: absolute;
    inset: 0;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-work-item:hover .tria-work-img {
    transform: scale(1.04);
  }

  .tria-work-overlay {
    position: absolute;
    inset: 0;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 2;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
    transition: background 0.4s ease;
  }

  .tria-work-item:hover .tria-work-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 60%);
  }

  .tria-work-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .tria-work-category {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 5px 12px;
    border-radius: 20px;
    backdrop-filter: blur(10px);
  }

  .tria-work-year {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.35);
  }

  .tria-work-grid-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .tria-work-name {
    color: #fff;
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 300;
    margin-bottom: 10px;
    line-height: 1.2;
    transform: translateY(10px);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-work-desc {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.8rem;
    line-height: 1.6;
    margin: 0;
    max-width: 380px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.05s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s;
  }

  .tria-work-item:hover .tria-work-name {
    transform: translateY(0);
  }

  .tria-work-item:hover .tria-work-desc {
    opacity: 1;
    transform: translateY(0);
  }

  .tria-work-arrow {
    position: absolute;
    top: 40px;
    right: 40px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 14px;
    transform: translateY(-6px);
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
  }

  .tria-work-item:hover .tria-work-arrow {
    opacity: 1;
    transform: translateY(0);
    background: rgba(255, 255, 255, 0.1);
  }

  /* Abstract decorative elements */
  .tria-work-abstract {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .tria-fa-grid {
    position: absolute;
    right: 40px;
    bottom: 120px;
    display: grid;
    grid-template-columns: repeat(3, 10px);
    gap: 6px;
    opacity: 0.12;
  }
  .tria-fa-grid div {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
  }

  .tria-cloud-rings {
    position: absolute;
    right: 30px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tria-cloud-rings div {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .tria-cloud-rings div:nth-child(1) { width: 80px; height: 80px; }
  .tria-cloud-rings div:nth-child(2) { width: 120px; height: 120px; }
  .tria-cloud-rings div:nth-child(3) { width: 160px; height: 160px; }

  /* CTA bar */
  .tria-work-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(0,0,0,0.08);
    padding-top: 40px;
  }

  .tria-work-cta-text {
    font-size: 1rem;
    color: rgba(0,0,0,0.4);
    margin: 0;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  @media (max-width: 991px) {
    .tria-work-grid {
      grid-template-columns: 1fr;
    }
    .tria-work-item--large,
    .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide),
    .tria-work-item--wide {
      grid-column: span 1;
    }
    .tria-work-item--large .tria-work-img-wrap {
      min-height: 400px;
    }
    .tria-work-header-right {
      justify-content: flex-start;
      margin-top: 30px;
    }
  }

  .tria-mt-30 { margin-top: 30px; }
  .tria-p-60-120 { padding: 60px 0 120px; }
</style>
