---
interface WorkItem {
  category: string;
  title: string;
  description: string;
  href: string;
  gradient: string;
  size?: 'large' | 'wide' | 'normal';
  abstractType?: 'fintech' | 'cloud' | 'ai' | 'none';
  previewImg?: string;
}

interface Props {
  suptitle?: string;
  heading: string;
  viewAllText?: string;
  viewAllHref?: string;
  projects: WorkItem[];
  padding?: string;
}

const {
  suptitle,
  heading,
  viewAllText,
  viewAllHref = "/portfolio",
  projects = [],
  padding = 'tria-p-120-0'
} = Astro.props;
---

<!-- featured work -->
<section class="tria-work-section" data-section-theme="light">
  <div class={`container ${padding}`}>
    <div class="tria-featured-header tria-up">
      <div>
        {suptitle && <span class="tria-suptitle tria-suptitle-dark">{suptitle}</span>}
        <h2 class="tria-mt-30" set:html={heading} />
      </div>
      {viewAllText && (
        <a href={viewAllHref} class="tria-featured-view-link">
          <span>{viewAllText}</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
    </div>
  </div>

  <div class="tria-work-grid">
    {projects.map((project) => (
      <a 
        href={project.href} 
        class={`tria-work-item tria-up ${
          project.size === 'large' ? 'tria-work-item--large' : 
          project.size === 'wide' ? 'tria-work-item--wide' : ''
        }`} 
        data-category={project.category}
        {project.previewImg ? 'data-preview' : ''}
      >
        <div class="tria-work-img-wrap">
          <div class="tria-work-img" style={project.previewImg ? `background-image: url(${project.previewImg}); background-size: cover; background-position: center;` : `background: ${project.gradient};`}></div>
          {project.previewImg && <div class="tria-work-img-glass"></div>}
          <span class="tria-work-category">{project.category}</span>
          <div class="tria-work-arrow">
            <i class="fas fa-arrow-right"></i>
          </div>
          {project.abstractType === 'fintech' && (
            <div class="tria-work-abstract tria-work-abstract--fintech">
              <div class="tria-fa-grid">
                <div></div><div></div><div></div>
                <div></div><div></div><div></div>
                <div></div><div></div><div></div>
              </div>
            </div>
          )}
          {project.abstractType === 'cloud' && (
            <div class="tria-work-abstract tria-work-abstract--cloud">
              <div class="tria-cloud-rings">
                <div></div><div></div><div></div>
              </div>
            </div>
          )}
          {project.abstractType === 'ai' && (
            <div class="tria-work-abstract tria-work-abstract--ai">
              <div class="tria-neural-dots"></div>
            </div>
          )}
        </div>
        <div class="tria-work-content">
          <p class="tria-work-desc">{project.description}</p>
        </div>
        <div class="tria-work-gradient-border"></div>
      </a>
    ))}
  </div>
</section>
<!-- featured work end -->

<style>
  .tria-featured-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 60px;
  }

  .tria-featured-view-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.35);
    text-decoration: none;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: color 0.4s var(--ease-spring), gap 0.4s var(--ease-spring);
    flex-shrink: 0;
  }

  .tria-featured-view-link svg {
    transition: transform 0.4s var(--ease-spring);
  }

  .tria-featured-view-link:hover {
    color: var(--accent);
    gap: 14px;
  }

  .tria-featured-view-link:hover svg {
    transform: translateX(4px);
  }

  .tria-work-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto;
    gap: 6px;
    padding: 0 20px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .tria-work-item {
    overflow: hidden;
    cursor: pointer;
    display: block;
    text-decoration: none;
    position: relative;
    border-radius: 18px;
    background: #0b0d17;
    border: 1px solid rgba(0,0,0,0.015);
    box-shadow: 0 1px 2px rgba(0,0,0,0.015);
    transition: box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease;
  }

  .tria-work-item:hover {
    box-shadow: 0 24px 56px rgba(0,0,0,0.06), 0 8px 20px rgba(0,0,0,0.02);
    border-color: rgba(6,142,140,0.06);
  }

  .tria-work-gradient-border {
    position: absolute;
    inset: 0;
    border-radius: 18px;
    padding: 1px;
    background: transparent;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.5s ease;
    opacity: 0;
  }

  .tria-work-item:hover .tria-work-gradient-border {
    opacity: 1;
    background: linear-gradient(135deg, rgba(6,142,140,0.3) 0%, rgba(6,142,140,0.08) 50%, transparent 100%);
  }

  .tria-work-item--large {
    grid-column: span 7;
    grid-row: span 2;
    align-self: start;
  }

  .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide) {
    grid-column: span 5;
  }

  .tria-work-item--wide {
    grid-column: span 12;
  }

  .tria-work-img-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .tria-work-img-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(11,13,23,0.08) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide) .tria-work-img-wrap {
    height: 240px;
  }

  .tria-work-item--large .tria-work-img-wrap {
    height: 560px;
  }

  .tria-work-item--wide .tria-work-img-wrap {
    height: 260px;
  }

  .tria-work-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-work-item:hover .tria-work-img {
    transform: scale(1.05);
  }

  .tria-work-img-glass {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(135deg, rgba(11,13,23,0.08) 0%, rgba(11,13,23,0.25) 100%);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    transition: all 0.6s ease;
  }

  .tria-work-item:hover .tria-work-img-glass {
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    background: linear-gradient(135deg, rgba(11,13,23,0.02) 0%, rgba(6,142,140,0.15) 100%);
  }

  .tria-work-content {
    padding: 14px 20px 16px;
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  .tria-work-desc {
    color: rgba(11, 13, 23, 0.55);
    font-size: 0.78rem;
    line-height: 1.6;
    margin: 0;
  }

  .tria-work-category {
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 5px 12px;
    border-radius: 6px;
    display: inline-block;
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 3;
  }

  .tria-work-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 11px;
    transition: all 0.4s var(--ease-spring);
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
  }

  .tria-work-item:hover .tria-work-arrow {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: translateX(4px);
  }

  .tria-work-abstract {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.08;
    transition: opacity 0.6s ease;
  }

  .tria-work-item:hover .tria-work-abstract {
    opacity: 0.15;
  }

  .tria-fa-grid {
    position: absolute;
    right: 24px;
    bottom: 24px;
    display: grid;
    grid-template-columns: repeat(3, 8px);
    gap: 6px;
    opacity: 0.12;
  }
  .tria-fa-grid div {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-work-item:hover .tria-fa-grid div:nth-child(1) { transform: translateY(-3px); }
  .tria-work-item:hover .tria-fa-grid div:nth-child(3) { transform: translateY(-3px); }
  .tria-work-item:hover .tria-fa-grid div:nth-child(7) { transform: translateY(-3px); }
  .tria-work-item:hover .tria-fa-grid div:nth-child(9) { transform: translateY(-3px); }

  .tria-cloud-rings {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tria-cloud-rings div {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.6s ease;
  }
  .tria-cloud-rings div:nth-child(1) { width: 60px; height: 60px; }
  .tria-cloud-rings div:nth-child(2) { width: 90px; height: 90px; }
  .tria-cloud-rings div:nth-child(3) { width: 120px; height: 120px; }
  .tria-work-item:hover .tria-cloud-rings div:nth-child(1) { transform: scale(1.15); border-color: rgba(6, 142, 140, 0.2); }
  .tria-work-item:hover .tria-cloud-rings div:nth-child(2) { transform: scale(1.08); border-color: rgba(6, 142, 140, 0.15); }
  .tria-work-item:hover .tria-cloud-rings div:nth-child(3) { transform: scale(1.04); border-color: rgba(6, 142, 140, 0.1); }

  .tria-neural-dots {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    width: 90px;
    height: 90px;
    background:
      radial-gradient(circle, rgba(255,255,255,0.06) 1.5px, transparent 1.5px);
    background-size: 18px 18px;
  }

  .tria-work-section {
    padding-bottom: 80px;
  }

  .tria-mt-30 { margin-top: 30px; }
  .tria-p-60-120 { padding: 60px 0 120px; }

  @media (max-width: 991px) {
    .tria-work-grid {
      grid-template-columns: 1fr;
      padding: 0 16px;
      gap: 4px;
    }
    .tria-work-item--large,
    .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide),
    .tria-work-item--wide {
      grid-column: span 1;
    }
    .tria-work-item--large .tria-work-img-wrap {
      height: 420px;
    }
    .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide) .tria-work-img-wrap {
      height: 220px;
    }
    .tria-featured-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 40px;
      padding: 0 16px;
    }
  }

  @media (max-width: 576px) {
    .tria-work-grid {
      padding: 0 12px;
    }
    .tria-work-content {
      padding: 10px 14px 12px;
    }
    .tria-work-desc {
      font-size: 0.7rem;
    }
    .tria-work-item:not(.tria-work-item--large):not(.tria-work-item--wide) .tria-work-img-wrap {
      height: 180px;
    }
    .tria-work-item--large .tria-work-img-wrap {
      height: 320px;
    }
    .tria-work-item--wide .tria-work-img-wrap {
      height: 200px;
    }
  }
</style>
