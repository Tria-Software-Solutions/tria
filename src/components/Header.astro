---
import { createT, localePath } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const locale = Astro.currentLocale;
const pathname = Astro.url.pathname;
const path = pathname.replace(/\/+$/, "") || "/";
const barePath = path.startsWith("/es") ? (path.replace(/^\/es/, "") || "/") : path;
const enHref = barePath;
const esHref = `/es${barePath === "/" ? "" : barePath}`;

const lp = (p: string) => localePath(locale, p);

// Helper to check if the current bare path matches a given href
function isCurrentPage(href: string): boolean {
  const cleanHref = href.replace(/\/+$/, "") || "/";
  // For hash-anchored links like /services#software-dev, compare the path part
  const pathPart = cleanHref.split("#")[0];
  return barePath === pathPart || barePath.startsWith(pathPart + "/");
}
---

<!-- menu -->
<div class="tria-menu-frame">
  <!-- Dynamic premium orbs for visual depth -->
  <div class="tria-menu-orb tria-menu-orb-1"></div>
  <div class="tria-menu-orb tria-menu-orb-2"></div>

  <div class="tria-menu-close">
    <div class="tria-menu-close-btn" onclick="document.querySelector('.tria-menu-btn').click()">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
  </div>
  <div class="tria-menu-content">
    <div class="tria-menu-grid" id="swupMenu">
      <div class="tria-menu-pages">
        <ul>
          {!isCurrentPage("/") && (
            <li>
              <a href={lp("/")} data-i18n="nav.home">{t("nav.home")}</a>
            </li>
          )}
          {!isCurrentPage("/about") && (
            <li>
              <a href={lp("/about")} data-i18n="nav.about">{t("nav.about")}</a>
            </li>
          )}
          {!isCurrentPage("/services") && (
            <li>
              <a href={lp("/services")} data-i18n="nav.services">{t("nav.services")}</a>
            </li>
          )}
          {!isCurrentPage("/team") && (
            <li>
              <a href={lp("/team")} data-i18n="nav.team">{t("nav.team")}</a>
            </li>
          )}
          {/* blog hidden for now */}
        </ul>
      </div>
      <div class="tria-menu-col">
        <div class="tria-menu-list-group">
          <span class="tria-menu-group-label" data-i18n="nav.services">{t("nav.services")}</span>
          <a href={lp("/services#software-dev")} data-i18n="nav.softwareDev">{t("nav.softwareDev")}</a>
          <a href={lp("/services#cloud-devops")} data-i18n="nav.cloudDevops">{t("nav.cloudDevops")}</a>
          <a href={lp("/services#ai-ml")} data-i18n="nav.aiMl">{t("nav.aiMl")}</a>
          <a href={lp("/services#cybersecurity")} data-i18n="nav.cybersecurity">{t("nav.cybersecurity")}</a>
        </div>
        <div class="tria-menu-list-group">
          <span class="tria-menu-group-label" data-i18n="nav.caseStudies">{t("nav.caseStudies")}</span>
          {!isCurrentPage("/projects/parkit") && (
            <a href={lp("/projects/parkit")} data-i18n="nav.fintechDashboard">{t("nav.fintechDashboard")}</a>
          )}
          {!isCurrentPage("/projects/choferes") && (
            <a href={lp("/projects/choferes")} data-i18n="nav.cloudInfra">{t("nav.cloudInfra")}</a>
          )}
          <a href="https://github.com/Tria-Software-Solutions/goalr" data-i18n="nav.goalr" target="_blank">{t("nav.goalr")}</a>
          <a href="https://github.com/Tria-Software-Solutions/las_granas" data-i18n="nav.lasGranas" target="_blank">{t("nav.lasGranas")}</a>
          <a href="https://github.com/lmhq-94/fault_diagnosis" data-i18n="nav.faultDiagnosis" target="_blank">{t("nav.faultDiagnosis")}</a>
        </div>
      </div>
      <div class="tria-menu-col">
        <div class="tria-menu-list-group">
          <span class="tria-menu-group-label" data-i18n="nav.usefulLinks">{t("nav.usefulLinks")}</span>
          {!isCurrentPage("/portfolio") && (
            <a href={lp("/portfolio")} data-i18n="nav.work">{t("nav.work")}</a>
          )}
          {!isCurrentPage("/contact") && (
            <a href={lp("/contact")} data-i18n="nav.contact">{t("nav.contact")}</a>
          )}
          <a href={lp("/privacy")} data-i18n="nav.privacyPolicy">{t("nav.privacyPolicy")}</a>
          <a href={lp("/terms")} data-i18n="nav.terms">{t("nav.terms")}</a>
          <a href={lp("/cookies")} data-i18n="nav.cookiePolicy">{t("nav.cookiePolicy")}</a>
          {/* careers hidden for now */}
        </div>

      </div>
      <div class="tria-menu-lang">
        <a href={enHref} data-lang="en" class:list={["tria-menu-lang-btn", { "is-active": locale === "en" }]}>EN</a>
        <span class="tria-menu-lang-sep">/</span>
        <a href={esHref} data-lang="es" class:list={["tria-menu-lang-btn", { "is-active": locale === "es" }]}>ES</a>
      </div>
    </div>
  </div>
</div>
<!-- menu end -->

<style is:global>
  /* Menu Frame Modern overrides */
  .tria-menu-frame {
    background: #080a14 !important;
    backdrop-filter: blur(24px) saturate(1.8) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.8) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow-y: auto;
  }

  /* Dynamic premium orbs for visual depth */
  .tria-menu-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  
  .tria-menu-orb-1 {
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(var(--accent-rgb), 0.2) 0%, transparent 70%);
    top: -100px;
    left: -100px;
  }
  
  .tria-menu-orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
    bottom: -50px;
    right: -50px;
  }

  .tria-menu-frame.tria-active .tria-menu-orb {
    opacity: 1;
  }

  .tria-menu-frame.tria-active .tria-menu-orb-1 {
    animation: menuOrbPulse1 14s infinite alternate ease-in-out;
  }
  
  .tria-menu-frame.tria-active .tria-menu-orb-2 {
    animation: menuOrbPulse2 11s infinite alternate ease-in-out;
  }

  @keyframes menuOrbPulse1 {
    0% { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.2) translate(30px, 40px); }
  }
  
  @keyframes menuOrbPulse2 {
    0% { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.15) translate(-40px, -30px); }
  }

  /* Close Button Redesign */
  .tria-menu-close {
    position: absolute;
    top: 40px;
    right: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    cursor: pointer;
    transition: all 0.4s var(--ease-spring) !important;
    padding: 0;
    z-index: 10;
  }
  
  .tria-menu-close:hover .tria-menu-close-btn {
    color: #fff;
  }

  .tria-menu-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: color 0.3s ease;
  }

  .tria-menu-close-btn:hover {
    color: #fff;
  }

  /* ═══════════════════════════════════════
     COLUMN ENTRANCE ANIMATIONS
     ═══════════════════════════════════════ */

  /* Columns slide up */
  .tria-menu-grid > * {
    opacity: 0;
    transform: translateY(35px);
    transition: transform 0.8s var(--ease-spring), opacity 0.8s ease;
  }
  
  .tria-menu-frame.tria-active .tria-menu-grid > *:nth-child(1) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.15s;
  }
  .tria-menu-frame.tria-active .tria-menu-grid > *:nth-child(2) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.25s;
  }
  .tria-menu-frame.tria-active .tria-menu-grid > *:nth-child(3) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.35s;
  }

  /* ═══════════════════════════════════════
     SECONDARY LINK ENTRANCE ANIMATIONS
     ═══════════════════════════════════════ */

  /* Base: hidden, shifted */
  .tria-menu-list-group > * {
    opacity: 0;
    transition: transform 0.6s var(--ease-spring), opacity 0.6s ease;
  }

  .tria-menu-list-group > .tria-menu-group-label {
    transform: translateY(12px);
  }

  .tria-menu-list-group > a {
    transform: translateX(-14px);
  }

  /* Active: fade in with staggered delays per item within each group */
  .tria-menu-frame.tria-active .tria-menu-list-group > .tria-menu-group-label {
    opacity: 1;
    transform: translateY(0);
  }
  .tria-menu-frame.tria-active .tria-menu-list-group > a {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Group 1 labels & links (Services + Useful Links, same depth) ── */
  .tria-menu-col .tria-menu-list-group:nth-child(1) > .tria-menu-group-label {
    transition-delay: 0.38s;
  }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(2) { transition-delay: 0.43s; }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(3) { transition-delay: 0.48s; }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(4) { transition-delay: 0.53s; }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(5) { transition-delay: 0.58s; }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(6) { transition-delay: 0.63s; }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(7) { transition-delay: 0.68s; }
  .tria-menu-col .tria-menu-list-group:nth-child(1) > a:nth-child(8) { transition-delay: 0.73s; }

  /* ── Group 2 (Case Studies) — longer stagger since it's the second group ── */
  .tria-menu-col .tria-menu-list-group:nth-child(2) > .tria-menu-group-label {
    transition-delay: 0.62s;
  }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(2) { transition-delay: 0.67s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(3) { transition-delay: 0.72s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(4) { transition-delay: 0.77s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(5) { transition-delay: 0.82s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(6) { transition-delay: 0.87s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(7) { transition-delay: 0.92s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(8) { transition-delay: 0.97s; }
  .tria-menu-col .tria-menu-list-group:nth-child(2) > a:nth-child(9) { transition-delay: 1.02s; }

  /* Main Links Styling */
  .tria-menu-pages ul li {
    margin-bottom: 12px !important;
  }

  .tria-menu-pages ul li a {
    font-size: 2.3rem !important;
    font-weight: 500 !important;
    font-family: var(--font-display);
    letter-spacing: -0.03em !important;
    color: rgba(255, 255, 255, 0.45) !important;
    transition: color 0.4s ease, transform 0.4s var(--ease-spring), text-shadow 0.4s ease !important;
    position: relative;
    display: block !important;
    width: 100%;
  }
  
  .tria-menu-pages ul li a:hover {
    color: #fff !important;
    transform: translateX(8px) !important;
    text-shadow: 0 0 20px rgba(var(--accent-rgb), 0.35);
  }
  
  .tria-menu-pages ul li.tria-active > a {
    color: var(--accent) !important;
    padding-left: 20px !important;
  }
  
  .tria-menu-pages ul li.tria-active > a::before {
    content: "" !important;
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) !important;
    width: 4px !important;
    height: 24px !important;
    background: var(--accent) !important;
    border-radius: 2px;
    transition: height 0.3s ease;
  }
  
  .tria-menu-pages ul li.tria-active > a:hover::before {
    height: 32px !important;
  }

  /* Secondary Links Styling */
  .tria-menu-list-group {
    gap: 8px !important;
  }
  
  .tria-menu-group-label {
    color: rgba(255, 255, 255, 0.2) !important;
    font-size: 0.7rem !important;
    letter-spacing: 0.15em !important;
    font-weight: 600 !important;
    margin-bottom: 8px !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding-bottom: 6px;
  }
  
  .tria-menu-list-group a {
    color: rgba(255, 255, 255, 0.45) !important;
    font-size: 0.9rem !important;
    transition: color 0.3s ease;
    padding: 4px 0 !important;
    display: flex !important;
    align-items: center;
    width: 100%;
  }
  
  .tria-menu-list-group a:hover {
    color: rgba(255, 255, 255, 0.85) !important;
  }

  @media screen and (max-width: 640px) {
    .tria-menu-pages ul li a {
      font-size: 1.8rem !important;
    }
    .tria-menu-close {
      top: 24px;
      right: 24px;
    }
    .tria-menu-pages ul li {
      margin-bottom: 10px !important;
    }
  }

  @media screen and (min-width: 641px) and (max-width: 991px) {
    .tria-menu-pages ul li a {
      font-size: 2rem !important;
    }
  }

  /* ── Menu language switcher ── */
  .tria-menu-lang {
    position: absolute;
    bottom: 36px;
    left: 60px;
    display: flex;
    align-items: center;
    gap: 4px;
    z-index: 10;
  }

  .tria-menu-lang-btn {
    pointer-events: all;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: color 0.3s ease;
    padding: 8px 8px;
  }

  .tria-menu-lang-btn.is-active {
    color: #fff;
    font-weight: 700;
  }

  .tria-menu-lang-btn:hover {
    color: #fff;
  }

  .tria-menu-lang-sep {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.15);
  }

  @media screen and (max-width: 640px) {
    .tria-menu-lang {
      left: 24px;
      bottom: 28px;
    }
  }

  @media screen and (max-width: 400px) {
    .tria-menu-pages ul li a {
      font-size: 1.4rem !important;
      letter-spacing: -0.02em !important;
    }
    .tria-menu-pages ul li {
      margin-bottom: 6px !important;
    }
    .tria-menu-group-label {
      font-size: 0.6rem !important;
      letter-spacing: 0.1em !important;
      padding-bottom: 4px;
      margin-bottom: 4px !important;
    }
    .tria-menu-list-group {
      gap: 4px !important;
    }
    .tria-menu-list-group a {
      font-size: 0.78rem !important;
      padding: 3px 0 !important;
    }
    .tria-menu-close {
      top: 18px !important;
      right: 14px !important;
      width: 40px;
      height: 40px;
    }
    .tria-menu-lang {
      left: 16px;
      bottom: 22px;
    }
    .tria-menu-lang-btn {
      font-size: 0.65rem;
      padding: 6px 6px;
    }
  }
</style>
