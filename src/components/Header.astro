---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const locale = Astro.currentLocale;
const pathname = Astro.url.pathname;
const path = pathname.replace(/\/+$/, "") || "/";
const barePath = path.startsWith("/es") ? (path.replace(/^\/es/, "") || "/") : path;
const enHref = barePath;
const esHref = `/es${barePath === "/" ? "" : barePath}`;
---

<!-- menu -->
<div class="tria-menu-frame">
  <div class="tria-frame-top">
    <a href="/" class="tria-logo">tria.</a>
    <div class="tria-menu-btn">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
  <div class="container">
    <div class="tria-menu-content">
      <div class="row">
        <div class="col-xl-5">
          <nav class="tria-main-menu" id="swupMenu">
            <ul>
              <li class="tria-active">
                <a href="/" data-i18n="nav.home">{t("nav.home")}</a>
              </li>
              <li>
                <a href="/about" data-i18n="nav.about">{t("nav.about")}</a>
              </li>
              <li>
                <a href="/work" data-i18n="nav.work">{t("nav.work")}</a>
              </li>
              <li class="tria-has-children">
                <a href="/services" data-i18n="nav.services">{t("nav.services")}</a>
                <ul>
                  <li><a href="/services#software-dev" data-i18n="nav.softwareDev">{t("nav.softwareDev")}</a></li>
                  <li><a href="/services#cloud-devops" data-i18n="nav.cloudDevops">{t("nav.cloudDevops")}</a></li>
                  <li><a href="/services#ai-ml" data-i18n="nav.aiMl">{t("nav.aiMl")}</a></li>
                  <li><a href="/services#cybersecurity" data-i18n="nav.cybersecurity">{t("nav.cybersecurity")}</a></li>
                </ul>
              </li>
              <li>
                <a href="/contact" data-i18n="nav.contact">{t("nav.contact")}</a>
              </li>
            </ul>
          </nav>
        </div>
        <div class="col-xl-7">
          <div class="tria-menu-right-frame">
            <div class="tria-animation-in">
              <div class="tria-animation-frame"></div>
            </div>
            <div class="tria-menu-right">
              <div class="row">
                <div class="col-lg-8 tria-mb-60">
                  <h6 class="tria-muted tria-mb-30" data-i18n="nav.projects">{t("nav.projects")}</h6>
                  <ul class="tria-menu-list">
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.fintechDashboard"
                        >{t("nav.fintechDashboard")}</a
                      >
                    </li>
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.cloudInfra"
                        >{t("nav.cloudInfra")}</a
                      >
                    </li>
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.ecommerce"
                        >{t("nav.ecommerce")}</a
                      >
                    </li>
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.aiAnalytics"
                        >{t("nav.aiAnalytics")}</a
                      >
                    </li>
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.iotFleet"
                        >{t("nav.iotFleet")}</a
                      >
                    </li>
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.healthcareData"
                        >{t("nav.healthcareData")}</a
                      >
                    </li>
                  </ul>
                </div>
                <div class="col-lg-4 tria-mb-60">
                  <h6 class="tria-muted tria-mb-30" data-i18n="nav.usefulLinks">{t("nav.usefulLinks")}</h6>
                  <ul class="tria-menu-list">
                    <li>
                      <a href="/work" class="tria-light-soft" data-i18n="nav.viewAllWork">{t("nav.viewAllWork")}</a>
                    </li>
                    <li>
                      <a href="/services" class="tria-light-soft" data-i18n="nav.ourServices">{t("nav.ourServices")}</a>
                    </li>
                    <li>
                      <a href="/about" class="tria-light-soft" data-i18n="nav.about">{t("nav.about")}</a>
                    </li>
                    <li>
                      <a href="/contact" class="tria-light-soft" data-i18n="nav.startProject">{t("nav.startProject")}</a>
                    </li>
                    <li><a href="#." class="tria-light-soft" data-i18n="nav.careers">{t("nav.careers")}</a></li>
                  </ul>
                </div>
              </div>
              <div class="tria-divider tria-mb-60"></div>
              <div class="row justify-content-between">
                <div class="col-lg-4 tria-mb-60">
                  <h6 class="tria-muted tria-mb-30" data-i18n="nav.location">{t("nav.location")}</h6>
                  <p class="tria-light-soft tria-up" data-i18n-html="nav.address" set:html={t("nav.address")} />
                </div>
                <div class="col-lg-4 tria-mb-60">
                  <h6 class="tria-muted tria-mb-30" data-i18n="nav.contactInfo">{t("nav.contactInfo")}</h6>
                  <p class="tria-light-soft">
                    <a href="mailto:hola@triacr.com" class="tria-light-soft"
                      >hola@triacr.com</a
                    ><br />
                    <a
                      href="https://wa.me/50662164040"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="tria-light-soft">+506 6216 4040</a
                    >
                  </p>
                </div>
                <div class="col-lg-4 tria-mb-60">
                  <h6 class="tria-muted tria-mb-30" data-i18n="nav.language">{t("nav.language")}</h6>
                  <div class="tria-menu-lang" aria-label="Language">
                    <a
                      href={enHref}
                      class="tria-light-soft tria-lang-btn"
                      class:list={{ "is-active": locale === "en" }}
                      data-lang="en"
                      data-i18n="nav.langEn"
                    >
                      {t("nav.langEn")}
                    </a>
                    <a
                      href={esHref}
                      class="tria-light-soft tria-lang-btn"
                      class:list={{ "is-active": locale === "es" }}
                      data-lang="es"
                      data-i18n="nav.langEs"
                    >
                      {t("nav.langEs")}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- menu end -->
