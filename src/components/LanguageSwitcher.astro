---
import { getLocale } from '../lib/i18n/request';

interface Props {
  translations: any;
}

const { translations } = Astro.props;
const locales = ['es', 'en'] as const;
const localeLabels: Record<string, string> = {
  es: 'ES',
  en: 'EN',
};
const currentLang = getLocale(Astro.url);
---

<div class="mil-language-switcher">
  {locales.map(locale => (
    <button
      type="button"
      class={`mil-lang-btn${locale === currentLang ? ' mil-active' : ''}`}
      data-lang={locale}
    >
      {localeLabels[locale]}
    </button>
  ))}
</div>

<style>
  .mil-current-page {
    pointer-events: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 12px;
    width: 300px;
    color: rgb(0, 0, 0);
    -webkit-transform: rotate(-90deg) translateX(138px) translateY(-138px);
            transform: rotate(-90deg) translateX(138px) translateY(-138px);
    display: flex;
    align-items: center;
  }

  .mil-lang-btn {
    font-weight: 500;
    text-transform: uppercase;
    text-decoration: none;
    color: rgb(0, 0, 0);
    letter-spacing: 2px;
    font-size: 12px;
    transition: opacity 0.3s ease;
    cursor: pointer;
    pointer-events: all;
    background: none;
    border: none;
    padding: 0;
    margin: 0 4px;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .mil-lang-btn:hover {
    opacity: 0.6;
  }

  .mil-lang-btn.mil-active {
    color: rgb(0, 0, 0);
    opacity: 1;
  }

  .mil-lang-btn:not(.mil-active) {
    opacity: 0.4;
  }

  @media screen and (max-width: 1200px) {
    .mil-language-switcher {
      display: none;
    }
  }
</style>

<script is:inline>
(function() {
  // Wait for translations to be available
  function waitForTranslations() {
    if (!window.translations || Object.keys(window.translations).length === 0) {
      setTimeout(waitForTranslations, 50);
      return;
    }
    
    initLanguageSwitcher();
  }
  
  function initLanguageSwitcher() {
    var translationsByLocale = window.translations;
    var currentLang = localStorage.getItem('preferred-lang') || window.currentLang || 'es';

    function getCurrentTranslations(lang) {
      var translations = translationsByLocale[lang] || translationsByLocale.es || {};
      return translations;
    }

    function getValueByPath(obj, path) {
      return path.split('.').reduce(function(acc, key) {
        if (acc === undefined || acc === null) return undefined;
        return acc[key];
      }, obj);
    }

    function applyDataTranslations(lang) {
      var t = getCurrentTranslations(lang);

      document.documentElement.lang = lang;
      if (t.common && t.common.page_title) {
        document.title = 'Tria | ' + t.common.page_title;
      }

      // Only translate elements outside the language switcher
      document.querySelectorAll('[data-i18n-text]:not(.mil-language-switcher [data-i18n-text])').forEach(function(el) {
        var path = el.getAttribute('data-i18n-text');
        var value = path ? getValueByPath(t, path) : undefined;
        if (value !== undefined) {
          el.textContent = String(value);
        }
      });

      document.querySelectorAll('[data-i18n-html]:not(.mil-language-switcher [data-i18n-html])').forEach(function(el) {
        var path = el.getAttribute('data-i18n-html');
        var value = path ? getValueByPath(t, path) : undefined;
        if (value !== undefined) {
          el.innerHTML = String(value);
        }
      });

      document.querySelectorAll('[data-i18n-placeholder]:not(.mil-language-switcher [data-i18n-placeholder])').forEach(function(el) {
        var path = el.getAttribute('data-i18n-placeholder');
        var value = path ? getValueByPath(t, path) : undefined;
        if (value !== undefined) {
          el.setAttribute('placeholder', String(value));
        }
      });
    }

    // Set initial active button
    var langButtons = document.querySelectorAll('.mil-lang-btn');
    langButtons.forEach(function(btn) {
      var btnLang = btn.getAttribute('data-lang');
      if (btnLang === currentLang) {
        btn.classList.add('mil-active');
      } else {
        btn.classList.remove('mil-active');
      }
    });

    // Add page name to language switcher
    var switcherContainer = document.querySelector('.mil-language-switcher');
    if (switcherContainer) {
      var navTranslations = getCurrentTranslations(currentLang).navigation || {};
      var currentSection = window.location.hash || '#home';
      var sectionKey = currentSection === '' ? 'home' : currentSection.substring(1);
      var pageName = navTranslations[sectionKey] || navTranslations.home || 'Home';
      
      // Create page name element
      var pageNameEl = document.createElement('span');
      pageNameEl.className = 'mil-current-page';
      pageNameEl.textContent = pageName;
      
      // Insert page name before language buttons
      switcherContainer.insertBefore(pageNameEl, switcherContainer.firstChild);
      
      // Add separator
      var separator = document.createElement('span');
      separator.textContent = '|';
      separator.style.opacity = '0.3';
      separator.style.margin = '0 8px';
      switcherContainer.insertBefore(separator, pageNameEl.nextSibling);
    }

    // Apply initial translations
    applyDataTranslations(currentLang);

    // Add click handlers
    langButtons.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var lang = btn.getAttribute('data-lang') || 'es';
       
        localStorage.setItem('preferred-lang', lang);
        
        // Update active button
        document.querySelectorAll('.mil-lang-btn').forEach(function(b) {
          b.classList.remove('mil-active');
        });
        btn.classList.add('mil-active');
        
        // Apply translations without affecting language switcher
        var t = getCurrentTranslations(lang);
        document.documentElement.lang = lang;
        if (t.common && t.common.page_title) {
          document.title = 'Tria | ' + t.common.page_title;
        }

        // Only translate elements outside the language switcher
        var textElements = document.querySelectorAll('[data-i18n-text]:not(.mil-language-switcher [data-i18n-text])');
        
        textElements.forEach(function(el) {
          var path = el.getAttribute('data-i18n-text');
          var value = path ? getValueByPath(t, path) : undefined;
          if (value !== undefined) {
            el.textContent = String(value);
          }
        });

        var htmlElements = document.querySelectorAll('[data-i18n-html]:not(.mil-language-switcher [data-i18n-html])');

        htmlElements.forEach(function(el) {
          var path = el.getAttribute('data-i18n-html');
          var value = path ? getValueByPath(t, path) : undefined;
          if (value !== undefined) {
            el.innerHTML = String(value);
          }
        });

        var placeholderElements = document.querySelectorAll('[data-i18n-placeholder]:not(.mil-language-switcher [data-i18n-placeholder])');
        
        placeholderElements.forEach(function(el) {
          var path = el.getAttribute('data-i18n-placeholder');
          var value = path ? getValueByPath(t, path) : undefined;
          if (value !== undefined) {
            el.setAttribute('placeholder', String(value));
          }
        });
        

      });
    });
  }

  // Start waiting for translations
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', waitForTranslations);
  } else {
    waitForTranslations();
  }
})();
</script>
