---
import Button from "./Button.astro";

interface PricingPlan {
  name: string;
  price: string;
  period?: string;
  description?: string;
  features: string[];
  highlighted?: boolean;
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  suptitle?: string;
  heading: string;
  description?: string;
  plans: PricingPlan[];
  theme?: 'light' | 'dark';
  padding?: string;
  suptitleKey?: string;
  headingKey?: string;
  descriptionKey?: string;
}

const {
  suptitle,
  heading,
  description,
  plans = [],
  theme = 'light',
  padding = 'tria-p-120-120',
  suptitleKey,
  headingKey,
  descriptionKey
} = Astro.props;

function getUniqueFeatures(plans: PricingPlan[]): string[] {
  const all = plans.flatMap((p) => p.features);
  return [...new Set(all)];
}

function hasFeature(plan: PricingPlan, feature: string): boolean {
  return plan.features.includes(feature);
}

const fixedPlans = plans.filter((p) => p.buttonText !== 'Contact Us');
const contactPlans = plans.filter((p) => p.buttonText === 'Contact Us');
const uniqueFeatures = getUniqueFeatures(fixedPlans);
const showTable = fixedPlans.length > 0;
---

<section class={`tria-pricing-section tria-pricing-${theme === 'dark' ? 'dark' : 'light'}`} data-section-theme={theme}>
  <div class={`container ${padding}`}>
    <div class="tria-pricing-header">
      <div class="row justify-content-between">
        <div class="col-lg-7">
          {suptitle && <span class={`tria-suptitle tria-up ${theme === 'dark' ? '' : 'tria-suptitle-dark'}`} data-i18n={suptitleKey || undefined}>{suptitle}</span>}
          <h2 class="tria-up tria-mt-30" set:html={heading} data-i18n-html={headingKey || undefined} />
        </div>
        {description && (
          <div class="col-lg-4 tria-pricing-intro-col">
            <p class="tria-up tria-pricing-intro" data-i18n={descriptionKey || undefined}>{description}</p>
          </div>
        )}
      </div>
    </div>

    {showTable && (
      <div class="tria-pricing-body tria-up">
        <div class="tria-pricing-scroll">
          <div class="tria-pricing-table-wrap">
            <table class="tria-pricing-table">
              <thead>
                <tr>
                  <th class="tria-pricing-th tria-pricing-th--feature"></th>
                  {fixedPlans.map((plan) => (
                    <th class={`tria-pricing-th tria-pricing-th--plan${plan.highlighted ? ' tria-pricing-th--plan--highlighted' : ''}`}>
                        <div class="tria-pricing-plan-card">
                          <span class="tria-pricing-plan-name">{plan.name}</span>
                          <div class="tria-pricing-plan-price-row">
                            <span class="tria-pricing-plan-price">{plan.price}</span>
                            {plan.period && <span class="tria-pricing-plan-period">{plan.period}</span>}
                          </div>
                        </div>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {uniqueFeatures.map((feature, i) => (
                  <tr class={`tria-pricing-row${i % 2 === 0 ? ' tria-pricing-row--even' : ''}`}>
                    <td class="tria-pricing-cell tria-pricing-cell--label">{feature}</td>
                    {fixedPlans.map((plan) => {
                      const has = hasFeature(plan, feature);
                      return (
                        <td class={`tria-pricing-cell tria-pricing-cell--value${has ? ' tria-pricing-cell--yes' : ' tria-pricing-cell--no'}`}>
                          {has ? (
                            <svg class="tria-pricing-check" width="16" height="16" viewBox="0 0 16 16" fill="none">
                              <path d="M4 9l3 3 5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          ) : (
                            <svg class="tria-pricing-x" width="16" height="16" viewBox="0 0 16 16" fill="none">
                              <path d="M5 5l6 6M11 5l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                          )}
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}

    {contactPlans.map((plan) => (
      <div class="tria-pricing-custom tria-up">
        <div class="tria-pricing-custom-inner">
          <div class="tria-pricing-custom-header">
            <h4 class="tria-pricing-custom-name">{plan.name}</h4>
            {plan.description && <p class="tria-pricing-custom-desc">{plan.description}</p>}
          </div>
          <ul class="tria-pricing-custom-features">
            {plan.features.map((f) => (
              <li class="tria-pricing-custom-feature">
                <svg class="tria-pricing-custom-check" width="18" height="18" viewBox="0 0 16 16" fill="none">
                  <path d="M4 9l3 3 5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <div class="tria-pricing-custom-action">
            <Button
              text={plan.buttonText || "Contact Us"}
              href={plan.buttonHref || "#"}
              variant="primary"
              size="sm"
            />
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .tria-pricing-section {
    position: relative;
  }

  .tria-pricing-light {
    background: #ffffff;
  }

  .tria-pricing-dark {
    background: #0b0d17;
  }

  .tria-pricing-header {
    margin-bottom: 120px;
  }

  .tria-pricing-section .tria-suptitle::before {
    background-color: rgba(6, 142, 140, 0.3);
  }

  .tria-pricing-dark h2 {
    color: #fff;
  }

  .tria-pricing-intro-col {
    display: flex;
    align-items: flex-end;
    padding-bottom: 8px;
  }

  .tria-pricing-intro {
    line-height: 1.7;
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.5);
    margin: 0;
  }

  .tria-pricing-dark .tria-pricing-intro {
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Body wrapper ── */
  .tria-pricing-body {
    position: relative;
  }

  .tria-pricing-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.08) transparent;
  }

  .tria-pricing-dark .tria-pricing-scroll {
    scrollbar-color: rgba(255,255,255,0.08) transparent;
  }

  /* ── Plan cards (in-table header) ── */
  .tria-pricing-plan-card {
    text-align: center;
    padding: 28px 20px 24px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    transition: box-shadow 0.3s ease;
  }

  .tria-pricing-dark .tria-pricing-plan-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
  }

  .tria-pricing-th--plan--highlighted .tria-pricing-plan-card {
    box-shadow: 0 4px 20px rgba(6, 142, 140, 0.08);
  }

  .tria-pricing-dark .tria-pricing-th--plan--highlighted .tria-pricing-plan-card {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .tria-pricing-plan-name {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #0b0d17;
    margin-bottom: 8px;
  }

  .tria-pricing-dark .tria-pricing-plan-name {
    color: rgba(255, 255, 255, 0.85);
  }

  .tria-pricing-plan-price-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 4px;
  }

  .tria-pricing-plan-price {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: #0b0d17;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .tria-pricing-dark .tria-pricing-plan-price {
    color: #fff;
  }

  .tria-pricing-plan-period {
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.2);
    font-weight: 380;
    margin-left: 2px;
  }

  .tria-pricing-dark .tria-pricing-plan-period {
    color: rgba(255, 255, 255, 0.2);
  }

  /* ── Table ── */
  .tria-pricing-table-wrap {
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02), 0 8px 32px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .tria-pricing-dark .tria-pricing-table-wrap {
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15), 0 8px 32px rgba(0, 0, 0, 0.1);
    border-color: rgba(255, 255, 255, 0.05);
  }

  .tria-pricing-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .tria-pricing-th--feature {
    min-width: 140px;
    max-width: 200px;
    text-align: left;
    padding: 28px 28px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    background: #fff;
    position: sticky;
    left: 0;
    z-index: 2;
  }

  .tria-pricing-dark .tria-pricing-th--feature {
    color: rgba(255, 255, 255, 0.3);
    border-bottom-color: rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  .tria-pricing-th--plan {
    text-align: center;
    vertical-align: top;
    background: #fff;
    padding: 24px 20px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .tria-pricing-th--plan:last-child {
    border-right: none;
  }

  .tria-pricing-dark .tria-pricing-th--plan {
    background: rgba(255, 255, 255, 0.02);
    border-bottom-color: rgba(255, 255, 255, 0.05);
  }

  .tria-pricing-row td {
    padding: 16px 28px;
    font-size: 0.85rem;
    transition: background 0.2s ease;
  }

  .tria-pricing-row:not(:last-child) td {
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .tria-pricing-dark .tria-pricing-row:not(:last-child) td {
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }

  .tria-pricing-row:hover td {
    background: rgba(6, 142, 140, 0.025);
  }

  .tria-pricing-dark .tria-pricing-row:hover td {
    background: rgba(255, 255, 255, 0.025);
  }

  .tria-pricing-row--even td {
    background: rgba(0, 0, 0, 0.015);
  }

  .tria-pricing-row--even:hover td {
    background: rgba(6, 142, 140, 0.035);
  }

  .tria-pricing-dark .tria-pricing-row--even td {
    background: rgba(255, 255, 255, 0.015);
  }

  .tria-pricing-dark .tria-pricing-row--even:hover td {
    background: rgba(255, 255, 255, 0.035);
  }

  .tria-pricing-cell--label {
    font-weight: 480;
    color: rgba(0, 0, 0, 0.65);
    position: sticky;
    left: 0;
    background: inherit;
    z-index: 1;
  }

  .tria-pricing-dark .tria-pricing-cell--label {
    color: rgba(255, 255, 255, 0.55);
  }

  .tria-pricing-cell--value {
    text-align: center;
    vertical-align: middle;
    width: 25%;
  }

  .tria-pricing-cell--yes {
    color: var(--accent);
  }

  .tria-pricing-check {
    width: 20px;
    height: 20px;
    display: inline-block;
    vertical-align: middle;
  }

  .tria-pricing-cell--no {
    color: rgba(0, 0, 0, 0.15);
  }

  .tria-pricing-dark .tria-pricing-cell--no {
    color: rgba(255, 255, 255, 0.12);
  }

  .tria-pricing-x {
    width: 20px;
    height: 20px;
    display: inline-block;
    vertical-align: middle;
  }

  .tria-pricing-x path {
    stroke-width: 2;
  }

  /* ── Custom / Contact plan section ── */
  .tria-pricing-custom {
    margin-top: 24px;
  }

  .tria-pricing-custom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02), 0 8px 32px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.04);
    padding: 28px 32px;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .tria-pricing-custom-inner:hover {
    border-color: rgba(6, 142, 140, 0.12);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02), 0 12px 40px rgba(6, 142, 140, 0.04);
  }

  .tria-pricing-dark .tria-pricing-custom-inner {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15), 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .tria-pricing-dark .tria-pricing-custom-inner:hover {
    border-color: rgba(6, 142, 140, 0.2);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15), 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  .tria-pricing-custom-header {
    flex-shrink: 0;
  }

  .tria-pricing-custom-name {
    font-size: 1rem;
    font-weight: 500;
    color: #0b0d17;
    margin: 0;
  }

  .tria-pricing-dark .tria-pricing-custom-name {
    color: #fff;
  }

  .tria-pricing-custom-desc {
    color: rgba(0, 0, 0, 0.4);
    font-size: 0.82rem;
    line-height: 1.5;
    margin: 6px 0 0;
    max-width: 360px;
  }

  .tria-pricing-dark .tria-pricing-custom-desc {
    color: rgba(255, 255, 255, 0.35);
  }

  .tria-pricing-custom-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 20px;
    flex: 1;
  }

  .tria-pricing-custom-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: rgba(0, 0, 0, 0.55);
    white-space: nowrap;
  }

  .tria-pricing-dark .tria-pricing-custom-feature {
    color: rgba(255, 255, 255, 0.4);
  }

  .tria-pricing-custom-check {
    color: var(--accent, #068e8c);
    flex-shrink: 0;
  }

  .tria-pricing-custom-action {
    flex-shrink: 0;
  }



  @media (max-width: 768px) {
    .tria-pricing-header {
      margin-bottom: 60px;
    }

    .tria-pricing-plan-card {
      padding: 24px 16px 20px;
    }

    .tria-pricing-plan-name {
      font-size: 0.9rem;
    }

    .tria-pricing-plan-price {
      font-size: 1.2rem;
    }



    .tria-pricing-body {
      margin-left: -20px;
      margin-right: -20px;
    }

    .tria-pricing-scroll {
      padding: 0 20px;
    }

    .tria-pricing-cell--label {
      font-size: 0.85rem;
      padding: 14px 18px;
      min-width: 120px;
    }

    .tria-pricing-cell--value {
      padding: 14px 16px;
    }

    .tria-pricing-th--feature {
      padding: 20px 18px;
      font-size: 0.65rem;
      min-width: 120px;
    }

    .tria-pricing-th--plan {
      padding: 20px 16px 0;
      min-width: 150px;
    }

    .tria-pricing-row td {
      padding: 14px 18px;
      font-size: 0.88rem;
    }

    .tria-pricing-custom-inner {
      flex-wrap: wrap;
      padding: 24px 24px;
    }
    .tria-pricing-custom-features {
      gap: 4px 16px;
    }

  }

  @media (max-width: 576px) {
    .tria-pricing-plan-card {
      padding: 16px 12px 14px;
    }
    .tria-pricing-plan-name {
      font-size: 0.82rem;
    }
    .tria-pricing-plan-price {
      font-size: 1rem;
    }
    .tria-pricing-plan-period {
      font-size: 0.65rem;
    }
    .tria-pricing-cell--label {
      font-size: 0.75rem;
      padding: 12px 14px;
      min-width: 100px;
    }
    .tria-pricing-cell--value {
      padding: 12px 10px;
    }
    .tria-pricing-th--feature {
      padding: 16px 14px;
      font-size: 0.58rem;
      min-width: 100px;
    }
    .tria-pricing-th--plan {
      padding: 16px 12px 0;
      min-width: 130px;
    }
    .tria-pricing-row td {
      padding: 12px 14px;
      font-size: 0.82rem;
    }
    .tria-pricing-check {
      width: 18px;
      height: 18px;
    }

    .tria-pricing-custom-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 20px 20px;
      gap: 16px;
    }
    .tria-pricing-custom-features {
      gap: 4px 12px;
    }
    .tria-pricing-custom-action {
      width: 100%;
    }
    .tria-pricing-custom-action :global(.tria-btn) {
      width: 100%;
    }

  }

  @media (max-width: 400px) {
    .tria-pricing-plan-card {
      padding: 14px 10px 12px;
    }
    .tria-pricing-plan-name {
      font-size: 0.7rem;
    }
    .tria-pricing-plan-price {
      font-size: 0.85rem;
    }

    .tria-pricing-cell--label {
      font-size: 0.68rem;
      padding: 10px 10px;
      min-width: 80px;
    }
    .tria-pricing-cell--value {
      padding: 10px 6px;
    }
    .tria-pricing-th--feature {
      padding: 12px 10px;
      font-size: 0.52rem;
      min-width: 80px;
    }
    .tria-pricing-th--plan {
      padding: 12px 8px 0;
      min-width: 100px;
    }
    .tria-pricing-row td {
      padding: 10px 10px;
      font-size: 0.72rem;
    }

    .tria-pricing-custom-inner {
      padding: 16px 16px;
      border-radius: 16px;
    }

  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var pricingTable = document.querySelector('.tria-pricing-table');
    if (!pricingTable || typeof gsap === 'undefined') return;

    var planHeaders = pricingTable.querySelectorAll('.tria-pricing-th--plan');
    if (planHeaders.length < 2) return;

    gsap.fromTo(planHeaders, {
      y: 24,
      opacity: 0,
    }, {
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: pricingTable,
        start: 'top 88%',
        toggleActions: 'play none none none',
      },
    });
  });
</script>