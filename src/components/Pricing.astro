<script>
  document.addEventListener('DOMContentLoaded', function () {
    var pricingTable = document.querySelector('.tria-pricing-table');
    if (!pricingTable || typeof gsap === 'undefined') return;

    var planHeaders = pricingTable.querySelectorAll('.tria-pricing-th--plan');
    if (planHeaders.length < 2) return;

    gsap.fromTo(planHeaders, {
      y: 24,
      opacity: 0,
    }, {
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: pricingTable,
        start: 'top 88%',
        toggleActions: 'play none none none',
      },
    });

    /* ── Scroll fade indicator ── */
    var scrollEl = document.querySelector('.tria-pricing-scroll');
    var body = document.querySelector('.tria-pricing-body');
    if (scrollEl && body) {
      function checkScroll() {
        body.classList.toggle('is-scrollable', scrollEl.scrollWidth > scrollEl.clientWidth);
      }
      checkScroll();
      window.addEventListener('resize', checkScroll);
    }
  });
</script>