---
import Button from "./Button.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);

interface PricingPlan {
  name: string;
  price: string;
  period?: string;
  description?: string;
  features?: string[];
  featureCategories?: string[];
  highlighted?: boolean;
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  suptitle?: string;
  heading: string;
  description?: string;
  plans: PricingPlan[];
  theme?: 'light' | 'dark';
  padding?: string;
  suptitleKey?: string;
  headingKey?: string;
  descriptionKey?: string;
}

const {
  suptitle,
  heading,
  description,
  plans = [],
  theme = 'light',
  padding = 'tria-p-120-120',
  suptitleKey,
  headingKey,
  descriptionKey
} = Astro.props;

const CATEGORIES: { key: string; label: string }[] = [
  { key: 'website', label: t("pricing.catWebsite") },
  { key: 'seoPerf', label: t("pricing.catSeoPerf") },
  { key: 'ecom', label: t("pricing.catEcom") },
  { key: 'webApp', label: t("pricing.catWebApp") },
  { key: 'mobile', label: t("pricing.catMobile") },
  { key: 'backend', label: t("pricing.catBackend") },
  { key: 'aiAuto', label: t("pricing.catAiAuto") },
  { key: 'devops', label: t("pricing.catDevops") },
  { key: 'security', label: t("pricing.catSecurity") },
  { key: 'support', label: t("pricing.catSupport") },
  { key: 'desktop', label: t("pricing.catDesktop") },
];

function hasCategory(plan: PricingPlan, key: string): boolean {
  return plan.featureCategories ? plan.featureCategories.includes(key) : false;
}

function isCustomPlan(plan: PricingPlan): boolean {
  return !!(plan.buttonHref && !plan.period);
}

const tablePlans = plans.filter(p => !isCustomPlan(p));
const customPlan = plans.find(p => isCustomPlan(p));
const showTable = tablePlans.length > 0;
---

<section id="pricing" class={`tria-pricing-section tria-pricing-${theme === 'dark' ? 'dark' : 'light'}`} data-section-theme={theme}>
  <div class={`container ${padding}`}>
    <div class="tria-pricing-header">
      <div class="row justify-content-between">
        <div class="col-lg-7">
          {suptitle && <span class={`tria-suptitle tria-up ${theme === 'dark' ? '' : 'tria-suptitle-dark'}`} data-i18n={suptitleKey || undefined}>{suptitle}</span>}
          <h2 class="tria-up tria-mt-30" set:html={heading} data-i18n-html={headingKey || undefined} />
        </div>
        {description && (
          <div class="col-lg-4 tria-pricing-intro-col">
            <p class="tria-up tria-pricing-intro" data-i18n={descriptionKey || undefined}>{description}</p>
          </div>
        )}
      </div>
    </div>

    {showTable && (
      <div class="tria-pricing-body tria-up">
        {/* ── Desktop: horizontal table ── */}
        <div class="tria-pricing-scroll">
          <div class="tria-pricing-table-wrap">
            <table class="tria-pricing-table">
              <thead>
                <tr>
                  <th class="tria-pricing-th tria-pricing-th--feature"></th>
                  {tablePlans.map((plan) => (
                    <th class={`tria-pricing-th tria-pricing-th--plan${plan.highlighted ? ' tria-pricing-th--plan--highlighted' : ''}`}>
                        <div class="tria-pricing-plan-card">
                          <span class="tria-pricing-plan-name">{plan.name}</span>
                          <div class="tria-pricing-plan-price-row">
                            <span class="tria-pricing-plan-price">{plan.price}</span>
                            {plan.period && <span class="tria-pricing-plan-period">{plan.period}</span>}
                          </div>
                          {plan.description && <p class="tria-pricing-plan-desc">{plan.description}</p>}
                          <div class="tria-pricing-plan-bar"></div>
                        </div>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {CATEGORIES.map((cat, i) => (
                  <tr class={`tria-pricing-row${i % 2 === 0 ? ' tria-pricing-row--even' : ''}`}>
                    <td class="tria-pricing-cell tria-pricing-cell--label">{cat.label}</td>
                    {tablePlans.map((plan) => {
                      const has = hasCategory(plan, cat.key);
                      return (
                        <td class={`tria-pricing-cell tria-pricing-cell--value${has ? ' tria-pricing-cell--yes' : ' tria-pricing-cell--no'}`}>
                          {has ? (
                            <svg class="tria-pricing-check" width="16" height="16" viewBox="0 0 16 16" fill="none">
                              <path d="M4 9l3 3 5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          ) : (
                            <span class="tria-pricing-cell-dash">&ndash;</span>
                          )}
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* ── Mobile: stacked plan cards ── */}
        <div class="tria-pricing-mobile-cards">
          {tablePlans.map((plan, planIdx) => (
            <div class={`tria-pricing-mobile-card${plan.highlighted ? ' tria-pricing-mobile-card--highlighted' : ''}`}>
              <div class="tria-pricing-mobile-card-header">
                <span class="tria-pricing-plan-name">{plan.name}</span>
                <div class="tria-pricing-plan-price-row">
                  <span class="tria-pricing-plan-price">{plan.price}</span>
                  {plan.period && <span class="tria-pricing-plan-period">{plan.period}</span>}
                </div>
                {plan.description && <p class="tria-pricing-plan-desc">{plan.description}</p>}
              </div>
              <div class="tria-pricing-mobile-card-features">
                {CATEGORIES.map((cat) => {
                  const has = hasCategory(plan, cat.key);
                  return (
                    <div class={`tria-pricing-mobile-feat${has ? ' tria-pricing-mobile-feat--yes' : ' tria-pricing-mobile-feat--no'}`}>
                      {has ? (
                        <svg class="tria-pricing-check" width="14" height="14" viewBox="0 0 16 16" fill="none">
                          <path d="M4 9l3 3 5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      ) : (
                        <span class="tria-pricing-cell-dash">&ndash;</span>
                      )}
                      <span class="tria-pricing-mobile-feat-label">{cat.label}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ── Custom Solution standalone card ── */}
    {customPlan && (
      <div class="tria-pricing-custom tria-up">
        <div class="tria-pricing-custom-card">
          <div class="tria-pricing-custom-header">
            <span class="tria-pricing-plan-name">{customPlan.name}</span>
            <div class="tria-pricing-plan-price-row">
              <span class="tria-pricing-plan-price">{customPlan.price}</span>
            </div>
            {customPlan.description && <p class="tria-pricing-plan-desc">{customPlan.description}</p>}
          </div>
          <ul class="tria-pricing-custom-features">
            {['pricing.plan4Feature1','pricing.plan4Feature2','pricing.plan4Feature3','pricing.plan4Feature4','pricing.plan4Feature5'].map((key) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 9l3 3 5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span data-i18n={key}>{t(key)}</span>
              </li>
            ))}
          </ul>
          <Button text={customPlan.buttonText || customPlan.price} href={customPlan.buttonHref} showArrow={true} size="sm" />
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .tria-pricing-section {
    position: relative;
  }

  .tria-pricing-light {
    background: #ffffff;
  }

  .tria-pricing-dark {
    background: #0b0d17;
  }

  .tria-pricing-header {
    margin-bottom: 120px;
  }

  .tria-pricing-section .tria-suptitle::before {
    background-color: rgba(6, 142, 140, 0.3);
  }

  .tria-pricing-dark h2 {
    color: #fff;
  }

  .tria-pricing-intro-col {
    display: flex;
    align-items: flex-end;
    padding-bottom: 8px;
  }

  .tria-pricing-intro {
    line-height: 1.7;
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.5);
    margin: 0;
  }

  .tria-pricing-dark .tria-pricing-intro {
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Body wrapper ── */
  .tria-pricing-body {
    position: relative;
  }

  .tria-pricing-scroll {
    position: relative;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.08) transparent;
  }

  .tria-pricing-dark .tria-pricing-scroll {
    scrollbar-color: rgba(255,255,255,0.08) transparent;
  }

  /* ── Plan cards (in-table header) ── */
  .tria-pricing-plan-card {
    text-align: center;
    padding: 28px 20px 24px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    transition: box-shadow 0.3s ease;
  }

  .tria-pricing-dark .tria-pricing-plan-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
  }

  .tria-pricing-th--plan--highlighted .tria-pricing-plan-card {
    box-shadow: 0 4px 20px rgba(6, 142, 140, 0.08);
  }

  .tria-pricing-dark .tria-pricing-th--plan--highlighted .tria-pricing-plan-card {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .tria-pricing-plan-name {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #0b0d17;
    margin-bottom: 6px;
  }

  .tria-pricing-dark .tria-pricing-plan-name {
    color: rgba(255, 255, 255, 0.85);
  }

  .tria-pricing-plan-desc {
    font-size: 0.68rem;
    color: rgba(0, 0, 0, 0.35);
    margin: 10px 0 0;
    line-height: 1.4;
    font-weight: 380;
    letter-spacing: -0.01em;
    max-width: 180px;
    margin-left: auto;
    margin-right: auto;
  }

  .tria-pricing-dark .tria-pricing-plan-desc {
    color: rgba(255, 255, 255, 0.3);
  }

  .tria-pricing-plan-bar {
    width: 32px;
    height: 3px;
    border-radius: 2px;
    background: var(--accent);
    margin: 14px auto 0;
    opacity: 0.3;
  }

  .tria-pricing-th--plan:nth-child(2) .tria-pricing-plan-bar { opacity: 0.2; }
  .tria-pricing-th--plan:nth-child(3) .tria-pricing-plan-bar { opacity: 0.35; }

  .tria-pricing-plan-price-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 4px;
  }

  .tria-pricing-plan-price {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    font-weight: 350;
    letter-spacing: -0.03em;
    color: #0b0d17;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .tria-pricing-dark .tria-pricing-plan-price {
    color: #fff;
  }

  .tria-pricing-plan-period {
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.2);
    font-weight: 380;
    margin-left: 2px;
  }

  .tria-pricing-dark .tria-pricing-plan-period {
    color: rgba(255, 255, 255, 0.2);
  }

  /* ── Table ── */
  .tria-pricing-table-wrap {
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02), 0 8px 32px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .tria-pricing-dark .tria-pricing-table-wrap {
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15), 0 8px 32px rgba(0, 0, 0, 0.1);
    border-color: rgba(255, 255, 255, 0.05);
  }

  .tria-pricing-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .tria-pricing-th--feature {
    min-width: 140px;
    max-width: 200px;
    text-align: left;
    padding: 28px 28px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    background: #fff;
    position: sticky;
    left: 0;
    z-index: 2;
  }

  .tria-pricing-dark .tria-pricing-th--feature {
    color: rgba(255, 255, 255, 0.3);
    border-bottom-color: rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  .tria-pricing-th--plan {
    text-align: center;
    vertical-align: top;
    background: #fff;
    padding: 24px 20px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .tria-pricing-th--plan:last-child {
    border-right: none;
  }

  .tria-pricing-dark .tria-pricing-th--plan {
    background: rgba(255, 255, 255, 0.02);
    border-bottom-color: rgba(255, 255, 255, 0.05);
  }

  .tria-pricing-row td {
    padding: 16px 28px;
    font-size: 0.85rem;
    transition: background 0.2s ease;
  }

  .tria-pricing-row:not(:last-child) td {
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .tria-pricing-dark .tria-pricing-row:not(:last-child) td {
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }

  .tria-pricing-row:hover td {
    background: rgba(6, 142, 140, 0.025);
  }

  .tria-pricing-dark .tria-pricing-row:hover td {
    background: rgba(255, 255, 255, 0.025);
  }

  .tria-pricing-row--even td {
    background: rgba(0, 0, 0, 0.015);
  }

  .tria-pricing-row--even:hover td {
    background: rgba(6, 142, 140, 0.035);
  }

  .tria-pricing-dark .tria-pricing-row--even td {
    background: rgba(255, 255, 255, 0.015);
  }

  .tria-pricing-dark .tria-pricing-row--even:hover td {
    background: rgba(255, 255, 255, 0.035);
  }

  .tria-pricing-cell--label {
    font-weight: 480;
    color: rgba(0, 0, 0, 0.65);
    position: sticky;
    left: 0;
    background: inherit;
    z-index: 1;
    font-size: 0.82rem;
    letter-spacing: -0.01em;
  }

  .tria-pricing-dark .tria-pricing-cell--label {
    color: rgba(255, 255, 255, 0.55);
  }

  .tria-pricing-cell--value {
    text-align: center;
    vertical-align: middle;
    width: 33.33%;
  }

  .tria-pricing-cell--yes {
    color: var(--accent);
  }

  .tria-pricing-check {
    width: 18px;
    height: 18px;
    display: inline-block;
    vertical-align: middle;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-pricing-row:hover .tria-pricing-check {
    transform: scale(1.15);
  }

  .tria-pricing-cell--no {
    color: rgba(0, 0, 0, 0.12);
  }

  .tria-pricing-dark .tria-pricing-cell--no {
    color: rgba(255, 255, 255, 0.1);
  }

  .tria-pricing-cell-dash {
    color: rgba(0, 0, 0, 0.08);
    font-size: 0.9rem;
  }

  .tria-pricing-dark .tria-pricing-cell-dash {
    color: rgba(255, 255, 255, 0.06);
  }

  /* ── Custom Solution standalone card ── */
  .tria-pricing-custom {
    margin-top: 48px;
  }

  .tria-pricing-custom-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    padding: 48px 44px;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02), 0 8px 32px rgba(0,0,0,0.04);
    display: grid;
    grid-template-columns: 1fr 1.4fr auto;
    gap: 40px;
    align-items: center;
    transition: box-shadow 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  .tria-pricing-custom-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.04), 0 12px 48px rgba(0,0,0,0.06);
    transform: translateY(-3px);
  }

  .tria-pricing-dark .tria-pricing-custom-card {
    background: rgba(255,255,255,0.02);
    border-color: rgba(255,255,255,0.06);
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .tria-pricing-custom-card .tria-pricing-plan-name {
    font-size: 1.2rem;
    margin-bottom: 8px;
  }

  .tria-pricing-custom-card .tria-pricing-plan-price {
    font-size: 1.1rem;
    color: rgba(0,0,0,0.4);
    font-weight: 400;
  }

  .tria-pricing-dark .tria-pricing-custom-card .tria-pricing-plan-price {
    color: rgba(255,255,255,0.4);
  }

  .tria-pricing-custom-card .tria-pricing-plan-desc {
    font-size: 0.75rem;
    color: rgba(0,0,0,0.3);
    max-width: 240px;
    margin: 8px 0 0;
    text-align: left;
  }

  .tria-pricing-dark .tria-pricing-custom-card .tria-pricing-plan-desc {
    color: rgba(255,255,255,0.3);
  }

  .tria-pricing-custom-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .tria-pricing-custom-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: rgba(0,0,0,0.5);
    line-height: 1.4;
  }

  .tria-pricing-dark .tria-pricing-custom-features li {
    color: rgba(255,255,255,0.4);
  }

  .tria-pricing-custom-features li svg {
    flex-shrink: 0;
    color: var(--accent);
    width: 16px;
    height: 16px;
  }

  .tria-pricing-custom-card :global(.tria-btn) {
    justify-self: start;
  }



  /* ── Mobile stacked cards (hidden on desktop) ── */
  .tria-pricing-mobile-cards {
    display: none;
    flex-direction: column;
    gap: 20px;
  }

  .tria-pricing-mobile-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    padding: 28px 24px;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
  }

  .tria-pricing-dark .tria-pricing-mobile-card {
    background: rgba(255,255,255,0.02);
    border-color: rgba(255,255,255,0.06);
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .tria-pricing-mobile-card--highlighted {
    border-color: rgba(6,142,140,0.2);
    box-shadow: 0 4px 20px rgba(6,142,140,0.06);
  }

  .tria-pricing-mobile-card-header {
    text-align: center;
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .tria-pricing-dark .tria-pricing-mobile-card-header {
    border-bottom-color: rgba(255,255,255,0.05);
  }

  .tria-pricing-mobile-card-features {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tria-pricing-mobile-feat {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    line-height: 1.4;
  }

  .tria-pricing-mobile-feat--yes {
    color: rgba(0,0,0,0.65);
  }

  .tria-pricing-dark .tria-pricing-mobile-feat--yes {
    color: rgba(255,255,255,0.65);
  }

  .tria-pricing-mobile-feat--no {
    color: rgba(0,0,0,0.15);
  }

  .tria-pricing-dark .tria-pricing-mobile-feat--no {
    color: rgba(255,255,255,0.1);
  }

  .tria-pricing-mobile-feat--yes .tria-pricing-check {
    color: var(--accent);
    flex-shrink: 0;
  }

  .tria-pricing-mobile-feat--no .tria-pricing-cell-dash {
    flex-shrink: 0;
    width: 14px;
    text-align: center;
  }

  .tria-pricing-mobile-feat-label {
    font-weight: 420;
  }

  /* ── Scroll fade overlay ── */
  .tria-pricing-body::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 40px;
    background: linear-gradient(to right, transparent, #fff);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .tria-pricing-dark .tria-pricing-body::after {
    background: linear-gradient(to right, transparent, #0b0d17);
  }

  .tria-pricing-body.is-scrollable::after {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .tria-pricing-header {
      margin-bottom: 60px;
    }

    /* ── Switch: hide table, show stacked cards ── */
    .tria-pricing-scroll {
      display: none;
    }
    .tria-pricing-body::after {
      display: none;
    }
    .tria-pricing-mobile-cards {
      display: flex;
    }

    .tria-pricing-body {
      margin-left: 0;
      margin-right: 0;
    }

    /* ── Custom card responsive ── */
    .tria-pricing-custom-card {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 36px 28px;
    }

    .tria-pricing-custom-card .tria-pricing-plan-desc {
      max-width: 100%;
    }

    .tria-pricing-custom-cta {
      justify-content: center;
