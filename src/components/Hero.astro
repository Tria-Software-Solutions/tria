---
import type { GradProps } from "../scripts/hero-gradient";
import Button from "./Button.astro";

interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  gradProps?: GradProps;
}

const {
  title,
  description,
  buttonText,
  buttonHref,
  gradProps
} = Astro.props;

const defaultGradProps: GradProps = {
  color1: "#0d2b2b",
  color2: "#1a2f3a",
  color3: "#068e8c",
  timeSpeed: 1.6,
  warpStrength: 1,
  warpFrequency: 5,
  warpSpeed: 2,
  warpAmplitude: 50,
  blendAngle: 0,
  blendSoftness: 0.05,
  rotationAmount: 500,
  noiseScale: 2,
  grainAmount: 0.1,
  grainScale: 2,
  contrast: 1.5,
  gamma: 1,
  saturation: 1,
  centerX: 0,
  centerY: 0,
  zoom: 0.9,
};

const finalGradProps = gradProps || defaultGradProps;
const gradData = JSON.stringify(finalGradProps);
---

<!-- banner -->
<section class="tria-banner" data-section-theme="dark">
  <div class="tria-hero-bg" data-grad-props={gradData}>
  </div>
  <div class="container">
    <div class="tria-banner-content">
      <h1 class="tria-muted tria-mb-60" set:html={title} />
      <div class="row">
        <div class="col-md-7 col-lg-5">
          <p class="tria-light-soft tria-mb-60">{description}</p>
        </div>
      </div>

      <Button
        text={buttonText}
        href={buttonHref}
        variant="glass"
        size="lg"
        showArrow={true}
      />

    </div>
  </div>
</section>
<!-- banner end -->

<style>
  .tria-banner {
    position: relative;
    overflow: hidden;
  }
  .tria-banner-content {
    position: relative;
    z-index: 1;
    opacity: 1;
  }
  .tria-banner-content h1 {
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .tria-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    min-height: 100vh;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    background-color: #0d2b2b;
  }
  .tria-banner .container {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .tria-banner-content {
      padding-bottom: 40px;
    }
  }

  @media (max-width: 576px) {
    .tria-banner-content h1 {
      font-size: clamp(2rem, 8vw, 2.5rem);
    }
    .tria-banner-content p {
      font-size: 0.9rem;
    }
  }
</style>