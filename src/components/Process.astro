---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<!-- process -->
<section class="tria-process-section" data-section-theme="dark">
  <div class="container tria-p-120-120">
    <div class="row tria-mb-90">
      <div class="col-lg-6">
        <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="process.suptitle">{t("process.suptitle")}</span>
        <h2 class="tria-up tria-mt-30" data-i18n-html="process.title" set:html={t("process.title")} />
      </div>
      <div class="col-lg-5 offset-lg-1 tria-process-intro-col">
        <p class="tria-up tria-process-intro" data-i18n="process.intro">{t("process.intro")}</p>
      </div>
    </div>

    <div class="tria-process-steps">
      <div class="tria-process-step tria-up">
        <div class="tria-process-num">01</div>
        <div class="tria-process-divider"></div>
        <div class="tria-process-body">
          <h4 class="tria-process-title" data-i18n="process.step1Title">{t("process.step1Title")}</h4>
          <p class="tria-process-desc" data-i18n="process.step1Desc">{t("process.step1Desc")}</p>
        </div>
        <div class="tria-process-tags">
          <span data-i18n="process.step1Tag1">{t("process.step1Tag1")}</span>
          <span data-i18n="process.step1Tag2">{t("process.step1Tag2")}</span>
          <span data-i18n="process.step1Tag3">{t("process.step1Tag3")}</span>
        </div>
      </div>

      <div class="tria-process-step tria-up">
        <div class="tria-process-num">02</div>
        <div class="tria-process-divider"></div>
        <div class="tria-process-body">
          <h4 class="tria-process-title" data-i18n="process.step2Title">{t("process.step2Title")}</h4>
          <p class="tria-process-desc" data-i18n="process.step2Desc">{t("process.step2Desc")}</p>
        </div>
        <div class="tria-process-tags">
          <span data-i18n="process.step2Tag1">{t("process.step2Tag1")}</span>
          <span data-i18n="process.step2Tag2">{t("process.step2Tag2")}</span>
          <span data-i18n="process.step2Tag3">{t("process.step2Tag3")}</span>
        </div>
      </div>

      <div class="tria-process-step tria-up">
        <div class="tria-process-num">03</div>
        <div class="tria-process-divider"></div>
        <div class="tria-process-body">
          <h4 class="tria-process-title" data-i18n="process.step3Title">{t("process.step3Title")}</h4>
          <p class="tria-process-desc" data-i18n="process.step3Desc">{t("process.step3Desc")}</p>
        </div>
        <div class="tria-process-tags">
          <span data-i18n="process.step3Tag1">{t("process.step3Tag1")}</span>
          <span data-i18n="process.step3Tag2">{t("process.step3Tag2")}</span>
          <span data-i18n="process.step3Tag3">{t("process.step3Tag3")}</span>
        </div>
      </div>

      <div class="tria-process-step tria-up">
        <div class="tria-process-num">04</div>
        <div class="tria-process-divider"></div>
        <div class="tria-process-body">
          <h4 class="tria-process-title" data-i18n="process.step4Title">{t("process.step4Title")}</h4>
          <p class="tria-process-desc" data-i18n="process.step4Desc">{t("process.step4Desc")}</p>
        </div>
        <div class="tria-process-tags">
          <span data-i18n="process.step4Tag1">{t("process.step4Tag1")}</span>
          <span data-i18n="process.step4Tag2">{t("process.step4Tag2")}</span>
          <span data-i18n="process.step4Tag3">{t("process.step4Tag3")}</span>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- process end -->

<style>
  .tria-process-section {
    background: #0b0d17;
  }

  .tria-process-section .tria-suptitle::before {
    background-color: rgba(255,255,255,0.15);
  }
  .tria-process-section .tria-suptitle {
    color: rgba(255,255,255,0.5);
  }
  .tria-process-section h2 {
    color: #fff;
  }
  .tria-process-section .tria-thin {
    color: rgba(255,255,255,0.4);
  }

  .tria-process-intro-col {
    display: flex;
    align-items: flex-end;
    padding-bottom: 8px;
  }

  .tria-process-intro {
    line-height: 1.7;
    color: rgba(255,255,255,0.6);
    font-size: 1rem;
    margin: 0;
  }

  .tria-process-steps {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tria-process-step {
    display: grid;
    grid-template-columns: 80px 1px 1fr auto;
    gap: 0 40px;
    align-items: start;
    padding: 50px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.4s ease;
    position: relative;
  }

  .tria-process-step::before {
    content: '';
    position: absolute;
    left: -24px;
    right: -24px;
    top: 0;
    bottom: 0;
    background: transparent;
    border-radius: 4px;
    transition: background 0.4s ease;
    z-index: -1;
  }

  .tria-process-step:hover::before {
    background: rgba(6, 142, 140, 0.06);
  }

  .tria-process-num {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.05em;
    padding-top: 6px;
    transition: color 0.3s;
  }

  .tria-process-step:hover .tria-process-num {
    color: var(--accent);
  }

  .tria-process-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.08);
    align-self: stretch;
    margin-top: 6px;
  }

  .tria-process-body {
    flex: 1;
  }

  .tria-process-title {
    font-size: 1.3rem;
    font-weight: 400;
    margin-bottom: 16px;
    color: #fff;
    transition: color 0.3s;
  }

  .tria-process-step:hover .tria-process-title {
    color: var(--accent);
  }

  .tria-process-desc {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.9rem;
    line-height: 1.75;
    max-width: 500px;
    margin: 0;
  }

  .tria-process-tags {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 4px;
    align-items: flex-end;
  }

  .tria-process-tags span {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    white-space: nowrap;
    transition: color 0.3s;
  }

  .tria-process-step:hover .tria-process-tags span {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .tria-process-step {
      grid-template-columns: 50px 1px 1fr;
      gap: 0 20px;
    }
    .tria-process-tags {
      display: none;
    }
    .tria-process-num {
      font-size: 0.9rem;
    }
  }

  .tria-mt-30 {
    margin-top: 30px;
  }
</style>
