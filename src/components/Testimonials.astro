---

---

<!-- reviews -->
<section class="tria-testimonials-section" data-section-theme="light">
  <div class="tria-ambient-temp">
    <div style="width:550px;height:550px;background:var(--accent);opacity:0.04;top:-150px;right:-100px;filter:blur(160px);"></div>
    <div style="width:400px;height:400px;background:var(--accent);opacity:0.03;bottom:-100px;left:-80px;filter:blur(120px);"></div>
  </div>
  <div class="container tria-p-120-120">
    <div class="row">
      <div class="col-lg-10">
          <span
            class="tria-suptitle tria-suptitle-right tria-suptitle-dark tria-up"
            data-i18n-html="testimonials.suptitle">What our clients say about <br />working with tria.</span
          >
        </div>
      </div>

      <h2 class="tria-center tria-up tria-mb-60" data-i18n-html="testimonials.title">
        Client <span class="tria-thin">Voices</span>
      </h2>

    <div class="tria-revi-pagination tria-up tria-mb-60"></div>

    <div class="row tria-relative justify-content-center">
      <div class="col-lg-8">
        <div class="tria-slider-nav tria-soft tria-reviews-nav tria-up">
          <div
            class="tria-slider-arrow tria-prev tria-revi-prev tria-arrow-place"
          >
          </div>
          <div class="tria-slider-arrow tria-revi-next tria-arrow-place"></div>
        </div>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 48 48"
          class="tria-quote-icon tria-up"
        >
          <path
            d="M 13.5 10 A 8.5 8.5 0 0 0 13.5 27 A 8.5 8.5 0 0 0 18.291016 25.519531 C 17.422273 29.222843 15.877848 31.803343 14.357422 33.589844 C 12.068414 36.279429 9.9433594 37.107422 9.9433594 37.107422 A 1.50015 1.50015 0 1 0 11.056641 39.892578 C 11.056641 39.892578 13.931586 38.720571 16.642578 35.535156 C 19.35357 32.349741 22 27.072581 22 19 A 1.50015 1.50015 0 0 0 21.984375 18.78125 A 8.5 8.5 0 0 0 13.5 10 z M 34.5 10 A 8.5 8.5 0 0 0 34.5 27 A 8.5 8.5 0 0 0 39.291016 25.519531 C 38.422273 29.222843 36.877848 31.803343 35.357422 33.589844 C 33.068414 36.279429 30.943359 37.107422 30.943359 37.107422 A 1.50015 1.50015 0 1 0 32.056641 39.892578 C 32.056641 39.892578 34.931586 38.720571 37.642578 35.535156 C 40.35357 32.349741 43 27.072581 43 19 A 1.50015 1.50015 0 0 0 42.984375 18.78125 A 8.5 8.5 0 0 0 34.5 10 z"
            fill="var(--accent)"></path>
        </svg>

        <div class="swiper-container tria-reviews-slider">
          <div class="swiper-wrapper">
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.1.name">{t("testimonial.1.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.1.title">
                  {t("testimonial.1.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.1.quote" set:html={t("testimonial.1.quote")}>
                </p>
              </div>
            </div>
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.2.name">{t("testimonial.2.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.2.title">
                  {t("testimonial.2.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.2.quote" set:html={t("testimonial.2.quote")}>
                </p>
              </div>
            </div>
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.3.name">{t("testimonial.3.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.3.title">
                  {t("testimonial.3.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.3.quote" set:html={t("testimonial.3.quote")}>
                </p>
              </div>
            </div>
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.4.name">{t("testimonial.4.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.4.title">
                  {t("testimonial.4.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.4.quote" set:html={t("testimonial.4.quote")}>
                </p>
              </div>
            </div>
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.1.name">{t("testimonial.1.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.1.title">
                  {t("testimonial.1.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.1.quote" set:html={t("testimonial.1.quote")}>
                </p>
              </div>
            </div>
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.2.name">{t("testimonial.2.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.2.title">
                  {t("testimonial.2.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.2.quote" set:html={t("testimonial.2.quote")}>
                </p>
              </div>
            </div>
            <div class="swiper-slide">
              <div
                class="tria-review-frame tria-center"
                data-swiper-parallax="-200"
                data-swiper-parallax-opacity="0"
              >
                <h5 class="tria-up tria-mb-10" data-i18n="testimonial.3.name">{t("testimonial.3.name")}</h5>
                <p class="tria-mb-5 tria-upper tria-up tria-mb-30" data-i18n="testimonial.3.title">
                  {t("testimonial.3.title")}
                </p>
                <p class="tria-text-xl tria-up" data-i18n="testimonial.3.quote" set:html={t("testimonial.3.quote")}>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- reviews end -->

<style>
  .tria-testimonials-section {
    background: #ffffff;
    position: relative;
  }
  .tria-testimonials-section .tria-review-frame {
    padding: 20px 0;
  }
  .tria-testimonials-section .tria-text-xl {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.7;
    color: #444;
  }
</style>
