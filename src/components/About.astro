<!-- about -->
<section id="about" data-section-theme="light">
  <div class="container tria-p-120-30">
    <div class="row justify-content-between align-items-center">
      <div class="col-lg-5">
        <div class="tria-mb-90">
          <h2 class="tria-up tria-mb-60" data-i18n-html="about.title">
            About <br /><span class="tria-thin">tria</span>
          </h2>
          <p class="tria-up tria-mb-30" data-i18n="about.description1">
            Founded in Costa Rica, tria is a software enterprise built
            by engineers who believe great technology starts with understanding
            real problems. We design, build, and scale digital products that
            simplify complexity and drive measurable outcomes.
          </p>
          <p class="tria-up tria-mb-60" data-i18n="about.description2">
            Our team spans cloud architecture, full-stack development, AI/ML,
            and cybersecurity — working together to deliver enterprise-grade
            solutions. Every project begins with a question: how can we make
            this simpler, faster, and more reliable?
          </p>
          <div class="tria-about-quote">
            <div class="tria-avatar tria-up">
              <img
                src="/logo-avatar.svg"
                alt="tria logo"
                class="tria-avatar-logo"
              />
            </div>
            <h6 class="tria-quote tria-up" data-i18n-html="about.quote">
              Crafted in Costa Rica, <span class="tria-thin"
                >Engineered for the World:</span
              > Software <span class="tria-thin">That Delivers</span>
            </h6>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="tria-about-photo tria-mb-90">
          <div class="tria-lines-place"></div>
