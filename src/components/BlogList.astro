---
import type { CollectionEntry } from "astro:content";
import { createT } from "../i18n/utils";

interface Props {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
const t = createT(Astro.currentLocale);
---

<div class="container tria-p-120-60">
  <div class="row">
    {
      posts.map((post) => (
        <div class="col-lg-6">
          <a href={`/blog/${post.id}`} class="tria-blog-card tria-mb-60">
            <div class="tria-cover-frame tria-up">
              <img src={post.data.image} alt={post.data.title} />
            </div>
            <div class="tria-post-descr">
              <div class="tria-labels tria-up tria-mb-30">
                <div class="tria-label tria-upper tria-accent">{post.data.category.toUpperCase()}</div>
                <div class="tria-label tria-upper">{new Date(post.data.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</div>
              </div>
              <h4 class="tria-up tria-mb-30">{post.data.title}</h4>
              <p class="tria-post-text tria-up tria-mb-30">{post.data.description}</p>
              <div class="tria-link tria-dark tria-arrow-place tria-up">
                <span data-i18n="blog.readMore">{t("blog.readMore")}</span>
              </div>
            </div>
          </a>
        </div>
      ))
    }
  </div>

  {
    totalPages > 1 && (
      <div class="row">
        <div class="col-12 tria-center">
          <div class="tria-pagination">
            {
              currentPage > 1 && (
                <a
                  href={currentPage === 2 ? "/blog" : `/blog/page/${currentPage - 1}`}
                  class="tria-link tria-dark tria-arrow-place"
                >
                  <span data-i18n="pagination.previous">{t("pagination.previous")}</span>
                </a>
              )
            }
            <span class="tria-pagination-info" data-i18n="pagination.page">
              {t("pagination.page").replace("{current}", currentPage).replace("{total}", totalPages)}
            </span>
            {
              currentPage < totalPages && (
                <a
                  href={`/blog/page/${currentPage + 1}`}
                  class="tria-link tria-dark tria-arrow-place"
                >
                  <span data-i18n="pagination.next">{t("pagination.next")}</span>
                </a>
              )
            }
          </div>
        </div>
      </div>
    )
  }
</div>

<style>
  .tria-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding-top: 40px;
  }
  .tria-pagination-info {
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.5);
  }
</style>
