  <div class="container tria-p-120-60">
    <div class="row tria-mb-60">
      <div class="col-lg-8">
        <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="techstack.suptitle">Technology</span>
        <h2 class="tria-up tria-mt-30" data-i18n-html="techstack.title">
          Our <span class="tria-thin">Stack</span>
        </h2>
      </div>
    </div>
  </div>

  <!-- Row 1 → right -->
  <div class="tria-logo-marquee tria-logo-marquee--right tria-up">
    <div class="tria-logo-track">
      <div class="tria-logo-item"><i class="ti ti-brand-react"></i><span>React</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-nextjs"></i><span>Next.js</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-typescript"></i><span>TypeScript</span></div>
