      <div class="tria-logo-item"><i class="ti ti-brand-graphql"></i><span>GraphQL</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-docker"></i><span>Docker</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-kubernetes"></i><span>Kubernetes</span></div>
      <!-- duplicate for seamless loop -->
      <div class="tria-logo-item"><i class="ti ti-brand-react"></i><span>React</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-nextjs"></i><span>Next.js</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-typescript"></i><span>TypeScript</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-nodejs"></i><span>Node.js</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-go"></i><span>Go</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-python"></i><span>Python</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-graphql"></i><span>GraphQL</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-docker"></i><span>Docker</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-kubernetes"></i><span>Kubernetes</span></div>
    </div>
  </div>

  <!-- Row 2 → left -->
  <div class="tria-logo-marquee tria-logo-marquee--left tria-up">
    <div class="tria-logo-track">
      <div class="tria-logo-item"><i class="ti ti-brand-aws"></i><span>AWS</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-google-cloud"></i><span>GCP</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-azure"></i><span>Azure</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-redis"></i><span>Redis</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-kafka"></i><span>Kafka</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-postgresql"></i><span>PostgreSQL</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-mongodb"></i><span>MongoDB</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-tailwind"></i><span>Tailwind</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-figma"></i><span>Figma</span></div>
      <!-- duplicate for seamless loop -->
      <div class="tria-logo-item"><i class="ti ti-brand-aws"></i><span>AWS</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-google-cloud"></i><span>GCP</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-azure"></i><span>Azure</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-redis"></i><span>Redis</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-kafka"></i><span>Kafka</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-postgresql"></i><span>PostgreSQL</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-mongodb"></i><span>MongoDB</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-tailwind"></i><span>Tailwind</span></div>
      <div class="tria-logo-item"><i class="ti ti-brand-figma"></i><span>Figma</span></div>
    </div>
  </div>

  <div class="container tria-p-60-120">
    <p class="tria-tech-footer tria-up" data-i18n="techstack.footer">
      We use the right tool for every job — from frontend to infrastructure.
    </p>
  </div>
</section>
<!-- tech stack end -->

<style>
  .tria-tech-section {
    position: relative;
    overflow: hidden;
    background: #ffffff;
  }

  .tria-tech-intro {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.75;
    margin: 0;
  }

  .tria-tech-footer {
    text-align: center;
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Logo marquee ── */
  .tria-logo-marquee {
    overflow: hidden;
    padding: 16px 0;
    position: relative;
    z-index: 1;
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }

  .tria-logo-marquee + .tria-logo-marquee {
    margin-top: 4px;
  }

  .tria-logo-track {
    display: flex;
    gap: 0;
    width: max-content;
    animation: tria-logo-scroll 40s linear infinite;
  }

  .tria-logo-marquee--right .tria-logo-track {
    animation-direction: normal;
  }

  .tria-logo-marquee--left .tria-logo-track {
    animation-direction: reverse;
  }

  @keyframes tria-logo-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .tria-logo-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    margin: 0 6px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    background: #fafafa;
    flex-shrink: 0;
    transition: all 0.3s var(--ease-spring);
    cursor: default;
  }

  .tria-logo-item:hover {
    border-color: rgba(0, 0, 0, 0.12);
    background: #f5f5f5;
    transform: translateY(-3px);
  }

  .tria-logo-item i {
    font-size: 22px;
    color: rgba(0, 0, 0, 0.5);
    transition: color 0.3s var(--ease-spring);
    flex-shrink: 0;
  }

  .tria-logo-item:hover i {
    color: var(--accent);
  }

  .tria-logo-item span {
    font-size: 0.8rem;
    font-weight: 450;
    color: rgba(0, 0, 0, 0.55);
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: color 0.3s var(--ease-spring);
  }

  .tria-logo-item:hover span {
    color: #0b0d17;
  }

  @media (max-width: 991px) {
    .tria-logo-item {
      padding: 12px 20px;
      gap: 10px;
    }
    .tria-logo-item i {
      font-size: 20px;
    }
    .tria-logo-item span {
      font-size: 0.78rem;
    }
    .tria-logo-marquee {
      padding: 14px 0;
    }
  }

  @media (max-width: 576px) {
    .tria-logo-item {
      padding: 10px 16px;
      gap: 8px;
    }
    .tria-logo-item i {
      font-size: 18px;
    }
    .tria-logo-item span {
      font-size: 0.72rem;
    }
    .tria-logo-marquee {
      padding: 10px 0;
    }
    @keyframes tria-logo-scroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .tria-logo-track {
      animation-duration: 30s;
    }
  }

  @media (max-width: 400px) {
    .tria-logo-item {
      padding: 8px 12px;
      gap: 6px;
      margin: 0 4px;
    }
    .tria-logo-item i {
      font-size: 16px;
    }
    .tria-logo-item span {
      font-size: 0.65rem;
    }
    .tria-logo-marquee {
      padding: 8px 0;
    }
  }

  .tria-mt-30 { margin-top: 30px; }
  .tria-p-60-120 { padding: 60px 0 120px; }
  .tria-p-120-60 { padding: 120px 0 60px; }
</style>
