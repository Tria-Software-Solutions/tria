---
const year = new Date().getFullYear();
---

<!-- footer -->
<footer class="tria-dark-bg">
  <div class="mi-invert-fix">
    <div class="container tria-p-120-60">
      <div class="row justify-content-between">
        <div class="col-md-4 col-lg-4 tria-mb-60">
          <div class="tria-muted tria-logo tria-up tria-mb-30">
            <img src="/logo.svg" alt="tria" class="tria-logo-img" /> tria.
          </div>
          <p class="tria-light-soft tria-up tria-mb-30">Stay in the loop:</p>
          <form class="tria-subscribe-form tria-up">
            <input type="text" placeholder="Enter our email" />
            <button
              type="submit"
              class="tria-button tria-icon-button-sm tria-arrow-place"></button>
          </form>
        </div>
        <div class="col-md-7 col-lg-6">
          <div class="row justify-content-end">
            <div class="col-md-6 col-lg-7">
              <nav class="tria-footer-menu tria-mb-60">
                <ul>
                  <li class="tria-up tria-active"><a href="/">Home</a></li>
                  <li class="tria-up"><a href="/services">Services</a></li>
                  <li class="tria-up"><a href="/contact">Contact</a></li>
                </ul>
              </nav>
            </div>
            <div class="col-md-6 col-lg-5">
              <ul class="tria-menu-list tria-up tria-mb-60">
                <li><a href="#." class="tria-light-soft">Privacy Policy</a></li>
                <li>
                  <a href="#." class="tria-light-soft">Terms and conditions</a>
                </li>
                <li><a href="#." class="tria-light-soft">Cookie Policy</a></li>
                <li><a href="#." class="tria-light-soft">Careers</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="row justify-content-between flex-sm-row-reverse">
        <div class="col-md-7 col-lg-6">
          <div class="row justify-content-between">
            <div class="col-md-6 col-lg-5 tria-mb-60">
              <h6 class="tria-muted tria-up tria-mb-30">Location</h6>
              <address
                class="tria-light-soft tria-up"
                style="font-style:normal"
              >
                Atenas, Alajuela<br />
                Costa Rica 20501
              </address>
            </div>
            <div class="col-md-6 col-lg-5 tria-mb-60">
              <h6 class="tria-muted tria-up tria-mb-20">Contact</h6>
              <div class="tria-premium-contact tria-up">
                <a
                  href="mailto:hola@triacr.com"
                  aria-label="Email hola@triacr.com"
                  class="tria-contact-btn"
                  data-tooltip="Email"
                >
                  <i class="fas fa-envelope" aria-hidden="true"></i>
                </a>
                <a
                  href="https://wa.me/50662164040"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="WhatsApp +506 6216 4040"
                  class="tria-contact-btn"
                  data-tooltip="WhatsApp"
                >
                  <i class="fab fa-whatsapp" aria-hidden="true"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 col-lg-6 tria-mb-60">
          <div class="tria-vert-between">
            <div class="tria-mb-30">
              <ul class="tria-social-icons tria-up">
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Facebook"
                    class="social-icon"
                    ><i class="fab fa-facebook-f" aria-hidden="true"></i></a
                  >
                </li>
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram"
                    class="social-icon"
                    ><i class="fab fa-instagram" aria-hidden="true"></i></a
                  >
                </li>
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn"
                    class="social-icon"
                    ><i class="fab fa-linkedin-in" aria-hidden="true"></i></a
                  >
                </li>
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="X"
                    class="social-icon"
                    ><svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 512 512"
                      style="width:14px;height:14px;fill:currentColor;vertical-align:middle"
                      ><path
                        d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"
                      ></path></svg
                    ></a
                  >
                </li>
              </ul>
            </div>
            <p class="tria-light-soft tria-up">
              &copy; {year} tria. All rights reserved.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
<!-- footer end -->

