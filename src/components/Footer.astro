---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const year = new Date().getFullYear();
---

<!-- footer -->
<footer style="background:#000" data-section-theme="dark">
  <div class="container tria-p-120-60">
      <div class="row justify-content-between">
        <div class="col-md-4 col-lg-4 tria-mb-60">
          <div class="tria-logo tria-light tria-up tria-mb-30">
            <img src="/assets/img/logo/logo.svg" alt="tria" class="tria-logo-img" /> tria.
          </div>
          <p class="tria-light-soft tria-up tria-mb-30" data-i18n="footer.stayInLoop">{t("footer.stayInLoop")}</p>
          <form class="tria-subscribe-form tria-up">
            <input type="text" placeholder={t("footer.emailPlaceholder")} data-i18n-placeholder="footer.emailPlaceholder" />
            <button
              type="submit"
              class="tria-button tria-icon-button-sm tria-arrow-place"></button>
          </form>
        </div>
        <div class="col-md-7 col-lg-6">
          <div class="row justify-content-end">
            <div class="col-md-6 col-lg-7">
              <nav class="tria-footer-menu tria-light tria-mb-60">
                <ul>
                  <li class="tria-up tria-active"><a href="/" data-i18n="nav.home">{t("nav.home")}</a></li>
                  <li class="tria-up"><a href="/about" data-i18n="nav.about">{t("nav.about")}</a></li>
                  <li class="tria-up"><a href="/work" data-i18n="nav.work">{t("nav.work")}</a></li>
                  <li class="tria-up"><a href="/services" data-i18n="nav.services">{t("nav.services")}</a></li>
                  <li class="tria-up"><a href="/contact" data-i18n="nav.contact">{t("nav.contact")}</a></li>
                </ul>
              </nav>
            </div>
            <div class="col-md-6 col-lg-5">
              <ul class="tria-menu-list tria-up tria-mb-60">
                <li><a href="/about" class="tria-light-soft" data-i18n="nav.about">{t("nav.about")}</a></li>
                <li><a href="#." class="tria-light-soft" data-i18n="nav.privacyPolicy">{t("nav.privacyPolicy")}</a></li>
                <li>
                  <a href="#." class="tria-light-soft" data-i18n="nav.terms">{t("nav.terms")}</a>
                </li>
                <li><a href="#." class="tria-light-soft" data-i18n="nav.cookiePolicy">{t("nav.cookiePolicy")}</a></li>
                <li><a href="#." class="tria-light-soft" data-i18n="nav.careers">{t("nav.careers")}</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="row justify-content-between flex-sm-row-reverse">
        <div class="col-md-7 col-lg-6">
          <div class="row justify-content-between">
            <div class="col-md-6 col-lg-5 tria-mb-60">
              <h6 class="tria-light tria-up tria-mb-30" data-i18n="nav.location">{t("nav.location")}</h6>
              <address
                class="tria-light-soft tria-up"
                style="font-style:normal"
                data-i18n-html="nav.address"
                set:html={t("nav.address")}
              />
            </div>
            <div class="col-md-6 col-lg-5 tria-mb-60">
              <h6 class="tria-light tria-up tria-mb-20" data-i18n="nav.contactInfo">{t("nav.contactInfo")}</h6>
              <div class="tria-premium-contact tria-up">
                <a
                  href="mailto:hola@triacr.com"
                  aria-label="Email hola@triacr.com"
                  class="tria-contact-btn"
                  data-tooltip="Email"
                >
                  <i class="fas fa-envelope" aria-hidden="true"></i>
                </a>
                <a
                  href="https://wa.me/50662164040"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="WhatsApp +506 6216 4040"
                  class="tria-contact-btn"
                  data-tooltip="WhatsApp"
                >
                  <i class="fab fa-whatsapp" aria-hidden="true"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 col-lg-6 tria-mb-60">
          <div class="tria-vert-between">
            <div class="tria-mb-30">
              <ul class="tria-social-icons tria-up">
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Facebook"
                    class="social-icon"
                    ><i class="fab fa-facebook-f" aria-hidden="true"></i></a
                  >
                </li>
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram"
                    class="social-icon"
                    ><i class="fab fa-instagram" aria-hidden="true"></i></a
                  >
                </li>
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn"
                    class="social-icon"
                    ><i class="fab fa-linkedin-in" aria-hidden="true"></i></a
                  >
                </li>
                <li>
                  <a
                    href="#."
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="X"
                    class="social-icon"
                    ><svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 512 512"
                      style="width:14px;height:14px;fill:currentColor;vertical-align:middle"
                      ><path
                        d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"
                      ></path></svg
                    ></a
                  >
                </li>
              </ul>
            </div>
            <p class="tria-light-soft tria-up" data-i18n="footer.allRights">
              {t("footer.allRights")}
            </p>
          </div>
        </div>
    </div>
  </div>
</footer>
<style>
  footer {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  footer .tria-subscribe-form input {
    background-color: rgba(255, 255, 255, 0.08);
    color: #fff;
    backdrop-filter: blur(4px);
  }

  footer .tria-subscribe-form input:focus,
  footer .tria-subscribe-form input:hover {
    background-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1);
  }

  footer .tria-subscribe-form input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  footer .tria-contact-btn {
    color: rgba(255, 255, 255, 0.5) !important;
    border-color: rgba(255, 255, 255, 0.12) !important;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  footer .tria-contact-btn:hover {
    color: #fff !important;
    border-color: rgba(255, 255, 255, 0.35) !important;
    background: rgba(255, 255, 255, 0.06) !important;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  footer .tria-contact-btn::after {
    color: rgba(255, 255, 255, 0.4);
  }

  footer .tria-logo-img {
    filter: brightness(0) invert(1);
  }

  footer .tria-social-icons li a {
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  footer .tria-social-icons li a:hover {
    transform: translateY(-2px) scale(1.1);
  }

  footer .tria-footer-menu ul li a {
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  footer .tria-footer-menu ul li a:hover {
    opacity: 0.7;
  }

  footer .tria-menu-list li a {
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  footer .tria-menu-list li a:hover {
    color: rgba(255, 255, 255, 0.8) !important;
  }
</style>

<!-- footer end -->
