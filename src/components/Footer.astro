---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const year = new Date().getFullYear();

const exploreLinks = [
  { href: "/", label: t("nav.home") },
  { href: "/about", label: t("nav.about") },
  { href: "/team", label: t("nav.team") },
  { href: "/portfolio", label: t("nav.work") },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: t("nav.contact") },
];

const serviceLinks = [
  { href: "/services#software-dev", label: t("nav.softwareDev"), html: true },
  { href: "/services#cloud-devops", label: t("nav.cloudDevops"), html: true },
  { href: "/services#ai-ml", label: t("nav.aiMl"), html: true },
  { href: "/services#cybersecurity", label: t("nav.cybersecurity"), html: true },
];

const projectLinks = [
  { href: "/project-1", label: t("nav.fintechDashboard") },
  { href: "/project-2", label: t("nav.cloudInfra") },
  { href: "/project-3", label: t("nav.ecommerce") },
  { href: "/project-4", label: t("nav.aiAnalytics") },
  { href: "/project-5", label: t("nav.iotFleet") },
  { href: "/project-6", label: t("nav.healthcareData") },
];

const contactLinks = [
  { href: "mailto:hola@triacr.com", label: t("footer.contactLink"), icon: "ti-mail" },
  { href: "mailto:support@triacr.com", label: t("footer.supportLink"), icon: "ti-headset" },
  { href: "mailto:sales@triacr.com", label: t("footer.salesLink"), icon: "ti-briefcase" },
  { href: "https://wa.me/50662164040", label: t("footer.whatsappLink"), icon: "ti-brand-whatsapp", external: true },
];

const socialLinks = [
  { href: "https://linkedin.com", label: "LinkedIn", icon: "ti ti-brand-linkedin" },
  { href: "https://x.com", label: "X", icon: "ti ti-brand-x" },
  { href: "https://instagram.com", label: "Instagram", icon: "ti ti-brand-instagram" },
  { href: "https://github.com", label: "GitHub", icon: "ti ti-brand-github" },
];
---

<footer class="tria-footer-section" data-section-theme="dark">
  <div class="tria-footer-glow"></div>
  <div class="tria-footer-glow tria-footer-glow--accent"></div>

  <div class="container">
    <!-- Navigation grid -->
    <div class="tria-footer-grid tria-up">
      <div class="tria-footer-col tria-footer-col--brand">
        <a href="/" class="tria-footer-logo" aria-label="tria home">
          tria<span class="tria-footer-logo-dot">.</span>
        </a>

        <p class="tria-footer-brand-desc" data-i18n="footer.description">{t("footer.description")}</p>

        <span class="tria-footer-label" data-i18n="contact.info.followUs">{t("contact.info.followUs")}</span>
        <ul class="tria-footer-social">
          {socialLinks.map((social) => (
            <li>
              <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label}>
                <i class={social.icon}></i>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col">
        <span class="tria-footer-label" data-i18n="nav.explore">{t("nav.explore")}</span>
        <ul class="tria-footer-nav">
          {exploreLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col">
        <span class="tria-footer-label" data-i18n="nav.services">{t("nav.services")}</span>
        <ul class="tria-footer-nav">
          {serviceLinks.map((link) => (
            <li>
              {link.html ? (
                <a href={link.href} set:html={link.label}></a>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col tria-footer-col--projects">
        <span class="tria-footer-label" data-i18n="nav.projects">{t("nav.projects")}</span>
        <ul class="tria-footer-nav">
          {projectLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col">
        <span class="tria-footer-label" data-i18n="nav.contactInfo">{t("nav.contactInfo")}</span>
        <ul class="tria-footer-contact">
          {contactLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
              >
                <span class="tria-footer-contact-icon"><i class={`ti ${link.icon}`}></i></span>
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="tria-footer-bottom tria-up">
      <p class="tria-footer-copyright">{t("footer.allRights").replace("{year}", String(year))}</p>
      <nav class="tria-footer-legal" aria-label="Legal">
        <a href="/privacy">{t("nav.privacyPolicy")}</a>
        <a href="/terms">{t("nav.terms")}</a>
        <a href="/cookies">{t("nav.cookiePolicy")}</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .tria-footer-section {
    position: relative;
    background: #0b0d17;
    overflow: hidden;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tria-footer-section .tria-suptitle {
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 1rem;
  }

  .tria-footer-glow {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .tria-footer-glow:first-of-type {
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.03) 0%, transparent 68%);
  }

  .tria-footer-glow--accent {
    bottom: -180px;
    right: -120px;
    width: 560px;
    height: 560px;
    background: radial-gradient(circle, rgba(var(--accent-rgb), 0.09) 0%, transparent 70%);
  }

  .tria-footer-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Main grid ── */
  .tria-footer-grid {
    display: grid;
    grid-template-columns: minmax(200px, 2.2fr) minmax(88px, 1fr) minmax(100px, 1.1fr) minmax(150px, 1.7fr) minmax(120px, 1.2fr);
    gap: clamp(24px, 3vw, 48px);
    padding: clamp(56px, 7vw, 80px) 0 clamp(48px, 6vw, 64px);
    align-items: start;
  }

  .tria-footer-col {
    min-width: 0;
  }

  .tria-footer-logo {
    display: inline-flex;
    align-items: center;
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #fff;
    text-decoration: none;
    margin-bottom: 28px;
    transition: opacity 0.3s var(--ease-smooth);
  }

  .tria-footer-logo:hover {
    opacity: 0.85;
  }

  .tria-footer-logo-dot {
    color: var(--accent);
    margin-left: -1px;
  }

  .tria-footer-brand-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.35);
    margin: -12px 0 20px;
    max-width: 260px;
  }

  .tria-footer-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin-bottom: 22px;
  }

  .tria-footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tria-footer-nav a {
    display: inline-block;
    font-size: 0.88rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring), transform 0.35s var(--ease-spring);
  }

  .tria-footer-nav a:hover {
    color: #fff;
    transform: translateX(4px);
  }

  .tria-footer-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-footer-contact a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring);
  }

  .tria-footer-contact a:hover {
    color: #fff;
  }

  .tria-footer-contact a:hover .tria-footer-contact-icon {
    color: var(--accent);
  }

  .tria-footer-contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
    transition: color 0.3s var(--ease-spring);
    width: 20px;
  }

  .tria-footer-social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tria-footer-social a {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: all 0.3s var(--ease-spring);
    line-height: 1;
  }

  .tria-footer-social a:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* ── Bottom bar ── */
  .tria-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 28px 0 40px;
    flex-wrap: wrap;
  }

  .tria-footer-copyright {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
  }

  .tria-footer-legal {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 32px);
    flex-wrap: wrap;
  }

  .tria-footer-legal a {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
    text-decoration: none;
    transition: color 0.3s var(--ease-smooth);
  }

  .tria-footer-legal a:hover {
    color: #fff;
  }

  /* ── Responsive ── */
  @media (max-width: 991px) {
    .tria-footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 40px 32px;
    }

    .tria-footer-col--brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 575px) {
    .tria-footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .tria-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .tria-footer-legal {
      gap: 20px;
    }
  }
</style>
