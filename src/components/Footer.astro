---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const year = new Date().getFullYear();

const exploreLinks = [
  { href: "/", label: t("nav.home") },
  { href: "/about", label: t("nav.about") },
  { href: "/team", label: t("nav.team") },
  { href: "/portfolio", label: t("nav.work") },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: t("nav.contact") },
];

const serviceLinks = [
  { href: "/services#software-dev", label: t("nav.softwareDev"), html: true },
  { href: "/services#cloud-devops", label: t("nav.cloudDevops"), html: true },
  { href: "/services#ai-ml", label: t("nav.aiMl"), html: true },
  { href: "/services#cybersecurity", label: t("nav.cybersecurity"), html: true },
];

const projectLinks = [
  { href: "/project-1", label: t("nav.fintechDashboard") },
  { href: "/project-2", label: t("nav.cloudInfra") },
  { href: "/project-3", label: t("nav.ecommerce") },
  { href: "/project-4", label: t("nav.aiAnalytics") },
  { href: "/project-5", label: t("nav.iotFleet") },
  { href: "/project-6", label: t("nav.healthcareData") },
];

const contactLinks = [
  { href: "mailto:hola@triacr.com", label: t("footer.contactLink"), icon: "ti-mail" },
  { href: "mailto:support@triacr.com", label: t("footer.supportLink"), icon: "ti-headset" },
  { href: "mailto:sales@triacr.com", label: t("footer.salesLink"), icon: "ti-briefcase" },
  { href: "https://wa.me/50662164040", label: t("footer.whatsappLink"), icon: "ti-brand-whatsapp", external: true },
];

const socialLinks = [
  { href: "https://linkedin.com", label: "LinkedIn", icon: "fab fa-linkedin-in" },
  { href: "https://x.com", label: "X", icon: "fab fa-twitter" },
  { href: "https://instagram.com", label: "Instagram", icon: "fab fa-instagram" },
  { href: "https://github.com", label: "GitHub", icon: "fab fa-github" },
];
---

<footer class="tria-footer-section" data-section-theme="dark">
  <div class="tria-footer-glow"></div>
  <div class="tria-footer-glow tria-footer-glow--accent"></div>

  <div class="container tria-p-120-0">
    <!-- CTA band -->
    <div class="tria-footer-hero tria-up">
      <div class="tria-footer-hero-content">
        <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="footer.stayInLoop">{t("footer.stayInLoop")}</span>
        <h2 class="tria-footer-hero-title tria-up" data-i18n-html="footer.newsletterHeading" set:html={t("footer.newsletterHeading")} />
        <p class="tria-footer-hero-desc tria-up" data-i18n="footer.description">{t("footer.description")}</p>
      </div>
      <div class="tria-footer-hero-actions tria-up">
        <a href="/contact" class="tria-button tria-arrow-place">
          <span data-i18n="cta.startProject">{t("cta.startProject")}</span>
        </a>
        <a href="mailto:hola@triacr.com" class="tria-footer-email-link">
          <i class="ti ti-mail"></i>
          <span data-i18n="header.email">{t("header.email")}</span>
        </a>
      </div>
    </div>

    <!-- Navigation grid -->
    <div class="tria-footer-grid tria-up">
      <div class="tria-footer-col tria-footer-col--brand">
        <a href="/" class="tria-footer-logo" aria-label="tria home">
          tria<span class="tria-footer-logo-dot">.</span>
        </a>
        <ul class="tria-footer-social">
          {socialLinks.map((social) => (
            <li>
              <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label}>
                <i class={social.icon}></i>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col">
        <span class="tria-footer-label" data-i18n="nav.explore">{t("nav.explore")}</span>
        <ul class="tria-footer-nav">
          {exploreLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col">
        <span class="tria-footer-label" data-i18n="nav.services">{t("nav.services")}</span>
        <ul class="tria-footer-nav">
          {serviceLinks.map((link) => (
            <li>
              {link.html ? (
                <a href={link.href} set:html={link.label}></a>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col tria-footer-col--projects">
        <span class="tria-footer-label" data-i18n="nav.projects">{t("nav.projects")}</span>
        <ul class="tria-footer-nav">
          {projectLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="tria-footer-col">
        <span class="tria-footer-label" data-i18n="nav.contactInfo">{t("nav.contactInfo")}</span>
        <ul class="tria-footer-contact">
          {contactLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
              >
                <span class="tria-footer-contact-icon"><i class={`ti ${link.icon}`}></i></span>
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Meta row -->
    <div class="tria-footer-meta tria-up">
      <div class="tria-footer-meta-item">
        <span class="tria-footer-meta-label" data-i18n="cta.responseLabel">{t("cta.responseLabel")}</span>
        <span class="tria-footer-meta-value" data-i18n="cta.responseValue">{t("cta.responseValue")}</span>
      </div>
      <div class="tria-footer-meta-item tria-footer-meta-item--center">
        <span class="tria-footer-meta-label" data-i18n="cta.locationLabel">{t("cta.locationLabel")}</span>
        <span class="tria-footer-meta-value" data-i18n="cta.locationValue">{t("cta.locationValue")}</span>
      </div>
      <div class="tria-footer-meta-item tria-footer-meta-item--end">
        <span class="tria-footer-meta-label" data-i18n="cta.availabilityLabel">{t("cta.availabilityLabel")}</span>
        <span class="tria-footer-meta-value" data-i18n="cta.availabilityValue">{t("cta.availabilityValue")}</span>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="tria-footer-bottom tria-up">
      <p class="tria-footer-copyright">{t("footer.allRights").replace("{year}", String(year))}</p>
      <nav class="tria-footer-legal" aria-label="Legal">
        <a href="/privacy">{t("nav.privacyPolicy")}</a>
        <a href="/terms">{t("nav.terms")}</a>
        <a href="/cookies">{t("nav.cookiePolicy")}</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .tria-footer-section {
    position: relative;
    background: #0b0d17;
    overflow: hidden;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tria-footer-section .tria-suptitle {
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 1rem;
  }

  .tria-footer-glow {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .tria-footer-glow:first-of-type {
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.03) 0%, transparent 68%);
  }

  .tria-footer-glow--accent {
    bottom: -180px;
    right: -120px;
    width: 560px;
    height: 560px;
    background: radial-gradient(circle, rgba(var(--accent-rgb), 0.09) 0%, transparent 70%);
  }

  .tria-footer-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Hero band ── */
  .tria-footer-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 80px);
    align-items: end;
    padding-bottom: clamp(48px, 6vw, 72px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tria-footer-hero-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 450;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0 0 16px;
  }

  .tria-footer-hero-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    max-width: 480px;
  }

  .tria-footer-hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding-bottom: 4px;
  }

  .tria-footer-section .tria-button {
    background-color: var(--accent) !important;
    border-color: var(--accent) !important;
    color: #fff !important;
    transition: background 0.4s var(--ease-spring), border-color 0.4s var(--ease-spring), transform 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring);
  }

  .tria-footer-section .tria-button:hover {
    background-color: var(--accent-hover) !important;
    border-color: var(--accent-hover) !important;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(var(--accent-rgb), 0.25);
  }

  .tria-footer-email-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring), transform 0.35s var(--ease-spring);
  }

  .tria-footer-email-link i {
    font-size: 1rem;
    color: var(--accent);
  }

  .tria-footer-email-link:hover {
    color: #fff;
    transform: translateX(4px);
  }

  /* ── Main grid ── */
  .tria-footer-grid {
    display: grid;
    grid-template-columns: minmax(160px, 2fr) minmax(88px, 1fr) minmax(100px, 1.1fr) minmax(150px, 1.7fr) minmax(120px, 1.2fr);
    gap: clamp(24px, 3vw, 48px);
    padding: clamp(56px, 7vw, 80px) 0 clamp(48px, 6vw, 64px);
    align-items: start;
  }

  .tria-footer-col {
    min-width: 0;
  }

  .tria-footer-logo {
    display: inline-flex;
    align-items: center;
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #fff;
    text-decoration: none;
    margin-bottom: 28px;
    transition: opacity 0.3s var(--ease-smooth);
  }

  .tria-footer-logo:hover {
    opacity: 0.85;
  }

  .tria-footer-logo-dot {
    color: var(--accent);
    margin-left: -1px;
  }

  .tria-footer-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin-bottom: 22px;
  }

  .tria-footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tria-footer-nav a {
    display: inline-block;
    font-size: 0.88rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring), transform 0.35s var(--ease-spring);
  }

  .tria-footer-nav a:hover {
    color: #fff;
    transform: translateX(4px);
  }

  .tria-footer-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-footer-contact a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring);
  }

  .tria-footer-contact a:hover {
    color: #fff;
  }

  .tria-footer-contact a:hover .tria-footer-contact-icon {
    background: rgba(var(--accent-rgb), 0.14);
    border-color: rgba(var(--accent-rgb), 0.35);
    color: var(--accent);
  }

  .tria-footer-contact-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
    transition: all 0.35s var(--ease-spring);
  }

  .tria-footer-social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tria-footer-social a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: all 0.35s var(--ease-spring);
  }

  .tria-footer-social a:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(var(--accent-rgb), 0.3);
  }

  /* ── Meta row ── */
  .tria-footer-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    padding: 48px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tria-footer-meta-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tria-footer-meta-item--center {
    text-align: center;
  }

  .tria-footer-meta-item--end {
    text-align: right;
  }

  .tria-footer-meta-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
  }

  .tria-footer-meta-value {
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.62);
  }

  /* ── Bottom bar ── */
  .tria-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 28px 0 40px;
    flex-wrap: wrap;
  }

  .tria-footer-copyright {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
  }

  .tria-footer-legal {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 32px);
    flex-wrap: wrap;
  }

  .tria-footer-legal a {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
    text-decoration: none;
    transition: color 0.3s var(--ease-smooth);
  }

  .tria-footer-legal a:hover {
    color: #fff;
  }

  /* ── Responsive ── */
  @media (max-width: 991px) {
    .tria-footer-hero {
      grid-template-columns: 1fr;
      align-items: flex-start;
    }

    .tria-footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 40px 32px;
    }

    .tria-footer-col--brand {
      grid-column: 1 / -1;
    }

    .tria-footer-meta {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .tria-footer-meta-item--center,
    .tria-footer-meta-item--end {
      text-align: left;
    }
  }

  @media (max-width: 575px) {
    .tria-footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .tria-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .tria-footer-legal {
      gap: 20px;
    }
  }
</style>
