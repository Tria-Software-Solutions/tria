---
interface FooterLink {
  href: string;
  label: string;
  html?: boolean;
  external?: boolean;
}

interface ContactLink extends FooterLink {
  icon: string;
}

interface SocialLink {
  href: string;
  label: string;
  icon: string;
}

interface Props {
  brandName?: string;
  brandHref?: string;
  brandDescription?: string;
  socialLabel?: string;
  exploreLabel?: string;
  servicesLabel?: string;
  projectsLabel?: string;
  contactLabel?: string;
  exploreLinks?: FooterLink[];
  serviceLinks?: FooterLink[];
  projectLinks?: FooterLink[];
  contactLinks?: ContactLink[];
  socialLinks?: SocialLink[];
  copyrightText?: string;
  legalLinks?: FooterLink[];
  showGlow?: boolean;
}

const {
  brandName = "tria",
  brandHref = "/",
  brandDescription,
  socialLabel,
  exploreLabel,
  servicesLabel,
  projectsLabel,
  contactLabel,
  exploreLinks = [],
  serviceLinks = [],
  projectLinks = [],
  contactLinks = [],
  socialLinks = [],
  copyrightText,
  legalLinks = [],
  showGlow = true
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class="tria-footer-section" data-section-theme="dark">
  {showGlow && <div class="tria-footer-glow"></div>}
  {showGlow && <div class="tria-footer-glow tria-footer-glow--accent"></div>}

  <div class="container">
    <!-- Navigation grid -->
    <div class="tria-footer-grid tria-up">
      <div class="tria-footer-col tria-footer-col--brand">
        <a href={brandHref} class="tria-footer-logo" aria-label={`${brandName} home`}>
          {brandName}<span class="tria-footer-logo-dot">.</span>
        </a>

        {brandDescription && <p class="tria-footer-brand-desc">{brandDescription}</p>}

        {socialLabel && <span class="tria-footer-label">{socialLabel}</span>}
        {socialLinks.length > 0 && (
          <ul class="tria-footer-social">
            {socialLinks.map((social) => (
              <li>
                <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label}>
                  <i class={social.icon}></i>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      {exploreLinks.length > 0 && (
        <div class="tria-footer-col">
          {exploreLabel && <span class="tria-footer-label">{exploreLabel}</span>}
          <ul class="tria-footer-nav">
            {exploreLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {serviceLinks.length > 0 && (
        <div class="tria-footer-col">
          {servicesLabel && <span class="tria-footer-label">{servicesLabel}</span>}
          <ul class="tria-footer-nav">
            {serviceLinks.map((link) => (
              <li>
                {link.html ? (
                  <a href={link.href} set:html={link.label}></a>
                ) : (
                  <a href={link.href}>{link.label}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}

      {projectLinks.length > 0 && (
        <div class="tria-footer-col tria-footer-col--projects">
          {projectsLabel && <span class="tria-footer-label">{projectsLabel}</span>}
          <ul class="tria-footer-nav">
            {projectLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {contactLinks.length > 0 && (
        <div class="tria-footer-col">
          {contactLabel && <span class="tria-footer-label">{contactLabel}</span>}
          <ul class="tria-footer-contact">
            {contactLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                >
                  <span class="tria-footer-contact-icon"><i class={`ti ${link.icon}`}></i></span>
                  <span>{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Bottom bar -->
    <div class="tria-footer-bottom tria-up">
      <p class="tria-footer-copyright">{copyrightText || `© ${year} ${brandName}. All rights reserved.`}</p>
      {legalLinks.length > 0 && (
        <nav class="tria-footer-legal" aria-label="Legal">
          {legalLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      )}
    </div>
  </div>
</footer>

<style>
  .tria-footer-section {
    position: relative;
    background: #0b0d17;
    overflow: hidden;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tria-footer-section .tria-suptitle {
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 1rem;
  }

  .tria-footer-glow {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .tria-footer-glow:first-of-type {
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.03) 0%, transparent 68%);
  }

  .tria-footer-glow--accent {
    bottom: -180px;
    right: -120px;
    width: 560px;
    height: 560px;
    background: radial-gradient(circle, rgba(var(--accent-rgb), 0.09) 0%, transparent 70%);
  }

  .tria-footer-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Main grid ── */
  .tria-footer-grid {
    display: grid;
    grid-template-columns: minmax(200px, 2.2fr) minmax(88px, 1fr) minmax(100px, 1.1fr) minmax(150px, 1.7fr) minmax(120px, 1.2fr);
    gap: clamp(24px, 3vw, 48px);
    padding: clamp(56px, 7vw, 80px) 0 clamp(48px, 6vw, 64px);
    align-items: start;
  }

  .tria-footer-col {
    min-width: 0;
  }

  .tria-footer-logo {
    display: inline-flex;
    align-items: center;
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #fff;
    text-decoration: none;
    margin-bottom: 28px;
    transition: opacity 0.3s var(--ease-smooth);
  }

  .tria-footer-logo:hover {
    opacity: 0.85;
  }

  .tria-footer-logo-dot {
    color: var(--accent);
    margin-left: -1px;
  }

  .tria-footer-brand-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.35);
    margin: -12px 0 20px;
    max-width: 260px;
  }

  .tria-footer-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin-bottom: 22px;
  }

  .tria-footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tria-footer-nav a {
    display: inline-block;
    font-size: 0.88rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring), transform 0.35s var(--ease-spring);
  }

  .tria-footer-nav a:hover {
    color: #fff;
    transform: translateX(4px);
  }

  .tria-footer-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-footer-contact a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    transition: color 0.35s var(--ease-spring);
  }

  .tria-footer-contact a:hover {
    color: #fff;
  }

  .tria-footer-contact a:hover .tria-footer-contact-icon {
    color: var(--accent);
  }

  .tria-footer-contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
    transition: color 0.3s var(--ease-spring);
    width: 20px;
  }

  .tria-footer-social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tria-footer-social a {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: all 0.3s var(--ease-spring);
    line-height: 1;
  }

  .tria-footer-social a:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* ── Bottom bar ── */
  .tria-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 28px 0 40px;
    flex-wrap: wrap;
  }

  .tria-footer-copyright {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
  }

  .tria-footer-legal {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 32px);
    flex-wrap: wrap;
  }

  .tria-footer-legal a {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
    text-decoration: none;
    transition: color 0.3s var(--ease-smooth);
  }

  .tria-footer-legal a:hover {
    color: #fff;
  }

  /* ── Responsive ── */
  @media (max-width: 991px) {
    .tria-footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 40px 32px;
    }

    .tria-footer-col--brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 575px) {
    .tria-footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .tria-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .tria-footer-legal {
      gap: 20px;
    }
  }
</style>
