---
export type ButtonVariant = 'primary' | 'secondary' | 'outline' | 'ghost' | 'glass';
export type ButtonSize = 'xs' | 'sm' | 'md' | 'lg';

interface Props {
  text?: string;
  href?: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
  color?: string;
  hoverColor?: string;
  showArrow?: boolean;
  arrowPosition?: 'left' | 'right';
  fullWidth?: boolean;
  target?: '_blank' | '_self';
  rel?: string;
  className?: string;
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  style?: string;
  active?: boolean;
  iconOnly?: boolean;
}

const {
  text,
  href,
  variant = 'primary',
  size = 'md',
  color,
  hoverColor,
  showArrow = false,
  arrowPosition = 'right',
  fullWidth = false,
  target = '_self',
  rel,
  className = '',
  id,
  type = 'button',
  style,
  active = false,
  iconOnly = false,
} = Astro.props;

const isLink = !!href;
const styleVars = color ? `--btn-color: ${color}; --btn-hover: ${hoverColor || color};` : '';
const cls = [
  'tria-btn',
  `tria-btn--${variant}`,
  `tria-btn--${size}`,
  showArrow ? 'tria-btn--arrow' : '',
  arrowPosition === 'left' ? 'tria-btn--arrow-left' : '',
  fullWidth ? 'tria-btn--full' : '',
  active ? 'tria-btn--active' : '',
  iconOnly ? 'tria-btn--icon-only' : '',
  className,
].filter(Boolean).join(' ');

const knownProps = new Set(['text', 'href', 'variant', 'size', 'color', 'hoverColor', 'showArrow', 'arrowPosition', 'fullWidth', 'target', 'rel', 'className', 'id', 'type', 'style', 'active', 'arrowStyle', 'iconOnly']);
const attrs: Record<string, any> = {};
for (const [key, val] of Object.entries(Astro.props)) {
  if (!knownProps.has(key) && val !== undefined) {
    attrs[key] = val;
  }
}
---

{isLink ? (
  <a href={href} class={cls} target={target} rel={rel} id={id} style={styleVars || style} {...attrs}>
    {iconOnly ? (
      <slot name="icon" />
    ) : (
      <>
        {arrowPosition === 'left' && showArrow && (
          <svg class="tria-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13 8H3M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
        <span class="tria-btn-text">{text}</span>
        {arrowPosition === 'right' && showArrow && (
          <svg class="tria-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
      </>
    )}
  </a>
) : (
  <button class={cls} id={id} type={type} style={styleVars} {...attrs}>
    {iconOnly ? (
      <slot name="icon" />
    ) : (
      <>
        {arrowPosition === 'left' && showArrow && (
          <svg class="tria-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13 8H3M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
        <span class="tria-btn-text">{text}</span>
        {arrowPosition === 'right' && showArrow && (
          <svg class="tria-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
      </>
    )}
  </button>
)}

<style>
  .tria-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 550;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  /* ── Sizes ── */
  .tria-btn--xs {
    height: 36px;
    padding: 0 1rem;
    font-size: 0.65rem;
    gap: 6px;
    letter-spacing: 0.08em;
  }

  .tria-btn--sm {
    height: 44px;
    padding: 0 1.25rem;
    font-size: 0.7rem;
    gap: 8px;
  }

  .tria-btn--md {
    height: 52px;
    padding: 0 1.75rem;
    font-size: 0.75rem;
    gap: 8px;
  }

  .tria-btn--lg {
    height: 60px;
    padding: 0 2.25rem;
    font-size: 0.82rem;
    gap: 10px;
  }

  .tria-btn--full {
    width: 100%;
  }

  /* ── Arrow (always inline style — no circle card) ── */
  .tria-btn-arrow {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-btn-arrow path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .tria-btn--arrow-left .tria-btn-arrow {
    order: -1;
  }

  .tria-btn:hover .tria-btn-arrow {
    transform: translateX(4px);
  }

  .tria-btn--arrow-left:hover .tria-btn-arrow {
    transform: translateX(-4px);
  }

  /* ── Primary ── */
  .tria-btn--primary {
    background-color: var(--btn-color, var(--accent));
    color: #fff;
  }

  .tria-btn--primary:hover {
    background-color: var(--btn-hover, color-mix(in srgb, var(--accent), white 15%));
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--accent), transparent 55%);
  }

  /* ── Secondary (dark) ── */
  .tria-btn--secondary {
    background-color: var(--btn-color, #0b0d17);
    color: #fff;
  }

  .tria-btn--secondary:hover {
    background-color: var(--btn-hover, #252b4a);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
  }

  /* ── Outline ── */
  .tria-btn--outline {
    background-color: transparent;
    color: var(--btn-color, var(--accent));
    box-shadow: inset 0 0 0 1.5px var(--btn-color, var(--accent));
  }

  .tria-btn--outline:hover {
    background-color: var(--btn-color, var(--accent));
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--accent), transparent 55%);
  }

  .tria-btn--outline.tria-btn--active {
    background-color: var(--btn-color, var(--accent));
    color: #fff;
  }

  /* ── Ghost ── */
  .tria-btn--ghost {
    background-color: transparent;
    color: var(--btn-color, var(--accent));
  }

  .tria-btn--ghost:hover {
    background-color: var(--btn-hover, var(--btn-color, var(--accent)));
    color: #fff;
    transform: translateY(-1px);
  }

  /* ── Glass (hero only — true glassmorphism, sin gradient) ── */
  .tria-btn--glass {
    background: rgba(255, 255, 255, 0.10);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255,255,255,0.1);
  }

  .tria-btn--glass:hover {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255,255,255,0.15);
  }

  /* ── Focus ── */
  .tria-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ── Disabled ── */
  .tria-btn:disabled,
  .tria-btn[aria-disabled="true"] {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ── Icon-only (circular) ── */
  .tria-btn--icon-only {
    padding: 0;
    border-radius: 50%;
    justify-content: center;
  }
  .tria-btn--icon-only.tria-btn--xs {
    width: 36px;
    height: 36px;
    padding: 0;
  }
  .tria-btn--icon-only.tria-btn--sm {
    width: 44px;
    height: 44px;
    padding: 0;
  }
  .tria-btn--icon-only.tria-btn--md {
    width: 52px;
    height: 52px;
    padding: 0;
  }
  .tria-btn--icon-only.tria-btn--lg {
    width: 60px;
    height: 60px;
    padding: 0;
  }
  .tria-btn--icon-only :slotted(svg) {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 576px) {
    .tria-btn--md { height: 48px; padding: 0 1.5rem; }
    .tria-btn--lg { height: 54px; padding: 0 1.75rem; font-size: 0.78rem; }
    .tria-btn--xs { height: 32px; padding: 0 0.75rem; }
    .tria-btn--sm { height: 40px; padding: 0 1rem; }
    .tria-btn--icon-only.tria-btn--xs { width: 32px; height: 32px; }
  }
  @media (max-width: 400px) {
    .tria-btn--md { height: 44px; padding: 0 1.25rem; }
    .tria-btn--lg { height: 50px; padding: 0 1.5rem; }
  }
</style>
