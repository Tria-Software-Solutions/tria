---
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<!-- team -->
<section data-section-theme="light">
  <div class="container tria-p-120-30">
    <div class="tria-mb-30">
      <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="team.suptitle">{t("team.suptitle")}</span>
      <h2 class="tria-up" style="margin-top:20px;" data-i18n-html="team.title" set:html={t("team.title")} />
    </div>
    <div class="row justify-content-between align-items-center">
      <div class="col-lg-5 col-xl-4">
        <div class="tria-mb-90">
          <p class="tria-up tria-mb-30" data-i18n="team.description1">{t("team.description1")}</p>
          <p class="tria-up tria-mb-60" data-i18n="team.description2">{t("team.description2")}</p>
          <p class="tria-up tria-mb-30" style="font-size:1rem;line-height:1.6;font-weight:450;color:rgb(0,0,0);" data-i18n-html="team.tagline" set:html={t("team.tagline")} />
          <div class="tria-up">
            <a href="/team" class="tria-button tria-arrow-place"><span data-i18n="team.readMore">{t("team.readMore")}</span></a>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="tria-team-list">
          <div class="tria-lines-place"></div>
          <div class="row tria-mb-60">
            <div class="col-sm-6">
              <div class="tria-team-card tria-up tria-mb-30">
                <img src="/assets/img/team/1.jpg" alt="Team member" />
                <div class="tria-description">
                  <div class="tria-secrc-text">
                    <h5 class="tria-dark tria-mb-5">
                      Sofia Rojas
                    </h5>
                    <p class="tria-link tria-dark-soft tria-mb-10" data-i18n="team.role1">{t("team.role1")}</p>
                    <ul class="tria-social-icons tria-dark tria-center">
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-behance"></i></a
                        >
                      </li>
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-dribbble"></i></a
                        >
                      </li>
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-twitter"></i></a
                        >
                      </li>
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-github"></i></a
                        >
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-sm-6">
                <p
                  class="tria-mobile-hidden tria-text-sm tria-mb-30"
                  style="height: 30px;"
                >
                  <span class="tria-accent">*</span><span data-i18n="team.coreNote">{t("team.coreNote")}</span>
                </p>
              <div class="tria-team-card tria-up tria-mb-30">
                <img src="/assets/img/team/2.jpg" alt="Team member" />
                <div class="tria-description">
                  <div class="tria-secrc-text">
                    <h5 class="tria-dark tria-mb-5">
                      Valeria Castro
                    </h5>
                    <p class="tria-link tria-dark-soft tria-mb-10" data-i18n="team.role2">{t("team.role2")}</p>
                    <ul class="tria-social-icons tria-dark tria-center">
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-behance"></i></a
                        >
                      </li>
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-dribbble"></i></a
                        >
                      </li>
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-twitter"></i></a
                        >
                      </li>
                      <li>
                        <a href="#." target="_blank" class="social-icon">
                          <i class="fab fa-github"></i></a
                        >
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- team end -->

<style>
  .tria-team-card {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-team-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.08);
  }
  .tria-team-card img {
    border-radius: 16px;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    width: 100%;
    display: block;
  }
  .tria-team-card:hover img {
    transform: scale(1.03);
  }
  .tria-team-card .tria-description {
    padding: 20px 0 0;
  }
  .tria-team-card .tria-social-icons {
    gap: 12px;
  }
  .tria-team-card .tria-social-icons li a {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.08);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: rgba(0,0,0,0.4);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-team-card .tria-social-icons li a:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: translateY(-2px);
  }
  @media (max-width: 768px) {
    .tria-team-card .tria-social-icons li a {
      width: 28px;
      height: 28px;
      font-size: 10px;
    }
  }
</style>
