---
interface Props {
  translations: any;
}

const { translations } = Astro.props;

const team = [
  { name: 'Carlos Rodriguez', role: 'CEO & Founder', socials: ['linkedin', 'twitter', 'github'] },
  { name: 'Maria Gonzalez', role: 'Lead Developer', socials: ['linkedin', 'twitter', 'github'] },
  { name: 'Ana Silva', role: 'UI/UX Designer', socials: ['linkedin', 'dribbble', 'behance'] },
  { name: 'Jose Martinez', role: 'Backend Engineer', socials: ['linkedin', 'twitter', 'github'] },
  { name: 'Laura Fernandez', role: 'Project Manager', socials: ['linkedin', 'twitter', 'github'] },
  { name: 'Diego Lopez', role: 'DevOps Engineer', socials: ['linkedin', 'twitter', 'github'] },
  { name: 'Sofia Herrera', role: 'QA Engineer', socials: ['linkedin', 'twitter', 'github'] },
  { name: 'Roberto Morales', role: 'Mobile Developer', socials: ['linkedin', 'twitter', 'github'] },
];
---

<section id="team">
  <div class="container mil-p-120-90">
    <div class="row">
      {team.map((member) => (
        <div class="col-sm-6 col-md-4 col-lg-3">
          <div class="mil-team-card mil-up mil-mb-30">
            <img src="/assets/images/placeholder.svg" alt={member.name} />
            <div class="mil-description">
              <div class="mil-secrc-text">
                <h5 class="mil-muted mil-mb-5"><a href="#.">{member.name}</a></h5>
                <p class="mil-link mil-light-soft mil-mb-10">{member.role}</p>
                <ul class="mil-social-icons mil-center">
                  {member.socials.map((social) => (
                    <li>
                      <a href="#" target="_blank" class="social-icon">
                        <i class={`fab fa-${social}`}></i>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
