---
import Button from "./Button.astro";
interface TeamMember {
  name: string;
  role: string;
  image: string;
  socialLinks?: { icon: string; href: string }[];
  isCore?: boolean;
}

interface Props {
  suptitle?: string;
  heading: string;
  description1?: string;
  description2?: string;
  tagline?: string;
  readMoreText?: string;
  readMoreHref?: string;
  coreNote?: string;
  members: TeamMember[];
  padding?: string;
}

const {
  suptitle,
  heading,
  description1,
  description2,
  tagline,
  readMoreText,
  readMoreHref = "/team",
  coreNote,
  members = [],
  padding = 'tria-p-120-30'
} = Astro.props;
---

<!-- team -->
<section data-section-theme="light">
  <div class={`container ${padding}`}>
    <div class="tria-mb-30">
      {suptitle && <span class="tria-suptitle tria-suptitle-dark tria-up">{suptitle}</span>}
      <h2 class="tria-up" style="margin-top:20px;" set:html={heading} />
    </div>
    <div class="row justify-content-between align-items-center">
      <div class="col-lg-5 col-xl-4">
        <div class="tria-mb-90">
          {description1 && <p class="tria-up tria-mb-30">{description1}</p>}
          {description2 && <p class="tria-up tria-mb-60">{description2}</p>}
          {tagline && <p class="tria-up tria-mb-30" style="font-size:1rem;line-height:1.6;font-weight:450;color:rgb(0,0,0);" set:html={tagline} />}
          {readMoreText && (
            <div class="tria-up">
              <Button text={readMoreText} href={readMoreHref} showArrow={true} />
            </div>
          )}
        </div>
      </div>
      <div class="col-lg-6">
        <div class="tria-team-list">
          <div class="tria-lines-place"></div>
          <div class="row tria-mb-60">
            {members.map((member, index) => (
              <div class="col-sm-6">
                {index === 1 && coreNote && (
                  <p class="tria-mobile-hidden tria-text-sm tria-mb-30" style="height: 30px;">
                    <span class="tria-accent">*</span><span>{coreNote}</span>
                  </p>
                )}
                <div class="tria-team-card tria-up tria-mb-30">
                  <img src={member.image} alt="Team member" />
                  <div class="tria-description">
                    <div class="tria-secrc-text">
                      <h5 class="tria-dark tria-mb-5">{member.name}</h5>
                      <p class="tria-link tria-dark-soft tria-mb-10">{member.role}</p>
                      {member.socialLinks && (
                        <ul class="tria-social-icons tria-dark tria-center">
                          {member.socialLinks.map((social) => (
                            <li>
                              <a href={social.href} target="_blank" class="social-icon" set:html={social.icon} />
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- team end -->

<style>
  .tria-team-card {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-team-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 70px rgba(0,0,0,0.1);
  }
  .tria-team-card img {
    border-radius: 16px;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    width: 100%;
    display: block;
  }
  .tria-team-card:hover img {
    transform: scale(1.05);
  }

  /* ── Modern glass overlay ── */
  .tria-team-card .tria-description {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 0;
    display: flex;
    align-items: flex-end;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.85) 0%,
      rgba(0,0,0,0.4) 50%,
      transparent 100%
    );
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .tria-team-card:hover .tria-description {
    opacity: 1;
    pointer-events: all;
  }

  .tria-team-card .tria-secrc-text {
    padding: 30px 24px;
    width: 100%;
    transform: translateY(20px);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-team-card:hover .tria-secrc-text {
    transform: translateY(0);
  }

  .tria-team-card .tria-secrc-text h5 {
    font-size: 1.1rem;
    font-weight: 500;
    color: #fff;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
    transform: translateY(12px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.05s;
  }
  .tria-team-card:hover .tria-secrc-text h5 {
    transform: translateY(0);
    opacity: 1;
  }

  .tria-team-card .tria-secrc-text p.tria-link {
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 16px;
    text-decoration: none;
    transform: translateY(12px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.1s;
  }
  .tria-team-card:hover .tria-secrc-text p.tria-link {
    transform: translateY(0);
    opacity: 1;
  }

  .tria-team-card .tria-social-icons {
    gap: 10px;
    transform: translateY(12px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.15s;
  }
  .tria-team-card:hover .tria-social-icons {
    transform: translateY(0);
    opacity: 1;
  }

  .tria-team-card .tria-social-icons li a {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    background: rgba(255,255,255,0.05);
  }
  .tria-team-card .tria-social-icons li a:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: translateY(-3px) scale(1.1);
  }

  /* ── Accent bar at bottom of card ── */
  .tria-team-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 0 0 16px 16px;
  }
  .tria-team-card:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 768px) {
    .tria-team-card .tria-social-icons li a {
      width: 30px;
      height: 30px;
      font-size: 10px;
    }
    .tria-team-card .tria-secrc-text {
      padding: 24px 20px;
    }
    .tria-team-card .tria-secrc-text h5 {
      font-size: 1rem;
    }
  }

  @media (max-width: 576px) {
    .tria-team-card {
      border-radius: 12px;
    }
    .tria-team-card img {
      border-radius: 12px;
    }
    .tria-team-card::after {
      height: 2px;
    }
    .tria-team-card .tria-secrc-text {
      padding: 20px 16px;
    }
    .tria-team-card .tria-secrc-text h5 {
      font-size: 0.9rem;
    }
    .tria-team-card .tria-secrc-text p.tria-link {
      font-size: 0.65rem;
      margin-bottom: 12px;
    }
    .tria-team-card .tria-social-icons li a {
      width: 26px;
      height: 26px;
      font-size: 9px;
    }
  }
</style>
