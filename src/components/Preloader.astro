---
interface Props {
  translations: any;
}

const { translations } = Astro.props;
---
<div class="mil-preloader">
  <div class="mil-preloader-animation">
    <div class="mil-pos-abs mil-animation-1">
      <p class="mil-h3 mil-muted mil-thin" data-i18n-text="preloader.word1">{translations.preloader?.word1 || 'Building'}</p>
      <p class="mil-h3 mil-muted" data-i18n-text="preloader.word2">{translations.preloader?.word2 || 'Digital'}</p>
      <p class="mil-h3 mil-muted mil-thin" data-i18n-text="preloader.word3">{translations.preloader?.word3 || 'Solutions'}</p>
    </div>
    <div class="mil-pos-abs mil-animation-2">
      <div class="mil-reveal-frame">
        <p class="mil-reveal-box"></p>
        <p class="mil-h3 mil-muted mil-thin">triacr.com</p>
      </div>
    </div>
  </div>
</div>
<div class="mil-progress-track">
  <div class="mil-progress"></div>
</div>
