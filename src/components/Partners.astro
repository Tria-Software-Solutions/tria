---
interface Partner {
  logo: string;
  href: string;
  alt?: string;
}

interface Props {
  partners: Partner[];
  padding?: string;
}

const {
  partners = [],
  padding = '80px 0'
} = Astro.props;

const repeat = (arr: Partner[], n: number) => Array.from({ length: n }, () => arr).flat();
const full = repeat(partners, 6);
---

<!-- partners -->
<section id="partners" class="tria-partners-section" data-section-theme="light" style={`padding: ${padding};`}>
  <div class="tria-tech-marquee tria-up">
    <div class="tria-tech-marquee-inner">
      <div class="tria-marquee-row tria-marquee-row--right">
        <div class="tria-marquee-track">
          {full.map((partner, i) => (
            <a key={i} href={partner.href} class="tria-marquee-icon">
              <img src={partner.logo} alt={partner.alt || 'logo'} />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
<!-- partners end -->

<style>
  .tria-partners-section {
    background: #faf8f5;
    position: relative;
  }

  .tria-partners-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(6,142,140,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .tria-tech-marquee {
    margin-top: 8px;
    padding-bottom: 0;
    position: relative;
    z-index: 1;
  }

  .tria-tech-marquee-inner {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-marquee-row {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }

  .tria-marquee-track {
    display: flex;
    gap: 64px;
    width: max-content;
    animation: tria-marquee-scroll 22s linear infinite;
    padding: 8px 0;
  }

  .tria-marquee-row--right .tria-marquee-track {
    animation-direction: normal;
  }

  @keyframes tria-marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .tria-marquee-icon {
    flex-shrink: 0;
    transition: opacity 0.3s var(--ease-spring), transform 0.3s var(--ease-spring);
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tria-marquee-icon img {
    height: 80px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    opacity: 1;
  }

  @media (max-width: 576px) {
    .tria-marquee-icon img {
      height: 56px;
      width: auto;
    }
    /* Mobile widths handled inline */
    .tria-marquee {
      gap: 48px;
    }
  }

  .tria-marquee-icon:hover {
    transform: scale(1.15);
  }
</style>
