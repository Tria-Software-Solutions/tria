---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.aboutTitle")} description={t("meta.aboutDesc")}>
  <PageBanner suptitleKey="about.suptitleAlt" headingKey="about.title" descriptionKey="about.heroDesc" />

  <!-- about content — white frameless -->
  <section class="tria-ab-section" data-section-theme="light">
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row justify-content-between align-items-center">
        <div class="col-lg-5">
          <p class="tria-up tria-ab-text" data-i18n="about.description1">{t("about.description1")}</p>
          <p class="tria-up tria-ab-text" data-i18n="about.description2">{t("about.description2")}</p>
          <div class="tria-ab-tagline tria-up">
            <div class="tria-ab-badge">
              <img src="/assets/img/logo/logo-avatar.svg" alt="tria" class="tria-ab-badge-icon" />
              <span data-i18n-html="about.tagline" set:html={t("about.tagline")} />
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="tria-ab-visual tria-up">
            <img src="/assets/img/about/about.svg" alt="Software engineering illustration" class="tria-ab-image" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- values — gray bg with cards like engagement models -->
  <section id="values" class="tria-ab-values" data-section-theme="light">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row tria-mb-60">
        <div class="col-lg-6">
          <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="about.valuesSuptitle">{t("about.valuesSuptitle")}</span>
          <h2 class="tria-up tria-ab-section-title" data-i18n-html="about.valuesTitle" set:html={t("about.valuesTitle")} />
        </div>
        <div class="col-lg-5 offset-lg-1 tria-up">
          <p class="tria-ab-values-intro" data-i18n="about.valuesIntro">{t("about.valuesIntro")}</p>
        </div>
      </div>

      <div class="row tria-ab-values-grid">
        <div class="col-md-6 tria-up tria-mb-30">
          <div class="tria-ab-value-card">
            <div class="tria-ab-value-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="tria-ab-value-card-title" data-i18n="about.value1Title">{t("about.value1Title")}</h3>
            <p class="tria-ab-value-card-desc" data-i18n="about.value1Desc">{t("about.value1Desc")}</p>
          </div>
        </div>
        <div class="col-md-6 tria-up tria-mb-30">
          <div class="tria-ab-value-card">
            <div class="tria-ab-value-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            </div>
            <h3 class="tria-ab-value-card-title" data-i18n="about.value2Title">{t("about.value2Title")}</h3>
            <p class="tria-ab-value-card-desc" data-i18n="about.value2Desc">{t("about.value2Desc")}</p>
          </div>
        </div>
        <div class="col-md-6 tria-up tria-mb-30">
          <div class="tria-ab-value-card">
            <div class="tria-ab-value-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9l-3 3 3 3"/><path d="M9 5l3-3 3 3"/><path d="M15 19l-3 3-3-3"/><path d="M19 9l3 3-3 3"/><path d="M2 12h20"/><path d="M12 2v20"/></svg>
            </div>
            <h3 class="tria-ab-value-card-title" data-i18n="about.value3Title">{t("about.value3Title")}</h3>
            <p class="tria-ab-value-card-desc" data-i18n="about.value3Desc">{t("about.value3Desc")}</p>
          </div>
        </div>
        <div class="col-md-6 tria-up tria-mb-30">
          <div class="tria-ab-value-card">
            <div class="tria-ab-value-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <h3 class="tria-ab-value-card-title" data-i18n="about.value4Title">{t("about.value4Title")}</h3>
            <p class="tria-ab-value-card-desc" data-i18n="about.value4Desc">{t("about.value4Desc")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

<Testimonials />

  <CTA 
    heading={t("ctaAbout.heading") || ""}
    description={t("ctaAbout.desc") || ""}
    primaryButtonText={t("ctaAbout.button") || ""}
    secondaryButtonText={t("ctaAbout.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/services"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════
     ABOUT CONTENT — White frameless
     ═══════════════════════════════════════ */
  .tria-ab-section {
    position: relative;
    overflow: hidden;
    background: #fff;
  }

  .tria-ab-text {
    color: rgba(0, 0, 0, 0.6);
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 24px;
    max-width: 520px;
  }
  .tria-ab-text:last-of-type {
    margin-bottom: 0;
  }

  .tria-ab-tagline {
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .tria-ab-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 22px 8px 16px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 100px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    font-size: 0.82rem;
    color: rgba(0, 0, 0, 0.4);
    line-height: 1.5;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    max-width: 100%;
  }
  .tria-ab-badge:hover {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(6, 142, 140, 0.2);
    box-shadow: 0 4px 20px rgba(6, 142, 140, 0.06);
  }
  .tria-ab-badge .tria-thin {
    color: rgba(0, 0, 0, 0.2);
  }

  .tria-ab-badge-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-ab-badge:hover .tria-ab-badge-icon {
    transform: scale(1.08);
  }

  .tria-ab-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tria-ab-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ═══════════════════════════════════════
     VALUES — Gray bg with cards
     ═══════════════════════════════════════ */
  .tria-ab-values {
    background: #f5f7f9;
    position: relative;
    overflow: hidden;
  }

  .tria-ab-section-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 450;
    letter-spacing: -0.025em;
    color: #0b0d17;
    margin-top: 20px;
    line-height: 1.15;
  }
  .tria-ab-section-title .tria-thin {
    color: rgba(0,0,0,0.2);
    font-weight: 200;
  }

  .tria-ab-values-intro {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.75;
    margin-top: 52px;
  }

  .tria-ab-values-grid {
    position: relative;
    z-index: 1;
  }

  .tria-ab-value-card {
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 20px;
    padding: 40px 34px;
    height: 100%;
    background: #fff;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-ab-value-card:hover {
    border-color: rgba(6,142,140,0.15);
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.04);
  }

  .tria-ab-value-card-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    background: rgba(6,142,140,0.07);
    color: var(--accent);
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-ab-value-card:hover .tria-ab-value-card-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }

  .tria-ab-value-card-title {
    font-size: 1.1rem;
    font-weight: 450;
    color: #0b0d17;
    margin-bottom: 14px;
  }
  .tria-ab-value-card:hover .tria-ab-value-card-title {
    color: var(--accent);
  }

  .tria-ab-value-card-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.75;
    margin: 0;
    transition: color 0.3s ease;
  }
  .tria-ab-value-card:hover .tria-ab-value-card-desc {
    color: #555;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 991px) {
    .tria-ab-visual { margin-top: 60px; }
    .tria-ab-values-intro { margin-top: 0; }
    .tria-ab-value-card { margin-bottom: 24px; }
    .tria-ab-value-card:last-child { margin-bottom: 0; }
  }

  @media (max-width: 768px) {
    .tria-ab-value-card { padding: 32px 28px; }
  }

  @media (max-width: 576px) {
    .tria-ab-text {
      font-size: 0.9rem;
      line-height: 1.75;
    }
    .tria-ab-badge {
      font-size: 0.75rem;
      padding: 6px 16px 6px 12px;
    }
    .tria-ab-badge-icon { width: 22px; height: 22px; }
    .tria-ab-visual { margin-top: 40px; }
    .tria-ab-value-card {
      padding: 28px 24px;
      margin-bottom: 20px;
    }
    .tria-ab-value-card-title { font-size: 1rem; }
    .tria-ab-value-card-desc { font-size: 0.78rem; }
    .tria-ab-value-card-icon {
      width: 40px; height: 40px;
      border-radius: 12px;
      margin-bottom: 18px;
    }
    .tria-ab-section-title { font-size: 1.5rem; }
    .tria-ab-values-intro { font-size: 0.82rem; }
  }

  @media (max-width: 400px) {
    .tria-ab-text { font-size: 0.82rem; }
    .tria-ab-tagline { margin-top: 28px; padding-top: 20px; }
    .tria-ab-value-card {
      padding: 22px 18px;
      margin-bottom: 16px;
    }
    .tria-ab-value-card-title { font-size: 0.9rem; }
    .tria-ab-value-card-desc { font-size: 0.72rem; }
  }
</style>
