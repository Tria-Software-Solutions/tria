---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Services from "../components/Services.astro";
import Stats from "../components/Stats.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <PageBanner suptitleKey="about.suptitleAlt" headingKey="about.title" descriptionKey="about.heroDesc" />

  <!-- about content -->
  <section class="tria-about-content" data-section-theme="light">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-2"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row justify-content-between align-items-center">
        <div class="col-lg-5">
          <p class="tria-up tria-about-text" data-i18n="about.description1">{t("about.description1")}</p>
          <p class="tria-up tria-about-text" data-i18n="about.description2">{t("about.description2")}</p>
          <div class="tria-about-tagline tria-up">
            <div class="tria-tagline-badge">
              <img src="/assets/img/logo/logo-avatar.svg" alt="tria" class="tria-tagline-icon" />
              <span data-i18n-html="about.tagline" set:html={t("about.tagline")} />
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="tria-about-visual tria-up">
            <img src="/assets/img/about/about.svg" alt="Software engineering illustration" class="tria-about-image" />
          </div>
        </div>
      </div>
    </div>
  </section>  <Services
    suptitle={t("about.valuesSuptitle") || ""}
    heading={t("about.valuesTitle") || ""}
    showTechMarquee={false}
    showArrow={false}
    services={[
      {
        title: t("about.value1Title") || "",
        description: t("about.value1Desc") || "",
        href: "/services",
        icon: "ti-components"
      },
      {
        title: t("about.value2Title") || "",
        description: t("about.value2Desc") || "",
        href: "/services",
        icon: "ti-shield-check"
      },
      {
        title: t("about.value3Title") || "",
        description: t("about.value3Desc") || "",
        href: "/services",
        icon: "ti-layers-difference"
      },
      {
        title: t("about.value4Title") || "",
        description: t("about.value4Desc") || "",
        href: "/services",
        icon: "ti-trending-up"
      }
    ]}
  />

  <Stats 
    stats={[
      { value: 25, suffix: '+', label: t("stats.projectsLabel") || "" },
      { value: 15, suffix: '+', label: t("stats.clientsLabel") || "" },
      { value: 7, suffix: '+', label: t("stats.yearsLabel") || "" },
      { value: 99, suffix: '%', label: t("stats.satisfactionLabel") || "" }
    ]}
  />

  <Testimonials />

  <CTA 
    heading={t("ctaAbout.heading") || ""}
    description={t("ctaAbout.desc") || ""}
    primaryButtonText={t("ctaAbout.button") || ""}
    secondaryButtonText={t("ctaAbout.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/services"
    theme="light"
    bgColor="#e8edf2"
    showIcon={true}
    padding="tria-p-120-120"
  />
  <SiteFooter /></Layout>

<style>
  .tria-about-content {
    position: relative;
    overflow: hidden;
    background: #fff;
  }

  .tria-about-text {
    color: rgba(0, 0, 0, 0.6);
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 24px;
    max-width: 520px;
  }
  .tria-about-text:last-of-type {
    margin-bottom: 0;
  }

  .tria-about-tagline {
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .tria-tagline-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 22px 8px 16px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 100px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    font-size: 0.82rem;
    color: rgba(0, 0, 0, 0.4);
    line-height: 1.5;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    max-width: 100%;
  }

  .tria-tagline-badge:hover {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(6, 142, 140, 0.2);
    box-shadow: 0 4px 20px rgba(6, 142, 140, 0.06);
  }

  .tria-tagline-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-tagline-badge:hover .tria-tagline-icon {
    transform: scale(1.08);
  }

  .tria-about-tagline .tria-thin {
    color: rgba(0, 0, 0, 0.2);
  }

  /* ── Visual / Image ── */
  .tria-about-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tria-about-image {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 991px) {
    .tria-about-visual {
      margin-top: 60px;
    }
  }

  @media (max-width: 576px) {
    .tria-about-text {
      font-size: 0.9rem;
      line-height: 1.75;
    }
    .tria-tagline-badge {
      font-size: 0.75rem;
      padding: 6px 16px 6px 12px;
    }
    .tria-tagline-icon {
      width: 22px;
      height: 22px;
    }
    .tria-about-visual {
      margin-top: 40px;
    }
  }

  @media (max-width: 400px) {
    .tria-about-text {
      font-size: 0.82rem;
    }
    .tria-about-tagline {
      margin-top: 28px;
      padding-top: 20px;
    }
  }
</style>
