---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import Process from "../components/Process.astro";
import Services from "../components/Services.astro";
import FeaturedWork from "../components/FeaturedWork.astro";
import Partners from "../components/Partners.astro";
import CTA from "../components/CTA.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import Quote from "../components/Quote.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale || 'en');
---

<Layout
  title="Tria — Software Solutions"
  description="Software enterprise crafting digital solutions."
>
  <Hero 
    title={t("hero.title") || ""}
    description={t("hero.description") || ""}
    buttonText={t("nav.startProject") || "Start a Project"}
    buttonHref="/contact"
  />
  <Stats 
    stats={[
      { value: 120, suffix: '+', label: t("stats.projectsLabel") || "" },
      { value: 48, suffix: '+', label: t("stats.clientsLabel") || "" },
      { value: 7, suffix: '+', label: t("stats.yearsLabel") || "" },
      { value: 99, suffix: '%', label: t("stats.satisfactionLabel") || "" }
    ]}
  />
  <Services 
    suptitle={t("services.suptitle") || ""}
    heading={t("services.modernSolutions") || ""}
    viewAllText={t("services.viewAll") || ""}
    viewAllHref="/services"
    services={[
      { 
        title: t("services.softwareDev") || "", 
        description: t("services.softwareDevDesc") || "", 
        href: "/services/software-dev",
        icon: "ti-code"
      },
      { 
        title: t("services.cloudDevops") || "", 
        description: t("services.cloudDevopsDesc") || "", 
        href: "/services/cloud-devops",
        icon: "ti-cloud"
      },
      { 
        title: t("services.aiMl") || "", 
        description: t("services.aiMlDesc") || "", 
        href: "/services/ai-ml",
        icon: "ti-robot"
      },
      { 
        title: t("services.itCybersecurity") || "", 
        description: t("services.itCybersecurityDesc") || "", 
        href: "/services/cybersecurity",
        icon: "ti-shield"
      }
    ]}
  />
  <FeaturedWork 
    suptitle={t("featured.suptitle") || ""}
    heading={t("featured.title") || ""}
    viewAllText={t("featured.viewAll") || ""}
    viewAllHref="/portfolio"
    ctaText={t("featured.viewProject") || "View project"}
    projects={[
      {
        category: t("featured.project1Cat") || "",
        title: t("featured.project1Title") || "",
        description: t("featured.project1Desc") || "",
        href: "/projects/parkit",
        gradient: "linear-gradient(135deg, #0b0d17 0%, #1a1f35 50%, #068e8c 100%)",
        tags: ["Express", "React Native", "Next.js", "PostgreSQL"],
        stat: "Multi-tenant",
        statLabel: "Architecture",
        previewImg: "/assets/img/featured/parkit.png"
      },
      {
        category: t("featured.project2Cat") || "",
        title: t("featured.project2Title") || "",
        description: t("featured.project2Desc") || "",
        href: "/projects/choferes",
        gradient: "linear-gradient(135deg, #1a1f35 0%, #2d3561 100%)",
        tags: ["React", "Material UI", "Node.js", "PostgreSQL"],
        stat: "OCR Pipeline",
        statLabel: "Automation",
        previewImg: "/assets/img/featured/choferes.png"
      },
      {
        category: t("featured.project6Cat") || "",
        title: t("featured.project6Title") || "",
        description: t("featured.project6Desc") || "",
        href: "https://github.com/Tria-Software-Solutions/goalr",
        gradient: "linear-gradient(135deg, #0f0c29 0%, #1a1a3e 40%, #068e8c 100%)",
        tags: ["NestJS", "Next.js", "React", "PostgreSQL"],
        stat: "Monorepo",
        statLabel: "Architecture",
        previewImg: "/assets/img/featured/goalr.png"
      },
      {
        category: t("featured.project7Cat") || "",
        title: t("featured.project7Title") || "",
        description: t("featured.project7Desc") || "",
        href: "https://github.com/Tria-Software-Solutions/las_granas",
        gradient: "linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #068e8c 100%)",
        tags: ["Next.js", "TypeScript", "Tailwind", "shadcn/ui"],
        stat: "B2B Trade",
        statLabel: "Platform",
        previewImg: "/assets/img/featured/lasgranas.png"
      },
      {
        category: t("featured.project5Cat") || "",
        title: t("featured.project5Title") || "",
        description: t("featured.project5Desc") || "",
        href: "https://github.com/lmhq-94/fault_diagnosis",
        gradient: "linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #068e8c 100%)",
        tags: ["TypeScript", "Vite", "Tailwind", "jsPDF"],
        stat: "Root Cause",
        statLabel: "Analysis",
        previewImg: "/assets/img/featured/fault-diagnosis.png"
      },
    ]}
  />
  <Partners 
    partners={[
      { logo: "/assets/img/partners/1.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/2.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/3.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/4.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/5.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/6.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/7.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/8.png", href: "#.", alt: "logo" },
      { logo: "/assets/img/partners/9.png", href: "#.", alt: "logo" },
    ]}
  />
  <Process 
    suptitle={t("process.suptitle") || ""}
    heading={t("process.title") || ""}
    intro={t("process.intro") || ""}
    steps={[
      {
        number: "01",
        title: t("process.step1Title") || "",
        description: t("process.step1Desc") || "",
        tags: [
          t("process.step1Tag1") || "",
          t("process.step1Tag2") || "",
          t("process.step1Tag3") || ""
        ]
      },
      {
        number: "02",
        title: t("process.step2Title") || "",
        description: t("process.step2Desc") || "",
        tags: [
          t("process.step2Tag1") || "",
          t("process.step2Tag2") || "",
          t("process.step2Tag3") || ""
        ]
      },
      {
        number: "03",
        title: t("process.step3Title") || "",
        description: t("process.step3Desc") || "",
        tags: [
          t("process.step3Tag1") || "",
          t("process.step3Tag2") || "",
          t("process.step3Tag3") || ""
        ]
      },
      {
        number: "04",
        title: t("process.step4Title") || "",
        description: t("process.step4Desc") || "",
        tags: [
          t("process.step4Tag1") || "",
          t("process.step4Tag2") || "",
          t("process.step4Tag3") || ""
        ]
      }
    ]}
  />
  <Pricing 
    suptitle={t("pricing.suptitle") || ""}
    heading={t("pricing.heading") || ""}
    description={t("pricing.description") || ""}
    suptitleKey="pricing.suptitle"
    headingKey="pricing.heading"
    descriptionKey="pricing.description"
    theme="light"
    padding="tria-p-120-120"
    plans={[
      {
        name: t("pricing.plan1Name") || "Starter",
        price: t("pricing.plan1Price") || "$999",
        period: t("pricing.plan1Period") || "/project",
        description: t("pricing.plan1Desc") || "",
        features: (() => {
          const f1 = [t("pricing.plan1Feature1"), t("pricing.plan1Feature2"), t("pricing.plan1Feature3"), t("pricing.plan1Feature4"), t("pricing.plan1Feature5")].filter(Boolean);
          return f1;
        })(),
        buttonHref: "/contact"
      },
      {
        name: t("pricing.plan2Name") || "Professional",
        price: t("pricing.plan2Price") || "$2,499",
        period: t("pricing.plan2Period") || "/project",
        description: t("pricing.plan2Desc") || "",
        features: (() => {
          const f1 = [t("pricing.plan1Feature1"), t("pricing.plan1Feature2"), t("pricing.plan1Feature3"), t("pricing.plan1Feature4"), t("pricing.plan1Feature5")].filter(Boolean);
          const f2 = [t("pricing.plan2Feature1"), t("pricing.plan2Feature2"), t("pricing.plan2Feature3"), t("pricing.plan2Feature4"), t("pricing.plan2Feature5"), t("pricing.plan2Feature6")].filter(Boolean);
          return [...f1, ...f2];
        })(),
        buttonHref: "/contact"
      },
      {
        name: t("pricing.plan3Name") || "Enterprise",
        price: t("pricing.plan3Price") || "$4,999",
        period: t("pricing.plan3Period") || "/project",
        description: t("pricing.plan3Desc") || "",
        features: (() => {
          const f1 = [t("pricing.plan1Feature1"), t("pricing.plan1Feature2"), t("pricing.plan1Feature3"), t("pricing.plan1Feature4"), t("pricing.plan1Feature5")].filter(Boolean);
          const f2 = [t("pricing.plan2Feature1"), t("pricing.plan2Feature2"), t("pricing.plan2Feature3"), t("pricing.plan2Feature4"), t("pricing.plan2Feature5"), t("pricing.plan2Feature6")].filter(Boolean);
          const f3 = [t("pricing.plan3Feature1"), t("pricing.plan3Feature2"), t("pricing.plan3Feature3"), t("pricing.plan3Feature4"), t("pricing.plan3Feature5"), t("pricing.plan3Feature6"), t("pricing.plan3Feature7")].filter(Boolean);
          return [...f1, ...f2, ...f3];
        })(),
        buttonHref: "/contact"
      },
      {
        name: t("pricing.plan4Name") || "Custom",
        price: t("pricing.plan4Price") || "Contact Us",
        period: t("pricing.plan4Period") || "",
        description: t("pricing.plan4Desc") || "",
        features: [
          t("pricing.plan4Feature1") || "",
          t("pricing.plan4Feature2") || "",
          t("pricing.plan4Feature3") || "",
          t("pricing.plan4Feature4") || "",
          t("pricing.plan4Feature5") || ""
        ],
        buttonText: "Contact Us",
        buttonHref: "/contact"
      }
    ]}
  />
  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />
  <Faq
    suptitle={t("faq.suptitle") || ""}
    heading={t("faq.title") || "Frequently Asked <span class=\"tria-thin\">Questions</span>"}
    items={[
      {
        question: t("faq.q1") || "",
        answer: t("faq.a1") || ""
      },
      {
        question: t("faq.q2") || "",
        answer: t("faq.a2") || ""
      },
      {
        question: t("faq.q3") || "",
        answer: t("faq.a3") || ""
      },
      {
        question: t("faq.q4") || "",
        answer: t("faq.a4") || ""
      },
      {
        question: t("faq.q5") || "",
        answer: t("faq.a5") || ""
      },
      {
        question: t("faq.q6") || "",
        answer: t("faq.a6") || ""
      },
      {
        question: t("faq.q7") || "",
        answer: t("faq.a7") || ""
      },
      {
        question: t("faq.q8") || "",
        answer: t("faq.a8") || ""
      }
    ]}
  />
  <CTA 
    heading={t("cta.heading") || ""}
    description={t("cta.description") || "From concept to deployment, we build software that scales."}
    primaryButtonText={t("cta.startProject") || ""}
    secondaryButtonText={t("cta.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>
