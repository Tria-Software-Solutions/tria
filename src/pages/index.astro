---
import Layout from "../layouts/Layout.astro";
import { getTranslations, type Translations } from '../lib/i18n/index';
import Preloader from '../components/Preloader.astro';
import Frame from '../components/Frame.astro';
import MenuFrame from '../components/MenuFrame.astro';
import Cursor from '../components/Cursor.astro';
import HiddenElements from '../components/HiddenElements.astro';
import Banner from '../components/Banner.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Team from '../components/Team.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';

const translations: Translations = getTranslations(Astro.url);
---

<Layout title="Home" translations={translations}>
  <div class="mil-wrapper" id="top">
    <Cursor translations={translations} />
    <Preloader translations={translations} />
    <div class="mil-progress-track">
      <div class="mil-progress"></div>
    </div>
    <Frame translations={translations} />
    <MenuFrame translations={translations} />
    <div class="mil-content">
      <div id="swupMain" class="mil-main-transition">
        <Banner translations={translations} />
        <About translations={translations} />
        <Services translations={translations} />
        <Team translations={translations} />
        <Testimonials translations={translations} />
        <Pricing translations={translations} />
        <Footer translations={translations} />
      </div>
    </div>
    <HiddenElements />
  </div>
</Layout>
