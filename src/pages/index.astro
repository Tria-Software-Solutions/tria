---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import Process from "../components/Process.astro";
import Services from "../components/Services.astro";
import FeaturedWork from "../components/FeaturedWork.astro";
import Team from "../components/Team.astro";
import Partners from "../components/Partners.astro";
import CTA from "../components/CTA.astro";
import Pricing from "../components/Pricing.astro";
import Quote from "../components/Quote.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale || 'en');
---

<Layout
  title="Tria — Software Solutions"
  description="Software enterprise crafting digital solutions."
>
  <Hero 
    title={t("hero.title") || ""}
    description={t("hero.description") || ""}
    buttonText={t("nav.startProject") || "Start a Project"}
    buttonHref="/contact"
  />
  <Stats 
    stats={[
      { value: 120, suffix: '+', label: t("stats.projectsLabel") || "" },
      { value: 48, suffix: '+', label: t("stats.clientsLabel") || "" },
      { value: 7, suffix: '+', label: t("stats.yearsLabel") || "" },
      { value: 99, suffix: '%', label: t("stats.satisfactionLabel") || "" }
    ]}
  />
  <Services 
    suptitle={t("services.suptitle") || ""}
    heading={t("services.modernSolutions") || ""}
    viewAllText={t("services.viewAll") || ""}
    viewAllHref="/services"
    services={[
      { 
        title: t("services.softwareDev") || "", 
        description: t("services.softwareDevDesc") || "", 
        href: "/service",
        icon: "ti-code"
      },
      { 
        title: t("services.cloudDevops") || "", 
        description: t("services.cloudDevopsDesc") || "", 
        href: "/service",
        icon: "ti-cloud"
      },
      { 
        title: t("services.aiMl") || "", 
        description: t("services.aiMlDesc") || "", 
        href: "/service",
        icon: "ti-robot"
      },
      { 
        title: t("services.itCybersecurity") || "", 
        description: t("services.itCybersecurityDesc") || "", 
        href: "/service",
        icon: "ti-shield"
      }
    ]}
  />
  <FeaturedWork 
    suptitle={t("featured.suptitle") || ""}
    heading={t("featured.title") || ""}
    viewAllText={t("featured.viewAll") || ""}
    viewAllHref="/portfolio"
    projects={[
      {
        category: t("featured.project1Cat") || "",
        title: t("featured.project1Title") || "",
        description: t("featured.project1Desc") || "",
        href: "/projects/parkit",
        gradient: "linear-gradient(135deg, #0b0d17 0%, #1a1f35 50%, #068e8c 100%)",
        previewImg: "/assets/img/featured/parkit-preview.png",
        size: "large",
        abstractType: "none"
      },
      {
        category: t("featured.project2Cat") || "",
        title: t("featured.project2Title") || "",
        description: t("featured.project2Desc") || "",
        href: "/projects/choferes",
        gradient: "linear-gradient(135deg, #1a1f35 0%, #2d3561 100%)",
        previewImg: "/assets/img/featured/choferes-preview.png",
        size: "normal",
        abstractType: "fintech"
      },
      {
        category: t("featured.project3Cat") || "",
        title: t("featured.project3Title") || "",
        description: t("featured.project3Desc") || "",
        href: "/portfolio",
        gradient: "linear-gradient(135deg, #0b0d17 0%, #068e8c 100%)",
        size: "normal",
        abstractType: "ai"
      },
      {
        category: t("featured.project4Cat") || "",
        title: t("featured.project4Title") || "",
        description: t("featured.project4Desc") || "",
        href: "/portfolio",
        gradient: "linear-gradient(135deg, #111827 0%, #1f2d40 50%, #0d3050 100%)",
        size: "wide",
        abstractType: "none"
      }
    ]}
  />
  <Partners 
    partners={[
      { logo: "/assets/img/partners/1.svg", href: "#.", width: "60px", alt: "logo" },
      { logo: "/assets/img/partners/2.svg", href: "#.", width: "100px", alt: "logo" },
      { logo: "/assets/img/partners/1.svg", href: "#.", width: "60px", alt: "logo" },
      { logo: "/assets/img/partners/2.svg", href: "#.", width: "100px", alt: "logo" }
    ]}
  />
  <CTA 
    suptitle={t("ctaAlt.suptitle") || ""}
    heading={t("ctaAlt.heading") || ""}
    primaryButtonText={t("ctaAlt.startProject") || ""}
    secondaryButtonText={t("ctaAlt.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="light"
    bgColor="#eef2f5"
    showIcon={true}
  />
  <Process 
    suptitle={t("process.suptitle") || ""}
    heading={t("process.title") || ""}
    intro={t("process.intro") || ""}
    steps={[
      {
        number: "01",
        title: t("process.step1Title") || "",
        description: t("process.step1Desc") || "",
        tags: [
          t("process.step1Tag1") || "",
          t("process.step1Tag2") || "",
          t("process.step1Tag3") || ""
        ]
      },
      {
        number: "02",
        title: t("process.step2Title") || "",
        description: t("process.step2Desc") || "",
        tags: [
          t("process.step2Tag1") || "",
          t("process.step2Tag2") || "",
          t("process.step2Tag3") || ""
        ]
      },
      {
        number: "03",
        title: t("process.step3Title") || "",
        description: t("process.step3Desc") || "",
        tags: [
          t("process.step3Tag1") || "",
          t("process.step3Tag2") || "",
          t("process.step3Tag3") || ""
        ]
      },
      {
        number: "04",
        title: t("process.step4Title") || "",
        description: t("process.step4Desc") || "",
        tags: [
          t("process.step4Tag1") || "",
          t("process.step4Tag2") || "",
          t("process.step4Tag3") || ""
        ]
      }
    ]}
  />
  <Pricing 
    suptitle={t("pricing.suptitle") || ""}
    heading={t("pricing.heading") || ""}
    description={t("pricing.description") || ""}
    suptitleKey="pricing.suptitle"
    headingKey="pricing.heading"
    descriptionKey="pricing.description"
    theme="light"
    padding="tria-p-120-120"
    plans={[
      {
        name: t("pricing.plan1Name") || "Starter",
        price: t("pricing.plan1Price") || "$999",
        period: t("pricing.plan1Period") || "/project",
        description: t("pricing.plan1Desc") || "",
        features: [
          t("pricing.plan1Feature1") || "",
          t("pricing.plan1Feature2") || "",
          t("pricing.plan1Feature3") || "",
          t("pricing.plan1Feature4") || "",
          t("pricing.plan1Feature5") || ""
        ],
        buttonHref: "/contact"
      },
      {
        name: t("pricing.plan2Name") || "Professional",
        price: t("pricing.plan2Price") || "$2,499",
        period: t("pricing.plan2Period") || "/project",
        description: t("pricing.plan2Desc") || "",
        features: [
          t("pricing.plan2Feature1") || "",
          t("pricing.plan2Feature2") || "",
          t("pricing.plan2Feature3") || "",
          t("pricing.plan2Feature4") || "",
          t("pricing.plan2Feature5") || "",
          t("pricing.plan2Feature6") || ""
        ],
        buttonHref: "/contact"
      },
      {
        name: t("pricing.plan3Name") || "Enterprise",
        price: t("pricing.plan3Price") || "$4,999",
        period: t("pricing.plan3Period") || "/project",
        description: t("pricing.plan3Desc") || "",
        features: [
          t("pricing.plan3Feature1") || "",
          t("pricing.plan3Feature2") || "",
          t("pricing.plan3Feature3") || "",
          t("pricing.plan3Feature4") || "",
          t("pricing.plan3Feature5") || "",
          t("pricing.plan3Feature6") || "",
          t("pricing.plan3Feature7") || ""
        ],
        buttonHref: "/contact"
      },
      {
        name: t("pricing.plan4Name") || "Custom",
        price: t("pricing.plan4Price") || "Contact Us",
        period: t("pricing.plan4Period") || "",
        description: t("pricing.plan4Desc") || "",
        features: [
          t("pricing.plan4Feature1") || "",
          t("pricing.plan4Feature2") || "",
          t("pricing.plan4Feature3") || "",
          t("pricing.plan4Feature4") || "",
          t("pricing.plan4Feature5") || ""
        ],
        buttonText: "Contact Us",
        buttonHref: "/contact"
      }
    ]}
  />
  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />
  <Team 
    suptitle={t("team.suptitle") || ""}
    heading={t("team.title") || ""}
    description1={t("team.description1") || ""}
    description2={t("team.description2") || ""}
    tagline={t("team.tagline") || ""}
    readMoreText={t("team.readMore") || ""}
    readMoreHref="/team"
    coreNote={t("team.coreNote") || ""}
    members={[
      {
        name: t("team.member1Name") || "",
        role: t("team.role1") || "",
        image: "/assets/img/team/1.jpg",
        socialLinks: [
          { icon: "fab fa-behance", href: "#." },
          { icon: "fab fa-dribbble", href: "#." },
          { icon: "fab fa-twitter", href: "#." },
          { icon: "fab fa-github", href: "#." }
        ]
      },
      {
        name: t("team.member2Name") || "",
        role: t("team.role2") || "",
        image: "/assets/img/team/2.jpg",
        socialLinks: [
          { icon: "fab fa-behance", href: "#." },
          { icon: "fab fa-dribbble", href: "#." },
          { icon: "fab fa-twitter", href: "#." },
          { icon: "fab fa-github", href: "#." }
        ]
      }
    ]}
  />
  <CTA 
    heading={t("cta.heading") || ""}
    description={t("cta.description") || "From concept to deployment, we build software that scales."}
    primaryButtonText={t("cta.startProject") || ""}
    secondaryButtonText={t("cta.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>
