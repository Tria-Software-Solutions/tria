---
import Layout from "../layouts/Layout.astro";
import { getTranslations, type Translations } from '../lib/i18n/index';

const translations: Translations = getTranslations();
---

<Layout title="Home" translations={translations}>
  <div class="mil-wrapper" id="top">
    <div class="mil-ball">
      <span class="mil-icon-1">
        <svg viewBox="0 0 128 128">
          <path
            d="M106.1,41.9c-1.2-1.2-3.1-1.2-4.2,0c-1.2,1.2-1.2,3.1,0,4.2L116.8,61H11.2l14.9-14.9c1.2-1.2,1.2-3.1,0-4.2	c-1.2-1.2-3.1-1.2-4.2,0l-20,20c-1.2,1.2-1.2,3.1,0,4.2l20,20c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9c1.2-1.2,1.2-3.1,0-4.2	L11.2,67h105.5l-14.9,14.9c-1.2,1.2-1.2,3.1,0,4.2c0.6,0.6,1.4,0.9,2.1,0.9s1.5-0.3,2.1-0.9l20-20c1.2-1.2,1.2-3.1,0-4.2L106.1,41.9	z"
          ></path>
        </svg>
      </span>
      <div class="mil-more-text">More</div>
      <div class="mil-choose-text">Сhoose</div>
    </div>
    <div class="mil-preloader">
      <div class="mil-preloader-animation">
        <div class="mil-pos-abs mil-animation-1">
          <p class="mil-h3 mil-muted mil-thin">Building</p>
          <p class="mil-h3 mil-muted">Digital</p>
          <p class="mil-h3 mil-muted mil-thin">Solutions</p>
        </div>
        <div class="mil-pos-abs mil-animation-2">
          <div class="mil-reveal-frame">
            <p class="mil-reveal-box"></p>
            <p class="mil-h3 mil-muted mil-thin">triacr.com</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mil-progress-track">
      <div class="mil-progress"></div>
    </div>
    <div class="mil-menu-frame">
      <div class="mil-frame-top">
        <a href="/" class="mil-logo">tria.</a>
        <div class="mil-menu-btn"><span></span></div>
      </div>
      <div class="container">
        <div class="mil-menu-content">
          <div class="row">
            <div class="col-xl-5">
              <nav class="mil-main-menu" id="swupMenu">
                <ul>
                  <li class="mil-active"><a href="/">Home</a></li>
                  <li><a href="#services">Services</a></li>
                  <li><a href="#pricing">Pricing</a></li>
                  <li><a href="#contact">Contact</a></li>
                </ul>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mil-curtain"></div>
    <div class="mil-frame">
      <div class="mil-frame-top">
        <a href="/" class="mil-logo">tria.</a>
        <div class="mil-menu-btn"><span></span></div>
      </div>
      <div class="mil-frame-bottom">
        <div class="mil-current-page"></div>
        <!-- <div class="mil-scroll-down">
					<a href="#about" class="mil-link mil-dark mil-arrow-place"><span>Scroll down</span></a>
				</div> -->
        <div class="mil-back-to-top">
          <a href="#top" class="mil-link mil-dark mil-arrow-place"
            ><span>Back to top</span></a
          >
        </div>
      </div>
    </div>
    <div class="mil-content">
      <div id="swupMain" class="mil-main-transition">
        <section class="mil-banner mil-dark-bg">
          <div class="mi-invert-fix">
            <div class="mil-animation-frame">
              <div
                class="mil-animation mil-position-1 mil-scale"
                data-value-1="7"
                data-value-2="1.6"
              >
              </div>
              <div
                class="mil-animation mil-position-2 mil-scale"
                data-value-1="4"
                data-value-2="1"
              >
              </div>
              <div
                class="mil-animation mil-position-3 mil-scale"
                data-value-1="1.2"
                data-value-2=".1"
              >
              </div>
            </div>
            <div class="mil-gradient"></div>
            <div class="container">
              <div class="mil-banner-content mil-up">
                <h1 class="mil-muted mil-mb-60">
                  Building <span class="mil-thin">Custom</span><br /> Software <span
                    class="mil-thin">Solutions</span>
                </h1>
                <div class="row">
                  <div class="col-md-7 col-lg-5">
                    <p class="mil-light-soft mil-mb-60">
                      We design, build, and scale digital products with a strong
                      focus on outcomes, speed, and engineering quality. Your
                      software engineering partner in Costa Rica and LATAM.
                    </p>
                  </div>
                </div>
                <a
                  href="#services"
                  class="mil-button mil-arrow-place mil-btn-space"
                  ><span>Our Services</span></a
                >
                <a href="#portfolio" class="mil-link mil-muted mil-arrow-place"
                  ><span>View Portfolio</span></a
                >
              </div>
              <div class="mil-circle-text">
                <svg
                  version="1.1"
                  xmlns="http://www.w3.org/2000/svg"
                  xmlns:xlink="http://www.w3.org/1999/xlink"
                  x="0px"
                  y="0px"
                  viewBox="0 0 300 300"
                  enable-background="new 0 0 300 300"
                  xml:space="preserve"
                  class="mil-ct-svg mil-rotate"
                  data-value="360"
                >
                  <defs>
                    <path
                      id="circlePath"
                      d="M 150, 150 m -60, 0 a 60,60 0 0,1 120,0 a 60,60 0 0,1 -120,0 "
                    ></path>
                  </defs>
                  <circle cx="150" cy="100" r="75" fill="none"></circle>
                  <g>
                    <use xlink:href="#circlePath" fill="none"></use>
                    <text style="letter-spacing: 6.5px">
                      <textPath xlink:href="#circlePath"
                        >Scroll down - Scroll down -
                      </textPath>
                    </text>
                  </g>
                </svg>
                <a
                  href="#about"
                  class="mil-button mil-arrow-place mil-icon-button mil-arrow-down"
                ></a>
              </div>
            </div>
          </div>
        </section>
        <section id="about">
          <div class="mi-invert-fix">
            <div class="mil-animation-frame">
              <div
                class="mil-animation mil-position-1 mil-scale"
                data-value-1="1.2"
                data-value-2=".2"
                style="top: 200px; right: -100px"
              >
              </div>
              <div
                class="mil-animation mil-position-2 mil-scale"
                data-value-1="1"
                data-value-2=".5"
                style="left: 100px"
              >
              </div>
            </div>
            <div class="container mil-p-120-30">
              <div class="row justify-content-between align-items-center">
                <div class="col-lg-6 col-xl-5">
                  <div class="mil-mb-90">
                    <h2
                      class="mil-up mil-mb-60"
                      set:html={translations.about.title}
                    />
                    <p class="mil-up mil-mb-30">
                      {translations.about.subtitle}
                    </p>
                    <p class="mil-up mil-mb-60">
                      {translations.about.subtitle2}
                    </p>
                    <div class="mil-about-quote">
                      <div class="mil-avatar mil-up">
                        <img src="/assets/images/placeholder.svg" alt="Founder" />
                      </div>
                      <h6
                        class="mil-quote mil-up"
                        set:html={translations.about.quote}
                      />
                    </div>
                  </div>
                </div>
                <div class="col-lg-5">
                  <div class="mil-about-photo mil-mb-90">
                    <div class="mil-lines-place"></div>
                    <div
                      class="mil-up mil-img-frame"
                      style="padding-bottom: 160%;"
                    >
                      <img
                        src="/assets/images/placeholder.svg"
                        alt="img"
                        class="mil-scale"
                        data-value-1="1"
                        data-value-2="1.2"
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
        <section id="services" class="mil-dark-bg">
          <div class="mi-invert-fix">
            <div class="mil-animation-frame">
              <div
                class="mil-animation mil-position-1 mil-scale"
                data-value-1="2.4"
                data-value-2="1.4"
                style="top: 300px; right: -100px"
              >
              </div>
              <div
                class="mil-animation mil-position-2 mil-scale"
                data-value-1="2"
                data-value-2="1"
                style="left: 150px"
              >
              </div>
            </div>
            <div class="container mil-p-120-0">
              <div class="mil-mb-120">
                <div class="row">
                  <div class="col-lg-10">
                    <span
                      class="mil-suptitle mil-light-soft mil-suptitle-right mil-up"
                      >Professionals focused on helping your brand<br /> grow and
                      move forward.</span
                    >
                  </div>
                </div>
                <div
                  class="mil-complex-text justify-content-center mil-up mil-mb-15"
                >
                  <h2 class="mil-h1 mil-muted mil-center">
                    Unique <span class="mil-thin">Ideas</span>
                  </h2>
                </div>
                <div class="mil-complex-text justify-content-center mil-up">
                  <h2 class="mil-h1 mil-muted mil-center">
                    For Your <span class="mil-thin">Business.</span>
                  </h2>
                </div>
              </div>
              <div class="row mil-services-grid m-0">
                <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
                  <a href="#" class="mil-service-card-sm mil-up">
                    <h5 class="mil-muted mil-mb-30">
                      Frontend <br />Development
                    </h5>
                    <p class="mil-light-soft mil-mb-30">
                      React, Next.js, TypeScript, Tailwind CSS for modern user
                      interfaces.
                    </p>
                    <div class="mil-button mil-icon-button-sm mil-arrow-place">
                    </div>
                  </a>
                </div>
                <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
                  <a href="#" class="mil-service-card-sm mil-up">
                    <h5 class="mil-muted mil-mb-30">
                      Mobile <br />Development
                    </h5>
                    <p class="mil-light-soft mil-mb-30">
                      iOS, Android, React Native for cross-platform mobile
                      applications.
                    </p>
                    <div class="mil-button mil-icon-button-sm mil-arrow-place">
                    </div>
                  </a>
                </div>
                <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
                  <a href="#" class="mil-service-card-sm mil-up">
                    <h5 class="mil-muted mil-mb-30">
                      Backend <br />Development
                    </h5>
                    <p class="mil-light-soft mil-mb-30">
                      Node.js, Python, PostgreSQL, APIs for robust server-side
                      solutions.
                    </p>
                    <div class="mil-button mil-icon-button-sm mil-arrow-place">
                    </div>
                  </a>
                </div>
                <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
                  <a href="#" class="mil-service-card-sm mil-up">
                    <h5 class="mil-muted mil-mb-30">DevOps & <br />Cloud</h5>
                    <p class="mil-light-soft mil-mb-30">
                      AWS, Docker, Kubernetes, CI/CD for modern deployment
                      infrastructure.
                    </p>
                    <div class="mil-button mil-icon-button-sm mil-arrow-place">
                    </div>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>
        <section id="team">
          <div class="mi-invert-fix">
            <div class="mil-animation-frame">
              <div
                class="mil-animation mil-position-1 mil-scale"
                data-value-1="1.5"
                data-value-2=".3"
                style="top: 100px; right: -50px"
              >
              </div>
              <div
                class="mil-animation mil-position-2 mil-scale"
                data-value-1="1.2"
                data-value-2=".4"
                style="left: 200px"
              >
              </div>
            </div>
            <div class="container mil-p-120-30">
              <div class="row justify-content-between align-items-center">
                <div class="col-lg-5 col-xl-4">
                  <div class="mil-mb-90">
                    <h2
                      class="mil-up mil-mb-60"
                      set:html={translations.team.title}
                    />
                    <p class="mil-up mil-mb-30">{translations.team.subtitle}</p>
                    <p class="mil-up mil-mb-60">
                      {translations.team.subtitle2}
                    </p>
                    <div class="mil-up">
                      <a
                        href="#contact"
                        class="mil-button mil-arrow-place mil-mb-60"
                        ><span>{translations.team.cta}</span></a>
                    </div>
                    <h4 class="mil-up" set:html={translations.team.deliver} />
                  </div>
                </div>
                <div class="col-lg-6">
                  <div class="mil-team-list">
                    <div class="mil-lines-place"></div>
                    <div class="row mil-mb-60">
                      <div class="col-sm-6">
                        <div class="mil-team-card mil-up mil-mb-30">
                          <img
                            src="/assets/images/placeholder.svg"
                            alt="Team member"
                          />
                          <div class="mil-description">
                            <div class="mil-secrc-text">
                              <h5 class="mil-muted mil-mb-5">Anna Oldman</h5>
                              <p class="mil-link mil-light-soft mil-mb-10">
                                Art Director
                              </p>
                              <ul class="mil-social-icons mil-center">
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-behance"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-dribbble"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-twitter"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-github"></i></a>
                                </li>
                              </ul>
                            </div>
                          </div>
                        </div>
                        <div class="mil-team-card mil-up mil-mb-30">
                          <img
                            src="/assets/images/placeholder.svg"
                            alt="Team member"
                          />
                          <div class="mil-description">
                            <div class="mil-secrc-text">
                              <h5 class="mil-muted mil-mb-5">Oscar Freeman</h5>
                              <p class="mil-link mil-light-soft mil-mb-10">
                                Frontend Dev
                              </p>
                              <ul class="mil-social-icons mil-center">
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-behance"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-dribbble"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-twitter"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-github"></i></a>
                                </li>
                              </ul>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div class="col-sm-6">
                        <p
                          class="mil-mobile-hidden mil-text-sm mil-mb-30"
                          style="height: 30px;"
                        >
                          <span class="mil-accent">*</span> The founders of our agency
                        </p>
                        <div class="mil-team-card mil-up mil-mb-30">
                          <img
                            src="/assets/images/placeholder.svg"
                            alt="Team member"
                          />
                          <div class="mil-description">
                            <div class="mil-secrc-text">
                              <h5 class="mil-muted mil-mb-5">Emma Newman</h5>
                              <p class="mil-link mil-light-soft mil-mb-10">
                                Founder
                              </p>
                              <ul class="mil-social-icons mil-center">
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-behance"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-dribbble"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-twitter"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-github"></i></a>
                                </li>
                              </ul>
                            </div>
                          </div>
                        </div>
                        <div class="mil-team-card mil-up mil-mb-30">
                          <img
                            src="/assets/images/placeholder.svg"
                            alt="Team member"
                          />
                          <div class="mil-description">
                            <div class="mil-secrc-text">
                              <h5 class="mil-muted mil-mb-5">Lisa Trueman</h5>
                              <p class="mil-link mil-light-soft mil-mb-10">
                                UI/UX Designer
                              </p>
                              <ul class="mil-social-icons mil-center">
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
                                  >
                                    <i class="fab fa-behance"></i></a>
                                </li>
                                <li>
                                  <a
                                    href="#"
                                    target="_blank"
                                    class="social-icon"
