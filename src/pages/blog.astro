---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Blog — tria">
  <section style="min-height:100vh;padding:160px 0 100px;">
    <div class="container">
      <p class="section-label" data-i18n="blog.newsletter">Newsletter</p>
      <h1
        style="font-family:var(--font-display);font-size:clamp(3rem,7vw,7rem);font-weight:300;"
        data-i18n-html="blog.popularPublications"
      >
        Popular<br /><em style="font-style:italic;color:var(--color-accent);"
          >Publications</em
        >
      </h1>
    </div>
  </section>
</Layout>
