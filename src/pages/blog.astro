---
import Layout from '../layouts/Layout.astro';
import { getTranslations, type Translations } from '../lib/i18n/index';

const translations: Translations = getTranslations();
---

<Layout title="Blog" translations={translations}>
<div class="mil-inner-banner mil-p-0-120">
					<div class="mil-banner-content mil-up">
						<div class="mil-animation-frame">
							<div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
						</div>
						<div class="container">
							<ul class="mil-breadcrumbs mil-mb-60">
								<li><a href="/">{translations.navigation.home}</a></li>
								<li><a href="/blog">Blog</a></li>
							</ul>
							<h1 class="mil-mb-60">Exploring <span class="mil-thin">Software</span> <br>Development <span class="mil-thin">Insights</span></h1>
							<a href="#blog" class="mil-link mil-dark mil-arrow-place mil-down-arrow"><span>Publications</span></a>
						</div>
					</div>
				</div>
				<section class="mil-soft-bg" id="blog">
					<div class="container mil-p-120-60">
						<div class="row align-items-center mil-mb-30">
							<div class="col-lg-6 mil-mb-30">
								<h3 class="mil-up">Popular Publications:</h3>
							</div>
							<div class="col-lg-6 mil-mb-30">
								<div class="mil-adaptive-right mil-up">
									<a href="/publication" class="mil-link mil-dark mil-arrow-place"><span>View all</span></a>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-lg-6">
								<a href="/publication" class="mil-blog-card mil-mb-60">
									<div class="mil-cover-frame mil-up">
										<img src="/assets/images/projects/pub-1.jpg" alt="cover">
									</div>
									<div class="mil-post-descr">
										<div class="mil-labels mil-up mil-mb-30">
											<div class="mil-label mil-upper mil-accent">TECHNOLOGY</div>
											<div class="mil-label mil-upper">may 24 2023</div>
										</div>
										<h4 class="mil-up mil-mb-30">How to Become a Full Stack Developer in 10 Steps</h4>
										<p class="mil-post-text mil-up mil-mb-30">Learn the essential skills and technologies needed to become a successful full stack developer in today's competitive tech landscape.</p>
										<div class="mil-link mil-dark mil-arrow-place mil-up"><span>Read more</span></div>
									</div>
								</a>
							</div>
							<div class="col-lg-6">
								<a href="/publication" class="mil-blog-card mil-mb-60">
									<div class="mil-cover-frame mil-up">
										<img src="/assets/images/projects/pub-2.jpg" alt="cover">
									</div>
									<div class="mil-post-descr">
										<div class="mil-labels mil-up mil-mb-30">
											<div class="mil-label mil-upper mil-accent">TECHNOLOGY</div>
											<div class="mil-label mil-upper">may 24 2023</div>
										</div>
										<h4 class="mil-up mil-mb-30">16 Best Online Courses for Software Development</h4>
										<p class="mil-post-text mil-up mil-mb-30">Discover the top online platforms and courses that can help you advance your software development career with flexible learning options.</p>
										<div class="mil-link mil-dark mil-arrow-place mil-up"><span>Read more</span></div>
									</div>
								</a>
							</div>
						</div>
					</div>
				</section>
				<section>
					<div class="container mil-p-120-120">
						<div class="row align-items-center mil-mb-30">
							<div class="col-lg-4 mil-mb-30">
								<h3 class="mil-up">Categories:</h3>
							</div>
							<div class="col-lg-8 mil-mb-30">
								<div class="mil-adaptive-right mil-up">
									<ul class="mil-category-list">
										<li><a href="/publication">Development</a></li>
										<li><a href="/publication">Design</a></li>
										<li><a href="/publication">Technology</a></li>
										<li><a href="/publication" class="mil-active">All categories</a></li>
									</ul>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-lg-12">
								<a href="/publication" class="mil-blog-card mil-blog-card-hori mil-more mil-mb-60">
									<div class="mil-cover-frame mil-up">
										<img src="/assets/images/projects/pub-3.jpg" alt="cover">
									</div>
									<div class="mil-post-descr">
										<div class="mil-labels mil-up mil-mb-30">
											<div class="mil-label mil-upper mil-accent">TECHNOLOGY</div>
											<div class="mil-label mil-upper">may 24 2023</div>
										</div>
										<h4 class="mil-up mil-mb-30">How to Create a Technical Guide for Your Software Project</h4>
										<p class="mil-post-text mil-up mil-mb-30">Learn the best practices for creating comprehensive technical documentation that helps teams collaborate effectively.</p>
										<div class="mil-link mil-dark mil-arrow-place mil-up"><span>Read more</span></div>
									</div>
								</a>
							</div>
							<div class="col-lg-12">
								<a href="/publication" class="mil-blog-card mil-blog-card-hori mil-more mil-mb-60">
									<div class="mil-cover-frame mil-up">
										<img src="/assets/images/projects/project-4.jpg" alt="cover">
									</div>
									<div class="mil-post-descr">
										<div class="mil-labels mil-up mil-mb-30">
											<div class="mil-label mil-upper mil-accent">TECHNOLOGY</div>
											<div class="mil-label mil-upper">may 24 2023</div>
										</div>
										<h4 class="mil-up mil-mb-30">Security Best Practices in Modern Web Development</h4>
										<p class="mil-post-text mil-up mil-mb-30">Essential security measures every developer should implement to protect web applications from common vulnerabilities.</p>
										<div class="mil-link mil-dark mil-arrow-place mil-up"><span>Read more</span></div>
									</div>
								</a>
							</div>
							<div class="col-lg-12">
								<a href="/publication" class="mil-blog-card mil-blog-card-hori mil-more mil-mb-60">
									<div class="mil-cover-frame mil-up">
										<img src="/assets/images/projects/project-5.jpg" alt="cover">
									</div>
									<div class="mil-post-descr">
										<div class="mil-labels mil-up mil-mb-30">
											<div class="mil-label mil-upper mil-accent">TECHNOLOGY</div>
											<div class="mil-label mil-upper">may 24 2023</div>
										</div>
										<h4 class="mil-up mil-mb-30">How to Design Scalable Software Architecture</h4>
										<p class="mil-post-text mil-up mil-mb-30">Key principles and patterns for building software systems that can grow with your business needs.</p>
										<div class="mil-link mil-dark mil-arrow-place mil-up"><span>Read more</span></div>
									</div>
								</a>
							</div>
							<div class="col-lg-12">
								<a href="/publication" class="mil-blog-card mil-blog-card-hori mil-more mil-mb-60">
									<div class="mil-cover-frame mil-up">
										<img src="/assets/images/projects/project-6.jpg" alt="cover">
									</div>
									<div class="mil-post-descr">
										<div class="mil-labels mil-up mil-mb-30">
											<div class="mil-label mil-upper mil-accent">TECHNOLOGY</div>
											<div class="mil-label mil-upper">may 24 2023</div>
										</div>
										<h4 class="mil-up mil-mb-30">How to Prevent Developer Burnout</h4>
										<p class="mil-post-text mil-up mil-mb-30">Strategies for maintaining work-life balance and mental health in the demanding field of software development.</p>
										<div class="mil-link mil-dark mil-arrow-place mil-up"><span>Read more</span></div>
									</div>
								</a>
							</div>
						</div>
					</div>
				</section>
</Layout>
