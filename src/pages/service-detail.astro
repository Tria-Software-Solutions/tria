---
import Layout from '../layouts/Layout.astro';
import { getTranslations, type Translations } from '../lib/i18n/index';

const translations: Translations = getTranslations();
---

<Layout title="Service" translations={translations}>
<div class="mil-inner-banner">
					<div class="mil-animation-frame">
						<div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
					</div>
					<div class="mil-banner-content mil-up">
						<div class="container">
							<ul class="mil-breadcrumbs mil-mb-60">
								<li><a href="/">{translations.navigation.home}</a></li>
								<li><a href="/services-list">{translations.navigation.services}</a></li>
								<li><a href="/service-detail">Service</a></li>
							</ul>
							<h1 class="mil-mb-60">Software <span class="mil-thin">Development</span><br> and <span class="mil-thin">Solutions</span></h1>
							<a href="#service" class="mil-link mil-dark mil-arrow-place mil-down-arrow"><span>About service</span></a>
						</div>
					</div>
				</div>
				<section id="service">
					<div class="container mil-p-120-90">
						<div class="row justify-content-between">
							<div class="col-lg-4 mil-relative mil-mb-90">
								<h4 class="mil-up mil-mb-30">Your <span class="mil-thin">Approach</span> <br>and <span class="mil-thin">Work Process</span></h4>
								<p class="mil-up mil-mb-30">At our agency, we have a unique approach to software development. We believe in creating solutions that not only work great but also perform well in terms of user experience, functionality, and scalability.</p>
								<div class="mil-up">
									<a href="/portfolio-1" class="mil-link mil-dark mil-arrow-place"><span>View works</span></a>
								</div>
							</div>
							<div class="col-lg-6">
								<div class="mil-accordion-group mil-up">
									<div class="mil-accordion-menu">
										<p class="mil-accordion-head">Requirements Analysis</p>
										<div class="mil-symbol mil-h3">
											<div class="mil-plus">+</div>
											<div class="mil-minus">-</div>
										</div>
									</div>
									<div class="mil-accordion-content">
										<p class="mil-mb-30">We start by understanding your business needs and technical requirements. Our team conducts thorough analysis to identify key objectives, constraints, and success metrics for your project.</p>
										<p class="mil-mb-30">During requirements gathering, we work closely with stakeholders to document functional specifications, user stories, and acceptance criteria that will guide the development process.</p>
									</div>
								</div>
								<div class="mil-accordion-group mil-up">
									<div class="mil-accordion-menu">
										<p class="mil-accordion-head">Design & Architecture</p>
										<div class="mil-symbol mil-h3">
											<div class="mil-plus">+</div>
											<div class="mil-minus">-</div>
										</div>
									</div>
									<div class="mil-accordion-content">
										<p class="mil-mb-30">Our design team creates intuitive user interfaces and robust system architectures. We focus on creating scalable, maintainable solutions that can grow with your business needs.</p>
										<p class="mil-mb-30">We use modern design patterns and best practices to ensure your software is both beautiful and functional, providing excellent user experiences across all devices.</p>
									</div>
								</div>
								<div class="mil-accordion-group mil-up">
									<div class="mil-accordion-menu">
										<p class="mil-accordion-head">Development & Testing</p>
										<div class="mil-symbol mil-h3">
											<div class="mil-plus">+</div>
											<div class="mil-minus">-</div>
										</div>
									</div>
									<div class="mil-accordion-content">
										<p class="mil-mb-30">Our development team follows agile methodologies to build high-quality software. We implement comprehensive testing strategies including unit tests, integration tests, and user acceptance testing.</p>
										<p class="mil-mb-30">We ensure your software is reliable, secure, and performs well under various conditions. Continuous integration and deployment practices help us deliver updates quickly and safely.</p>
									</div>
								</div>
								<div class="mil-accordion-group mil-up">
									<div class="mil-accordion-menu">
										<p class="mil-accordion-head">Deployment & Support</p>
										<div class="mil-symbol mil-h3">
											<div class="mil-plus">+</div>
											<div class="mil-minus">-</div>
										</div>
									</div>
									<div class="mil-accordion-content">
										<p class="mil-mb-30">We handle the complete deployment process and provide ongoing support. Our team ensures smooth transitions to production environments and offers maintenance services to keep your software running optimally.</p>
										<p class="mil-mb-30">Post-deployment, we monitor performance, provide updates, and offer technical support to ensure your software continues to meet business requirements and user expectations.</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</section>
				<section class="mil-dark-bg">
					<div class="mi-invert-fix">
						<div class="container mil-p-120-120">
							<div class="mil-center">
								<h2 class="mil-muted mil-up mil-mb-30">Flexible <span class="mil-thin">Pricing</span> <br>for Every <span class="mil-thin">Project</span></h2>
								<p class="mil-light-soft mil-up mil-mb-120">We offer competitive pricing for high-quality software development services. <br>Customized solutions tailored to your specific needs and budget.</p>
							</div>
							<a href="/contact" class="mil-price-card mil-choose mil-accent-cursor mil-up">
								<div class="row align-items-center">
									<div class="col-lg-2">
										<div class="mil-price-number mil-mb-30"><span class="mil-muted mil-thin">$</span><span class="mil-accent">5k</span></div>
									</div>
									<div class="col-lg-4">
										<h5 class="mil-muted mil-mb-30">Starter Package<br>for Small Projects</h5>
									</div>
									<div class="col-lg-4">
										<p class="mil-light-soft mil-mb-30">Perfect for startups and small businesses looking to establish their digital presence with essential features.</p>
									</div>
									<div class="col-lg-2">
										<div class="mil-adaptive-right mil-mb-30">
											<div class="mil-button mil-icon-button-sm mil-arrow-place"></div>
										</div>
									</div>
								</div>
							</a>
							<a href="/contact" class="mil-price-card mil-choose mil-accent-cursor mil-up">
								<div class="row align-items-center">
									<div class="col-lg-2">
										<div class="mil-price-number mil-mb-30"><span class="mil-muted mil-thin">$</span><span class="mil-accent">15k</span></div>
									</div>
									<div class="col-lg-4">
										<h5 class="mil-muted mil-mb-30">Professional Package<br>for Growing Businesses</h5>
									</div>
									<div class="col-lg-4">
										<p class="mil-light-soft mil-mb-30">Comprehensive solutions for established businesses needing advanced features and scalability.</p>
									</div>
									<div class="col-lg-2">
										<div class="mil-adaptive-right mil-mb-30">
											<div class="mil-button mil-icon-button-sm mil-arrow-place"></div>
										</div>
									</div>
								</div>
							</a>
							<a href="/contact" class="mil-price-card mil-choose mil-accent-cursor mil-up">
								<div class="row align-items-center">
									<div class="col-lg-2">
										<div class="mil-price-number mil-mb-30"><span class="mil-muted mil-thin">$</span><span class="mil-accent">25k+</span></div>
									</div>
									<div class="col-lg-4">
										<h5 class="mil-muted mil-mb-30">Enterprise Solutions<br>Custom Development</h5>
									</div>
									<div class="col-lg-4">
										<p class="mil-light-soft mil-mb-30">Tailored enterprise-grade solutions with full support and maintenance packages.</p>
									</div>
									<div class="col-lg-2">
										<div class="mil-adaptive-right mil-mb-30">
											<div class="mil-button mil-icon-button-sm mil-arrow-place"></div>
										</div>
									</div>
								</div>
							</a>
						</div>
					</div>
				</section>
</Layout>
