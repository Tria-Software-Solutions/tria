---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import CTA from "../components/CTA.astro";
import Button from "../components/Button.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>

  <PageBanner suptitleKey="portfolio.suptitle" headingKey="portfolio.title" descriptionKey="portfolio.desc" />

  <!-- filter + grid -->
  <section data-section-theme="light" class="tria-portfolio-section">
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-2"></div>
    </div>

    <!-- Filter -->
    <div class="container" style="padding-top:60px;">
      <div class="tria-portfolio-filter tria-up">
        <Button variant="outline" size="xs" color="#0b0d17" active data-filter="all" data-i18n="portfolio.filter.all" text={t("portfolio.filter.all")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="fintech" data-i18n="portfolio.filter.fintech" text={t("portfolio.filter.fintech")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="cloud" data-i18n="portfolio.filter.cloud" text={t("portfolio.filter.cloud")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="ai" data-i18n="portfolio.filter.ai" text={t("portfolio.filter.ai")} />
      </div>
    </div>

    <!-- Grid -->
    <div class="container tria-p-120-120">
      <div class="tria-portfolio-grid" id="portfolioGrid">

        <!-- Parkit -->
        <div class="tria-portfolio-card tria-pf-observe" data-cat="fintech" data-index="0">
          <div class="tria-pf-img" style="background-image:url(/assets/img/featured/parkit-preview.png);background-size:cover;background-position:center;">
            <div class="tria-pf-img-glass"></div>
            <div class="tria-pf-abstract tria-pf-abstract--grid"></div>
            <div class="tria-pf-glow"></div>
          </div>
          <div class="tria-pf-body">
            <div class="tria-pf-body-inner">
              <h3 class="tria-pf-title" data-i18n="featured.project1Title">{t("featured.project1Title")}</h3>
              <p class="tria-pf-desc" data-i18n="featured.project1Desc">{t("featured.project1Desc")}</p>
            </div>
            <div class="tria-pf-footer">
              <div class="tria-pf-tags">
                <span>React</span><span>Go</span><span>PostgreSQL</span><span>AWS</span>
              </div>
              <a href="/projects/parkit" class="tria-pf-link">
                <span data-i18n="featured.viewProject">{t("featured.viewProject")}</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Choferes -->
        <div class="tria-portfolio-card tria-pf-observe" data-cat="cloud" data-index="1">
          <div class="tria-pf-img" style="background-image:url(/assets/img/featured/choferes-preview.png);background-size:cover;background-position:center;">
            <div class="tria-pf-img-glass"></div>
            <div class="tria-pf-abstract tria-pf-abstract--rings"></div>
            <div class="tria-pf-glow"></div>
          </div>
          <div class="tria-pf-body">
            <div class="tria-pf-body-inner">
              <h3 class="tria-pf-title" data-i18n="featured.project2Title">{t("featured.project2Title")}</h3>
              <p class="tria-pf-desc" data-i18n="featured.project2Desc">{t("featured.project2Desc")}</p>
            </div>
            <div class="tria-pf-footer">
              <div class="tria-pf-tags">
                <span>Kubernetes</span><span>Terraform</span><span>GCP</span><span>AWS</span>
              </div>
              <a href="/projects/choferes" class="tria-pf-link">
                <span data-i18n="featured.viewProject">{t("featured.viewProject")}</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- SafeData -->
        <div class="tria-portfolio-card tria-pf-observe" data-cat="ai" data-index="2">
          <div class="tria-pf-img" style="background-image:url(/assets/img/featured/safedata-preview.svg);background-size:cover;background-position:center;background-color:#0b0d17;">
            <div class="tria-pf-img-glass"></div>
            <div class="tria-pf-abstract tria-pf-abstract--dots"></div>
            <div class="tria-pf-glow"></div>
          </div>
          <div class="tria-pf-body">
            <div class="tria-pf-body-inner">
              <h3 class="tria-pf-title" data-i18n="featured.project3Title">{t("featured.project3Title")}</h3>
              <p class="tria-pf-desc" data-i18n="featured.project3Desc">{t("featured.project3Desc")}</p>
            </div>
            <div class="tria-pf-footer">
              <div class="tria-pf-tags">
                <span>Python</span><span>PyTorch</span><span>Kafka</span><span>Snowflake</span>
              </div>
              <a href="#" class="tria-pf-link">
                <span data-i18n="featured.viewProject">{t("featured.viewProject")}</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- SafePath -->
        <div class="tria-portfolio-card tria-pf-observe" data-cat="ai" data-index="3">
          <div class="tria-pf-img" style="background-image:url(/assets/img/featured/safepath-preview.svg);background-size:cover;background-position:center;background-color:#0b0d17;">
            <div class="tria-pf-img-glass"></div>
            <div class="tria-pf-abstract tria-pf-abstract--grid"></div>
            <div class="tria-pf-glow"></div>
          </div>
          <div class="tria-pf-body">
            <div class="tria-pf-body-inner">
              <h3 class="tria-pf-title" data-i18n="featured.project4Title">{t("featured.project4Title")}</h3>
              <p class="tria-pf-desc" data-i18n="featured.project4Desc">{t("featured.project4Desc")}</p>
            </div>
            <div class="tria-pf-footer">
              <div class="tria-pf-tags">
                <span>FastAPI</span><span>Python</span><span>OSMnx</span><span>NetworkX</span>
              </div>
              <a href="https://github.com/lmhq-94/safepath_api" class="tria-pf-link" target="_blank" rel="noopener noreferrer">
                <span data-i18n="featured.viewProject">{t("featured.viewProject")}</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Fault Diagnosis -->
        <div class="tria-portfolio-card tria-pf-observe" data-cat="cloud" data-index="4">
          <div class="tria-pf-img">
            <div class="tria-pf-iframe-wrap">
              <iframe src="https://diagnostico-fallas.vercel.app" class="tria-pf-iframe" loading="lazy" title="Fault Diagnosis"></iframe>
            </div>
            <div class="tria-pf-img-glass"></div>
            <div class="tria-pf-abstract tria-pf-abstract--rings"></div>
            <div class="tria-pf-glow"></div>
          </div>
          <div class="tria-pf-body">
            <div class="tria-pf-body-inner">
              <h3 class="tria-pf-title" data-i18n="featured.project5Title">{t("featured.project5Title")}</h3>
              <p class="tria-pf-desc" data-i18n="featured.project5Desc">{t("featured.project5Desc")}</p>
            </div>
            <div class="tria-pf-footer">
              <div class="tria-pf-tags">
                <span>TypeScript</span><span>Vite</span><span>Tailwind</span><span>jsPDF</span>
              </div>
              <a href="https://github.com/lmhq-94/fault_diagnosis" class="tria-pf-link" target="_blank" rel="noopener noreferrer">
                <span data-i18n="featured.viewProject">{t("featured.viewProject")}</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <CTA 
    heading={t("ctaPortfolio.heading") || ""}
    primaryButtonText={t("ctaPortfolio.button") || ""}
    secondaryButtonText={t("ctaPortfolio.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/services"
    theme="light"
    bgColor="#e8ebee"
    showIcon={true}
    padding="tria-p-120-120"
  />

  <SiteFooter />
</Layout>

<style>
  /* ── Section ── */
  .tria-portfolio-section {
    background: #faf7f2;
    position: relative;
  }

  /* ── Filter ── */
  .tria-portfolio-filter {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  /* ── Grid ── */
  .tria-portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  /* ── Card ── */
  .tria-portfolio-card {
    background: #fff;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03), 0 4px 12px rgba(0,0,0,0.02);
    transition: box-shadow 0.6s var(--ease-spring),
                transform 0.6s var(--ease-spring),
                opacity 0.6s var(--ease-spring),
                filter 0.6s var(--ease-spring);
    will-change: transform, opacity;
    position: relative;
  }

  /* ── Filter hide/show with transition ── */
  .tria-portfolio-card.tria-pf-hidden {
    opacity: 0;
    filter: blur(6px) saturate(0.4);
    transform: scale(0.92);
    pointer-events: none;
  }

  .tria-portfolio-card.tria-pf-collapsed {
    display: none;
  }

  /* ── Scroll animation initial state ── */
  .tria-portfolio-card.tria-pf-initial {
    opacity: 0;
    filter: blur(6px) saturate(0.4);
    transform: translateY(30px) scale(0.97);
  }

  .tria-portfolio-card.tria-pf-visible {
    opacity: 1;
    filter: blur(0) saturate(1);
    transform: translateY(0) scale(1);
  }

  .tria-portfolio-card.tria-pf-visible:nth-child(1) { transition-delay: 0.05s; }
  .tria-portfolio-card.tria-pf-visible:nth-child(2) { transition-delay: 0.12s; }
  .tria-portfolio-card.tria-pf-visible:nth-child(3) { transition-delay: 0.19s; }
  .tria-portfolio-card.tria-pf-visible:nth-child(4) { transition-delay: 0.26s; }
  .tria-portfolio-card.tria-pf-visible:nth-child(5) { transition-delay: 0.33s; }

  .tria-portfolio-card:hover {
    box-shadow: 0 16px 48px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
    transform: translateY(-4px);
  }

  /* ── Image area ── */
  .tria-pf-img {
    height: 280px;
    position: relative;
    overflow: hidden;
    transition: transform 0.8s var(--ease-spring);
  }

  .tria-portfolio-card:hover .tria-pf-img {
    transform: scale(1.05);
  }  /* ── Iframe embed ── */
  .tria-pf-iframe-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    background: #0b0d17;
  }

  .tria-pf-iframe {
    width: 1440px;
    height: 900px;
    border: none;
    pointer-events: none;
    transform-origin: 0 0;
    transform: scale(0.27);
  }

  .tria-pf-img-glass {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(135deg, rgba(11,13,23,0.04) 0%, rgba(11,13,23,0.2) 100%);
    backdrop-filter: blur(1.5px);
    -webkit-backdrop-filter: blur(1.5px);
    transition: all 0.6s ease;
  }

  .tria-portfolio-card:hover .tria-pf-img-glass {
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    background: linear-gradient(135deg, rgba(11,13,23,0.01) 0%, rgba(6,142,140,0.15) 100%);
  }

  /* ── Abstract decorations ── */
  .tria-pf-abstract {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.07;
    transition: opacity 0.6s ease;
  }

  .tria-portfolio-card:hover .tria-pf-abstract {
    opacity: 0.15;
  }

  .tria-pf-abstract--grid::after {
    content: '';
    position: absolute;
    width: 200px;
    height: 200px;
    right: -40px;
    bottom: -40px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 50%;
    box-shadow: 0 0 0 40px rgba(6,142,140,0.015),
                0 0 0 80px rgba(6,142,140,0.008);
    transition: box-shadow 0.6s ease, border-color 0.6s ease;
  }

  .tria-portfolio-card:hover .tria-pf-abstract--grid::after {
    box-shadow: 0 0 0 40px rgba(6,142,140,0.04),
                0 0 0 80px rgba(6,142,140,0.02);
    border-color: rgba(6, 142, 140, 0.06);
  }

  .tria-pf-abstract--rings::before {
    content: '';
    position: absolute;
    width: 140px;
    height: 140px;
    top: 30px;
    right: 30px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: 0 0 0 30px rgba(255,255,255,0.015);
    transition: border-color 0.6s ease, box-shadow 0.6s ease;
  }

  .tria-portfolio-card:hover .tria-pf-abstract--rings::before {
    border-color: rgba(6, 142, 140, 0.08);
    box-shadow: 0 0 0 30px rgba(6,142,140,0.02);
  }

  .tria-pf-abstract--dots::after {
    content: '';
    position: absolute;
    right: 28px;
    top: 28px;
    width: 80px;
    height: 80px;
    background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 10px 10px;
    transition: background-image 0.6s ease;
  }

  .tria-portfolio-card:hover .tria-pf-abstract--dots::after {
    background-image: radial-gradient(rgba(6,142,140,0.18) 1px, transparent 1px);
  }

  /* ── Accent glow behind image on hover ── */
  .tria-pf-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(ellipse at 50% 100%, rgba(6,142,140,0.15) 0%, transparent 60%);
    transition: opacity 0.8s var(--ease-spring);
  }

  .tria-portfolio-card:hover .tria-pf-glow {
    opacity: 1;
  }

  /* ── Body ── */
  .tria-pf-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    background: #fff;
    position: relative;
    z-index: 1;
  }

  .tria-pf-body-inner {
    padding: 28px 24px 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .tria-pf-title {
    font-size: 1.2rem;
    font-weight: 480;
    color: #0b0d17;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.02em;
    transition: color 0.4s ease;
  }

  .tria-portfolio-card:hover .tria-pf-title {
    color: var(--accent);
  }

  .tria-pf-desc {
    font-size: 0.82rem;
    color: #999;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .tria-portfolio-card:hover .tria-pf-desc {
    color: #888;
  }

  /* ── Footer (tags + link) ── */
  .tria-pf-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    border-top: 1px solid rgba(0,0,0,0.04);
    margin-top: 24px;
    transition: border-color 0.4s var(--ease-spring);
  }

  .tria-portfolio-card:hover .tria-pf-footer {
    border-top-color: rgba(6, 142, 140, 0.1);
  }

  .tria-pf-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tria-pf-tags span {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    color: rgba(0,0,0,0.3);
    transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease;
  }

  .tria-portfolio-card:hover .tria-pf-tags span {
    border-color: rgba(6, 142, 140, 0.12);
    color: rgba(6, 142, 140, 0.5);
    background: rgba(6, 142, 140, 0.025);
  }

  /* ── Link ── */
  .tria-pf-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.25);
    text-decoration: none;
    transition: color 0.4s var(--ease-spring), gap 0.4s var(--ease-spring);
    flex-shrink: 0;
  }

  .tria-pf-link svg {
    transition: transform 0.4s var(--ease-spring);
  }

  .tria-pf-link:hover {
    color: var(--accent) !important;
    gap: 10px;
  }

  .tria-pf-link:hover svg {
    transform: translateX(4px);
  }

  /* ── Responsive ── */
  @media (max-width: 991px) {
    .tria-portfolio-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .tria-pf-img { height: 220px; }
    .tria-pf-body-inner { padding: 22px 20px 0; }
    .tria-pf-footer { padding: 16px 20px; }
  }

  @media (max-width: 600px) {
    .tria-portfolio-grid { grid-template-columns: 1fr; gap: 16px; }
    .tria-pf-img { height: 200px; }
    .tria-pf-body-inner { padding: 20px 18px 0; gap: 10px; }
    .tria-pf-title { font-size: 1.05rem; }
    .tria-pf-desc { font-size: 0.78rem; }
    .tria-pf-footer { padding: 14px 18px; flex-direction: column; align-items: flex-start; gap: 12px; }
  }

  @media (max-width: 400px) {
    .tria-pf-img { height: 180px; }
    .tria-pf-body-inner { padding: 16px 14px 0; }
    .tria-pf-title { font-size: 0.95rem; }
    .tria-pf-desc { font-size: 0.74rem; }
    .tria-pf-tags span { font-size: 0.5rem; padding: 3px 8px; }
    .tria-pf-link { font-size: 0.6rem; }
    .tria-pf-footer { padding: 12px 14px; }
  }
</style>

<script is:inline>
  (function () {
    function initPortfolioAnimations() {
      var items = document.querySelectorAll('.tria-pf-observe');
      if (!items.length) return;

      // Add initial state class for scroll animation
      items.forEach(function (item) {
        if (!item.classList.contains('tria-pf-initial') && !item.classList.contains('tria-pf-visible') && !item.classList.contains('tria-pf-hidden')) {
          item.classList.add('tria-pf-initial');
        }
      });

      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.remove('tria-pf-initial');
              entry.target.classList.add('tria-pf-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        items.forEach(function (item) {
          observer.observe(item);
        });
      } else {
        // Fallback: show all immediately
        items.forEach(function (item) {
          item.classList.remove('tria-pf-initial');
          item.classList.add('tria-pf-visible');
        });
      }
    }

    function initFilter() {
      var btns = document.querySelectorAll('[data-filter]');
      var grid = document.getElementById('portfolioGrid');
      if (!btns.length || !grid) return;

      var gridItems = Array.from(grid.children);
      var hideTimers = {};

      function hideCard(card) {
        var idx = card.getAttribute('data-index');
        if (hideTimers[idx]) return;
        card.classList.remove('tria-pf-visible', 'tria-pf-initial');
        card.classList.add('tria-pf-hidden');
        hideTimers[idx] = setTimeout(function () {
          card.classList.add('tria-pf-collapsed');
        }, 420);
      }

      function showCard(card) {
        var idx = card.getAttribute('data-index');
        if (hideTimers[idx]) {
          clearTimeout(hideTimers[idx]);
          delete hideTimers[idx];
        }
        card.classList.remove('tria-pf-collapsed', 'tria-pf-hidden', 'tria-pf-visible');
        card.classList.add('tria-pf-initial');
        void card.offsetHeight;
        card.classList.remove('tria-pf-initial');
        card.classList.add('tria-pf-visible');
      }

      btns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          btns.forEach(function (b) { b.classList.remove('tria-btn--active'); });
          btn.classList.add('tria-btn--active');

          var filter = btn.getAttribute('data-filter');

          gridItems.forEach(function (card) {
            var cat = card.getAttribute('data-cat');
            if (filter === 'all' || cat === filter) {
              showCard(card);
            } else {
              hideCard(card);
            }
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initPortfolioAnimations();
        initFilter();
      });
    } else {
      initPortfolioAnimations();
      initFilter();
    }

    document.addEventListener('swup:contentReplaced', function () {
      initPortfolioAnimations();
      initFilter();
    });
  })();
</script>
