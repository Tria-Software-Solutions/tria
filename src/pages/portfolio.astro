---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Tria — Software Solutions" description="Explore our portfolio of software engineering projects.">
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
    </div>
    <div class="container page-hero-inner">
      <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n="portfolio.suptitle">Our Work</span>
      <h1 class="page-hero-heading tria-up" data-i18n-html="portfolio.title">
        Selected<br /><span class="page-hero-em">Projects</span>
      </h1>
    </div>
  </section>

  <section class="tria-soft-bg" data-section-theme="light" style="padding:120px 0;">
    <div class="container">
      <p class="tria-center tria-dark-soft" style="font-size:1.1rem;" data-i18n-html="portfolio.body">View our full portfolio on the <a href="/work" style="color:var(--accent);">Work page</a>.</p>
    </div>
  </section>

  <Footer />
</Layout>
