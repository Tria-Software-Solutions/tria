---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import CTA from "../components/CTA.astro";
import Button from "../components/Button.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>

  <PageBanner suptitleKey="portfolio.suptitle" headingKey="portfolio.title" descriptionKey="portfolio.desc">
    <div class="tria-ph-stats-col">
      <div class="tria-ph-stats">
        <div class="tria-ph-stat">
          <span class="tria-ph-stat-num">120+</span>
          <span class="tria-ph-stat-label" data-i18n="portfolio.stats.projects">{t("portfolio.stats.projects")}</span>
        </div>
        <div class="tria-ph-stat">
          <span class="tria-ph-stat-num">6</span>
          <span class="tria-ph-stat-label" data-i18n="portfolio.stats.industries">{t("portfolio.stats.industries")}</span>
        </div>
      </div>
    </div>
  </PageBanner>

  <!-- filter + grid -->
  <section data-section-theme="light" class="tria-work-section-bg">
    <div class="container" style="padding-top:80px;padding-bottom:40px;">
      <div class="tria-work-filter tria-up">
        <Button variant="outline" size="xs" color="#0b0d17" active data-filter="all" data-i18n="portfolio.filter.all" text={t("portfolio.filter.all")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="fintech" data-i18n="portfolio.filter.fintech" text={t("portfolio.filter.fintech")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="cloud" data-i18n="portfolio.filter.cloud" text={t("portfolio.filter.cloud")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="ai" data-i18n="portfolio.filter.ai" text={t("portfolio.filter.ai")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="healthcare" data-i18n="portfolio.filter.healthcare" text={t("portfolio.filter.healthcare")} />
        <Button variant="outline" size="xs" color="#0b0d17" data-filter="ecommerce" data-i18n="portfolio.filter.ecommerce" text={t("portfolio.filter.ecommerce")} />
      </div>
    </div>

    <div class="container">
      <div class="tria-portfolio-grid tria-up">

        <div class="tria-portfolio-card" data-cat="fintech">
          <div class="tria-pc-img" style="background:linear-gradient(135deg,#0b0d17 0%,#1a1f35 55%,#068e8c 100%);">
            <div class="tria-pc-abstract tria-pc-abstract--lines"></div>
          </div>
          <div class="tria-pc-body">
            <div class="tria-pc-meta">
              <span class="tria-pc-cat" data-i18n="featured.project1Cat">{t("featured.project1Cat")}</span>
            </div>
            <h3 class="tria-pc-title" data-i18n="featured.project1Title">{t("featured.project1Title")}</h3>
            <p class="tria-pc-desc" data-i18n="featured.project1Desc">{t("featured.project1Desc")}</p>
            <div class="tria-pc-tags">
              <span>React</span><span>Go</span><span>PostgreSQL</span><span>AWS</span>
            </div>
            <a href="#" class="tria-pc-link tria-link tria-arrow-place">
              <span data-i18n="portfolio.card.caseStudy">{t("portfolio.card.caseStudy")}</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <div class="tria-portfolio-card" data-cat="cloud">
          <div class="tria-pc-img" style="background:linear-gradient(135deg,#111827 0%,#1e3a5f 100%);">
            <div class="tria-pc-abstract tria-pc-abstract--rings"></div>
          </div>
          <div class="tria-pc-body">
            <div class="tria-pc-meta">
              <span class="tria-pc-cat" data-i18n="featured.project2Cat">{t("featured.project2Cat")}</span>
            </div>
            <h3 class="tria-pc-title" data-i18n="featured.project2Title">{t("featured.project2Title")}</h3>
            <p class="tria-pc-desc" data-i18n="featured.project2Desc">{t("featured.project2Desc")}</p>
            <div class="tria-pc-tags">
              <span>Kubernetes</span><span>Terraform</span><span>GCP</span><span>AWS</span>
            </div>
            <a href="#" class="tria-pc-link tria-link tria-arrow-place">
              <span data-i18n="portfolio.card.caseStudy">{t("portfolio.card.caseStudy")}</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <div class="tria-portfolio-card" data-cat="ecommerce">
          <div class="tria-pc-img" style="background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);">
          </div>
          <div class="tria-pc-body">
            <div class="tria-pc-meta">
              <span class="tria-pc-cat" data-i18n="featured.project5Cat">{t("featured.project5Cat")}</span>
            </div>
            <h3 class="tria-pc-title" data-i18n="featured.project5Title">{t("featured.project5Title")}</h3>
            <p class="tria-pc-desc" data-i18n="featured.project5Desc">{t("featured.project5Desc")}</p>
            <div class="tria-pc-tags">
              <span>Next.js</span><span>Node.js</span><span>Redis</span><span>Stripe</span>
            </div>
            <a href="#" class="tria-pc-link tria-link tria-arrow-place">
              <span data-i18n="portfolio.card.caseStudy">{t("portfolio.card.caseStudy")}</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <div class="tria-portfolio-card" data-cat="ai">
          <div class="tria-pc-img" style="background:linear-gradient(135deg,#0d0d0d 0%,#1a0f0f 50%,#068e8c 100%);">
            <div class="tria-pc-abstract tria-pc-abstract--dots"></div>
          </div>
          <div class="tria-pc-body">
            <div class="tria-pc-meta">
              <span class="tria-pc-cat" data-i18n="featured.project3Cat">{t("featured.project3Cat")}</span>
            </div>
            <h3 class="tria-pc-title" data-i18n="featured.project3Title">{t("featured.project3Title")}</h3>
            <p class="tria-pc-desc" data-i18n="featured.project3Desc">{t("featured.project3Desc")}</p>
            <div class="tria-pc-tags">
              <span>Python</span><span>PyTorch</span><span>Kafka</span><span>Snowflake</span>
            </div>
            <a href="#" class="tria-pc-link tria-link tria-arrow-place">
              <span data-i18n="portfolio.card.caseStudy">{t("portfolio.card.caseStudy")}</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <div class="tria-portfolio-card" data-cat="cloud">
          <div class="tria-pc-img" style="background:linear-gradient(135deg,#0a0a1a 0%,#0d2137 100%);">
          </div>
          <div class="tria-pc-body">
            <div class="tria-pc-meta">
              <span class="tria-pc-cat" data-i18n="featured.project6Cat">{t("featured.project6Cat")}</span>
            </div>
            <h3 class="tria-pc-title" data-i18n="featured.project6Title">{t("featured.project6Title")}</h3>
            <p class="tria-pc-desc" data-i18n="featured.project6Desc">{t("featured.project6Desc")}</p>
            <div class="tria-pc-tags">
              <span>Go</span><span>MQTT</span><span>InfluxDB</span><span>Azure</span>
            </div>
            <a href="#" class="tria-pc-link tria-link tria-arrow-place">
              <span data-i18n="portfolio.card.caseStudy">{t("portfolio.card.caseStudy")}</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <div class="tria-portfolio-card" data-cat="healthcare">
          <div class="tria-pc-img" style="background:linear-gradient(135deg,#071a2c 0%,#0c3b5e 100%);">
          </div>
          <div class="tria-pc-body">
            <div class="tria-pc-meta">
              <span class="tria-pc-cat" data-i18n="featured.project4Cat">{t("featured.project4Cat")}</span>
            </div>
            <h3 class="tria-pc-title" data-i18n="featured.project4Title">{t("featured.project4Title")}</h3>
            <p class="tria-pc-desc" data-i18n="featured.project4Desc">{t("featured.project4Desc")}</p>
            <div class="tria-pc-tags">
              <span>Python</span><span>Spark</span><span>dbt</span><span>GCP</span>
            </div>
            <a href="#" class="tria-pc-link tria-link tria-arrow-place">
              <span data-i18n="portfolio.card.caseStudy">{t("portfolio.card.caseStudy")}</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section data-section-theme="light" class="tria-work-section-bg">
    <div class="container" style="padding:0 0 120px;">
      <div class="tria-work-page-cta tria-up">
        <div class="tria-wpc-left">
          <h4 class="tria-wpc-heading" data-i18n="portfolio.cta.heading">{t("portfolio.cta.heading")}</h4>
          <p class="tria-wpc-sub" data-i18n="portfolio.cta.subtext">{t("portfolio.cta.subtext")}</p>
        </div>
        <Button text={t("portfolio.cta.button")} href="/contact" showArrow={true} />
      </div>
    </div>
  </section>

  <CTA 
    heading={t("cta.heading") || ""}
    description={t("cta.description") || "From concept to deployment, we build software that scales."}
    primaryButtonText={t("cta.startProject") || ""}
    secondaryButtonText={t("cta.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />

  <SiteFooter />
</Layout>

<style>
  .tria-ph-stats-col {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding-bottom: 12px;
  }
  .tria-ph-stats {
    display: flex;
    gap: 50px;
  }
  .tria-ph-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }
  .tria-ph-stat-num {
    font-size: 2.5rem;
    font-weight: 300;
    color: rgba(255,255,255,0.8);
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    line-height: 1;
  }
  .tria-ph-stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-top: 6px;
  }

  .tria-work-section-bg {
    background: #faf7f2;
  }

  .tria-work-filter {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 60px;
  }

  .tria-portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .tria-portfolio-card {
    background: #fff;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
    transition: box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-portfolio-card:hover {
    box-shadow: 0 12px 36px rgba(0,0,0,0.07), 0 3px 12px rgba(0,0,0,0.04);
    transform: translateY(-3px);
  }
  .tria-portfolio-card.tria-hidden {
    display: none;
  }
  .tria-pc-img {
    height: 240px;
    position: relative;
    overflow: hidden;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-portfolio-card:hover .tria-pc-img {
    transform: scale(1.04);
  }
  .tria-pc-abstract {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .tria-pc-abstract--lines::after {
    content: '';
    position: absolute;
    width: 200px;
    height: 200px;
    right: -30px;
    bottom: -30px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 50%;
    box-shadow: 0 0 0 40px rgba(255,255,255,0.03), 0 0 0 80px rgba(255,255,255,0.015);
  }
  .tria-pc-abstract--rings::before {
    content: '';
    position: absolute;
    width: 160px;
    height: 160px;
    top: 20px;
    right: 20px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 0 0 30px rgba(255,255,255,0.03);
  }
  .tria-pc-abstract--dots::after {
    content: '';
    position: absolute;
    right: 30px;
    top: 30px;
    width: 80px;
    height: 80px;
    background-image: radial-gradient(rgba(255,255,255,0.15) 1px, transparent 1px);
    background-size: 12px 12px;
  }
  .tria-pc-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }
  .tria-pc-meta {
    display: flex;
    align-items: center;
  }
  .tria-pc-cat {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }
  .tria-pc-title {
    font-size: 1.25rem;
    font-weight: 400;
    color: #0b0d17;
    line-height: 1.25;
    margin: 0;
    transition: color 0.3s ease;
  }
  .tria-portfolio-card:hover .tria-pc-title {
    color: var(--accent);
  }
  .tria-pc-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }
  .tria-pc-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tria-pc-tags span {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 20px;
    color: rgba(0,0,0,0.4);
    transition: border-color 0.3s ease;
  }
  .tria-portfolio-card:hover .tria-pc-tags span {
    border-color: rgba(0,0,0,0.18);
  }
  .tria-pc-link {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: #0b0d17;
    margin-top: 8px;
  }
  .tria-pc-link i {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-pc-link:hover i {
    transform: translateX(4px);
  }

  .tria-work-page-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 50px 60px;
    background: #fff;
    gap: 24px;
    transition: box-shadow 0.4s ease;
  }
  .tria-work-page-cta:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.06);
  }
  .tria-wpc-heading {
    font-weight: 300;
    font-size: 1.8rem;
    margin: 0;
  }
  .tria-wpc-sub {
    color: #888;
    font-size: 0.9rem;
    margin: 8px 0 0;
  }

  @media (max-width: 991px) {
    .tria-portfolio-grid { grid-template-columns: repeat(2, 1fr); }
    .tria-ph-stats-col { display: none; }
  }
  @media (max-width: 600px) {
    .tria-portfolio-grid { grid-template-columns: 1fr; }
    .tria-work-page-cta { padding: 36px; }
    .tria-wpc-heading { font-size: 1.4rem; }
  }

  .tria-mb-20 { margin-bottom: 20px; }
</style>

<script is:inline>
  (function () {
    function initFilter() {
      var btns = document.querySelectorAll('[data-filter]');
      var cards = document.querySelectorAll('.tria-portfolio-card');
      if (!btns.length) return;
      btns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          btns.forEach(function (b) { b.classList.remove('tria-btn--active'); });
          btn.classList.add('tria-btn--active');
          var filter = btn.getAttribute('data-filter');
          cards.forEach(function (card) {
            var cat = card.getAttribute('data-cat');
            if (filter === 'all' || cat === filter) {
              card.classList.remove('tria-hidden');
            } else {
              card.classList.add('tria-hidden');
            }
          });
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFilter);
    } else {
      initFilter();
    }
    document.addEventListener('swup:contentReplaced', initFilter);
  })();
</script>
