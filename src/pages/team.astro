---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import CTA from "../components/CTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <PageBanner suptitleKey="team.suptitle" headingKey="team.title" />

  <section class="tria-soft-bg" data-section-theme="light" style="padding:120px 0;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 tria-center">
          <p class="tria-dark-soft" style="font-size:1.1rem;line-height:1.8;max-width:600px;margin:0 auto;" data-i18n="team.body">{t("team.body")}</p>
        </div>
      </div>
    </div>
  </section>

  <CTA 
    heading={t("cta.heading") || ""}
    description={t("cta.description") || "From concept to deployment, we build software that scales."}
    primaryButtonText={t("cta.startProject") || ""}
    secondaryButtonText={t("cta.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>

<style>
  .page-hero .tria-thin {
    color: rgba(255,255,255,0.35);
    font-style: italic;
  }
</style>
