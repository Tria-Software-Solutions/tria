---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Tria — Software Solutions" description="Meet the team behind tria — software engineers, architects, and problem solvers from Costa Rica.">
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
    </div>
    <div class="container page-hero-inner">
      <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n="team.suptitle">Who we are</span>
      <h1 class="page-hero-heading tria-up" data-i18n-html="team.title">
        Meet the<br /><span class="page-hero-em">Team</span>
      </h1>
    </div>
  </section>

  <section class="tria-soft-bg" data-section-theme="light" style="padding:120px 0;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 tria-center">
          <p class="tria-dark-soft" style="font-size:1.1rem;line-height:1.8;max-width:600px;margin:0 auto;" data-i18n="team.body">
            We are engineers, architects, and problem solvers who thrive on building software that works. Our team spans cloud infrastructure, full-stack development, AI/ML, and cybersecurity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
