---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Team from "../components/Team.astro";
import CTA from "../components/CTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <PageBanner suptitleKey="team.suptitle" headingKey="team.title" descriptionKey="team.heroDesc" />

  <Team 
    description1={t("team.description1") || ""}
    description2={t("team.description2") || ""}
    tagline={t("team.tagline") || ""}
    coreNote={t("team.coreNote") || ""}
    members={[
      {
        name: t("team.member1Name") || "",
        role: t("team.role1") || "",
        image: "/assets/img/team/1.jpeg",
        socialLinks: [
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>', href: "https://www.facebook.com/luisherreracr" },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>', href: "https://www.instagram.com/luismigue_l" }
        ]
      },
      {
        name: t("team.member2Name") || "",
        role: t("team.role2") || "",
        image: "/assets/img/team/2.jpeg",
        socialLinks: [
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>', href: "https://facebook.com/danilumix" },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>', href: "https://www.instagram.com/danilumix" }
        ]
      }
    ]}
  />

  <!-- culture / approach — gray bg like engagement models -->
  <section class="tria-tm-culture" data-section-theme="light">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row tria-mb-60">
        <div class="col-lg-6">
          <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="team.cultureSuptitle">{t("team.cultureSuptitle")}</span>
          <h2 class="tria-up tria-tm-title" data-i18n-html="team.cultureTitle" set:html={t("team.cultureTitle")} />
        </div>
      </div>
      <div class="row tria-tm-grid">
        <div class="col-md-4 tria-up tria-mb-30">
          <div class="tria-tm-card">
            <div class="tria-tm-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/></svg>
            </div>
            <h4 class="tria-tm-card-title" data-i18n="team.culture1Title">{t("team.culture1Title")}</h4>
            <p class="tria-tm-card-desc" data-i18n="team.culture1Desc">{t("team.culture1Desc")}</p>
          </div>
        </div>
        <div class="col-md-4 tria-up tria-mb-30">
          <div class="tria-tm-card">
            <div class="tria-tm-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h4 class="tria-tm-card-title" data-i18n="team.culture2Title">{t("team.culture2Title")}</h4>
            <p class="tria-tm-card-desc" data-i18n="team.culture2Desc">{t("team.culture2Desc")}</p>
          </div>
        </div>
        <div class="col-md-4 tria-up tria-mb-30">
          <div class="tria-tm-card">
            <div class="tria-tm-card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h4 class="tria-tm-card-title" data-i18n="team.culture3Title">{t("team.culture3Title")}</h4>
            <p class="tria-tm-card-desc" data-i18n="team.culture3Desc">{t("team.culture3Desc")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

<CTA 
    heading={t("ctaTeam.heading") || ""}
    description={t("ctaTeam.desc") || ""}
    primaryButtonText={t("ctaTeam.button") || ""}
    secondaryButtonText={t("ctaTeam.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>

<style>
  .page-hero .tria-thin {
    color: rgba(255,255,255,0.35);
    font-style: italic;
  }

  /* ═══════════════════════════════════════
     CULTURE — Gray bg with cards
     ═══════════════════════════════════════ */
  .tria-tm-culture {
    background: #f5f7f9;
    position: relative;
    overflow: hidden;
  }

  .tria-tm-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 450;
    letter-spacing: -0.025em;
    color: #0b0d17;
    margin-top: 20px;
    line-height: 1.15;
  }
  .tria-tm-title .tria-thin {
    color: rgba(0,0,0,0.2);
    font-weight: 200;
  }

  .tria-tm-grid {
    position: relative;
    z-index: 1;
  }

  .tria-tm-card {
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 20px;
    padding: 44px 36px;
    height: 100%;
    background: #fff;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-tm-card:hover {
    border-color: rgba(6,142,140,0.15);
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.04);
  }

  .tria-tm-card-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    background: rgba(6,142,140,0.07);
    color: var(--accent);
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-tm-card:hover .tria-tm-card-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }

  .tria-tm-card-title {
    font-size: 1.1rem;
    font-weight: 450;
    color: #0b0d17;
    margin-bottom: 14px;
  }
  .tria-tm-card:hover .tria-tm-card-title {
    color: var(--accent);
  }

  .tria-tm-card-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.75;
    margin: 0;
    transition: color 0.3s ease;
  }
  .tria-tm-card:hover .tria-tm-card-desc {
    color: #555;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 991px) {
    .tria-tm-card { margin-bottom: 24px; }
    .tria-tm-card:last-child { margin-bottom: 0; }
  }

  @media (max-width: 768px) {
    .tria-tm-card { padding: 36px 28px; }
  }

  @media (max-width: 576px) {
    .tria-tm-card {
      padding: 28px 24px;
      margin-bottom: 20px;
    }
    .tria-tm-card-title { font-size: 1rem; }
    .tria-tm-card-desc { font-size: 0.78rem; }
    .tria-tm-card-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      margin-bottom: 18px;
    }
    .tria-tm-title { font-size: 1.5rem; }
  }

  @media (max-width: 400px) {
    .tria-tm-card {
      padding: 22px 18px;
      margin-bottom: 16px;
    }
    .tria-tm-card-title { font-size: 0.9rem; }
    .tria-tm-card-desc { font-size: 0.72rem; }
  }
</style>
