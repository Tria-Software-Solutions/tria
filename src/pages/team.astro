---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
    </div>
    <div class="container page-hero-inner">
      <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n="team.suptitle">{t("team.suptitle")}</span>
      <h1 class="page-hero-heading tria-up" data-i18n-html="team.title" set:html={t("team.title")} />
    </div>
  </section>

  <section class="tria-soft-bg" data-section-theme="light" style="padding:120px 0;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 tria-center">
          <p class="tria-dark-soft" style="font-size:1.1rem;line-height:1.8;max-width:600px;margin:0 auto;" data-i18n="team.body">{t("team.body")}</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero .tria-thin {
    color: rgba(255,255,255,0.35);
    font-style: italic;
  }
</style>
