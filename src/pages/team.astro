---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Team from "../components/Team.astro";
import Stats from "../components/Stats.astro";
import Quote from "../components/Quote.astro";
import CTA from "../components/CTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <PageBanner suptitleKey="team.suptitle" headingKey="team.title" descriptionKey="team.heroDesc" />

  <Team 
    suptitle={t("team.suptitle") || ""}
    heading={t("team.title") || ""}
    description1={t("team.description1") || ""}
    description2={t("team.description2") || ""}
    tagline={t("team.tagline") || ""}
    coreNote={t("team.coreNote") || ""}
    members={[
      {
        name: t("team.member1Name") || "",
        role: t("team.role1") || "",
        image: "/assets/img/team/1.jpg",
        socialLinks: [
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 7h-7V2H9v5H2v9h7v5h6v-5h7V7z"/></svg>', href: "#." },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 5.46 11.43 5.1 18.5"/><path d="M15.44 2.75c-4.37 6.03-5.46 11.43-5.1 18.5"/><path d="M2 12h20"/><path d="M12 2C7 8 7 16 12 22c5-6 5-14 0-20z"/></svg>', href: "#." },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>', href: "#." },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>', href: "#." }
        ]
      },
      {
        name: t("team.member2Name") || "",
        role: t("team.role2") || "",
        image: "/assets/img/team/2.jpg",
        socialLinks: [
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 7h-7V2H9v5H2v9h7v5h6v-5h7V7z"/></svg>', href: "#." },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 5.46 11.43 5.1 18.5"/><path d="M15.44 2.75c-4.37 6.03-5.46 11.43-5.1 18.5"/><path d="M2 12h20"/><path d="M12 2C7 8 7 16 12 22c5-6 5-14 0-20z"/></svg>', href: "#." },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>', href: "#." },
          { icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>', href: "#." }
        ]
      }
    ]}
  />

  <!-- values / approach -->
  <section class="tria-team-values" data-section-theme="light">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row tria-mb-60">
        <div class="col-lg-6">
          <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="team.cultureSuptitle">{t("team.cultureSuptitle")}</span>
          <h2 class="tria-up" style="margin-top:20px;" data-i18n-html="team.cultureTitle" set:html={t("team.cultureTitle")} />
        </div>
      </div>
      <div class="row">
        <div class="col-md-4 tria-up tria-mb-30">
          <div class="tria-tv-card">
            <div class="tria-tv-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/></svg>
            </div>
            <h4 class="tria-tv-title" data-i18n="team.culture1Title">{t("team.culture1Title")}</h4>
            <p class="tria-tv-desc" data-i18n="team.culture1Desc">{t("team.culture1Desc")}</p>
          </div>
        </div>
        <div class="col-md-4 tria-up tria-mb-30">
          <div class="tria-tv-card">
            <div class="tria-tv-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h4 class="tria-tv-title" data-i18n="team.culture2Title">{t("team.culture2Title")}</h4>
            <p class="tria-tv-desc" data-i18n="team.culture2Desc">{t("team.culture2Desc")}</p>
          </div>
        </div>
        <div class="col-md-4 tria-up tria-mb-30">
          <div class="tria-tv-card">
            <div class="tria-tv-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h4 class="tria-tv-title" data-i18n="team.culture3Title">{t("team.culture3Title")}</h4>
            <p class="tria-tv-desc" data-i18n="team.culture3Desc">{t("team.culture3Desc")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Stats 
    stats={[
      { value: 25, suffix: '+', label: t("stats.projectsLabel") || "" },
      { value: 15, suffix: '+', label: t("stats.clientsLabel") || "" },
      { value: 7, suffix: '+', label: t("stats.yearsLabel") || "" },
      { value: 99, suffix: '%', label: t("stats.satisfactionLabel") || "" }
    ]}
  />

  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />

  <CTA 
    heading={t("ctaTeam.heading") || ""}
    description={t("ctaTeam.desc") || ""}
    primaryButtonText={t("ctaTeam.button") || ""}
    secondaryButtonText={t("ctaTeam.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>

<style>
  .page-hero .tria-thin {
    color: rgba(255,255,255,0.35);
    font-style: italic;
  }

  .tria-team-values {
    background: #fff;
    position: relative;
  }

  .tria-team-values::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 30%, rgba(6, 142, 140, 0.02) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 70%, rgba(6, 142, 140, 0.015) 0%, transparent 50%);
    pointer-events: none;
  }

  .tria-team-values .tria-thin {
    color: rgba(0, 0, 0, 0.2);
  }

  .tria-tv-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 40px 34px;
    height: 100%;
    background: #fff;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-tv-card:hover {
    border-color: rgba(6,142,140,0.2);
    transform: translateY(-6px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.06);
  }

  .tria-tv-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(6,142,140,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 20px;
    margin-bottom: 24px;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-tv-card:hover .tria-tv-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }

  .tria-tv-title {
    font-size: 1.05rem;
    font-weight: 450;
    color: #0b0d17;
    margin-bottom: 12px;
    transition: color 0.3s ease;
  }

  .tria-tv-card:hover .tria-tv-title {
    color: var(--accent);
  }

  .tria-tv-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.75;
    margin: 0;
    transition: color 0.3s ease;
  }

  .tria-tv-card:hover .tria-tv-desc {
    color: #555;
  }

  @media (max-width: 768px) {
    .tria-tv-card {
      padding: 32px 28px;
    }
  }

  @media (max-width: 576px) {
    .tria-tv-card {
      padding: 24px 20px;
      margin-bottom: 20px;
    }
    .tria-tv-title {
      font-size: 0.95rem;
    }
    .tria-tv-desc {
      font-size: 0.78rem;
    }
    .tria-tv-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      margin-bottom: 18px;
    }
  }

  @media (max-width: 400px) {
    .tria-tv-card {
      padding: 18px 16px;
      margin-bottom: 16px;
    }
    .tria-tv-title {
      font-size: 0.85rem;
    }
    .tria-tv-desc {
      font-size: 0.72rem;
    }
  }
</style>
