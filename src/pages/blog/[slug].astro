---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Quote from "../../components/Quote.astro";
import CTA from "../../components/CTA.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Button from "../../components/Button.astro";
import { createT } from "../../i18n/utils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const t = createT(Astro.currentLocale);
const { post } = Astro.props;
---

<Layout title={`${post.data.title} — tria`} description={post.data.description}>
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-bg-dots"></div>
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
      <div class="page-hero-gradient-overlay"></div>
      <div class="tria-hero-grain"></div>
      <div class="tria-ambient-temp">
        <div class="tria-at-glow-1"></div>
        <div class="tria-at-glow-2"></div>
      </div>
    </div>
    <div class="container page-hero-inner">
      <a href="/blog" class="tria-link tria-light-soft tria-up" style="display:inline-flex;align-items:center;gap:6px;margin-bottom:24px;font-size:0.75rem;">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M11 4L7 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back to Blog
      </a>
      <div class="tria-labels tria-up tria-mb-20">
        <div class="tria-label tria-upper tria-accent">{post.data.category.toUpperCase()}</div>
        <div class="tria-label tria-upper">{new Date(post.data.pubDate).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</div>
      </div>
      <h1 class="page-hero-heading tria-up">{post.data.title}</h1>
      <p class="page-hero-sub tria-up">{post.data.description}</p>
    </div>
  </section>

  <section class="tria-soft-bg" data-section-theme="light" style="padding:80px 0;position:relative;">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-2"></div>
    </div>
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
          <article class="tria-article" set:html={post.rendered.html}></article>

          <div class="tria-post-footer tria-up" style="margin-top:60px;padding-top:40px;border-top:1px solid rgba(0,0,0,0.08);">
            <div class="tria-tags">
              {
                post.data.tags.map((tag) => (
                  <span class="tria-label tria-upper">{tag}</span>
                ))
              }
            </div>
            <Button text="&larr; Back to all posts" href="/blog" variant="ghost" size="sm" arrowStyle="inline" style="margin-top:24px;" />
          </div>
        </div>
      </div>
    </div>
  </section>
  <Quote
    heading={'Get a <span class="tria-thin">Custom Quote</span>'}
    description="Tell us about your project and we'll create a tailored solution with transparent pricing."
    buttonText="Request a Quote"
    buttonHref="/contact"
    features={[
      "Personalized scope",
      "Transparent pricing",
      "Flexible timeline",
      "Dedicated support"
    ]}
  />

  <CTA 
    heading={t("ctaBlog.heading") || ""}
    description={t("ctaBlog.desc") || ""}
    primaryButtonText={t("ctaBlog.button") || ""}
    secondaryButtonText={t("ctaBlog.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/contact"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>

<style>
  
  .tria-article :global(h2) {
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #111;
  }
  .tria-article :global(h3) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #111;
  }
  .tria-article :global(p) {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    color: rgba(0, 0, 0, 0.75);
  }
  .tria-article :global(ul),
  .tria-article :global(ol) {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: rgba(0, 0, 0, 0.75);
  }
  .tria-article :global(li) {
    margin-bottom: 0.5rem;
  }
  .tria-article :global(strong) {
    font-weight: 600;
    color: #111;
  }
  .tria-article :global(pre) {
    background: #111;
    color: #f5f5f5;
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .tria-article :global(code) {
    font-family: "SF Mono", "Fira Code", monospace;
    font-size: 0.9em;
  }
  .tria-article :global(:not(pre) > code) {
    background: rgba(0, 0, 0, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
  .tria-article :global(blockquote) {
    border-left: 3px solid var(--accent, #555);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: rgba(0, 0, 0, 0.6);
    font-style: italic;
  }
  .tria-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .tria-article :global(th),
  .tria-article :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    text-align: left;
  }
  .tria-article :global(th) {
    font-weight: 600;
    color: #111;
  }
  .tria-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tria-labels {
    display: flex;
    gap: 12px;
    align-items: center;
  }
</style>
