---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Footer from "../../../components/Footer.astro";
import BlogList from "../../../components/BlogList.astro";
import { createT } from "../../../i18n/utils";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const pageSize = 6;
  const totalPages = Math.ceil(allPosts.length / pageSize);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2;
    const posts = allPosts.slice((page - 1) * pageSize, page * pageSize);
    return {
      params: { page: String(page) },
      props: { posts, currentPage: page, totalPages },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
const t = createT(Astro.currentLocale);
---

<Layout title={`Tria — Software Solutions`} description="Read insights on software engineering, AI, cloud infrastructure, and technology from the tria team.">
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
    </div>
    <div class="container page-hero-inner">
      <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;" data-i18n="blog.newsletter">{t("blog.newsletter")}</span>
      <h1 class="page-hero-heading tria-up" data-i18n-html="blog.popularPublications" set:html={t("blog.popularPublications")} />
    </div>
  </section>

  <section class="tria-soft-bg" data-section-theme="light" style="padding:120px 0;">
    <BlogList posts={posts} currentPage={currentPage} totalPages={totalPages} />
  </section>

  <Footer />
</Layout>
