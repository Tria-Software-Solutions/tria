---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import PageBanner from "../../../components/PageBanner.astro";
import Quote from "../../../components/Quote.astro";
import CTA from "../../../components/CTA.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import BlogList from "../../../components/BlogList.astro";
import { createT } from "../../../i18n/utils";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const pageSize = 6;
  const totalPages = Math.ceil(allPosts.length / pageSize);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2;
    const posts = allPosts.slice((page - 1) * pageSize, page * pageSize);
    return {
      params: { page: String(page) },
      props: { posts, currentPage: page, totalPages },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.blogTitle")} description={t("meta.blogDesc")}>
  <PageBanner suptitleKey="blog.newsletter" headingKey="blog.popularPublications" descriptionKey="blog.heroDesc" />

  <section class="tria-soft-bg" data-section-theme="light" style="padding:120px 0;">
    <BlogList posts={posts} currentPage={currentPage} totalPages={totalPages} />
  </section>

  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />

  <CTA 
    heading={t("cta.heading") || ""}
    description={t("cta.description") || "From concept to deployment, we build software that scales."}
    primaryButtonText={t("cta.startProject") || ""}
    secondaryButtonText={t("cta.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />

  <SiteFooter />
</Layout>
