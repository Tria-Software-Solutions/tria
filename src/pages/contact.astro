---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Ashley">
  <section style="min-height:100vh;padding:160px 0 100px;">
    <div class="container">
      <p class="section-label">Get in touch</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(3rem,7vw,7rem);font-weight:300;">
        Let's work<br><em style="font-style:italic;color:var(--color-accent);">together</em>
      </h1>
      <div style="margin-top:60px;display:grid;grid-template-columns:1fr 1fr;gap:80px;max-width:900px;">
        <div>
          <p style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:8px;">Canada</p>
          <p style="font-size:.9rem;line-height:1.8;color:#555;">71 South Los Carneros Road, California<br>+51 174 705 812</p>
        </div>
        <div>
          <p style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:8px;">Germany</p>
          <p style="font-size:.9rem;line-height:1.8;color:#555;">Leehove 40, 2678 MC De Lier, Netherlands<br>+31 174 705 811</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
