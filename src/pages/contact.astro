  /* ═══════════════════════════════════════
     SERVICES MULTI-SELECT DROPDOWN
     ═══════════════════════════════════════ */
  .tria-svdd {
    position: relative;
    width: 100%;
  }
  .tria-svdd-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    height: 50px;
    padding: 0 24px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 60px;
    background: #f5f7f9;
    font-family: 'Outfit', sans-serif;
    font-size: 0.88rem;
    font-weight: 380;
    color: rgba(0,0,0,0.2);
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    text-align: left;
  }
  .tria-svdd-trigger:hover {
    border-color: rgba(0,0,0,0.12);
  }
  .tria-svdd--open .tria-svdd-trigger,
  .tria-svdd-trigger:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 0 0 6px rgba(6,142,140,0.06), inset 0 0 0 1px rgba(6,142,140,0.05);
    background: #fff;
  }
  .tria-svdd-chevron {
    flex-shrink: 0;
    color: rgba(0,0,0,0.2);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.3s ease;
    margin-left: auto;
  }
  .tria-svdd--open .tria-svdd-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }
  .tria-svdd-label {
    transition: color 0.3s ease;
    flex: 1;
  }
  .tria-svdd-count {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    background: rgba(6,142,140,0.08);
    padding: 2px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── Dropdown menu ── */
  .tria-svdd-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 50;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 6px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0.3s;
    max-height: 360px;
    overflow-y: auto;
  }
  .tria-svdd--open .tria-svdd-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Category group label ── */
  .tria-svdd-group-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.2);
    padding: 10px 14px 4px;
    pointer-events: none;
  }
  .tria-svdd-group-label:not(:first-child) {
    margin-top: 2px;
    border-top: 1px solid rgba(0,0,0,0.04);
  }

  /* ── Service option ── */
  .tria-svdd-option {
    padding: 8px 14px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .tria-svdd-option:hover {
    background: #f5f7f9;
  }
  .tria-svdd-option--selected {
    background: rgba(6,142,140,0.06);
  }
  .tria-svdd-option--selected:hover {
    background: rgba(6,142,140,0.10);
  }

  .tria-svdd-opt-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .tria-svdd-opt-label {
    font-size: 0.82rem;
    font-weight: 450;
    color: #0b0d17;
    letter-spacing: -0.01em;
  }
  .tria-svdd-opt-check {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid rgba(0,0,0,0.12);
    color: transparent;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-svdd-option--selected .tria-svdd-opt-check {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .tria-cf-note {
    font-size: 0.7rem;
    color: rgba(0,0,0,0.3);
    margin: 0;
    text-align: center;
  }

  /* ── Success state ── */
  .tria-cf-success {
    text-align: center;
    padding: 60px 40px;
    border: 1px solid rgba(6,142,140,0.12);
    border-radius: 20px;
    background: rgba(6,142,140,0.02);
    max-width: 820px;
  }
  .tria-cfs-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .tria-cf-success h4 { margin-bottom: 10px; color: #0b0d17; }
  .tria-cf-success p { color: #888; font-size: 0.9rem; }

  /* ═══════════════════════════════════════
     SIDEBAR — location card
     ═══════════════════════════════════════ */
  .tria-cfs-card-label-sm {
    font-size: 0.78rem;
    font-weight: 520;
    color: #0b0d17;
    margin: 0 0 12px;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }
  .tria-cfs-card-value-sm {
