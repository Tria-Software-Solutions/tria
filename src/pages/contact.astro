---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Button from "../components/Button.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const sendingText = t('contact.form.sending');

const serviceGroups = [
  {
    categoryKey: 'contact.form.svcCat.digital',
    services: [
      { value: 'website', key: 'contact.form.service.website' },
      { value: 'webapp', key: 'contact.form.service.webapp' },
      { value: 'mobile', key: 'contact.form.service.mobile' },
      { value: 'desktop', key: 'contact.form.service.desktop' },
      { value: 'ecommerce', key: 'contact.form.service.ecommerce' },
    ],
  },
  {
    categoryKey: 'contact.form.svcCat.backend',
    services: [
      { value: 'api', key: 'contact.form.service.api' },
      { value: 'microservices', key: 'contact.form.service.microservices' },
      { value: 'database', key: 'contact.form.service.database' },
      { value: 'legacy', key: 'contact.form.service.legacy' },
    ],
  },
  {
    categoryKey: 'contact.form.svcCat.cloud',
    services: [
      { value: 'cloudMigration', key: 'contact.form.service.cloudMigration' },
      { value: 'kubernetes', key: 'contact.form.service.kubernetes' },
      { value: 'cicd', key: 'contact.form.service.cicd' },
      { value: 'iac', key: 'contact.form.service.iac' },
    ],
  },
  {
    categoryKey: 'contact.form.svcCat.ai',
    services: [
      { value: 'chatbot', key: 'contact.form.service.chatbot' },
      { value: 'llm', key: 'contact.form.service.llm' },
      { value: 'automation', key: 'contact.form.service.automation' },
      { value: 'computerVision', key: 'contact.form.service.computerVision' },
      { value: 'dataPipeline', key: 'contact.form.service.dataPipeline' },
    ],
  },
  {
    categoryKey: 'contact.form.svcCat.security',
    services: [
      { value: 'securityAudit', key: 'contact.form.service.securityAudit' },
      { value: 'pentest', key: 'contact.form.service.pentest' },
      { value: 'compliance', key: 'contact.form.service.compliance' },
      { value: 'incidentResponse', key: 'contact.form.service.incidentResponse' },
    ],
  },
  {
    categoryKey: 'contact.form.svcCat.advisory',
    services: [
      { value: 'techStrategy', key: 'contact.form.service.techStrategy' },
      { value: 'architectureReview', key: 'contact.form.service.architectureReview' },
      { value: 'codeAudit', key: 'contact.form.service.codeAudit' },
    ],
  },
];
---

<Layout title={t("meta.contactTitle")} description={t("meta.contactDesc")}>

  <PageBanner suptitleKey="contact.getInTouch" headingKey="contact.letsBuild" descriptionKey="contact.heroSub" />

  <!-- contact form - white, frameless -->
  <section id="contact-form" class="tria-cf-section" data-section-theme="light" style="position:relative;">
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row">
        <div class="col-lg-7">
          <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="contact.suptitle">{t("contact.suptitle")}</span>
          <h2 class="tria-up tria-cf-heading" data-i18n-html="contact.heading" set:html={t("contact.heading")} />
          <p class="tria-cf-hero-desc tria-up" data-i18n="contact.heroSub">{t("contact.heroSub")}</p>
        </div>
      </div>

      <div class="tria-cf-divider tria-up"></div>

      <div class="row tria-cf-main-row">
        <div class="col-lg-7">
          <form class="tria-cf-form tria-up" id="triaContactForm">
            <div class="tria-cf-row">
              <div class="tria-cf-group">
                <label class="tria-cf-label" for="cf-name" data-i18n="contact.form.label.name">{t("contact.form.label.name")}</label>
                <input class="tria-cf-input" type="text" id="cf-name" name="name" data-i18n-placeholder="contact.form.placeholder.name" placeholder={t("contact.form.placeholder.name")} required />
              </div>
              <div class="tria-cf-group">
                <label class="tria-cf-label" for="cf-email" data-i18n="contact.form.label.email">{t("contact.form.label.email")}</label>
                <input class="tria-cf-input" type="email" id="cf-email" name="email" data-i18n-placeholder="contact.form.placeholder.email" placeholder={t("contact.form.placeholder.email")} required />
              </div>
            </div>

            <div class="tria-cf-row">
              <div class="tria-cf-group">
                <label class="tria-cf-label" for="cf-company" data-i18n="contact.form.label.company">{t("contact.form.label.company")}</label>
                <input class="tria-cf-input" type="text" id="cf-company" name="company" data-i18n-placeholder="contact.form.placeholder.company" placeholder={t("contact.form.placeholder.company")} />
              </div>
              <div class="tria-cf-group">
                <label class="tria-cf-label" data-i18n="contact.form.label.budget">{t("contact.form.label.budget")}</label>
                <!-- Custom Dropdown -->
                <div class="tria-dd" id="cf-budget-dd">
                  <button class="tria-dd-trigger" type="button">
                    <span class="tria-dd-label" data-i18n="contact.form.placeholder.budget">{t("contact.form.placeholder.budget")}</span>
                    <svg class="tria-dd-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </button>
                  <div class="tria-dd-menu">
                    <div class="tria-dd-option" data-value="website" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.website">{t("contact.form.option.website")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.website">{t("contact.form.dropdown.website")}</span>
                    </div>
                    <div class="tria-dd-option" data-value="webapp" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.webapp">{t("contact.form.option.webapp")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.webapp">{t("contact.form.dropdown.webapp")}</span>
                    </div>
                    <div class="tria-dd-option" data-value="backend" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.backend">{t("contact.form.option.backend")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.backend">{t("contact.form.dropdown.backend")}</span>
                    </div>
                    <div class="tria-dd-option" data-value="enterprise" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.enterprise">{t("contact.form.option.enterprise")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.enterprise">{t("contact.form.dropdown.enterprise")}</span>
                    </div>
                    <div class="tria-dd-divider"></div>
                    <div class="tria-dd-option" data-value="tbd" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.tbd">{t("contact.form.option.tbd")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.tbd">{t("contact.form.dropdown.tbd")}</span>
                    </div>
                  </div>
                </div>
                <input type="hidden" id="cf-budget" name="budget" value="" />
              </div>
            </div>

        <div class="tria-cf-group">
          <label class="tria-cf-label" data-i18n="contact.form.label.services">{t("contact.form.label.services")}</label>
          <!-- Multi-select grouped dropdown for services -->
          <div class="tria-svdd" id="cf-services-dd">
            <button class="tria-svdd-trigger" type="button">
              <span class="tria-svdd-label" data-i18n="contact.form.servicesPlaceholder">{t("contact.form.servicesPlaceholder")}</span>
              <span class="tria-svdd-count" style="display:none;"></span>
              <svg class="tria-svdd-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tria-svdd-menu">
              {serviceGroups.map((group) => (
                <>
                  <div class="tria-svdd-group-label" data-i18n={group.categoryKey}>{t(group.categoryKey)}</div>
                  {group.services.map((svc) => (
                    <div class="tria-svdd-option" data-value={svc.value} role="option">
                      <div class="tria-svdd-opt-main">
                        <span class="tria-svdd-opt-label" data-i18n={svc.key}>{t(svc.key)}</span>
                        <span class="tria-svdd-opt-check">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                    </div>
                  ))}
                </>
              ))}
            </div>
          </div>
          <input type="hidden" id="cf-services" name="services" value="" />
        </div>

        <div class="tria-cf-group">
          <label class="tria-cf-label" for="cf-message" data-i18n="contact.form.label.message">{t("contact.form.label.message")}</label>
          <textarea class="tria-cf-input tria-cf-textarea" id="cf-message" name="message" data-i18n-placeholder="contact.form.placeholder.message" placeholder={t("contact.form.placeholder.message")} rows="6" required></textarea>
        </div>

        <Button text={t("contact.form.submit")} showArrow={true} arrowStyle="inline" size="sm" fullWidth={true} id="cf-submit-btn" type="submit" />

        <p class="tria-cf-note" data-i18n="contact.form.note">{t("contact.form.note")}</p>
      </form>
          </div> <!-- /col-lg-7 -->
          <div class="col-lg-5">
            <aside class="tria-cf-sidebar">
              <div class="tria-cfs-card">
                <div class="tria-cfs-card-icon">
                  <i class="ti ti-message-2"></i>
                </div>
                <h4 class="tria-cfs-card-title" data-i18n="contact.sidebar.direct">{t("contact.sidebar.direct")}</h4>
                <a href="mailto:hola@triacr.com" class="tria-cfs-link">
                  <i class="ti ti-mail"></i>
                  {t("footer.contactLink")}
                </a>
                <a href="mailto:support@triacr.com" class="tria-cfs-link">
                  <i class="ti ti-headset"></i>
                  {t("footer.supportLink")}
                </a>
                <a href="mailto:sales@triacr.com" class="tria-cfs-link">
                  <i class="ti ti-briefcase"></i>
                  {t("footer.salesLink")}
                </a>
                <a href="https://wa.me/50662164040" class="tria-cfs-link" target="_blank" rel="noopener noreferrer">
                  <i class="ti ti-brand-whatsapp"></i>
                  {t("contact.sidebar.whatsapp")}
                </a>
              </div>
              <div class="tria-cfs-card">
                <div class="tria-cfs-card-icon">
                  <i class="ti ti-clock"></i>
                </div>
                <h4 class="tria-cfs-card-title" data-i18n="contact.sidebar.response">{t("contact.sidebar.response")}</h4>
                <p class="tria-cfs-card-desc" data-i18n="contact.sidebar.responseDesc">{t("contact.sidebar.responseDesc")}</p>
                <div class="tria-cfs-availability">
                  <span class="tria-cfs-dot"></span>
                  <span data-i18n="contact.info.availability">{t("contact.info.availability")}</span>
                </div>
              </div>
              <!-- Location -->
              <div class="tria-cfs-card">
                <div class="tria-cfs-card-icon">
                  <i class="ti ti-map-pin"></i>
                </div>
                <h4 class="tria-cfs-card-label-sm" data-i18n="contact.info.location">{t("contact.info.location")}</h4>
                <p class="tria-cfs-card-value-sm" set:html={t("contact.info.locationValue")} />
              </div>
            </aside>
          </div> <!-- /col-lg-5 -->
        </div> <!-- /row tria-cf-main-row -->

      <div class="tria-cf-success" id="triaFormSuccess" style="display:none;">
        <div class="tria-cfs-icon"><i class="ti ti-check"></i></div>
        <h4 data-i18n="contact.form.success.title">{t("contact.form.success.title")}</h4>
        <p data-i18n="contact.form.success.text">{t("contact.form.success.text")}</p>
      </div>
    </div>
  </section>





  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════
     FORM SECTION — White, frameless
     ═══════════════════════════════════════ */
  .tria-cf-section {
    background: #fff;
    position: relative;
  }  .tria-cf-section .tria-suptitle-dark::before {
    background-color: rgba(0,0,0,0.1);
  }

  .tria-cf-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 450;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #0b0d17;
    margin-top: 20px;
  }
  .tria-cf-heading .tria-thin {
    color: rgba(0,0,0,0.18);
    font-weight: 200;
  }

  .tria-cf-hero-desc {
    font-size: 0.95rem;
    color: rgba(0,0,0,0.4);
    max-width: 520px;
    margin: 16px 0 0;
    line-height: 1.7;
  }

  .tria-cf-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(0,0,0,0.05) 20%, rgba(0,0,0,0.05) 80%, transparent);
    margin: 48px 0 40px;
  }

  .tria-cf-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .tria-cf-main-row {
    position: relative;
  }

  .tria-cf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .tria-cf-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-cf-label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    font-weight: 500;
  }

  .tria-cf-input {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 60px;
    height: 50px;
    padding: 0 24px;
    font-size: 0.88rem;
    font-weight: 380;
    color: #0b0d17;
    background: #f5f7f9;
    font-family: 'Outfit', sans-serif;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    letter-spacing: 0.01em;
  }
  .tria-cf-input::placeholder {
    color: rgba(0,0,0,0.2);
    font-weight: 380;
  }
  .tria-cf-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 6px rgba(6,142,140,0.06), inset 0 0 0 1px rgba(6,142,140,0.05);
    background: #fff;
  }
  .tria-cf-input:not(:placeholder-shown) {
    background: #fff;
  }

  .tria-cf-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.65;
    padding: 16px 24px !important;
    border-radius: 24px !important;
  }

  /* ═══════════════════════════════════════
     CUSTOM DROPDOWN — replaces native select
     ═══════════════════════════════════════ */
  .tria-dd {
    position: relative;
    width: 100%;
  }
  .tria-dd-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 50px;
    padding: 0 24px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 60px;
    background: #f5f7f9;
    font-family: 'Outfit', sans-serif;
    font-size: 0.88rem;
    font-weight: 380;
    color: rgba(0,0,0,0.2);
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    text-align: left;
  }
  .tria-dd-trigger:hover {
    border-color: rgba(0,0,0,0.12);
  }
  .tria-dd--open .tria-dd-trigger,
  .tria-dd-trigger:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 0 0 6px rgba(6,142,140,0.06), inset 0 0 0 1px rgba(6,142,140,0.05);
    background: #fff;
  }
  .tria-dd-chevron {
    flex-shrink: 0;
    color: rgba(0,0,0,0.2);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.3s ease;
  }
  .tria-dd--open .tria-dd-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }
  .tria-dd-label {
    transition: color 0.3s ease;
  }
  .tria-dd-label--filled {
    color: #0b0d17;
    font-weight: 420;
  }

  /* ── Dropdown menu ── */
  .tria-dd-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 50;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 6px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0.3s;
  }
  .tria-dd--open .tria-dd-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-dd-option {
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .tria-dd-option:hover {
    background: #f5f7f9;
  }
  .tria-dd-option--selected {
    background: rgba(6,142,140,0.06);
  }
  .tria-dd-option--selected:hover {
    background: rgba(6,142,140,0.10);
  }

  .tria-dd-opt-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .tria-dd-opt-label {
    font-size: 0.85rem;
    font-weight: 480;
    color: #0b0d17;
    letter-spacing: -0.01em;
  }
  .tria-dd-opt-check {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.04);
    color: transparent;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-dd-option--selected .tria-dd-opt-check {
    background: var(--accent);
    color: #fff;
  }

  .tria-dd-opt-desc {
    display: block;
    font-size: 0.7rem;
    color: rgba(0,0,0,0.3);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }
  .tria-dd-option--selected .tria-dd-opt-desc {
    color: rgba(6,142,140,0.6);
  }

  .tria-dd-divider {
    height: 1px;
    background: rgba(0,0,0,0.04);
    margin: 4px 14px;
  }

  /* ═══════════════════════════════════════
     SIDEBAR — right column content
     ═══════════════════════════════════════ */
  .tria-cf-sidebar {
    padding-left: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tria-cfs-card {
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 20px;
    padding: 28px 26px;
    background: #fff;
  }

  .tria-cfs-card-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    background: rgba(6,142,140,0.07);
    color: var(--accent);
  }

  .tria-cfs-card-title {
    font-size: 0.78rem;
    font-weight: 520;
    color: #0b0d17;
    margin: 0 0 12px;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .tria-cfs-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: rgba(0,0,0,0.55);
    text-decoration: none;
    padding: 6px 0;
  }
  .tria-cfs-link .ti {
    flex-shrink: 0;
