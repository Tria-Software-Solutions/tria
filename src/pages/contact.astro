---
import Layout from '../layouts/Layout.astro';
import { getTranslations, type Translations } from '../lib/i18n/index';

const translations: Translations = getTranslations();
---

<Layout title="Contact" translations={translations}>
<div class="mil-inner-banner mil-p-0-120">
					<div class="mil-banner-content mil-center mil-up">
						<div class="container">
							<ul class="mil-breadcrumbs mil-center mil-mb-60">
								<li><a href="/">{translations.navigation.home}</a></li>
								<li><a href="/contact">{translations.navigation.contact}</a></li>
							</ul>
							<h1 class="mil-mb-60">Get in touch!</h1>
							<a href="#contact" class="mil-link mil-dark mil-arrow-place mil-down-arrow"><span>Send message</span></a>
						</div>
					</div>
				</div>
				<div class="mil-map-frame mil-up">
					<div class="mil-map">
						<iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1396.5769090312324!2d-73.6519672!3d45.5673453!3m2!1i1024!2i768!4f13.1!3m3!1m2!1sen!2sua!4v1685485811069!5m2!1sen!2sua" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
					</div>
				</div>
				<section id="contact">
					<div class="container mil-p-120-90">
						<h3 class="mil-center mil-up mil-mb-120">Let's <span class="mil-thin">Talk</span></h3>
						<form id="contactForm" class="row align-items-center">
							<div class="col-lg-6 mil-up">
								<input type="text" id="name" name="name" placeholder="What's your name" required>
							</div>
							<div class="col-lg-6 mil-up">
								<input type="email" id="email" name="email" placeholder="Your Email" required>
							</div>
							<div class="col-lg-12 mil-up">
								<textarea id="message" name="message" placeholder="Tell us about your project" required></textarea>
							</div>
							<div class="col-lg-8 mil-up">
								<p class="mil-up mil-mb-30"><span class="mil-accent">*</span> We promise not to disclose your personal information to third parties.</p>
							</div>
							<div class="col-lg-4 mil-up">
								<div class="mil-adaptive-right mil-up mil-mb-30">
									<button type="submit" class="mil-button mil-arrow-place"><span>Send message</span></button>
								</div>
							</div>
						</form>
						<div id="formResponse" style="margin-top: 20px;"></div>
					</div>
				</section>
</Layout>
