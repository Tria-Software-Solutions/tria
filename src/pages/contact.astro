    .tria-cfs-link { font-size: 0.75rem; }
    .tria-cfs-card-value-sm { font-size: 0.78rem; }
  }
</style>

<script is:inline>
  (function () {
    var SENDING_TEXT = "{sendingText}";

    /* ── Custom Dropdown ── */
    function initDropdown() {
      var dd = document.getElementById('cf-budget-dd');
      if (!dd) return;

      var trigger = dd.querySelector('.tria-dd-trigger');
      var menu = dd.querySelector('.tria-dd-menu');
      var options = dd.querySelectorAll('.tria-dd-option');
      var hiddenInput = document.getElementById('cf-budget');
      var label = dd.querySelector('.tria-dd-label');

      function closeAll() {
        document.querySelectorAll('.tria-dd--open').forEach(function (d) {
          d.classList.remove('tria-dd--open');
        });
      }

      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = dd.classList.contains('tria-dd--open');
        closeAll();
        if (!isOpen) {
          dd.classList.add('tria-dd--open');
        }
      });

      options.forEach(function (opt) {
        opt.addEventListener('click', function (e) {
          e.stopPropagation();
          var value = opt.getAttribute('data-value');
          var optLabel = opt.querySelector('.tria-dd-opt-label').textContent;
          hiddenInput.value = value;
          label.textContent = optLabel;
          label.classList.add('tria-dd-label--filled');
          dd.classList.remove('tria-dd--open');

          options.forEach(function (o) { o.classList.remove('tria-dd-option--selected'); });
          opt.classList.add('tria-dd-option--selected');
        });
      });

      document.addEventListener('click', closeAll);
    }

    /* ── Multi-select Services Dropdown ── */
    function initServicesDropdown() {
      var dd = document.getElementById('cf-services-dd');
      if (!dd) return;

      var trigger = dd.querySelector('.tria-svdd-trigger');
      var menu = dd.querySelector('.tria-svdd-menu');
      var options = dd.querySelectorAll('.tria-svdd-option');
      var hiddenInput = document.getElementById('cf-services');
      var label = dd.querySelector('.tria-svdd-label');
      var countEl = dd.querySelector('.tria-svdd-count');
      var selected = new Set();

      function updateLabel() {
        var count = selected.size;
        if (count === 0) {
          label.style.display = '';
          countEl.textContent = '';
        } else {
          label.style.display = 'none';
          countEl.textContent = count + ' selected';
          countEl.style.display = '';
        }
        hiddenInput.value = Array.from(selected).join(',');
      }

      function closeAll() {
        document.querySelectorAll('.tria-svdd--open').forEach(function (d) {
          d.classList.remove('tria-svdd--open');
        });
      }

      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = dd.classList.contains('tria-svdd--open');
        closeAll();
        if (!isOpen) {
          dd.classList.add('tria-svdd--open');
        }
      });

      options.forEach(function (opt) {
        opt.addEventListener('click', function (e) {
          e.stopPropagation();
          var value = opt.getAttribute('data-value');
          if (selected.has(value)) {
            selected.delete(value);
            opt.classList.remove('tria-svdd-option--selected');
          } else {
            selected.add(value);
            opt.classList.add('tria-svdd-option--selected');
          }
          updateLabel();
        });
      });

      document.addEventListener('click', closeAll);
    }

    function getServices() {
      var input = document.getElementById('cf-services');
      if (!input || !input.value) return [];
      return input.value.split(',').filter(Boolean);
    }

    function initForm() {
      var form = document.getElementById('triaContactForm');
      var success = document.getElementById('triaFormSuccess');
      if (!form) return;

      form.addEventListener('submit', function (e) {
        e.preventDefault();

        var btn = document.getElementById('cf-submit-btn');
        if (btn) {
          btn.disabled = true;
          var btnSpan = btn.querySelector('span');
          if (btnSpan) btnSpan.textContent = SENDING_TEXT;
        }

        var data = {
          name: document.getElementById('cf-name').value,
          email: document.getElementById('cf-email').value,
          company: document.getElementById('cf-company').value,
          budget: document.getElementById('cf-budget').value,
          services: getServices(),
          message: document.getElementById('cf-message').value,
        };

        fetch('/api/create-jira-ticket', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })
          .then(function (res) { return res.json(); })
          .then(function (result) {
            if (result.success) {
              form.style.display = 'none';
              if (success) success.style.display = 'block';
            } else {
              throw new Error(result.error || 'Unknown error');
            }
          })
          .catch(function (err) {
            console.error('Jira ticket creation failed:', err);
            // fallback: show success anyway so the user isn't left hanging
            form.style.display = 'none';
            if (success) success.style.display = 'block';
          });
      });
    }

    function init() {
      initDropdown();
      initServicesDropdown();
      initForm();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('swup:contentReplaced', init);
  })();
</script>
