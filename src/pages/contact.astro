---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Button from "../components/Button.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
const sendingText = t('contact.form.sending');
---

<Layout title="Tria — Software Solutions" description="Start a project with tria. Get in touch with our team to discuss your software needs.">

  <PageBanner suptitleKey="contact.getInTouch" headingKey="contact.letsBuild" descriptionKey="contact.heroSub" />

  <!-- contact form - white, frameless -->
  <section class="tria-cf-section" data-section-theme="light" style="position:relative;">
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row">
        <div class="col-lg-7">
          <span class="tria-suptitle tria-up" data-i18n="contact.suptitle">{t("contact.suptitle")}</span>
          <h2 class="tria-up tria-cf-heading" data-i18n-html="contact.heading" set:html={t("contact.heading")} />
          <p class="tria-cf-hero-desc tria-up" data-i18n="contact.heroSub">{t("contact.heroSub")}</p>
        </div>
      </div>

      <div class="tria-cf-divider tria-up"></div>

      <div class="row tria-cf-main-row">
        <div class="col-lg-7">
          <form class="tria-cf-form tria-up" id="triaContactForm">
            <div class="tria-cf-row">
              <div class="tria-cf-group">
                <label class="tria-cf-label" for="cf-name" data-i18n="contact.form.label.name">{t("contact.form.label.name")}</label>
                <input class="tria-cf-input" type="text" id="cf-name" name="name" data-i18n-placeholder="contact.form.placeholder.name" placeholder={t("contact.form.placeholder.name")} required />
              </div>
              <div class="tria-cf-group">
                <label class="tria-cf-label" for="cf-email" data-i18n="contact.form.label.email">{t("contact.form.label.email")}</label>
                <input class="tria-cf-input" type="email" id="cf-email" name="email" data-i18n-placeholder="contact.form.placeholder.email" placeholder={t("contact.form.placeholder.email")} required />
              </div>
            </div>

            <div class="tria-cf-row">
              <div class="tria-cf-group">
                <label class="tria-cf-label" for="cf-company" data-i18n="contact.form.label.company">{t("contact.form.label.company")}</label>
                <input class="tria-cf-input" type="text" id="cf-company" name="company" data-i18n-placeholder="contact.form.placeholder.company" placeholder={t("contact.form.placeholder.company")} />
              </div>
              <div class="tria-cf-group">
                <label class="tria-cf-label" data-i18n="contact.form.label.budget">{t("contact.form.label.budget")}</label>
                <!-- Custom Dropdown -->
                <div class="tria-dd" id="cf-budget-dd">
                  <button class="tria-dd-trigger" type="button">
                    <span class="tria-dd-label" data-i18n="contact.form.placeholder.budget">{t("contact.form.placeholder.budget")}</span>
                    <svg class="tria-dd-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </button>
                  <div class="tria-dd-menu">
                    <div class="tria-dd-option" data-value="under-10k" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.under10k">{t("contact.form.option.under10k")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.under10k">{t("contact.form.dropdown.under10k")}</span>
                    </div>
                    <div class="tria-dd-option" data-value="10k-50k" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.10k50k">{t("contact.form.option.10k50k")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.10k50k">{t("contact.form.dropdown.10k50k")}</span>
                    </div>
                    <div class="tria-dd-option" data-value="50k-150k" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.50k150k">{t("contact.form.option.50k150k")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.50k150k">{t("contact.form.dropdown.50k150k")}</span>
                    </div>
                    <div class="tria-dd-option" data-value="150k-plus" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.150kPlus">{t("contact.form.option.150kPlus")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.150kPlus">{t("contact.form.dropdown.150kPlus")}</span>
                    </div>
                    <div class="tria-dd-divider"></div>
                    <div class="tria-dd-option" data-value="tbd" role="option">
                      <div class="tria-dd-opt-main">
                        <span class="tria-dd-opt-label" data-i18n="contact.form.option.tbd">{t("contact.form.option.tbd")}</span>
                        <span class="tria-dd-opt-check">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      </div>
                      <span class="tria-dd-opt-desc" data-i18n="contact.form.dropdown.tbd">{t("contact.form.dropdown.tbd")}</span>
                    </div>
                  </div>
                </div>
                <input type="hidden" id="cf-budget" name="budget" value="" />
              </div>
            </div>

        <div class="tria-cf-group">
          <label class="tria-cf-label" data-i18n="contact.form.label.services">{t("contact.form.label.services")}</label>
          <div class="tria-cf-chips">
            <label class="tria-cf-chip">
              <input type="checkbox" name="services" value="software" />
              <span data-i18n="contact.form.chip.software">{t("contact.form.chip.software")}</span>
            </label>
            <label class="tria-cf-chip">
              <input type="checkbox" name="services" value="cloud" />
              <span data-i18n="contact.form.chip.cloud">{t("contact.form.chip.cloud")}</span>
            </label>
            <label class="tria-cf-chip">
              <input type="checkbox" name="services" value="ai" />
              <span data-i18n="contact.form.chip.ai">{t("contact.form.chip.ai")}</span>
            </label>
            <label class="tria-cf-chip">
              <input type="checkbox" name="services" value="security" />
              <span data-i18n="contact.form.chip.security">{t("contact.form.chip.security")}</span>
            </label>
            <label class="tria-cf-chip">
              <input type="checkbox" name="services" value="advisory" />
              <span data-i18n="contact.form.chip.advisory">{t("contact.form.chip.advisory")}</span>
            </label>
          </div>
        </div>

        <div class="tria-cf-group">
          <label class="tria-cf-label" for="cf-message" data-i18n="contact.form.label.message">{t("contact.form.label.message")}</label>
          <textarea class="tria-cf-input tria-cf-textarea" id="cf-message" name="message" data-i18n-placeholder="contact.form.placeholder.message" placeholder={t("contact.form.placeholder.message")} rows="6" required></textarea>
        </div>

        <Button text={t("contact.form.submit")} showArrow={true} fullWidth={true} id="cf-submit-btn" type="submit" />

        <p class="tria-cf-note" data-i18n="contact.form.note">{t("contact.form.note")}</p>
      </form>
          </div> <!-- /col-lg-7 -->
          <div class="col-lg-5">
            <aside class="tria-cf-sidebar">
              <div class="tria-cfs-card">
                <div class="tria-cfs-card-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <h4 class="tria-cfs-card-title" data-i18n="contact.sidebar.direct">{t("contact.sidebar.direct")}</h4>
                <a href="mailto:hola@triacr.com" class="tria-cfs-link">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4l-10 8L2 4"/></svg>
                  hola@triacr.com
                </a>
                <a href="tel:+50662164040" class="tria-cfs-link">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  +506 6216 4040
                </a>
              </div>
              <div class="tria-cfs-card">
                <div class="tria-cfs-card-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                </div>
                <h4 class="tria-cfs-card-title" data-i18n="contact.sidebar.response">{t("contact.sidebar.response")}</h4>
                <p class="tria-cfs-card-desc" data-i18n="contact.sidebar.responseDesc">{t("contact.sidebar.responseDesc")}</p>
                <div class="tria-cfs-availability">
                  <span class="tria-cfs-dot"></span>
                  <span data-i18n="contact.info.availability">{t("contact.info.availability")}</span>
                </div>
              </div>
              <!-- Location -->
              <div class="tria-cfs-card">
                <div class="tria-cfs-card-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h4 class="tria-cfs-card-label-sm" data-i18n="contact.info.location">{t("contact.info.location")}</h4>
                <p class="tria-cfs-card-value-sm" set:html={t("contact.info.locationValue")} />
              </div>
            </aside>
          </div> <!-- /col-lg-5 -->
        </div> <!-- /row tria-cf-main-row -->

      <div class="tria-cf-success" id="triaFormSuccess" style="display:none;">
        <div class="tria-cfs-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg></div>
        <h4 data-i18n="contact.form.success.title">{t("contact.form.success.title")}</h4>
        <p data-i18n="contact.form.success.text">{t("contact.form.success.text")}</p>
      </div>
    </div>
  </section>





  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════
     FORM SECTION — White, frameless
     ═══════════════════════════════════════ */
  .tria-cf-section {
    background: #fff;
    position: relative;
  }
  .tria-cf-section .tria-suptitle::before {
    background-color: rgba(0,0,0,0.1);
  }
  .tria-cf-section .tria-suptitle {
    color: rgba(0,0,0,0.4);
  }

  .tria-cf-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 450;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #0b0d17;
    margin-top: 20px;
  }
  .tria-cf-heading .tria-thin {
    color: rgba(0,0,0,0.18);
    font-weight: 200;
  }

  .tria-cf-hero-desc {
    font-size: 0.95rem;
    color: rgba(0,0,0,0.4);
    max-width: 520px;
    margin: 16px 0 0;
    line-height: 1.7;
  }

  .tria-cf-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(0,0,0,0.05) 20%, rgba(0,0,0,0.05) 80%, transparent);
    margin: 48px 0 40px;
  }

  .tria-cf-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .tria-cf-main-row {
    position: relative;
  }

  .tria-cf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .tria-cf-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tria-cf-label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    font-weight: 500;
  }

  .tria-cf-input {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 60px;
    height: 50px;
    padding: 0 24px;
    font-size: 0.88rem;
    font-weight: 380;
    color: #0b0d17;
    background: #f5f7f9;
    font-family: 'Outfit', sans-serif;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    letter-spacing: 0.01em;
  }
  .tria-cf-input::placeholder {
    color: rgba(0,0,0,0.2);
    font-weight: 380;
  }
  .tria-cf-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 6px rgba(6,142,140,0.06), inset 0 0 0 1px rgba(6,142,140,0.05);
    background: #fff;
  }
  .tria-cf-input:not(:placeholder-shown) {
    background: #fff;
  }

  .tria-cf-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.65;
    padding: 16px 24px !important;
    border-radius: 24px !important;
  }

  /* ═══════════════════════════════════════
     CUSTOM DROPDOWN — replaces native select
     ═══════════════════════════════════════ */
  .tria-dd {
    position: relative;
    width: 100%;
  }
  .tria-dd-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 50px;
    padding: 0 24px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 60px;
    background: #f5f7f9;
    font-family: 'Outfit', sans-serif;
    font-size: 0.88rem;
    font-weight: 380;
    color: rgba(0,0,0,0.2);
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    text-align: left;
  }
  .tria-dd-trigger:hover {
    border-color: rgba(0,0,0,0.12);
  }
  .tria-dd--open .tria-dd-trigger,
  .tria-dd-trigger:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 0 0 6px rgba(6,142,140,0.06), inset 0 0 0 1px rgba(6,142,140,0.05);
    background: #fff;
  }
  .tria-dd-chevron {
    flex-shrink: 0;
    color: rgba(0,0,0,0.2);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.3s ease;
  }
  .tria-dd--open .tria-dd-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }
  .tria-dd-label {
    transition: color 0.3s ease;
  }
  .tria-dd-label--filled {
    color: #0b0d17;
    font-weight: 420;
  }

  /* ── Dropdown menu ── */
  .tria-dd-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 50;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 6px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0.3s;
  }
  .tria-dd--open .tria-dd-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-dd-option {
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .tria-dd-option:hover {
    background: #f5f7f9;
  }
  .tria-dd-option--selected {
    background: rgba(6,142,140,0.06);
  }
  .tria-dd-option--selected:hover {
    background: rgba(6,142,140,0.10);
  }

  .tria-dd-opt-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .tria-dd-opt-label {
    font-size: 0.85rem;
    font-weight: 480;
    color: #0b0d17;
    letter-spacing: -0.01em;
  }
  .tria-dd-opt-check {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.04);
    color: transparent;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-dd-option--selected .tria-dd-opt-check {
    background: var(--accent);
    color: #fff;
  }

  .tria-dd-opt-desc {
    display: block;
    font-size: 0.7rem;
    color: rgba(0,0,0,0.3);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }
  .tria-dd-option--selected .tria-dd-opt-desc {
    color: rgba(6,142,140,0.6);
  }

  .tria-dd-divider {
    height: 1px;
    background: rgba(0,0,0,0.04);
    margin: 4px 14px;
  }

  /* ═══════════════════════════════════════
     SIDEBAR — right column content
     ═══════════════════════════════════════ */
  .tria-cf-sidebar {
    padding-left: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tria-cfs-card {
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 20px;
    padding: 28px 26px;
    background: #fff;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-cfs-card:hover {
    border-color: rgba(6,142,140,0.12);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.04);
  }

  .tria-cfs-card-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    background: rgba(6,142,140,0.07);
    color: var(--accent);
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-cfs-card:hover .tria-cfs-card-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-2px);
  }

  .tria-cfs-card-title {
    font-size: 0.78rem;
    font-weight: 520;
    color: #0b0d17;
    margin: 0 0 12px;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .tria-cfs-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: rgba(0,0,0,0.55);
    text-decoration: none;
    padding: 6px 0;
    transition: color 0.3s ease, gap 0.3s ease;
  }
  .tria-cfs-link:hover {
    color: var(--accent);
    gap: 14px;
  }
  .tria-cfs-link svg {
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }
  .tria-cfs-link:hover svg {
    opacity: 1;
  }

