---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — tria">
  <section style="min-height:100vh;padding:160px 0 100px;">
    <div class="container">
      <p class="section-label">Get in touch</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(3rem,7vw,7rem);font-weight:300;">
        Let's build<br><em style="font-style:italic;color:var(--color-accent);">together</em>
      </h1>
      <div style="margin-top:60px;display:grid;grid-template-columns:1fr 1fr;gap:80px;max-width:900px;">
        <div>
          <p style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:8px;">Location</p>
          <p style="font-size:.9rem;line-height:1.8;color:#555;">Atenas, Alajuela<br>Costa Rica 20501</p>
        </div>
        <div>
          <p style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:8px;">Contact</p>
          <p style="font-size:.9rem;line-height:1.8;color:#555;">
            <a href="mailto:hola@triacr.com" style="color:#555;text-decoration:none;">hola@triacr.com</a><br>
            <a href="mailto:contacto@triacr.com" style="color:#555;text-decoration:none;">contacto@triacr.com</a><br>
            <a href="https://wa.me/50662164040" target="_blank" rel="noopener noreferrer" style="color:#555;text-decoration:none;">+506 6216 4040</a>
          </p>
        </div>
      </div>
        <div>
          <p style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:8px;">Email</p>
          <p style="font-size:.9rem;line-height:1.8;color:#555;">hola@triacr.com</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
