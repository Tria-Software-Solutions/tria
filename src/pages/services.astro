---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import CTA from "../components/CTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.url);
---

<Layout title="Tria — Software Solutions" description="Enterprise software services: Software Development, Cloud & DevOps, AI/ML, and Cybersecurity consulting.">

  <PageBanner suptitleKey="services.hero.suptitle" headingKey="services.hero.title" descriptionKey="services.hero.desc" />

  <!-- main services list -->
  <section data-section-theme="light" style="background:#faf7f2;">
    <div class="container tria-p-120-0">
      <div class="tria-services-list">

        <div class="tria-service-row tria-up" id="software-dev">
          <div class="tria-sr-num">01</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title" data-i18n-html="services.softwareDev" set:html={t("services.softwareDev")} />
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc" data-i18n="services.desc1">{t("services.desc1")}</p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li data-i18n="services.feature1">{t("services.feature1")}</li>
                  <li data-i18n="services.feature2">{t("services.feature2")}</li>
                  <li data-i18n="services.feature3">{t("services.feature3")}</li>
                  <li data-i18n="services.feature4">{t("services.feature4")}</li>
                  <li data-i18n="services.feature5">{t("services.feature5")}</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags" data-i18n="services.tech1">{t("services.tech1")}</div>
            </div>
          </div>
        </div>

        <div class="tria-service-row tria-up" id="cloud-devops">
          <div class="tria-sr-num">02</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title" data-i18n-html="services.cloudDevops" set:html={t("services.cloudDevops")} />
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc" data-i18n="services.desc2">{t("services.desc2")}</p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li data-i18n="services.feature6">{t("services.feature6")}</li>
                  <li data-i18n="services.feature7">{t("services.feature7")}</li>
                  <li data-i18n="services.feature8">{t("services.feature8")}</li>
                  <li data-i18n="services.feature9">{t("services.feature9")}</li>
                  <li data-i18n="services.feature10">{t("services.feature10")}</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags" data-i18n="services.tech2">{t("services.tech2")}</div>
            </div>
          </div>
        </div>

        <div class="tria-service-row tria-up" id="ai-ml">
          <div class="tria-sr-num">03</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title" data-i18n-html="services.aiMl" set:html={t("services.aiMl")} />
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc" data-i18n="services.desc3">{t("services.desc3")}</p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li data-i18n="services.feature11">{t("services.feature11")}</li>
                  <li data-i18n="services.feature12">{t("services.feature12")}</li>
                  <li data-i18n="services.feature13">{t("services.feature13")}</li>
                  <li data-i18n="services.feature14">{t("services.feature14")}</li>
                  <li data-i18n="services.feature15">{t("services.feature15")}</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags" data-i18n="services.tech3">{t("services.tech3")}</div>
            </div>
          </div>
        </div>

        <div class="tria-service-row tria-up" id="cybersecurity">
          <div class="tria-sr-num">04</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title" data-i18n-html="services.cybersecurity" set:html={t("services.cybersecurity")} />
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc" data-i18n="services.desc4">{t("services.desc4")}</p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li data-i18n="services.feature16">{t("services.feature16")}</li>
                  <li data-i18n="services.feature17">{t("services.feature17")}</li>
                  <li data-i18n="services.feature18">{t("services.feature18")}</li>
                  <li data-i18n="services.feature19">{t("services.feature19")}</li>
                  <li data-i18n="services.feature20">{t("services.feature20")}</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags" data-i18n="services.tech4">{t("services.tech4")}</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- engagement models -->
  <section class="tria-soft-bg" data-section-theme="light">
    <div class="container tria-p-120-120">
      <div class="row tria-mb-60">
        <div class="col-lg-6">
          <span class="tria-suptitle tria-suptitle-dark tria-up" data-i18n="services.engagement.suptitle">{t("services.engagement.suptitle")}</span>
          <h2 class="tria-up" style="margin-top:20px;" data-i18n-html="services.engagement.title" set:html={t("services.engagement.title")} />
        </div>
      </div>
      <div class="row tria-engagement-grid">
        <div class="col-md-4 tria-up">
          <div class="tria-engagement-card">
            <div class="tria-ec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg></div>
            <h4 class="tria-ec-title" data-i18n="services.engagement.projectBased">{t("services.engagement.projectBased")}</h4>
            <p class="tria-ec-desc" data-i18n="services.engagement.projectBasedDesc">{t("services.engagement.projectBasedDesc")}</p>
            <ul class="tria-ec-list">
              <li data-i18n="services.engagement.projectBased1">{t("services.engagement.projectBased1")}</li>
              <li data-i18n="services.engagement.projectBased2">{t("services.engagement.projectBased2")}</li>
              <li data-i18n="services.engagement.projectBased3">{t("services.engagement.projectBased3")}</li>
            </ul>
          </div>
        </div>
        <div class="col-md-4 tria-up">
          <div class="tria-engagement-card tria-engagement-card--featured">
            <div class="tria-ec-badge" data-i18n="services.engagement.mostPopular">{t("services.engagement.mostPopular")}</div>
            <div class="tria-ec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
            <h4 class="tria-ec-title" data-i18n="services.engagement.dedicatedTeam">{t("services.engagement.dedicatedTeam")}</h4>
            <p class="tria-ec-desc" data-i18n="services.engagement.dedicatedTeamDesc">{t("services.engagement.dedicatedTeamDesc")}</p>
            <ul class="tria-ec-list">
              <li data-i18n="services.engagement.dedicatedTeam1">{t("services.engagement.dedicatedTeam1")}</li>
              <li data-i18n="services.engagement.dedicatedTeam2">{t("services.engagement.dedicatedTeam2")}</li>
              <li data-i18n="services.engagement.dedicatedTeam3">{t("services.engagement.dedicatedTeam3")}</li>
            </ul>
          </div>
        </div>
        <div class="col-md-4 tria-up">
          <div class="tria-engagement-card">
            <div class="tria-ec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg></div>
            <h4 class="tria-ec-title" data-i18n="services.engagement.advisory">{t("services.engagement.advisory")}</h4>
            <p class="tria-ec-desc" data-i18n="services.engagement.advisoryDesc">{t("services.engagement.advisoryDesc")}</p>
            <ul class="tria-ec-list">
              <li data-i18n="services.engagement.advisory1">{t("services.engagement.advisory1")}</li>
              <li data-i18n="services.engagement.advisory2">{t("services.engagement.advisory2")}</li>
              <li data-i18n="services.engagement.advisory3">{t("services.engagement.advisory3")}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA 
    heading={t("cta.heading") || ""}
    description={t("cta.description") || "From concept to deployment, we build software that scales."}
    primaryButtonText={t("cta.startProject") || ""}
    secondaryButtonText={t("cta.seeWork") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />
  <SiteFooter />
</Layout>

<style>
  .tria-sh-right {
    display: flex;
    align-items: flex-end;
    padding-bottom: 12px;
  }

  .tria-services-list {
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .tria-service-row {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 0 40px;
    padding: 60px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    position: relative;
  }
  .tria-service-row::before {
    content: '';
    position: absolute;
    inset: 8px -16px;
    background: transparent;
    border-radius: 16px;
    transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  .tria-service-row:hover::before {
    background: rgba(6,142,140,0.04);
  }
  .tria-service-row > * {
    position: relative;
    z-index: 1;
  }
  .tria-sr-num {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: 0.9rem;
    color: rgba(0,0,0,0.15);
    padding-top: 8px;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    letter-spacing: 0.05em;
  }
  .tria-service-row:hover .tria-sr-num {
    color: var(--accent);
  }
  .tria-sr-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 20px;
  }
  .tria-sr-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 400;
    line-height: 1.15;
    margin: 0;
    color: #0b0d17;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-service-row:hover .tria-sr-title {
    color: var(--accent);
  }
  .tria-sr-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(6,142,140,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 20px;
    flex-shrink: 0;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-service-row:hover .tria-sr-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px) scale(1.05);
  }
  .tria-sr-desc {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.8;
    margin: 0;
  }
  .tria-sr-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tria-sr-features li {
    font-size: 0.82rem;
    color: #444;
    padding-left: 20px;
    position: relative;
    transition: color 0.3s ease;
  }
  .tria-service-row:hover .tria-sr-features li {
    color: #0b0d17;
  }
  .tria-sr-features li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
  }
  .tria-sr-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 40px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .tria-sr-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tria-sr-tags span {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 20px;
    color: rgba(0,0,0,0.35);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-service-row:hover .tria-sr-tags span {
    border-color: rgba(6,142,140,0.2);
    color: var(--accent);
  }

  .tria-sr-cta {
    font-size: 0.75rem !important;
  }

  /* ── Engagement cards ── */
  .tria-engagement-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 44px 36px;
    height: 100%;
    position: relative;
    background: #fff;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-engagement-card:hover {
    border-color: rgba(6,142,140,0.2);
    transform: translateY(-6px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.06);
  }
  .tria-engagement-card--featured {
    border-color: var(--accent);
    background: #0b0d17;
  }
  .tria-engagement-card--featured .tria-ec-title,
  .tria-engagement-card--featured .tria-ec-desc,
  .tria-engagement-card--featured .tria-ec-list li {
    color: rgba(255,255,255,0.85) !important;
  }
  .tria-engagement-card--featured:hover {
    border-color: var(--accent);
    box-shadow: 0 24px 64px rgba(6,142,140,0.15);
  }
  .tria-ec-badge {
    position: absolute;
    top: -12px;
    left: 36px;
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 5px 14px;
    border-radius: 20px;
    font-weight: 500;
  }
  .tria-ec-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(6,142,140,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 20px;
    margin-bottom: 24px;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tria-engagement-card--featured .tria-ec-icon {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
  }
  .tria-engagement-card:hover .tria-ec-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }
  .tria-ec-title {
    font-size: 1.15rem;
    font-weight: 400;
    margin-bottom: 16px;
    color: #0b0d17;
  }
  .tria-ec-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.75;
    margin-bottom: 24px;
  }
  .tria-ec-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tria-ec-list li {
    font-size: 0.78rem;
    color: #555;
    padding-left: 18px;
    position: relative;
  }
  .tria-ec-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
  }
  .tria-engagement-card--featured .tria-ec-list li::before {
    color: rgba(255,255,255,0.35);
  }

  @media (max-width: 991px) {
    .tria-service-row {
      grid-template-columns: 50px 1fr;
      gap: 0 20px;
      padding: 50px 0;
    }
    .tria-sr-header { flex-direction: column; gap: 16px; }
  }
  @media (max-width: 768px) {
    .tria-sr-num { display: none; }
    .tria-service-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>
