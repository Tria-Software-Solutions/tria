---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Services — tria">
  <section style="min-height:100vh;padding:160px 0 100px;background:var(--color-dark);color:var(--color-light);">
    <div class="container">
      <p class="section-label" style="color:rgba(255,255,255,.4);">What we do</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(3rem,7vw,7rem);font-weight:300;color:var(--color-light);">
        Our<br><em style="font-style:italic;color:var(--color-accent);">Services</em>
      </h1>
    </div>
  </section>
</Layout>
