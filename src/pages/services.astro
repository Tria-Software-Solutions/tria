---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Services — tria" description="Enterprise software services: Software Development, Cloud & DevOps, AI/ML, and Cybersecurity consulting.">

  <!-- hero -->
  <section class="tria-dark-bg tria-services-hero" data-section-theme="dark">
    <div class="mi-invert-fix">
      <div class="tria-sh-bg">
        <div class="tria-animation-frame"></div>
      </div>
      <div class="container tria-sh-inner">
        <div class="row align-items-end">
          <div class="col-lg-7">
            <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:20px;">What we do</span>
            <h1 class="tria-up" style="font-size:clamp(3rem,7vw,6.5rem);font-weight:300;color:#fff;line-height:1.05;letter-spacing:-0.02em;">
              Our<br /><em style="color:rgba(255,255,255,0.35);font-style:italic;">Services</em>
            </h1>
          </div>
          <div class="col-lg-5 tria-sh-right">
            <p class="tria-up" style="color:rgba(255,255,255,0.5);font-size:0.9rem;line-height:1.8;max-width:380px;">
              From first-line code to enterprise-grade infrastructure —
              we deliver complete software solutions tailored to your business objectives.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- main services list -->
  <section data-section-theme="light">
    <div class="container tria-p-120-0">
      <div class="tria-services-list">

        <div class="tria-service-row tria-up" id="software-dev">
          <div class="tria-sr-num">01</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title">Software <span class="tria-thin">Development</span></h2>
              <div class="tria-sr-icon">
                <i class="fas fa-code"></i>
              </div>
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc">
                  Custom web and mobile applications designed for performance, scalability, and maintainability.
                  We build with modern frameworks and proven architectures — from greenfield products to complex system migrations.
                </p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li>Web & Mobile Applications</li>
                  <li>API Design & Development</li>
                  <li>Microservices Architecture</li>
                  <li>Legacy System Modernization</li>
                  <li>Real-time Systems</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags">
                <span>React</span><span>Next.js</span><span>Node.js</span><span>Go</span><span>TypeScript</span>
              </div>
              <a href="/contact" class="tria-button tria-arrow-place tria-sr-cta">
                <span>Get a quote</span>
              </a>
            </div>
          </div>
        </div>

        <div class="tria-service-row tria-up" id="cloud-devops">
          <div class="tria-sr-num">02</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title">Cloud &amp; <span class="tria-thin">DevOps</span></h2>
              <div class="tria-sr-icon">
                <i class="fas fa-cloud"></i>
              </div>
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc">
                  Scalable cloud infrastructure designed for reliability and cost efficiency.
                  We automate everything — from provisioning to deployments — so your team moves faster with fewer incidents.
                </p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li>Cloud Architecture Design</li>
                  <li>CI/CD Pipeline Automation</li>
                  <li>Infrastructure as Code</li>
                  <li>Kubernetes Orchestration</li>
                  <li>Cost Optimization</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags">
                <span>AWS</span><span>GCP</span><span>Terraform</span><span>Kubernetes</span><span>Docker</span>
              </div>
              <a href="/contact" class="tria-button tria-arrow-place tria-sr-cta">
                <span>Get a quote</span>
              </a>
            </div>
          </div>
        </div>

        <div class="tria-service-row tria-up" id="ai-ml">
          <div class="tria-sr-num">03</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title">AI &amp; <span class="tria-thin">Machine Learning</span></h2>
              <div class="tria-sr-icon">
                <i class="fas fa-brain"></i>
              </div>
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc">
                  Intelligent systems that learn, predict, and automate. We design end-to-end ML pipelines —
                  from data engineering and model development to production deployment and monitoring.
                </p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li>Predictive Modeling</li>
                  <li>LLM Integration & Fine-tuning</li>
                  <li>Data Pipeline Engineering</li>
                  <li>Computer Vision Systems</li>
                  <li>MLOps & Model Monitoring</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags">
                <span>Python</span><span>PyTorch</span><span>LangChain</span><span>Spark</span><span>dbt</span>
              </div>
              <a href="/contact" class="tria-button tria-arrow-place tria-sr-cta">
                <span>Get a quote</span>
              </a>
            </div>
          </div>
        </div>

        <div class="tria-service-row tria-up" id="cybersecurity">
          <div class="tria-sr-num">04</div>
          <div class="tria-sr-content">
            <div class="tria-sr-header">
              <h2 class="tria-sr-title">IT &amp; <span class="tria-thin">Cybersecurity</span></h2>
              <div class="tria-sr-icon">
                <i class="fas fa-shield-alt"></i>
              </div>
            </div>
            <div class="row">
              <div class="col-lg-6">
                <p class="tria-sr-desc">
                  Proactive security consulting to protect your assets and ensure compliance.
                  We combine penetration testing, risk assessment, and strategic advisory to build a robust security posture.
                </p>
              </div>
              <div class="col-lg-5 offset-lg-1">
                <ul class="tria-sr-features">
                  <li>Security Architecture Review</li>
                  <li>Penetration Testing</li>
                  <li>HIPAA / SOC2 Compliance</li>
                  <li>Incident Response Planning</li>
                  <li>Zero Trust Implementation</li>
                </ul>
              </div>
            </div>
            <div class="tria-sr-footer">
              <div class="tria-sr-tags">
                <span>OWASP</span><span>SIEM</span><span>Zero Trust</span><span>ISO 27001</span>
              </div>
              <a href="/contact" class="tria-button tria-arrow-place tria-sr-cta">
                <span>Get a quote</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- engagement models -->
  <section class="tria-soft-bg" data-section-theme="light">
    <div class="container tria-p-120-120">
      <div class="row tria-mb-60">
        <div class="col-lg-6">
          <span class="tria-suptitle tria-suptitle-dark tria-up">Engagement</span>
          <h2 class="tria-up" style="margin-top:20px;">How We <span class="tria-thin">Engage</span></h2>
        </div>
      </div>
      <div class="row tria-engagement-grid">
        <div class="col-md-4 tria-up">
          <div class="tria-engagement-card">
            <div class="tria-ec-icon"><i class="fas fa-rocket"></i></div>
            <h4 class="tria-ec-title">Project-Based</h4>
            <p class="tria-ec-desc">Fixed scope, timeline, and budget. Ideal for defined product builds, platform launches, or specific feature development.</p>
            <ul class="tria-ec-list">
              <li>Clear deliverables</li>
              <li>Fixed pricing</li>
              <li>Milestone-based payments</li>
            </ul>
          </div>
        </div>
        <div class="col-md-4 tria-up">
          <div class="tria-engagement-card tria-engagement-card--featured">
            <div class="tria-ec-badge">Most Popular</div>
            <div class="tria-ec-icon"><i class="fas fa-users"></i></div>
            <h4 class="tria-ec-title">Dedicated Team</h4>
            <p class="tria-ec-desc">A full-time extension of your engineering team. Senior engineers embedded in your workflow, culture, and tools.</p>
            <ul class="tria-ec-list">
              <li>Full team ownership</li>
              <li>Daily collaboration</li>
              <li>Long-term partnership</li>
            </ul>
          </div>
        </div>
        <div class="col-md-4 tria-up">
          <div class="tria-engagement-card">
            <div class="tria-ec-icon"><i class="fas fa-lightbulb"></i></div>
            <h4 class="tria-ec-title">Advisory</h4>
            <p class="tria-ec-desc">Strategic CTO-level guidance for architecture decisions, technology selection, and team scaling without full engagement.</p>
            <ul class="tria-ec-list">
              <li>Architecture reviews</li>
              <li>Tech stack audits</li>
              <li>Flexible hours</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .tria-services-hero {
    position: relative;
    overflow: hidden;
  }
  .tria-sh-bg {
    position: absolute;
    inset: 0;
    background: #0b0d17;
  }
  .tria-sh-inner {
    padding-top: 160px;
    padding-bottom: 100px;
    position: relative;
    z-index: 1;
  }
  .tria-sh-right {
    display: flex;
    align-items: flex-end;
    padding-bottom: 12px;
  }

  /* ── Services List ── */
  .tria-services-list {
    border-top: 1px solid rgba(0,0,0,0.1);
  }
  .tria-service-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0 40px;
    padding: 70px 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    position: relative;
  }
  .tria-service-row::before {
    content: '';
    position: absolute;
    left: -24px;
    right: -24px;
    top: 0;
    bottom: 0;
    background: transparent;
    border-radius: 6px;
    transition: background 0.4s ease;
    z-index: -1;
  }
  .tria-service-row:hover::before {
    background: rgba(86,5,29,0.02);
  }
  .tria-sr-num {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 1rem;
    color: rgba(0,0,0,0.2);
    padding-top: 10px;
    transition: color 0.3s;
  }
  .tria-service-row:hover .tria-sr-num {
    color: var(--accent, #56051d);
  }
  .tria-sr-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 40px;
  }
  .tria-sr-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    margin: 0;
    color: #0b0d17;
    transition: color 0.3s;
  }
  .tria-service-row:hover .tria-sr-title {
    color: var(--accent, #56051d);
  }
  .tria-sr-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(86,5,29,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent, #56051d);
    font-size: 22px;
    flex-shrink: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .tria-service-row:hover .tria-sr-icon {
    background: var(--accent, #56051d);
    color: #fff;
    transform: rotate(5deg);
  }
  .tria-sr-desc {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.8;
    margin: 0;
  }
  .tria-sr-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tria-sr-features li {
    font-size: 0.82rem;
    color: #444;
    padding-left: 18px;
    position: relative;
  }
  .tria-sr-features li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent, #56051d);
    font-size: 0.7rem;
  }
  .tria-sr-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 50px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .tria-sr-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tria-sr-tags span {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 20px;
    color: rgba(0,0,0,0.4);
  }

  /* ── Engagement cards ── */
  .tria-engagement-grid {
    gap: 20px 0;
  }
  .tria-engagement-card {
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    padding: 50px 40px;
    height: 100%;
    position: relative;
    background: #fff;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .tria-engagement-card:hover {
    border-color: rgba(86,5,29,0.25);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.07);
  }
  .tria-engagement-card--featured {
    border-color: var(--accent, #56051d);
    background: #0b0d17;
  }
  .tria-engagement-card--featured .tria-ec-title,
  .tria-engagement-card--featured .tria-ec-desc,
  .tria-engagement-card--featured .tria-ec-list li {
    color: rgba(255,255,255,0.8) !important;
  }
  .tria-engagement-card--featured:hover {
    border-color: var(--accent, #56051d);
    box-shadow: 0 20px 60px rgba(86,5,29,0.2);
  }
  .tria-ec-badge {
    position: absolute;
    top: -12px;
    left: 40px;
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--accent, #56051d);
    color: #fff;
    padding: 4px 12px;
    border-radius: 20px;
  }
  .tria-ec-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(86,5,29,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent, #56051d);
    font-size: 20px;
    margin-bottom: 24px;
    transition: background 0.3s, transform 0.3s;
  }
  .tria-engagement-card--featured .tria-ec-icon {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
  }
  .tria-engagement-card:hover .tria-ec-icon {
    background: var(--accent, #56051d);
    color: #fff;
    transform: translateY(-2px);
  }
  .tria-ec-title {
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 16px;
    color: #0b0d17;
  }
  .tria-ec-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.75;
    margin-bottom: 28px;
  }
  .tria-ec-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tria-ec-list li {
    font-size: 0.78rem;
    color: #555;
    padding-left: 16px;
    position: relative;
  }
  .tria-ec-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent, #56051d);
    font-size: 0.7rem;
  }
  .tria-engagement-card--featured .tria-ec-list li::before {
    color: rgba(255,255,255,0.4);
  }

  @media (max-width: 768px) {
    .tria-service-row {
      grid-template-columns: 50px 1fr;
      gap: 0 16px;
      padding: 50px 0;
    }
    .tria-sr-header { flex-direction: column; gap: 20px; }
  }
</style>
