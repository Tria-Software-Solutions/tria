---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createT } from "../i18n/utils";
const t = createT(Astro.currentLocale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <section class="page-hero" data-section-theme="dark" style="min-height:80vh;align-items:center;">
    <div class="page-hero-bg">
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
    </div>
    <div class="container page-hero-inner">
      <div class="tria-center">
        <h1 class="page-hero-heading" style="font-size:clamp(6rem,15vw,12rem);margin-bottom:10px;" data-i18n="404.title">404</h1>
        <p class="page-hero-sub" style="max-width:none;font-size:1.1rem;margin-bottom:40px;" data-i18n="404.subtitle">Page not found</p>
        <Button text="Back to home" href="/" variant="glass" showArrow={true} />
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>