---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — tria">
  <section
    style="min-height:100vh;padding:160px 0 100px;display:flex;align-items:center;"
  >
    <div class="container" style="text-align:center;">
      <h1
        style="font-family:var(--font-display);font-size:clamp(6rem,15vw,12rem);font-weight:300;margin:0;"
      >
        404
      </h1>
      <p style="font-size:1.1rem;color:var(--color-muted);margin:20px 0 40px;">
        Page not found
      </p>
      <a
        href="/"
        style="text-decoration:none;border:1px solid var(--color-accent);padding:12px 32px;border-radius:6px;color:var(--color-accent);font-size:.85rem;transition:.3s;"
      >
        Back to home
      </a>
    </div>
  </section>
</Layout>
