---
import Layout from "../../layouts/Layout.astro";
import PageBanner from "../../components/PageBanner.astro";
import Button from "../../components/Button.astro";
import Quote from "../../components/Quote.astro";
import CTA from "../../components/CTA.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { createT } from "../../i18n/utils";
const t = createT(Astro.currentLocale);
const deepwikiUrl = "https://deepwiki.com/Tria-Building-Digital-Solutions/parkit";
const deepwikiCta = Astro.currentLocale === "es" ? "Leer caso de estudio completo en DeepWiki" : "Read full case study on DeepWiki";
const liveUrl = "https://parkit-valet.vercel.app";
const liveCta = Astro.currentLocale === "es" ? "Ver sitio en vivo" : "View Live Site";
---

<Layout title={t("featured.project1Title")} description={t("featured.project1Desc")}>
  <PageBanner suptitleKey="featured.project1Cat" headingKey="featured.project1Title" descriptionKey="featured.project1Desc" />

  <!-- overview -->
  <section class="tria-project-section" data-section-theme="light">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="tria-project-overview-grid">
        <!-- Screenshot -->
        <div class="tria-project-visual tria-up">
          <img src="/assets/img/featured/parkit.png" alt="Parkit app preview" class="tria-project-img" loading="lazy" />
        </div>
        <!-- Content -->
        <div class="tria-project-content tria-up">
          <div class="tria-project-tags">
            <span>React</span>
            <span>Go</span>
            <span>PostgreSQL</span>
            <span>AWS</span>
            <span>React Native</span>
          </div>
          <h2 class="tria-project-title">Project Overview</h2>
          <p class="tria-project-desc">{t("featured.project1Desc")}</p>

          <div class="tria-project-stats">
            <div class="tria-project-stat">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              <div>
                <div class="tria-project-stat-val">3</div>
                <div class="tria-project-stat-lbl">Platforms</div>
              </div>
            </div>
            <div class="tria-project-stat">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <div>
                <div class="tria-project-stat-val">Multi</div>
                <div class="tria-project-stat-lbl">Tenant</div>
              </div>
            </div>
            <div class="tria-project-stat">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <div class="tria-project-stat-val">Real</div>
                <div class="tria-project-stat-lbl">Time</div>
              </div>
            </div>
          </div>

          <div class="tria-project-cta-wrap">
            <Button
              href={deepwikiUrl}
              variant="primary"
              color="#0b0d17"
              hoverColor="#068e8c"
              text={deepwikiCta}
              showArrow
              arrowStyle="inline"
              size="sm"
              target="_blank"
              rel="noopener noreferrer"
            />
            <Button
              href={liveUrl}
              variant="outline"
              color="#068e8c"
              text={liveCta}
              showArrow
              arrowStyle="inline"
              size="sm"
              target="_blank"
              rel="noopener noreferrer"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- challenge / approach / results -->
  <section class="tria-project-detail-section" data-section-theme="light">
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-2"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row justify-content-center tria-mb-30">
        <div class="col-lg-8 tria-center">
          <span class="tria-suptitle tria-suptitle-dark tria-up">Deep Dive</span>
          <h2 class="tria-up tria-pd-section-title">Understanding the <span class="tria-accent-text">Process</span></h2>
        </div>
      </div>
      <div class="row tria-pd-grid">
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <h4 class="tria-pd-title" data-i18n="project.challenge">{t("project.challenge")}</h4>
          <p class="tria-pd-desc" data-i18n="parkit.challenge">{t("parkit.challenge")}</p>
        </div>
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h4 class="tria-pd-title" data-i18n="project.approach">{t("project.approach")}</h4>
          <p class="tria-pd-desc" data-i18n="parkit.approach">{t("parkit.approach")}</p>
        </div>
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h4 class="tria-pd-title" data-i18n="project.result">{t("project.result")}</h4>
          <p class="tria-pd-desc" data-i18n="parkit.result">{t("parkit.result")}</p>
        </div>
      </div>
    </div>
  </section>

  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />

  <CTA 
    heading={t("ctaProject.heading") || ""}
    primaryButtonText={t("ctaProject.button") || ""}
    secondaryButtonText={t("ctaProject.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />

  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════
     OVERVIEW — minimal split layout
     ═══════════════════════════════════════ */
  .tria-project-section {
    background: #f5f7f9;
    position: relative;
  }

  .tria-project-overview-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* ── Image ── */
  .tria-project-visual {
    position: relative;
  }

  .tria-project-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }

  /* ── Content ── */
  .tria-project-content {
    position: relative;
    z-index: 2;
  }

  .tria-project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .tria-project-tags span {
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 100px;
    color: rgba(0,0,0,0.35);
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .tria-project-tags span:hover {
    color: var(--accent);
    border-color: rgba(6,142,140,0.2);
  }

  .tria-project-title {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 350;
    color: #0b0d17;
    margin-bottom: 14px;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .tria-project-desc {
    font-size: 0.85rem;
    line-height: 1.85;
    color: rgba(11, 13, 23, 0.5);
    margin-bottom: 36px;
    max-width: 480px;
  }

  /* ── Stats ── */
  .tria-project-stats {
    display: flex;
    gap: 6px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .tria-project-stat {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: 8px;
    background: rgba(255,255,255,0.5);
    transition: background 0.3s ease;
    flex: 1;
    min-width: 110px;
  }

  .tria-project-stat:hover {
    background: rgba(255,255,255,0.85);
  }

  .tria-project-stat svg {
    width: 14px;
    height: 14px;
    color: var(--accent);
    flex-shrink: 0;
    opacity: 0.5;
  }

  .tria-project-stat-val {
    font-size: 0.75rem;
    font-weight: 500;
    color: #0b0d17;
    line-height: 1.2;
  }

  .tria-project-stat-lbl {
    font-size: 0.45rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.25);
    margin-top: 1px;
  }

  .tria-project-cta-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }



  /* ═══════════════════════════════════════
     DEEP DIVE — clean columns, frameless
     ═══════════════════════════════════════ */
  .tria-project-detail-section {
    background: #fff;
    position: relative;
  }

  .tria-pd-section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    color: #0b0d17;
    line-height: 1.15;
    margin-bottom: 40px;
  }

  .tria-accent-text {
    color: var(--accent);
  }

  .tria-pd-grid {
    gap: 48px 0;
  }

  .tria-pd-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 20px;
    transition: transform 0.4s var(--ease-spring);
  }

  .tria-pd-icon:hover {
    transform: translateY(-2px);
  }

  .tria-pd-title {
    font-size: 1rem;
    font-weight: 500;
    color: #0b0d17;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .tria-pd-desc {
    font-size: 0.85rem;
    color: rgba(0,0,0,0.45);
    line-height: 1.75;
    margin: 0;
    max-width: 320px;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 991px) {
    .tria-project-overview-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .tria-project-img {
      max-width: 600px;
      margin: 0 auto;
    }
    .tria-project-content {
      text-align: center;
    }
    .tria-project-desc {
      margin-left: auto;
      margin-right: auto;
    }
    .tria-project-stats {
      justify-content: center;
    }
    .tria-project-tags {
      justify-content: center;
    }
    .tria-pd-section-title {
      margin-bottom: 28px;
    }
  }

  @media (max-width: 576px) {
    .tria-project-cta-wrap {
      flex-wrap: wrap;
    }
    .tria-project-stats {
      flex-direction: column;
      align-items: stretch;
    }
    .tria-project-stat {
      min-width: auto;
    }
    .tria-project-desc {
      font-size: 0.85rem;
    }
    .tria-project-tags span {
      font-size: 0.5rem;
      padding: 4px 10px;
    }
    .tria-project-title {
      font-size: 1.3rem;
    }
    .tria-pd-section-title {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 400px) {
    .tria-project-title {
      font-size: 1.1rem;
    }
  }
</style>
