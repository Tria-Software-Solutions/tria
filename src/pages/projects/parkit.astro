---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import Quote from "../../components/Quote.astro";
import CTA from "../../components/CTA.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { createT } from "../../i18n/utils";
const t = createT(Astro.currentLocale);
const deepwikiUrl = "https://deepwiki.com/Tria-Building-Digital-Solutions/parkit";
const deepwikiCta = Astro.currentLocale === "es" ? "Leer caso de estudio completo en DeepWiki" : "Read full case study on DeepWiki";
---

<Layout title={t("featured.project1Title")} description={t("featured.project1Desc")}>
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-bg-dots"></div>
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
      <div class="page-hero-gradient-overlay"></div>
      <div class="tria-hero-grain"></div>
      <div class="tria-ambient-temp">
        <div class="tria-at-glow-1"></div>
        <div class="tria-at-glow-2"></div>
      </div>
    </div>
    <div class="container page-hero-inner">
      <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;">{t("featured.project1Cat")}</span>
      <h1 class="page-hero-heading tria-up">{t("featured.project1Title")}</h1>
      <p class="page-hero-sub tria-up">{t("featured.project1Desc")}</p>
    </div>
  </section>

  <!-- overview -->
  <section class="tria-project-section" data-section-theme="dark">
    <div class="tria-dot-pattern"></div>
    <div class="tria-grain-overlay"></div>
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-3"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="tria-project-body tria-up">
            <div class="tria-project-tags">
              <span>React</span>
              <span>Go</span>
              <span>PostgreSQL</span>
              <span>AWS</span>
              <span>React Native</span>
            </div>
            <h2 class="tria-project-title">Project Overview</h2>
            <p class="tria-project-desc">{t("featured.project1Desc")}</p>

            <div class="tria-project-stats">
              <div class="tria-project-stat">
                <div class="tria-project-stat-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </div>
                <span class="tria-project-stat-num">3</span>
                <span class="tria-project-stat-label">Platforms</span>
              </div>
              <div class="tria-project-stat-divider"></div>
              <div class="tria-project-stat">
                <div class="tria-project-stat-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <span class="tria-project-stat-num">Multi</span>
                <span class="tria-project-stat-label">Tenant</span>
              </div>
              <div class="tria-project-stat-divider"></div>
              <div class="tria-project-stat">
                <div class="tria-project-stat-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <span class="tria-project-stat-num">Real</span>
                <span class="tria-project-stat-label">Time</span>
              </div>
            </div>

            <div class="tria-project-cta-wrap">
              <Button
                href={deepwikiUrl}
                variant="primary"
                color="#0b0d17"
                hoverColor="#068e8c"
                text={deepwikiCta}
                showArrow
                arrowStyle="inline"
                target="_blank"
                rel="noopener noreferrer"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- challenge / approach / results -->
  <section class="tria-project-detail-section" data-section-theme="light">
    <div class="tria-ambient-temp">
      <div class="tria-at-glow-1"></div>
      <div class="tria-at-glow-2"></div>
    </div>
    <div class="container tria-p-120-120">
      <div class="row justify-content-center tria-mb-30">
        <div class="col-lg-8 tria-center">
          <span class="tria-suptitle" style="color:rgba(0,0,0,0.35);">Deep Dive</span>
          <h2 class="tria-up tria-pd-section-title">Understanding the <span class="tria-accent-text">Process</span></h2>
        </div>
      </div>
      <div class="row tria-pd-grid">
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <h4 class="tria-pd-title" data-i18n="project.challenge">{t("project.challenge")}</h4>
          <p class="tria-pd-desc" data-i18n="parkit.challenge">{t("parkit.challenge")}</p>
        </div>
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h4 class="tria-pd-title" data-i18n="project.approach">{t("project.approach")}</h4>
          <p class="tria-pd-desc" data-i18n="parkit.approach">{t("parkit.approach")}</p>
        </div>
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h4 class="tria-pd-title" data-i18n="project.result">{t("project.result")}</h4>
          <p class="tria-pd-desc" data-i18n="parkit.result">{t("parkit.result")}</p>
        </div>
      </div>
    </div>
  </section>

  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />

  <CTA 
    heading={t("ctaProject.heading") || ""}
    primaryButtonText={t("ctaProject.button") || ""}
    secondaryButtonText={t("ctaProject.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />

  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════
     OVERVIEW — light clean
     ═══════════════════════════════════════ */
  .tria-project-section {
    background: #f5f7f9;
    position: relative;
  }

  .tria-project-body {
    text-align: center;
    position: relative;
    z-index: 2;
  }

  /* ── Tags ── */
  .tria-project-tags {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .tria-project-tags span {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 20px;
    color: rgba(0,0,0,0.35);
    transition: border-color 0.4s var(--ease-spring), color 0.4s var(--ease-spring), background 0.4s var(--ease-spring);
  }

  .tria-project-tags span:hover {
    border-color: rgba(6,142,140,0.2);
    color: var(--accent);
    background: rgba(6,142,140,0.04);
  }

  /* ── Title & Desc ── */
  .tria-project-title {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 400;
    color: #0b0d17;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .tria-project-desc {
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(11, 13, 23, 0.6);
    margin-bottom: 48px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Stats ── */
  .tria-project-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    margin-bottom: 48px;
    padding: 0;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    background: #fff;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    overflow: hidden;
    transition: box-shadow 0.6s var(--ease-spring), border-color 0.6s var(--ease-spring), transform 0.6s var(--ease-spring);
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
  }

  .tria-project-stats:hover {
    border-color: rgba(6,142,140,0.12);
    box-shadow: 0 16px 48px rgba(6,142,140,0.06), 0 4px 16px rgba(0,0,0,0.03);
    transform: translateY(-3px);
  }

  .tria-project-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 32px 28px;
    flex: 1;
    transition: background 0.4s var(--ease-spring);
    position: relative;
  }

  .tria-project-stat:hover {
    background: rgba(6,142,140,0.025);
  }

  .tria-project-stat-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(6,142,140,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    transition: background 0.4s var(--ease-spring), transform 0.4s var(--ease-spring), color 0.4s var(--ease-spring);
    margin-bottom: 4px;
  }

  .tria-project-stat:hover .tria-project-stat-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-2px) scale(1.05);
  }

  .tria-project-stat-divider {
    width: 1px;
    height: 48px;
    background: rgba(0,0,0,0.05);
    flex-shrink: 0;
    transition: background 0.4s var(--ease-spring);
  }

  .tria-project-stats:hover .tria-project-stat-divider {
    background: rgba(6,142,140,0.06);
  }

  .tria-project-stat-num {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
    transition: transform 0.4s var(--ease-spring);
  }

  .tria-project-stat:hover .tria-project-stat-num {
    transform: scale(1.05);
  }

  .tria-project-stat-label {
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    transition: color 0.4s var(--ease-spring);
  }

  .tria-project-stat:hover .tria-project-stat-label {
    color: rgba(0,0,0,0.45);
  }

  .tria-project-cta-wrap {
    position: relative;
    z-index: 1;
  }

  /* ═══════════════════════════════════════
     DEEP DIVE — clean columns, frameless
     ═══════════════════════════════════════ */
  .tria-project-detail-section {
    background: #fff;
    position: relative;
  }

  .tria-pd-section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    color: #0b0d17;
    line-height: 1.15;
    margin-bottom: 40px;
  }

  .tria-accent-text {
    color: var(--accent);
  }

  .tria-pd-grid {
    gap: 48px 0;
  }

  .tria-pd-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 20px;
    transition: transform 0.4s var(--ease-spring);
  }

  .tria-pd-icon:hover {
    transform: translateY(-2px);
  }

  .tria-pd-title {
    font-size: 1rem;
    font-weight: 500;
    color: #0b0d17;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .tria-pd-desc {
    font-size: 0.85rem;
    color: rgba(0,0,0,0.45);
    line-height: 1.75;
    margin: 0;
    max-width: 320px;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 991px) {
    .tria-pd-section-title {
      margin-bottom: 28px;
    }
  }

  @media (max-width: 576px) {
    .tria-project-stats {
      flex-direction: row;
      border-radius: 16px;
    }
    .tria-project-stat {
      padding: 24px 16px;
      gap: 6px;
    }
    .tria-project-stat-icon {
      width: 34px;
      height: 34px;
      border-radius: 10px;
    }
    .tria-project-stat-icon svg {
      width: 15px;
      height: 15px;
    }
    .tria-project-stat-num {
      font-size: 1.1rem;
    }
    .tria-project-stat-divider {
      height: 36px;
    }
    .tria-project-desc {
      font-size: 0.9rem;
    }
    .tria-project-tags span {
      font-size: 0.55rem;
      padding: 5px 10px;
    }
    .tria-pd-card {
      padding: 28px 24px;
      margin-bottom: 20px;
    }
    .tria-pd-section-title {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 400px) {
    .tria-project-stat {
      padding: 18px 12px;
    }
    .tria-project-stat-icon {
      width: 28px;
      height: 28px;
    }
    .tria-project-stat-icon svg {
      width: 13px;
      height: 13px;
    }
    .tria-project-stat-num {
      font-size: 1rem;
    }
    .tria-project-stat-label {
      font-size: 0.5rem;
    }
    .tria-project-stat-divider {
      height: 28px;
    }
    .tria-pd-card {
      padding: 22px 18px;
      margin-bottom: 16px;
    }
  }
</style>
