---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import Quote from "../../components/Quote.astro";
import CTA from "../../components/CTA.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { createT } from "../../i18n/utils";
const t = createT(Astro.currentLocale);
const deepwikiUrl = "https://deepwiki.com/Tria-Building-Digital-Solutions/choferes";
const deepwikiCta = Astro.currentLocale === "es" ? "Leer caso de estudio completo en DeepWiki" : "Read full case study on DeepWiki";
---

<Layout title={t("featured.project2Title")} description={t("featured.project2Desc")}>
  <section class="page-hero" data-section-theme="dark">
    <div class="page-hero-bg">
      <div class="page-hero-bg-dots"></div>
      <div class="page-hero-orb page-hero-orb--1"></div>
      <div class="page-hero-orb page-hero-orb--2"></div>
      <div class="page-hero-gradient-overlay"></div>
      <div class="tria-hero-grain"></div>
      <div class="tria-ambient-temp">
        <div class="tria-at-glow-1"></div>
        <div class="tria-at-glow-2"></div>
      </div>
    </div>
    <div class="container page-hero-inner">
      <span class="tria-suptitle tria-light-soft tria-up" style="display:block;margin-bottom:24px;">{t("featured.project2Cat")}</span>
      <h1 class="page-hero-heading tria-up">{t("featured.project2Title")}</h1>
      <p class="page-hero-sub tria-up">{t("featured.project2Desc")}</p>
    </div>
  </section>

  <section class="tria-project-section" data-section-theme="light">
    <div class="tria-project-glow"></div>
    <div class="container tria-p-120-120">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="tria-project-body tria-up">
            <div class="tria-project-tags">
              <span>Kubernetes</span>
              <span>Python</span>
              <span>OCR</span>
              <span>RBAC</span>
              <span>PostgreSQL</span>
            </div>
            <h2 class="tria-project-title">Project Overview</h2>
            <p class="tria-project-desc">{t("featured.project2Desc")}</p>

            <div class="tria-project-stats">
              <div class="tria-project-stat">
                <span class="tria-project-stat-num">OCR</span>
                <span class="tria-project-stat-label">Pipeline</span>
              </div>
              <div class="tria-project-stat">
                <span class="tria-project-stat-num">Real</span>
                <span class="tria-project-stat-label">Time</span>
              </div>
              <div class="tria-project-stat">
                <span class="tria-project-stat-num">RBAC</span>
                <span class="tria-project-stat-label">Security</span>
              </div>
            </div>

            <div class="tria-project-cta-wrap">
              <Button
                href={deepwikiUrl}
                variant="primary"
                color="#0b0d17"
                hoverColor="#068e8c"
                text={deepwikiCta}
                showArrow
                arrowStyle="inline"
                target="_blank"
                rel="noopener noreferrer"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- challenge / approach / results -->
  <section class="tria-project-detail-section" data-section-theme="light">
    <div class="container tria-p-120-120">
      <div class="row">
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-card">
            <div class="tria-pd-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <h4 class="tria-pd-title" data-i18n="project.challenge">{t("project.challenge")}</h4>
            <p class="tria-pd-desc" data-i18n="choferes.challenge">{t("choferes.challenge")}</p>
          </div>
        </div>
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-card">
            <div class="tria-pd-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h4 class="tria-pd-title" data-i18n="project.approach">{t("project.approach")}</h4>
            <p class="tria-pd-desc" data-i18n="choferes.approach">{t("choferes.approach")}</p>
          </div>
        </div>
        <div class="col-lg-4 tria-up">
          <div class="tria-pd-card">
            <div class="tria-pd-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h4 class="tria-pd-title" data-i18n="project.result">{t("project.result")}</h4>
            <p class="tria-pd-desc" data-i18n="choferes.result">{t("choferes.result")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Quote
    heading={t("cotizacion.heading") || 'Get a <span class="tria-thin">Custom Quote</span>'}
    description={t("cotizacion.description") || ""}
    buttonText={t("cotizacion.buttonText") || "Request a Quote"}
    buttonHref="/contact"
    features={[
      t("cotizacion.feature1") || "",
      t("cotizacion.feature2") || "",
      t("cotizacion.feature3") || "",
      t("cotizacion.feature4") || ""
    ]}
  />

  <CTA 
    heading={t("ctaProject.heading") || ""}
    primaryButtonText={t("ctaProject.button") || ""}
    secondaryButtonText={t("ctaProject.button2") || ""}
    primaryButtonHref="/contact"
    secondaryButtonHref="/portfolio"
    theme="dark"
    showIcon={true}
    padding=""
    primaryButtonVariant="primary"
    primaryButtonColor="#0b0d17"
    primaryButtonHoverColor="#1a1f35"
  />

  <SiteFooter />
</Layout>

<style>
  .tria-project-section {
    background: #faf7f2;
    position: relative;
  }

  .tria-project-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 700px;
    height: 700px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(6, 142, 140, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  .tria-project-body {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .tria-project-tags {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .tria-project-tags span {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 20px;
    color: rgba(0,0,0,0.35);
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .tria-project-tags span:hover {
    border-color: rgba(6,142,140,0.2);
    color: var(--accent);
  }

  .tria-project-title {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 400;
    color: #0b0d17;
    margin-bottom: 20px;
  }

  .tria-project-desc {
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(11, 13, 23, 0.6);
    margin-bottom: 48px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .tria-project-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 48px;
    padding: 32px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    background: #fff;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    transition: box-shadow 0.4s ease, border-color 0.4s ease;
  }

  .tria-project-stats:hover {
    border-color: rgba(6,142,140,0.12);
    box-shadow: 0 8px 32px rgba(0,0,0,0.04);
  }

  .tria-project-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .tria-project-stat-num {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .tria-project-stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
  }

  .tria-project-detail-section {
    background: #fff;
    position: relative;
  }

  .tria-pd-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 40px 34px;
    height: 100%;
    background: #faf7f2;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-pd-card:hover {
    border-color: rgba(6,142,140,0.2);
    transform: translateY(-6px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.06);
  }

  .tria-pd-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(6,142,140,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 20px;
    margin-bottom: 24px;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tria-pd-card:hover .tria-pd-icon {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }

  .tria-pd-title {
    font-size: 1.05rem;
    font-weight: 450;
    color: #0b0d17;
    margin-bottom: 12px;
    transition: color 0.3s ease;
  }

  .tria-pd-card:hover .tria-pd-title {
    color: var(--accent);
  }

  .tria-pd-desc {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.75;
    margin: 0;
    transition: color 0.3s ease;
  }

  .tria-pd-card:hover .tria-pd-desc {
    color: #555;
  }

  @media (max-width: 576px) {
    .tria-project-stats {
      gap: 24px;
      padding: 24px;
    }
    .tria-project-desc {
      font-size: 0.9rem;
    }
    .tria-project-tags span {
      font-size: 0.55rem;
      padding: 5px 10px;
    }
    .tria-pd-card {
      padding: 28px 24px;
      margin-bottom: 20px;
    }
  }

  @media (max-width: 400px) {
    .tria-pd-card {
      margin-bottom: 16px;
    }
  }
</style>
