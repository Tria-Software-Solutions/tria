# ── Jira Cloud integration ──
# Required for the contact form → ticket creation
JIRA_EMAIL=luis.herrera506@gmail.com
JIRA_TOKEN=your_jira_api_token_here

# Jira project key where contact form tickets will be created
# (change to any of your Jira project keys: TRI, SUP, etc.)
JIRA_PROJECT_KEY=TRI

# ── Slack notifications (optional) ──
# Set this to receive a message in your Slack channel when a new lead comes in
# Create a webhook: https://api.slack.com/apps → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# ── Email notifications (optional) ──
# Send email notifications when a new lead comes in
# Get a free API key at https://resend.com
# Note: the free tier only sends to the email registered in Resend
RESEND_API_KEY=

# Email address to receive lead notifications (requires RESEND_API_KEY)
# Must match the email registered in Resend (or use a verified domain)
NOTIFICATION_EMAIL=luis@triacr.com
